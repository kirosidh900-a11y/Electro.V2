<!DOCTYPE html>
<html>
<head>
    <title>Error - Electro</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 flex items-center justify-center min-h-screen p-6">
    <div class="max-w-md w-full bg-white shadow-lg rounded-lg p-8 text-center">
        <div class="text-red-500 mb-4">
            <i class="fa-solid fa-circle-exclamation text-5xl"></i>
        </div>
        
        <h1 class="text-2xl font-bold text-gray-900 mb-2">Something went wrong</h1>
        
        <p class="text-gray-600 mb-6">
            <%= locals.message || 'An unexpected error occurred while processing your request.' %>
        </p>

        <% if (locals.error && error.stack) { %>
            <div class="text-left bg-gray-100 p-4 rounded mb-6 overflow-x-auto">
                <pre class="text-[10px] text-gray-700"><%= error.stack %></pre>
            </div>
        <% } %>

        <a href="/shop" class="inline-block bg-[#2874F0] text-white px-6 py-2 rounded-sm font-medium hover:bg-blue-600 transition-colors">
            Back to Shop
        </a>
    </div>
</body>
</html>