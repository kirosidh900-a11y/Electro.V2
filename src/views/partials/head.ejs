<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<script src="https://cdn.tailwindcss.com"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<style>
    :root { color-scheme: dark; }
    body { background-color: #020406; color: #e2e8f0; font-family: 'Inter', sans-serif; margin: 0; }
    
    /* Layout Logic */
    #sidebar { 
        transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1); 
        width: 288px; /* w-72 */
    }
    #mainContent { 
        transition: margin-left 0.3s cubic-bezier(0.4, 0, 0.2, 1); 
    }

    /* Desktop Toggle State */
    .sidebar-closed #sidebar { transform: translateX(-100%); }
    .sidebar-closed #mainContent { margin-left: 0 !important; }

    /* Mobile Toggle State */
    @media (max-width: 1023px) {
        #sidebar { transform: translateX(-100%); }
        #mainContent { margin-left: 0 !important; }
        .mobile-open #sidebar { transform: translateX(0); }
    }

    /* Tablet & Desktop Default */
    @media (min-width: 1024px) {
        #mainContent { margin-left: 288px; }
    }

    .glass-card {
        background: rgba(10, 14, 20, 0.8);
        border: 1px solid rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(10px);
    }
</style>