  <!-- Enhanced Particles Effect -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="particle-glow"></div>
    <div class="particle-glow" style="animation-delay: 0.5s; top: 60%; left: 70%"></div>
    <div class="particle-glow" style="animation-delay: 1s; top: 30%; left: 80%"></div>
    <div class="particle-glow" style="animation-delay: 1.5s; top: 70%; left: 20%"></div>
    <div class="particle-glow" style="animation-delay: 2s; top: 50%; left: 40%"></div>
  </div>

  <!-- Floating Tech Icons -->
  <div class="absolute inset-0 pointer-events-none opacity-10">
    <div class="tech-icon" style="top: 15%; left: 10%">⚡</div>
    <div class="tech-icon" style="top: 25%; left: 85%; animation-delay: 0.5s">🔋</div>
    <div class="tech-icon" style="top: 70%; left: 15%; animation-delay: 1s">📱</div>
    <div class="tech-icon" style="top: 80%; left: 90%; animation-delay: 1.5s">💻</div>
  </div>
</div>

<style>
  /* Spinning animations */
  @keyframes spin-reverse {
    from { transform: rotate(360deg); }
    to { transform: rotate(0deg); }
  }

  .animate-spin-reverse {
    animation: spin-reverse 1.5s linear infinite;
  }

  /* Shimmer effect for progress bar */
  @keyframes shimmer {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(200%); }
  }

  .animate-shimmer {
    animation: shimmer 1.8s ease-in-out infinite;
  }

  /* Loading dots animation */
  .loading-dots::after {
    content: '';
    animation: dots 1.5s steps(4, end) infinite;
  }

  @keyframes dots {
    0%, 20% { content: ''; }
    40% { content: '.'; }
    60% { content: '..'; }
    80%, 100% { content: '...'; }
  }

  /* Enhanced particle glow effect */
  .particle-glow {
    position: absolute;
    width: 6px;
    height: 6px;
    background: radial-gradient(circle, rgba(34, 211, 238, 0.8), rgba(59, 130, 246, 0.4), transparent);
    border-radius: 50%;
    animation: float-glow 4s ease-in-out infinite;
    box-shadow: 0 0 20px rgba(34, 211, 238, 0.6);
    top: 30%;
    left: 20%;
  }

  @keyframes float-glow {
    0%, 100% {
      transform: translate(0, 0) scale(1);
      opacity: 0.4;
    }
    25% {
      transform: translate(30px, -30px) scale(1.3);
      opacity: 0.8;
    }
    50% {
      transform: translate(60px, -10px) scale(1);
      opacity: 0.6;
    }
    75% {
      transform: translate(30px, 20px) scale(1.2);
      opacity: 0.9;
    }
  }

  /* Glowing animation */
  @keyframes glow {
    0%, 100% {
      opacity: 0.3;
      transform: scale(1);
    }
    50% {
      opacity: 0.6;
      transform: scale(1.05);
    }
  }

  .animate-glow {
    animation: glow 3s ease-in-out infinite;
  }

  /* Letter float animation */
  @keyframes float {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-10px);
    }
  }

  .animate-float {
    animation: float 3s ease-in-out infinite;
  }

  /* Fade in animations */
  @keyframes fade-in {
    from {
      opacity: 0;
      transform: scale(0.9);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in {
    animation: fade-in 1s ease-out;
  }

  .animate-fade-in-up {
    animation: fade-in-up 1s ease-out 0.3s both;
  }

  /* Gradient animation */
  @keyframes gradient {
    0%, 100% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
  }

  .animate-gradient {
    background-size: 200% 200%;
    animation: gradient 3s ease infinite;
  }

  /* Ping animation (slower) */
  @keyframes ping-slow {
    0% {
      transform: scale(1);
      opacity: 1;
    }
    75%, 100% {
      transform: scale(2);
      opacity: 0;
    }
  }

  .animate-ping-slow {
    animation: ping-slow 3s cubic-bezier(0, 0, 0.2, 1) infinite;
  }

  /* Pulse animation (slower) */
  @keyframes pulse-slow {
    0%, 100% {
      opacity: 1;
    }
    50% {
      opacity: 0.3;
    }
  }

  .animate-pulse-slow {
    animation: pulse-slow 4s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }

  /* Fast pulse */
  .animate-pulse-fast {
    animation: pulse 1s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }

  /* Stars effect */
  .star {
    position: absolute;
    width: 2px;
    height: 2px;
    background: white;
    border-radius: 50%;
    animation: twinkle 3s ease-in-out infinite;
    box-shadow: 0 0 10px rgba(255, 255, 255, 0.8);
    top: 30%;
    left: 40%;
  }

  @keyframes twinkle {
    0%, 100% {
      opacity: 0.3;
      transform: scale(1);
    }
    50% {
      opacity: 1;
      transform: scale(1.5);
    }
  }

  /* Grid lines */
  .grid-line {
    position: absolute;
    background: linear-gradient(90deg, transparent, rgba(59, 130, 246, 0.3), transparent);
  }

  .grid-line.horizontal {
    width: 100%;
    height: 1px;
    animation: scan-horizontal 3s ease-in-out infinite;
  }

  .grid-line.vertical {
    width: 1px;
    height: 100%;
    background: linear-gradient(180deg, transparent, rgba(59, 130, 246, 0.3), transparent);
    animation: scan-vertical 4s ease-in-out infinite;
  }

  @keyframes scan-horizontal {
    0%, 100% {
      opacity: 0.2;
    }
    50% {
      opacity: 0.8;
    }
  }

  @keyframes scan-vertical {
    0%, 100% {
      opacity: 0.2;
    }
    50% {
      opacity: 0.6;
    }
  }

  /* Tech icons float */
  .tech-icon {
    position: absolute;
    font-size: 3rem;
    animation: float-icons 6s ease-in-out infinite;
  }

  @keyframes float-icons {
    0%, 100% {
      transform: translateY(0) rotate(0deg);
      opacity: 0.3;
    }
    50% {
      transform: translateY(-30px) rotate(10deg);
      opacity: 0.6;
    }
  }

  /* Loader fade out */
  #appLoader {
    transition: opacity 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  }
</style>

<script>
  // Simulate loading with percentage counter
  let progress = 0;
  const progressText = document.querySelector('#appLoader .text-xs');
  
  const progressInterval = setInterval(() => {
    progress += Math.random() * 15;
    if (progress > 100) progress = 100;
    
    if (progressText) {
      progressText.textContent = `Loading assets... ${Math.floor(progress)}%`;
    }
    
    if (progress >= 100) {
      clearInterval(progressInterval);
    }
  }, 150);

  // Hide loader when page is fully loaded
  window.addEventListener('load', function() {
    const loader = document.getElementById('appLoader');
    if (loader) {
      clearInterval(progressInterval);
      if (progressText) {
        progressText.textContent = 'Ready! 100%';
      }
      
      setTimeout(() => {
        loader.style.opacity = '0';
        loader.style.transform = 'scale(1.05)';
        setTimeout(() => loader.remove(), 800);
      }, 600);
    }
  });

  // Safety timeout - remove loader after 12 seconds regardless
  setTimeout(() => {
    const loader = document.getElementById('appLoader');
    if (loader) {
      clearInterval(progressInterval);
      loader.remove();
    }
  }, 12000);
</script>
