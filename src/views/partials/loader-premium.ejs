      <!-- Glowing background -->
      <div class="absolute inset-0 bg-gradient-to-r from-cyan-500 to-blue-500 rounded-full blur-xl opacity-30 animate-pulse"></div>
      
      <!-- Outer ring with gradient -->
      <div class="absolute inset-0 border-4 border-transparent border-t-cyan-400 border-r-blue-400 rounded-full animate-spin shadow-lg shadow-cyan-500/50"></div>
      
      <!-- Middle ring -->
      <div class="absolute inset-3 border-4 border-transparent border-t-blue-400 border-r-purple-400 rounded-full animate-spin-reverse shadow-lg shadow-blue-500/50"></div>
      
      <!-- Inner ring -->
      <div class="absolute inset-6 border-2 border-transparent border-t-purple-400 border-r-pink-400 rounded-full animate-spin" style="animation-duration: 1s"></div>
      
      <!-- Center glowing core -->
      <div class="absolute inset-0 flex items-center justify-center">
        <div class="relative">
          <div class="absolute inset-0 w-6 h-6 bg-gradient-to-r from-cyan-400 to-purple-400 rounded-full blur-sm animate-pulse"></div>
          <div class="relative w-6 h-6 bg-gradient-to-r from-cyan-400 via-blue-400 to-purple-400 rounded-full animate-pulse-fast shadow-lg"></div>
        </div>
      </div>
    </div>

    <!-- Loading Text with Typewriter Effect -->
    <div class="text-cyan-100 text-lg font-semibold mb-6">
      <span class="inline-block loading-text tracking-wider">Initializing</span>
