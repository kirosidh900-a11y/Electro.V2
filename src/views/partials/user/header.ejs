<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
<link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet"></link>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
<script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>

<div class="bg-white border-b border-gray-200 py-1.5">
  <div class="max-w-7xl mx-auto px-6 flex justify-between items-center text-[12px]">
    <span class="text-gray-600">
      Summer Sale For All Swim Suits And Free Express Delivery – OFF 50%!
      <a href="/shop" class="font-bold text-black underline ml-1 hover:text-red-600 transition-colors">ShopNow</a>
    </span>
    <!-- <div class="text-gray-700 font-semibold uppercase text-[11px] cursor-pointer flex items-center">
      English <i class="fas fa-chevron-down text-[9px] ml-1"></i>
    </div> -->
  </div>
</div>

<header class="bg-[#f8f9fa] py-3 sticky top-0 z-50 border-b border-gray-200 shadow-sm">
  <div class="max-w-7xl mx-auto px-6 flex items-center justify-between gap-4">

    <div class="flex-shrink-0">
      <a href="/" class="text-2xl font-black text-black no-underline tracking-tighter uppercase italic">
        Electro<span class="text-red-600">.</span>
      </a>
    </div>

    <div class="flex-1 max-w-2xl hidden md:block">
      <form action="/search" method="GET" class="relative">
        <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400">
          <i class="fas fa-search text-sm"></i>
        </span>
        <input type="text" name="q" placeholder="Search for products..."
          class="w-full bg-white border border-gray-300 rounded-md py-2 pl-11 pr-4 text-sm focus:outline-none focus:ring-2 focus:ring-red-600 focus:border-transparent transition-all shadow-sm">
      </form>
    </div>

    <div class="flex items-center gap-3">

      <!-- Premium User Section -->
      <div class="relative inline-block">

        <% if (typeof user !=="undefined" && user?.name) { %>

          <!-- User Button -->
          <button onclick="toggleDropdown()" id="dropdownButton" class="group bg-gradient-to-r from-[#1e1e1e] to-[#2c2c2c] text-white 
             flex items-center gap-3 rounded-full px-4 py-2 
             hover:shadow-lg hover:scale-[1.02] transition-all duration-300 
             border border-gray-700">

            <!-- Profile Image -->
            <div class="relative">
              <img id="headImg"
                src="<%= user.photo ? user.photo : 'https://res.cloudinary.com/dxtiklfxy/image/upload/v1773824246/profile/qhvfjaqer1o81nwkxvcz.png' %>"
                class="w-8 h-8 rounded-full object-cover border border-gray-600 shadow-sm" />

              <!-- Online Dot -->
              <span
                class="absolute bottom-0 right-0 w-2.5 h-2.5 bg-green-500 border-2 border-black rounded-full"></span>
            </div>

            <!-- Name -->
            <span id="headName" class="text-sm font-semibold hidden sm:inline tracking-wide">
              <%= user.name %>
            </span>

            <i id="chevronIcon"
              class="fas fa-chevron-down text-xs transition-transform duration-300 group-hover:rotate-180"></i>
          </button>

          <!-- Dropdown -->
          <ul id="dropdownMenu" class="hidden absolute right-0 mt-3 w-60 
             bg-white/90 backdrop-blur-xl 
             shadow-2xl rounded-2xl overflow-hidden 
             border border-gray-200 animate-fadeIn z-50">

            <li class="px-5 py-4 border-b bg-gray-50">
              <p id="headName1" class="font-semibold text-gray-800 text-sm">
                <%= user.name %>
              </p>
              <p id="headerEmail" class="text-xs text-gray-500 truncate">
                <%= user.email %>
              </p>
            </li>

            <li>
              <a href="/myProfile" class="flex items-center gap-3 px-5 py-3 hover:bg-gray-100 transition">
                <i class="fas fa-user text-gray-500"></i> My Profile
              </a>
            </li>

            <li>
              <a href="/orders" class="flex items-center gap-3 px-5 py-3 hover:bg-gray-100 transition">
                <i class="fas fa-box text-gray-500"></i> Orders
              </a>
            </li>

            <li>
              <a href="/wishlist" class="flex justify-between items-center px-5 py-3 hover:bg-gray-100 transition">
                <span class="flex items-center gap-3">
                  <i class="fas fa-heart text-gray-500"></i> Wishlist
                </span>
                <span id="wishlistCount" class="text-xs bg-red-500 text-white px-2 py-0.5 rounded-full">
                  <%= wishlist?.items?.length || 0 %>
                </span>
              </a>
            </li>

            <li>
              <a href="/cart" class="flex justify-between items-center px-5 py-3 hover:bg-gray-100 transition">
                <span class="flex items-center gap-3">
                  <i class="fas fa-shopping-cart text-gray-500"></i> Cart
                </span>
                <span id="cartCount" class="text-xs bg-black text-white px-2 py-0.5 rounded-full">
                  <%= cart?.count || 0 %>
                </span>
              </a>
            </li>

            <li class="border-t">
              <a id="logout"
                class="flex items-center gap-3 px-5 py-3 text-red-500 hover:bg-red-50 transition cursor-pointer">
                <i class="fas fa-sign-out-alt"></i> Logout
              </a>
            </li>

          </ul>

          <% } else { %>

            <!-- Guest Button -->
            <button onclick="toggleDropdown()" id="dropdownButton" class="bg-gradient-to-r from-[#1e1e1e] to-[#2c2c2c] text-white 
             flex items-center gap-2 rounded-full px-5 py-2 
             hover:shadow-lg hover:scale-[1.02] transition-all duration-300">

              <i class="fas fa-user-circle text-lg"></i>
              <span class="text-sm font-semibold">Account</span>
              <i class="fas fa-chevron-down text-xs"></i>
            </button>

            <ul id="dropdownMenu" class="hidden absolute right-0 mt-3 w-48 
             bg-white shadow-2xl rounded-xl border 
             animate-fadeIn z-50">

              <li>
                <a href="/auth/signUp" class="block px-5 py-3 hover:bg-gray-100 transition font-medium">
                  Sign Up
                </a>
              </li>

              <li>
                <a href="/auth/logIn" class="block px-5 py-3 hover:bg-gray-100 transition font-medium">
                  Log In
                </a>
              </li>

            </ul>

            <% } %>

      </div>

      <div class="flex items-center gap-2">
        <button
          class="w-10 h-10 flex items-center justify-center border border-gray-300 rounded text-gray-600 hover:bg-white hover:text-red-600 transition-colors relative">
          <i class="fas fa-bell"></i>
          <span
            class="absolute -top-1 -right-1 bg-red-600 text-white text-[10px] rounded-full w-4 h-4 flex items-center justify-center font-bold">0</span>
        </button>

        <button
          class="w-10 h-10 flex items-center justify-center border border-gray-300 rounded text-gray-600 hover:bg-white hover:text-red-600 transition-colors">
          <i class="fas fa-headset"></i>
        </button>
      </div>

    </div>
  </div>
</header>

<!-- Logout Modal -->
<div id="logoutModal" class="fixed inset-0 hidden items-center justify-center bg-black/50 backdrop-blur-sm z-50">

  <div class="bg-gray-900 text-white rounded-2xl shadow-2xl w-[90%] max-w-md p-7 border border-gray-800">

    <!-- Icon -->
    <div class="flex items-center justify-center mb-4">
      <div class="flex items-center justify-center w-14 h-14 rounded-full bg-red-500/20 text-red-400">
        <i class="fa-solid fa-right-from-bracket text-2xl"></i>
      </div>
    </div>

    <!-- Title -->
    <h2 class="text-xl font-semibold text-center mb-2">
      Logout from Shop?
    </h2>

    <!-- Message -->
    <p class="text-gray-400 text-center mb-6 text-sm">
      You will be signed out of your account and need to login again to continue parchese.
    </p>

    <!-- Buttons -->
    <div class="flex justify-center gap-3">

      <button id="cancelLogout" class="px-5 py-2 rounded-lg bg-gray-700 hover:bg-gray-600 transition text-sm">
        Cancel
      </button>

      <button id="confirmLogout"
        class="px-5 py-2 rounded-lg bg-red-500 hover:bg-red-600 transition text-sm font-medium shadow-lg">
        Logout
      </button>

    </div>

  </div>
</div>

<script>
  function toggleDropdown() {
    const menu = document.getElementById('dropdownMenu');
    const chevron = document.getElementById('chevronIcon');

    // Toggle visibility
    menu.classList.toggle('hidden');

    // Toggle chevron rotation
    chevron.classList.toggle('rotate-180');
  }

  // Optional: Close dropdown if user clicks anywhere else on the screen
  window.onclick = function (event) {
    if (!event.target.closest('#dropdownButton')) {
      const menu = document.getElementById('dropdownMenu');
      const chevron = document.getElementById('chevronIcon');
      if (!menu.classList.contains('hidden')) {
        menu.classList.add('hidden');
        chevron.classList.remove('rotate-180');
      }
    }
  }

</script>

<script type="module">
  import { showToast } from "../../partials/errorMsg.utils.js";

  const logoutBtn = document.getElementById("logout");
  const modal = document.getElementById("logoutModal");
  const cancelBtn = document.getElementById("cancelLogout");
  const confirmBtn = document.getElementById("confirmLogout");

  logoutBtn?.addEventListener("click", (e) => {
    e.preventDefault();
    modal.classList.remove("hidden");
    modal.classList.add("flex");
  });

  cancelBtn?.addEventListener("click", () => {
    modal.classList.add("hidden");
    modal.classList.remove("flex");
  });

  confirmBtn?.addEventListener("click", async () => {
    try {
      const response = await fetch("/auth/logout", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
      });

      if (!response.ok) throw new Error("Logout failed");

      window.location.href = "/";
    } catch (error) {
      showToast(error.message, "error");
    }
  });

  // close modal if clicking background
  modal?.addEventListener("click", (e) => {
    if (e.target === modal) {
      modal.classList.add("hidden");
      modal.classList.remove("flex");
    }
  });

</script>