<!-- Favicon -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg">
<link rel="alternate icon" href="/favicon.ico">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<script src="https://cdn.tailwindcss.com"></script>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
<script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>

<!-- Mobile search overlay -->
<div id="mobileSearchOverlay" class="fixed inset-0 bg-black/60 z-[60] hidden items-center justify-start pt-4 px-4">
  <div class="w-full max-w-2xl mx-auto">
    <form action="/search" method="GET" class="relative">
      <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400">
        <i class="fas fa-search text-sm"></i>
      </span>
      <input type="text" name="q" id="mobileSearchInput" placeholder="Search for products..."
        autofocus
        class="w-full bg-white border border-gray-300 rounded-xl py-3.5 pl-11 pr-12 text-sm focus:outline-none focus:ring-2 focus:ring-red-600 shadow-xl">
      <button type="button" onclick="closeMobileSearch()" class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-700">
        <i class="fas fa-times text-base"></i>
      </button>
    </form>
  </div>
</div>

<div class="bg-white border-b border-gray-200 py-1.5">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 flex justify-between items-center text-[12px]">
    <span class="text-gray-600 truncate">
      Summer Sale – Free Express Delivery OFF 50%!
      <a href="/shop" class="font-bold text-black underline ml-1 hover:text-red-600 transition-colors">Shop Now</a>
    </span>
  </div>
</div>

<header class="bg-white py-3 sticky top-0 z-50 border-b border-gray-200 shadow-sm">
  <div class="max-w-7xl mx-auto px-3 sm:px-6 flex items-center justify-between gap-2 sm:gap-4">

    <!-- Logo -->
    <div class="flex-shrink-0">
      <a href="/" class="text-xl sm:text-2xl font-black text-black no-underline tracking-tighter uppercase italic">
        Electro<span class="text-red-600">.</span>
      </a>
    </div>

    <!-- Desktop Search (hidden — space reserved for layout balance) -->
    <div class="flex-1 max-w-2xl hidden md:block" aria-hidden="true"></div>

    <!-- Right Actions -->
    <div class="flex items-center gap-2 sm:gap-3">

      <!-- Mobile Search Button (hidden — search disabled) -->

      <!-- User Section -->
      <div class="relative inline-block">
        <% if (typeof user !=="undefined" && user?.name) { %>

          <button onclick="toggleDropdown()" id="dropdownButton" class="group bg-gradient-to-r from-[#1e1e1e] to-[#2c2c2c] text-white 
             flex items-center gap-2 sm:gap-3 rounded-full px-3 sm:px-4 py-2 
             hover:shadow-lg transition-all duration-300 border border-gray-700">
            <div class="relative">
              <img id="headImg"
                src="<%= user.photo ? user.photo : 'https://res.cloudinary.com/dxtiklfxy/image/upload/v1773824246/profile/qhvfjaqer1o81nwkxvcz.png' %>"
                class="w-7 h-7 sm:w-8 sm:h-8 rounded-full object-cover border border-gray-600" loading="lazy"/>
              <span class="absolute bottom-0 right-0 w-2 h-2 bg-green-500 border-2 border-black rounded-full"></span>
            </div>
            <span id="headName" class="text-sm font-semibold hidden sm:inline tracking-wide max-w-[80px] truncate">
              <%= user.name %>
            </span>
            <i id="chevronIcon" class="fas fa-chevron-down text-xs transition-transform duration-300"></i>
          </button>

          <ul id="dropdownMenu" class="hidden absolute right-0 mt-3 w-56 sm:w-60 
             bg-white shadow-2xl rounded-2xl overflow-hidden border border-gray-100 z-50">
            <li class="px-5 py-4 border-b bg-gray-50">
              <p id="headName1" class="font-semibold text-gray-800 text-sm truncate"><%= user.name %></p>
              <p id="headerEmail" class="text-xs text-gray-500 truncate"><%= user.email %></p>
            </li>
            <li><a href="/myProfile" class="flex items-center gap-3 px-5 py-3 hover:bg-gray-50 transition text-sm text-gray-700"><i class="fas fa-user w-4 text-gray-400"></i> My Profile</a></li>
            <li><a href="/orders" class="flex items-center gap-3 px-5 py-3 hover:bg-gray-50 transition text-sm text-gray-700"><i class="fas fa-box w-4 text-gray-400"></i> Orders</a></li>
            <li>
              <a href="/wishlist" class="flex justify-between items-center px-5 py-3 hover:bg-gray-50 transition text-sm text-gray-700">
                <span class="flex items-center gap-3"><i class="fas fa-heart w-4 text-gray-400"></i> Wishlist</span>
                <span id="wishlistCount" class="text-xs bg-red-500 text-white px-2 py-0.5 rounded-full"><%= wishlist?.items?.length || 0 %></span>
              </a>
            </li>
            <li><a href="/wallet" class="flex items-center gap-3 px-5 py-3 hover:bg-gray-50 transition text-sm text-gray-700"><i class="fas fa-wallet w-4 text-gray-400"></i> Wallet</a></li>
            <li class="border-t">
              <a id="logout" class="flex items-center gap-3 px-5 py-3 text-red-500 hover:bg-red-50 transition cursor-pointer text-sm"><i class="fas fa-sign-out-alt w-4"></i> Logout</a>
            </li>
          </ul>

        <% } else { %>

          <button onclick="toggleDropdown()" id="dropdownButton" class="bg-gradient-to-r from-[#1e1e1e] to-[#2c2c2c] text-white 
             flex items-center gap-2 rounded-full px-4 py-2 hover:shadow-lg transition-all duration-300">
            <i class="fas fa-user-circle text-base"></i>
            <span class="text-sm font-semibold hidden sm:inline">Account</span>
            <i class="fas fa-chevron-down text-xs"></i>
          </button>

          <ul id="dropdownMenu" class="hidden absolute right-0 mt-3 w-44 bg-white shadow-2xl rounded-xl border border-gray-100 z-50">
            <li><a href="/auth/signUp" class="block px-5 py-3 hover:bg-gray-50 transition text-sm font-medium text-gray-700">Sign Up</a></li>
            <li><a href="/auth/logIn" class="block px-5 py-3 hover:bg-gray-50 transition text-sm font-medium text-gray-700">Log In</a></li>
          </ul>

        <% } %>
      </div>

      <!-- Cart + Notification -->
      <% if (typeof user !=="undefined" && user?.name) { %>
        <a href="/cart" class="relative flex items-center justify-center gap-1.5 px-2.5 sm:px-3 h-9 sm:h-10 bg-red-600 hover:bg-red-700 text-white rounded-lg transition-all duration-200 shadow-sm hover:shadow-md">
          <i class="fas fa-shopping-cart text-sm"></i>
          <span class="text-xs font-bold hidden sm:inline">Cart</span>
          <span id="cartCount" class="absolute -top-1.5 -right-1.5 bg-black text-white text-[10px] rounded-full w-4 h-4 flex items-center justify-center font-bold"><%= cart?.count || 0 %></span>
        </a>
        <button class="w-9 h-9 sm:w-10 sm:h-10 flex items-center justify-center border border-gray-200 rounded-lg text-gray-600 hover:bg-gray-50 hover:text-red-600 transition-colors relative">
          <i class="fas fa-bell text-sm"></i>
          <span class="absolute -top-1 -right-1 bg-red-600 text-white text-[10px] rounded-full w-4 h-4 flex items-center justify-center font-bold">0</span>
        </button>
      <% } %>

      <button class="w-9 h-9 sm:w-10 sm:h-10 flex items-center justify-center border border-gray-200 rounded-lg text-gray-600 hover:bg-gray-50 hover:text-red-600 transition-colors">
        <i class="fas fa-headset text-sm"></i>
      </button>
    </div>
  </div>
</header>

<!-- Logout Modal -->
<div id="logoutModal" class="fixed inset-0 hidden items-center justify-center bg-black/50 backdrop-blur-sm z-50">
  <div class="bg-gray-900 text-white rounded-2xl shadow-2xl w-[90%] max-w-md p-7 border border-gray-800">
    <div class="flex items-center justify-center mb-4">
      <div class="flex items-center justify-center w-14 h-14 rounded-full bg-red-500/20 text-red-400">
        <i class="fa-solid fa-right-from-bracket text-2xl"></i>
      </div>
    </div>
    <h2 class="text-xl font-semibold text-center mb-2">Logout from Shop?</h2>
    <p class="text-gray-400 text-center mb-6 text-sm">You will be signed out and need to login again to continue.</p>
    <div class="flex justify-center gap-3">
      <button id="cancelLogout" class="px-5 py-2 rounded-lg bg-gray-700 hover:bg-gray-600 transition text-sm">Cancel</button>
      <button id="confirmLogout" class="px-5 py-2 rounded-lg bg-red-500 hover:bg-red-600 transition text-sm font-medium shadow-lg">Logout</button>
    </div>
  </div>
</div>

<script>
  function toggleDropdown() {
    const menu = document.getElementById('dropdownMenu');
    const chevron = document.getElementById('chevronIcon');
    menu.classList.toggle('hidden');
    if (chevron) chevron.classList.toggle('rotate-180');
  }

  window.onclick = function(event) {
    if (!event.target.closest('#dropdownButton')) {
      const menu = document.getElementById('dropdownMenu');
      const chevron = document.getElementById('chevronIcon');
      if (menu && !menu.classList.contains('hidden')) {
        menu.classList.add('hidden');
        if (chevron) chevron.classList.remove('rotate-180');
      }
    }
  }

  function openMobileSearch() {
    const overlay = document.getElementById('mobileSearchOverlay');
    overlay.classList.remove('hidden');
    overlay.classList.add('flex');
    setTimeout(() => document.getElementById('mobileSearchInput')?.focus(), 100);
  }

  function closeMobileSearch() {
    const overlay = document.getElementById('mobileSearchOverlay');
    overlay.classList.add('hidden');
    overlay.classList.remove('flex');
  }

  // Close mobile search on overlay click
  document.getElementById('mobileSearchOverlay')?.addEventListener('click', function(e) {
    if (e.target === this) closeMobileSearch();
  });

  // Close on Escape key
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeMobileSearch();
  });
</script>

<script type="module">
  import { showToast } from "../../partials/errorMsg.utils.js";

  const logoutBtn = document.getElementById("logout");
  const modal = document.getElementById("logoutModal");
  const cancelBtn = document.getElementById("cancelLogout");
  const confirmBtn = document.getElementById("confirmLogout");

  logoutBtn?.addEventListener("click", (e) => {
    e.preventDefault();
    modal.classList.remove("hidden");
    modal.classList.add("flex");
  });

  cancelBtn?.addEventListener("click", () => {
    modal.classList.add("hidden");
    modal.classList.remove("flex");
  });

  confirmBtn?.addEventListener("click", async () => {
    try {
      const response = await fetch("/auth/logout", { method: "POST", headers: { "Content-Type": "application/json" } });
      if (!response.ok) throw new Error("Logout failed");
      window.location.href = "/";
    } catch (error) {
      showToast(error.message, "error");
    }
  });

  modal?.addEventListener("click", (e) => {
    if (e.target === modal) {
      modal.classList.add("hidden");
      modal.classList.remove("flex");
    }
  });
</script>