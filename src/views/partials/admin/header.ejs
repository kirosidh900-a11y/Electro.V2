<header
    class="h-20 flex items-center justify-between px-6 lg:px-10 bg-[#020406]/80 backdrop-blur-xl sticky top-0 z-30 border-b border-white/5">
    <div class="flex items-center gap-6">
        <button onclick="toggleSidebar()"
            class="p-2.5 rounded-xl bg-white/5 hover:bg-white/10 text-white transition-all active:scale-95">
            <i class="fas fa-bars-staggered text-lg"></i>
        </button>
        <h2 class="hidden md:block text-sm font-mono text-gray-500 tracking-widest uppercase">System // <span
                class="text-cyan-500">Live</span></h2>
    </div>

    <div class="flex items-center gap-4">
        <div class="text-right hidden sm:block">
            <p class="text-xs font-black text-white">
                <%= admin?.name || "Admin Root" %>
            </p>
            <p class="text-[10px] text-emerald-500 font-mono tracking-tighter uppercase">Secure</p>
        </div>
        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-cyan-500 to-blue-600 border border-white/20"></div>
    </div>
</header>