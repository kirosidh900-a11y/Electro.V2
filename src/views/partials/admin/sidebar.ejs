<div id="sidebarOverlay" onclick="toggleSidebar()" class="fixed inset-0 bg-black/80 z-40 hidden lg:hidden"></div>

<aside id="sidebar" class="fixed inset-y-0 left-0 z-50 bg-[#05070a] border-r border-white/5 flex flex-col">

    <!-- Logo -->
    <div class="p-6 flex items-center justify-between border-b border-white/5">

        <div class="flex items-center gap-3">

            <div
                class="w-9 h-9 bg-cyan-500 rounded-xl flex items-center justify-center text-white shadow-lg shadow-cyan-500/20">
                <i class="fas fa-bolt"></i>
            </div>

            <span class="text-xl font-black tracking-tighter uppercase text-white">
                Electro
            </span>

        </div>

        <button onclick="toggleSidebar()" class="lg:hidden text-gray-500 hover:text-white">
            <i class="fas fa-times"></i>
        </button>

    </div>


    <!-- Navigation -->
    <nav class="flex-1 px-4 py-8 space-y-1 overflow-y-auto">

        <p class="text-[10px] text-gray-500 font-bold uppercase tracking-widest px-4 mb-4">
            Main Menu
        </p>

        <% menu.forEach(item=> { %>

            <% if(!item.children){ %>

                <!-- Normal Menu -->
                <a href="<%= item.path %>" class="flex items-center gap-4 px-4 py-3 rounded-xl transition-all
<%= currentPath.startsWith(item.path)
? 'bg-cyan-600 text-white font-bold shadow-lg shadow-cyan-900/20'
: 'text-gray-400 hover:bg-white/5' %>">

                    <i class="<%= item.icon %> w-5"></i>
                    <%= item.name %>

                </a>

                <% } else { %>

                    <% const isParentActive=item.children.some(child=>
                        currentPath.startsWith(child.path)
                        );
                        %>

                        <!-- Parent Menu -->
                        <div class="menu-parent">

                            <button onclick="toggleMenu('<%= item.name %>')" class="flex items-center justify-between w-full px-4 py-3 rounded-xl transition
<%= isParentActive
? 'text-white'
: 'text-gray-400 hover:bg-white/5' %>">

                                <div class="flex items-center gap-4">
                                    <i class="<%= item.icon %> w-5"></i>
                                    <%= item.name %>
                                </div>

                                <i class="fas fa-chevron-down text-xs <%= isParentActive ? 'rotate-180' : '' %>"></i>

                            </button>


                            <!-- Children -->
                            <div id="submenu-<%= item.name %>"
                                class="ml-8 mt-1 space-y-1 <%= isParentActive ? '' : 'hidden' %>">

                                <% item.children.forEach(child=> { %>

                                    <a href="<%= child.path %>" class="block px-4 py-2 rounded-lg text-sm transition
<%= currentPath.startsWith(child.path)
? 'bg-cyan-600 text-white'
: 'text-gray-400 hover:bg-white/5' %>">

                                        <%= child.name %>

                                    </a>

                                    <% }) %>

                            </div>

                        </div>

                        <% } %>

                            <% }) %>

    </nav>


    <!-- Logout -->
    <div class="p-6 border-t border-white/5">

        <button id="logout"
            class="flex items-center gap-3 text-red-500 font-bold hover:bg-red-500/10 w-full p-3 rounded-xl transition-all">

            <i class="fas fa-power-off"></i>
            Logout

        </button>

    </div>

</aside>

<!-- Logout Modal -->
<div id="logoutModal" class="fixed inset-0 hidden items-center justify-center bg-black/50 backdrop-blur-sm z-50">

    <div class="bg-gray-900 text-white rounded-2xl shadow-2xl w-[90%] max-w-md p-7 border border-gray-800">

        <!-- Icon -->
        <div class="flex items-center justify-center mb-4">
            <div class="flex items-center justify-center w-14 h-14 rounded-full bg-red-500/20 text-red-400">
                <i class="fa-solid fa-right-from-bracket text-2xl"></i>
            </div>
        </div>

        <!-- Title -->
        <h2 class="text-xl font-semibold text-center mb-2">
            Logout from Dashboard?
        </h2>

        <!-- Message -->
        <p class="text-gray-400 text-center mb-6 text-sm">
            You will be signed out of your account and need to login again to continue.
        </p>

        <!-- Buttons -->
        <div class="flex justify-center gap-3">

            <button id="cancelLogout" class="px-5 py-2 rounded-lg bg-gray-700 hover:bg-gray-600 transition text-sm">
                Cancel
            </button>

            <button id="confirmLogout"
                class="px-5 py-2 rounded-lg bg-red-500 hover:bg-red-600 transition text-sm font-medium shadow-lg">
                Logout
            </button>

        </div>

    </div>
</div>

<script type="module">
    import { showToast } from "../../partials/errorMsg.utils.js";

    const logoutBtn = document.getElementById("logout");
    const modal = document.getElementById("logoutModal");
    const cancelBtn = document.getElementById("cancelLogout");
    const confirmBtn = document.getElementById("confirmLogout");

    logoutBtn?.addEventListener("click", (e) => {
        e.preventDefault();
        modal.classList.remove("hidden");
        modal.classList.add("flex");
    });

    cancelBtn?.addEventListener("click", () => {
        modal.classList.add("hidden");
        modal.classList.remove("flex");
    });

    confirmBtn?.addEventListener("click", async () => {
        try {
            const response = await fetch("/admin/logout", {
                method: "POST",
                headers: { "Content-Type": "application/json" }
            });

            if (!response.ok) throw new Error("Logout failed");

            window.location.href = "/admin";

        } catch (error) {
            showToast(error.message, "error");
        }
    });

    // close modal if clicking background
    modal?.addEventListener("click", (e) => {
        if (e.target === modal) {
            modal.classList.add("hidden");
            modal.classList.remove("flex");
        }
    });

</script>

<script>
    function toggleSidebar() {
        const body = document.body;
        const overlay = document.getElementById('sidebarOverlay');
        if (window.innerWidth >= 1024) {
            body.classList.toggle('sidebar-closed'); // Laptop Logic
        } else {
            body.classList.toggle('mobile-open'); // Phone Logic
            overlay.classList.toggle('hidden');
        }
    }

    function toggleMenu(menuName) {

        const submenu = document.getElementById(`submenu-${menuName}`);

        if (!submenu) return;

        submenu.classList.toggle("hidden");

    }
</script>