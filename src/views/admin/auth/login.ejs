<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Electro Admin | Command Center</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;500;800&display=swap');

        body {
            font-family: 'JetBrains Mono', monospace;
            background: #020406;
            color: #e2e8f0;
        }

        .hex-bg {
            background-color: #020406;
            background-image: radial-gradient(#1e293b 0.5px, transparent 0.5px);
            background-size: 24px 24px;
        }

        .terminal-panel {
            background: rgba(10, 14, 20, 0.8);
            border: 1px solid #1e293b;
            box-shadow: 0 0 40px rgba(0, 0, 0, 0.8);
        }

        .scanline {
            width: 100%;
            height: 2px;
            background: rgba(0, 210, 255, 0.1);
            position: absolute;
            top: 0;
            z-index: 20;
            animation: scan 4s linear infinite;
        }

        @keyframes scan {
            0% {
                top: 0;
            }

            100% {
                top: 100%;
            }
        }

        input:focus {
            background: rgba(0, 210, 255, 0.03) !important;
            border-color: #00d2ff !important;
            box-shadow: 0 0 10px rgba(0, 210, 255, 0.1);
        }

        .btn-primary {
            background: #00d2ff;
            color: #020406;
            transition: all 0.2s ease;
        }

        .btn-primary:hover {
            background: #ffffff;
            box-shadow: 0 0 20px rgba(255, 255, 255, 0.2);
        }
    </style>
</head>

<body class="min-h-screen flex items-center justify-center p-6 hex-bg relative overflow-hidden">

    <div class="scanline"></div>

    <div
        class="max-w-4xl w-full flex flex-col md:flex-row terminal-panel rounded-lg overflow-hidden relative z-10 border-t-4 border-t-[#00d2ff]">

        <div class="hidden md:flex md:w-1/3 p-8 flex-col bg-black/40 border-r border-white/5">
            <div class="mb-10">
                <div class="flex items-center gap-2 mb-1">
                    <i class="fas fa-bolt text-[#00d2ff]"></i>
                    <span class="text-lg font-800 tracking-tighter">ELECTRO<span
                            class="text-white/30 font-light">_v3</span></span>
                </div>
                <div class="text-[10px] text-gray-500 font-mono">CORE ADMIN INTERFACE</div>
            </div>

            <div class="space-y-6">
                <div>
                    <div class="text-[10px] text-gray-500 mb-2 uppercase tracking-widest">Environment</div>
                    <div class="text-xs text-white flex items-center gap-2">
                        <span class="w-2 h-2 rounded-full bg-emerald-500"></span>
                        PRODUCTION_NODE_01
                    </div>
                </div>

                <div>
                    <div class="text-[10px] text-gray-500 mb-2 uppercase tracking-widest">Encryption</div>
                    <div class="text-xs text-white">RSA_4096_BIT</div>
                </div>

                <div>
                    <div class="text-[10px] text-gray-500 mb-2 uppercase tracking-widest">IP_RESOLVER</div>
                    <div class="text-xs text-cyan-400 font-mono">192.168.1.104</div>
                </div>
            </div>

            <div class="mt-auto opacity-20">
                <i class="fas fa-microchip text-6xl"></i>
            </div>
        </div>

        <div class="w-full md:w-2/3 p-10 md:p-16">
            <div class="mb-10">
                <div class="inline-block px-2 py-1 bg-[#00d2ff]/10 text-[#00d2ff] text-[10px] font-bold rounded mb-4">
                    SECURE GATEWAY</div>
                <h2 class="text-2xl font-bold text-white mb-2 italic">INITIALIZE LOGIN</h2>
                <div class="h-1 w-12 bg-[#00d2ff]"></div>
            </div>

            <form id="loginForm" class="space-y-6">
                <div class="space-y-2">
                    <div class="flex justify-between">
                        <label class="text-[10px] font-bold text-gray-500 uppercase tracking-widest">Admin
                            Identifier</label>
                    </div>
                    <div class="relative">
                        <input id="email" type="email" name="email" required
                            class="w-full bg-[#05070a] border border-white/10 rounded px-4 py-4 focus:outline-none transition-all text-sm font-mono text-white"
                            placeholder="admin@electro.root">
                    </div>
                </div>

                <div class="space-y-2">
                    <div class="flex justify-between items-center">
                        <label class="text-[10px] font-bold text-gray-500 uppercase tracking-widest">Secret Key</label>
                        <a href="/admin/forgot"
                            class="text-[10px] text-[#00d2ff] hover:underline uppercase tracking-tighter">Forgot
                            Key?</a>
                    </div>
                    <div class="relative">
                        <input id="password" type="password" name="password" required
                            class="w-full bg-[#05070a] border border-white/10 rounded px-4 py-4 focus:outline-none transition-all text-sm font-mono text-white"
                            placeholder="****************">
                    </div>
                </div>

                <button type="submit"
                    class="btn-primary w-full font-800 py-4 rounded text-xs uppercase tracking-[0.3em] flex items-center justify-center gap-3">
                    EXECUTE_LOGIN
                </button>
            </form>

            <div class="mt-12 flex items-center justify-between border-t border-white/5 pt-6 font-mono">
                <div class="flex flex-col">
                    <span class="text-[8px] text-gray-600 uppercase">Latency</span>
                    <span class="text-[10px] text-emerald-500">24ms</span>
                </div>
                <div class="flex flex-col">
                    <span class="text-[8px] text-gray-600 uppercase">Uptime</span>
                    <span class="text-[10px] text-white">99.9%</span>
                </div>
                <div class="flex flex-col">
                    <span class="text-[8px] text-gray-600 uppercase">Auth_Mode</span>
                    <span class="text-[10px] text-white">OAUTH2</span>
                </div>
                <div class="flex flex-col items-end">
                    <span class="text-[8px] text-gray-600 uppercase">Session</span>
                    <span class="text-[10px] text-white">TLS_1.3</span>
                </div>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="/admin/js/auth.public.js"></script>
</body>

</html>