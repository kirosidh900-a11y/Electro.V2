<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <%- include('../partials/head') %>
</head>
<body class="min-h-screen flex">

  <%- include('../partials/admin/sidebar') %>

  <div id="mainContent" class="flex-1 flex flex-col min-w-0 transition-all duration-300">
    <%- include('../partials/admin/header') %>

    <main class="flex-1 flex items-center justify-center p-8">
      <div class="text-center max-w-md">

        <div class="text-8xl font-black text-white/10 mb-4 select-none">404</div>

        <div class="w-16 h-16 bg-cyan-500/10 rounded-2xl flex items-center justify-center mx-auto mb-6">
          <i class="fas fa-map-signs text-cyan-400 text-2xl"></i>
        </div>

        <h1 class="text-2xl font-bold text-white mb-2">Page Not Found</h1>
        <p class="text-gray-400 text-sm mb-8">
          The page you're looking for doesn't exist or has been moved.
        </p>

        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a href="/admin/dashboard"
            class="px-6 py-2.5 bg-cyan-600 hover:bg-cyan-700 text-white text-sm font-semibold rounded-lg transition">
            <i class="fas fa-home mr-2"></i>Go to Dashboard
          </a>
          <button onclick="history.back()"
            class="px-6 py-2.5 bg-white/5 hover:bg-white/10 text-gray-300 text-sm font-semibold rounded-lg border border-white/10 transition">
            <i class="fas fa-arrow-left mr-2"></i>Go Back
          </button>
        </div>

      </div>
    </main>
  </div>

</body>
</html>
