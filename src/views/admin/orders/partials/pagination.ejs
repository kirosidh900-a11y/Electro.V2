<%
  const makeLink = (page) => {
    const params = new URLSearchParams(query || {});
    params.set("page", page);
    return `/admin/orders?${params.toString()}`;
  };

  const WINDOW = 2;
  const pages  = [];

  if (totalPages > 1) {
    pages.push(1);
    if (currentPage - WINDOW > 2)          pages.push(null);
    for (let i = Math.max(2, currentPage - WINDOW); i <= Math.min(totalPages - 1, currentPage + WINDOW); i++) {
      pages.push(i);
    }
    if (currentPage + WINDOW < totalPages - 1) pages.push(null);
    if (totalPages > 1) pages.push(totalPages);
  }
%>

<% if (totalPages > 1) { %>
<div class="flex items-center justify-center gap-1.5 flex-wrap">

  <%# Prev %>
  <a href="<%= makeLink(currentPage - 1) %>" data-page="<%= currentPage - 1 %>"
     class="pagination-link flex items-center gap-1.5 px-3 py-2 rounded-lg text-xs font-medium transition
            <%= currentPage === 1 ? 'opacity-30 pointer-events-none bg-white/5 text-gray-500' : 'bg-white/5 hover:bg-white/10 text-gray-300' %>">
    <i class="fas fa-chevron-left text-[10px]"></i> Prev
  </a>

  <% pages.forEach(p => { %>
    <% if (p === null) { %>
      <span class="px-2 py-2 text-gray-600 text-xs select-none">•••</span>
    <% } else { %>
      <a href="<%= makeLink(p) %>" data-page="<%= p %>"
         class="pagination-link w-9 h-9 flex items-center justify-center rounded-lg text-sm font-semibold transition
                <%= p === currentPage
                  ? 'bg-cyan-600 text-white shadow-lg shadow-cyan-900/30'
                  : 'bg-white/5 hover:bg-white/10 text-gray-300' %>">
        <%= p %>
      </a>
    <% } %>
  <% }) %>

  <%# Next %>
  <a href="<%= makeLink(currentPage + 1) %>" data-page="<%= currentPage + 1 %>"
     class="pagination-link flex items-center gap-1.5 px-3 py-2 rounded-lg text-xs font-medium transition
            <%= currentPage === totalPages ? 'opacity-30 pointer-events-none bg-white/5 text-gray-500' : 'bg-white/5 hover:bg-white/10 text-gray-300' %>">
    Next <i class="fas fa-chevron-right text-[10px]"></i>
  </a>

</div>
<% } %>
