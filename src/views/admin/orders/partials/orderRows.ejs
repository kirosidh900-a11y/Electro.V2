<% if (!orders || orders.length === 0) { %>
  <tr>
    <td colspan="9" class="text-center py-12 text-gray-500">
      <i class="fas fa-box text-2xl mb-2 block"></i>
      <p>No orders found</p>
    </td>
  </tr>
<% } else { %>
  <% orders.forEach((order, index) => { %>
    <% const status = (order.orderStatus || "").toLowerCase(); %>
    <% const paymentStatus = (order.payment?.status || "").toLowerCase(); %>

    <tr
      id="row-<%= order._id %>"
      onclick="location.href='/admin/orders/<%= order._id %>'"
      class="border-b border-white/5 hover:bg-white/5 cursor-pointer"
    >
      <td class="px-6 py-4 text-gray-400">
        <%= (currentPage - 1) * limit + index + 1 %>
      </td>

      <td class="px-6 py-4 font-semibold text-white">
        <%= order.orderNumber %>
      </td>

      <td class="px-6 py-4">
        <div class="flex flex-col">
          <span class="text-gray-200 font-medium"><%= order.user.name || "-" %></span>
          <span class="text-xs text-gray-500"><%= order.user.email || "" %></span>
        </div>
      </td>

      <td class="px-6 py-4 text-gray-300">
        <%= order.itemsCount || 0 %>
      </td>

      <td class="px-6 py-4 text-gray-300">
        ₹<%= order.pricing?.finalAmount ?? 0 %>
      </td>

      <td class="px-6 py-4">
        <div class="flex flex-col gap-1">
          <span class="text-xs uppercase text-gray-200">
            <%= order.paymentMethodLabel || order.payment?.method || "-" %>
          </span>
          <span class="text-[11px] px-2 py-1 rounded-full w-fit
            <%= paymentStatus === 'paid' ? 'bg-emerald-500/20 text-emerald-400' :
                paymentStatus === 'refunded' ? 'bg-blue-500/20 text-blue-400' :
                paymentStatus === 'failed' ? 'bg-red-500/20 text-red-400' :
                'bg-yellow-500/20 text-yellow-400' %>">
            <%= order.paymentStatusLabel || order.payment?.status || "-" %>
          </span>
        </div>
      </td>

      <td class="px-6 py-4">
        <span class="px-3 py-1 rounded-full text-xs
          <%= status === 'delivered' ? 'bg-emerald-500/20 text-emerald-400' :
              status === 'cancelled' ? 'bg-red-500/20 text-red-400' :
              status === 'confirmed' ? 'bg-cyan-500/20 text-cyan-400' :
              status === 'shipped' ? 'bg-violet-500/20 text-violet-400' :
              status === 'out_for_delivery' ? 'bg-blue-500/20 text-blue-400' :
              'bg-yellow-500/20 text-yellow-400' %>">
          <%= order.statusLabel || order.orderStatus %>
        </span>
      </td>

      <td class="px-6 py-4 text-xs text-gray-400">
        <%= new Date(order.createdAt).toLocaleDateString('en-IN', {
          day: '2-digit',
          month: 'short',
          year: 'numeric'
        }) %>
      </td>

      <td class="px-6 py-4 text-right">
        <a
          href="/admin/orders/<%= order._id %>"
          class="inline-flex items-center gap-2 px-3 py-1.5 rounded-md text-xs bg-cyan-500/20 text-cyan-400 hover:bg-cyan-500/30"
          onclick="event.stopPropagation()"
        >
          View
        </a>
      </td>
    </tr>
  <% }) %>
<% } %>