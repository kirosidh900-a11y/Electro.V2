<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <%- include('../../partials/head') %>
</head>
<body class="min-h-screen flex">

  <%- include('../../partials/admin/sidebar') %>

  <div id="mainContent" class="flex-1 flex flex-col min-w-0 transition-all duration-300">
    <%- include('../../partials/admin/header') %>

    <main class="flex-1 p-4 sm:p-6 lg:p-8 w-full space-y-6">

      <!-- Page Header -->
      <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
        <div>
          <h1 class="text-2xl font-bold text-white tracking-tight flex items-center gap-2">
            <i class="fas fa-rotate-left text-amber-400 text-xl"></i>
            Return Requests
          </h1>
          <p class="text-sm text-gray-400 mt-1">
            Manage customer return requests — approve, schedule pickup, and process refunds
          </p>
        </div>
        <a href="/admin/orders"
          class="inline-flex items-center gap-2 px-4 py-2 text-xs font-semibold text-gray-300 bg-white/5 hover:bg-white/10 border border-white/10 rounded-xl transition">
          <i class="fas fa-clipboard-list text-cyan-400"></i> All Orders
        </a>
      </div>

      <!-- Stats Cards -->
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
        <%
          const completedCount = (counts.returned || 0) + (counts.refund_processed || 0);
          const statCards = [
            { label: 'Total',            key: 'total',             count: counts.total,      icon: 'fas fa-layer-group',  color: 'text-gray-300',    bg: 'bg-white/5',        border: 'border-white/10',       href: '' },
            { label: 'Pending Review',   key: 'return_requested',  count: counts.return_requested,  icon: 'fas fa-clock',         color: 'text-amber-400',   bg: 'bg-amber-500/10',   border: 'border-amber-500/20',   href: '?status=return_requested' },
            { label: 'Approved',         key: 'return_approved',   count: counts.return_approved,   icon: 'fas fa-circle-check',  color: 'text-blue-400',    bg: 'bg-blue-500/10',    border: 'border-blue-500/20',    href: '?status=return_approved' },
            { label: 'Pickup Scheduled', key: 'pickup_scheduled',  count: counts.pickup_scheduled,  icon: 'fas fa-truck',         color: 'text-purple-400',  bg: 'bg-purple-500/10',  border: 'border-purple-500/20',  href: '?status=pickup_scheduled' },
            { label: 'Completed',        key: 'returned',          count: completedCount,    icon: 'fas fa-box-open',     color: 'text-emerald-400', bg: 'bg-emerald-500/10', border: 'border-emerald-500/20', href: '?status=returned' },
          ];
        %>
        <% statCards.forEach(card => { %>
          <a href="/admin/returns<%= card.href %>"
            class="<%= card.bg %> border <%= card.border %> rounded-2xl p-4 flex flex-col gap-1 hover:brightness-110 transition cursor-pointer
              <%= filterStatus === card.key || (card.key === 'total' && !filterStatus) ? 'ring-2 ring-offset-1 ring-offset-[#060d1a] ring-current ' + card.color : '' %>">
            <div class="flex items-center justify-between mb-1">
              <i class="<%= card.icon %> text-sm <%= card.color %>"></i>
              <% if (card.key === 'return_requested' && counts.return_requested > 0) { %>
                <span class="w-2 h-2 rounded-full bg-amber-400 animate-pulse"></span>
              <% } %>
            </div>
            <p class="text-2xl font-black <%= card.color %>"><%= card.count || 0 %></p>
            <p class="text-[11px] text-gray-400 font-medium leading-tight"><%= card.label %></p>
          </a>
        <% }) %>
      </div>

      <!-- Filters Bar -->
      <div class="w-full bg-[#0b1220] border border-white/5 rounded-2xl p-4 flex flex-wrap gap-3 items-center">
        <div class="flex items-center gap-2 text-xs text-gray-400 font-semibold uppercase tracking-widest">
          <i class="fas fa-filter text-gray-600"></i> Filter
        </div>
        <div class="flex flex-wrap gap-2 flex-1">
          <%
            const filterTabs = [
              { value: '',                 label: 'All',              color: 'text-gray-300 border-gray-600 hover:border-gray-400' },
              { value: 'return_requested', label: 'Pending Review',   color: 'text-amber-400 border-amber-500/40 hover:border-amber-400' },
              { value: 'return_approved',  label: 'Approved',         color: 'text-blue-400 border-blue-500/40 hover:border-blue-400' },
              { value: 'pickup_scheduled', label: 'Pickup Scheduled', color: 'text-purple-400 border-purple-500/40 hover:border-purple-400' },
              { value: 'returned',         label: 'Returned',         color: 'text-emerald-400 border-emerald-500/40 hover:border-emerald-400' },
              { value: 'return_rejected',  label: 'Rejected',         color: 'text-red-400 border-red-500/40 hover:border-red-400' },
            ];
          %>
          <% filterTabs.forEach(tab => { %>
            <a href="/admin/returns?status=<%= tab.value %>&page=1"
              class="px-3 py-1.5 text-xs font-semibold rounded-lg border transition
                <%= filterStatus === tab.value ? 'bg-white/10 ' + tab.color : 'bg-transparent border-white/10 text-gray-500 hover:text-gray-300 hover:border-white/20' %>">
              <%= tab.label %>
              <% if (tab.value && counts[tab.value] > 0) { %>
                <span class="ml-1 px-1.5 py-0.5 rounded-full text-[10px] font-bold bg-white/10"><%= counts[tab.value] %></span>
              <% } %>
            </a>
          <% }) %>
        </div>
      </div>

      <!-- Main Content: Table or Empty State -->
      <% if (!items || items.length === 0) { %>

        <!-- Empty State -->
        <div class="w-full bg-[#0b1220] border border-white/5 rounded-3xl shadow-xl flex flex-col items-center justify-center py-24 px-6 text-center">
          <div class="w-20 h-20 rounded-full bg-white/5 flex items-center justify-center mb-5">
            <i class="fas fa-rotate-left text-3xl text-gray-600"></i>
          </div>
          <h3 class="text-white font-bold text-lg mb-2">
            <% if (filterStatus) { %>
              No <%= filterStatus.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase()) %> requests
            <% } else { %>
              No return requests yet
            <% } %>
          </h3>
          <p class="text-gray-500 text-sm max-w-sm">
            <% if (filterStatus) { %>
              There are no return requests with this status right now. Try a different filter or check back later.
            <% } else { %>
              When customers request returns, they'll show up here. You can approve, schedule pickups, and process refunds all from this page.
            <% } %>
          </p>
          <% if (filterStatus) { %>
            <a href="/admin/returns"
              class="mt-6 px-5 py-2 text-sm font-semibold bg-white/5 hover:bg-white/10 text-gray-300 border border-white/10 rounded-xl transition">
              <i class="fas fa-xmark mr-1.5"></i> Clear Filter
            </a>
          <% } %>
        </div>

      <% } else { %>

        <!-- Returns Table -->
        <div class="w-full bg-[#0b1220] border border-white/5 rounded-3xl shadow-xl overflow-x-auto">
          <table class="w-full text-sm text-left text-gray-300">
            <thead class="bg-white/5 text-gray-400 uppercase text-xs tracking-widest border-b border-white/5">
              <tr>
                <th class="px-5 py-4">#</th>
                <th class="px-5 py-4">Order</th>
                <th class="px-5 py-4">Customer</th>
                <th class="px-5 py-4">Product</th>
                <th class="px-5 py-4">Return Info</th>
                <th class="px-5 py-4">Status</th>
                <th class="px-5 py-4">Timeline</th>
                <th class="px-5 py-4 text-right">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% items.forEach((item, idx) => { %>
                <%
                  const statusMeta = {
                    return_requested: { color: 'bg-amber-500/20 text-amber-400',    label: 'Pending Review'    },
                    return_approved:  { color: 'bg-blue-500/20 text-blue-400',      label: 'Approved'          },
                    pickup_scheduled: { color: 'bg-purple-500/20 text-purple-400',  label: 'Pickup Scheduled'  },
                    returned:         { color: 'bg-emerald-500/20 text-emerald-400', label: 'Returned'         },
                    refund_processed: { color: 'bg-emerald-500/20 text-emerald-400', label: 'Returned & Refunded' },
                    return_rejected:  { color: 'bg-red-500/20 text-red-400',        label: 'Rejected'          },
                  };
                  const meta = statusMeta[item.itemStatus] || { color: 'bg-gray-500/20 text-gray-400', label: item.itemStatus };

                  const conditionLabels = {
                    sealed_new:    { label: 'Sealed / New',       color: 'text-emerald-400' },
                    opened_good:   { label: 'Opened, Good',       color: 'text-cyan-400'    },
                    damaged:       { label: 'Damaged',            color: 'text-red-400'     },
                    missing_parts: { label: 'Missing Parts',      color: 'text-amber-400'   },
                    defective:     { label: 'Defective',          color: 'text-red-400'     },
                  };
                  const cond = conditionLabels[item.return?.itemCondition];
                %>
                <tr class="border-b border-white/5 hover:bg-white/[0.03] transition group" id="return-row-<%= item._id %>">

                  <!-- # -->
                  <td class="px-5 py-4 text-gray-600 text-xs font-mono">
                    <%= (currentPage - 1) * 10 + idx + 1 %>
                  </td>

                  <!-- Order -->
                  <td class="px-5 py-4">
                    <a href="/admin/orders/<%= item.orderId %>"
                      class="text-cyan-400 hover:text-cyan-300 font-mono text-xs font-bold transition">
                      #<%= item.order?.orderNumber || String(item.orderId).slice(-6).toUpperCase() %>
                    </a>
                    <p class="text-[11px] text-gray-600 mt-0.5 uppercase">
                      <%= item.order?.payment?.method || '' %>
                    </p>
                  </td>

                  <!-- Customer -->
                  <td class="px-5 py-4">
                    <p class="text-white text-xs font-semibold"><%= item.order?.userId?.name || '—' %></p>
                    <p class="text-gray-500 text-[11px] mt-0.5 truncate max-w-[140px]"><%= item.order?.userId?.email || '' %></p>
                  </td>

                  <!-- Product -->
                  <td class="px-5 py-4">
                    <div class="flex items-center gap-3">
                      <% if (item.images?.[0]) { %>
                        <img src="<%= item.images[0] %>"
                          class="w-11 h-11 object-contain rounded-xl bg-white/5 border border-white/10 p-1 shrink-0">
                      <% } else { %>
                        <div class="w-11 h-11 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center shrink-0">
                          <i class="fas fa-box text-gray-600 text-xs"></i>
                        </div>
                      <% } %>
                      <div class="min-w-0">
                        <p class="text-white text-xs font-medium line-clamp-1 max-w-[160px]"><%= item.name %></p>
                        <% if (item.attributes && Object.keys(item.attributes).length) { %>
                          <p class="text-gray-500 text-[11px] mt-0.5">
                            <%= Object.values(item.attributes).join(' · ') %>
                          </p>
                        <% } %>
                        <p class="text-gray-600 text-[11px]">Qty: <%= item.quantity %> &nbsp;·&nbsp; ₹<%= item.pricing?.total?.toLocaleString('en-IN') || '—' %></p>
                      </div>
                    </div>
                  </td>

                  <!-- Return Info -->
                  <td class="px-5 py-4">
                    <p class="text-xs text-gray-200 capitalize font-medium">
                      <%= (item.return?.reason || '—').replace(/_/g, ' ') %>
                    </p>
                    <% if (cond) { %>
                      <p class="text-[11px] mt-0.5 <%= cond.color %>">
                        <i class="fas fa-box text-[9px] mr-1"></i><%= cond.label %>
                      </p>
                    <% } %>
                    <% if (item.return?.comments) { %>
                      <p class="text-[11px] text-gray-500 mt-0.5 line-clamp-1 max-w-[160px]" title="<%= item.return.comments %>">
                        "<%= item.return.comments %>"
                      </p>
                    <% } %>
                    <% if (item.return?.rejectReason) { %>
                      <p class="text-[11px] text-red-400 mt-0.5 line-clamp-1">
                        <i class="fas fa-ban text-[9px] mr-1"></i><%= item.return.rejectReason %>
                      </p>
                    <% } %>
                  </td>

                  <!-- Status -->
                  <td class="px-5 py-4">
                    <span class="px-2.5 py-1 rounded-full text-[11px] font-bold uppercase tracking-wide whitespace-nowrap <%= meta.color %>">
                      <%= meta.label %>
                    </span>
                    <% if (item.itemStatus === 'pickup_scheduled' && item.return?.pickupDate) { %>
                      <p class="text-[11px] text-purple-300 mt-1">
                        <i class="fas fa-calendar-day text-[9px] mr-1"></i>
                        <%= new Date(item.return.pickupDate).toLocaleDateString('en-IN', { day:'numeric', month:'short' }) %>
                      </p>
                    <% } %>
                    <% if (item.refund?.status === 'processed') { %>
                      <p class="text-[11px] text-emerald-400 mt-1">
                        <i class="fas fa-wallet text-[9px] mr-1"></i>₹<%= item.refund.amount?.toLocaleString('en-IN') %> refunded
                      </p>
                    <% } %>
                  </td>

                  <!-- Timeline -->
                  <td class="px-5 py-4 text-[11px] text-gray-500 space-y-0.5 whitespace-nowrap">
                    <% if (item.return?.requestedAt) { %>
                      <p><span class="text-gray-600">Req:</span>
                        <%= new Date(item.return.requestedAt).toLocaleDateString('en-IN', { day:'numeric', month:'short' }) %>
                      </p>
                    <% } %>
                    <% if (item.return?.approvedAt) { %>
                      <p><span class="text-gray-600">Appr:</span>
                        <%= new Date(item.return.approvedAt).toLocaleDateString('en-IN', { day:'numeric', month:'short' }) %>
                      </p>
                    <% } %>
                    <% if (item.return?.completedAt) { %>
                      <p><span class="text-gray-600">Done:</span>
                        <%= new Date(item.return.completedAt).toLocaleDateString('en-IN', { day:'numeric', month:'short' }) %>
                      </p>
                    <% } %>
                    <% if (!item.return?.requestedAt && !item.return?.approvedAt) { %>
                      <p><%= new Date(item.updatedAt).toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' }) %></p>
                    <% } %>
                  </td>

                  <!-- Actions -->
                  <td class="px-5 py-4 text-right">
                    <div class="flex justify-end gap-2 flex-wrap">

                      <% if (item.itemStatus === 'return_requested') { %>
                        <button onclick="handleReturn('<%= item._id %>', 'approve')"
                          class="px-3 py-1.5 text-xs font-semibold bg-emerald-500/20 text-emerald-400 hover:bg-emerald-500/30 border border-emerald-500/20 rounded-lg transition">
                          <i class="fas fa-check mr-1"></i>Approve
                        </button>
                        <button onclick="openRejectModal('<%= item._id %>')"
                          class="px-3 py-1.5 text-xs font-semibold bg-red-500/20 text-red-400 hover:bg-red-500/30 border border-red-500/20 rounded-lg transition">
                          <i class="fas fa-xmark mr-1"></i>Reject
                        </button>
                      <% } %>

                      <% if (item.itemStatus === 'return_approved') { %>
                        <button onclick="openPickupModal('<%= item._id %>')"
                          class="px-3 py-1.5 text-xs font-semibold bg-purple-500/20 text-purple-400 hover:bg-purple-500/30 border border-purple-500/20 rounded-lg transition">
                          <i class="fas fa-truck mr-1"></i>Schedule Pickup
                        </button>
                      <% } %>

                      <% if (item.itemStatus === 'pickup_scheduled') { %>
                        <button onclick="completeReturn('<%= item._id %>')"
                          class="px-3 py-1.5 text-xs font-semibold bg-cyan-500/20 text-cyan-400 hover:bg-cyan-500/30 border border-cyan-500/20 rounded-lg transition">
                          <i class="fas fa-box-open mr-1"></i>Mark Returned
                        </button>
                      <% } %>

                      <a href="/admin/orders/<%= item.orderId %>"
                        class="px-3 py-1.5 text-xs font-semibold bg-white/5 text-gray-400 hover:bg-white/10 border border-white/10 rounded-lg transition">
                        <i class="fas fa-eye mr-1"></i>View
                      </a>

                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

        <!-- Pagination -->
        <% if (totalPages > 1) { %>
          <div class="flex flex-wrap justify-center items-center gap-2 mt-2">
            <% if (currentPage > 1) { %>
              <a href="?page=<%= currentPage - 1 %>&status=<%= filterStatus %>"
                class="px-4 py-2 text-sm bg-[#0b1220] border border-white/10 text-gray-300 rounded-xl hover:bg-white/5 transition">
                <i class="fas fa-chevron-left text-xs mr-1"></i> Prev
              </a>
            <% } %>
            <% for (let p = 1; p <= totalPages; p++) { %>
              <a href="?page=<%= p %>&status=<%= filterStatus %>"
                class="px-4 py-2 text-sm rounded-xl border transition
                  <%= p === currentPage ? 'bg-cyan-600 border-cyan-600 text-white font-bold' : 'bg-[#0b1220] border-white/10 text-gray-300 hover:bg-white/5' %>">
                <%= p %>
              </a>
            <% } %>
            <% if (currentPage < totalPages) { %>
              <a href="?page=<%= currentPage + 1 %>&status=<%= filterStatus %>"
                class="px-4 py-2 text-sm bg-[#0b1220] border border-white/10 text-gray-300 rounded-xl hover:bg-white/5 transition">
                Next <i class="fas fa-chevron-right text-xs ml-1"></i>
              </a>
            <% } %>
          </div>
        <% } %>

      <% } %>

    </main>
  </div>

  <!-- ── Reject Modal ── -->
  <div id="rejectModal" class="fixed inset-0 bg-black/70 backdrop-blur-sm hidden z-50 flex items-center justify-center p-4">
    <div class="bg-[#0b1220] w-full max-w-md rounded-2xl border border-white/10 shadow-2xl overflow-hidden">
      <div class="flex items-center justify-between px-6 py-4 border-b border-white/10 bg-white/5">
        <div class="flex items-center gap-2">
          <div class="w-7 h-7 rounded-full bg-red-500/20 flex items-center justify-center">
            <i class="fas fa-xmark text-red-400 text-xs"></i>
          </div>
          <h3 class="text-white font-bold text-sm">Reject Return Request</h3>
        </div>
        <button onclick="closeRejectModal()" class="text-gray-500 hover:text-white transition">
          <i class="fas fa-times"></i>
        </button>
      </div>
      <div class="p-6 space-y-4">
        <input type="hidden" id="rejectItemId">
        <div>
          <label class="text-xs text-gray-400 uppercase tracking-widest mb-2 block">
            Rejection Reason <span class="text-red-400">*</span>
          </label>
          <textarea id="rejectReason" rows="3"
            placeholder="Explain why the return is being rejected..."
            class="w-full bg-[#0f172a] border border-white/10 text-gray-200 text-sm rounded-xl px-4 py-3 focus:outline-none focus:border-red-500 resize-none placeholder-gray-600 transition"></textarea>
          <span id="rejectReasonError" class="text-red-400 text-xs mt-1 hidden block">
            <i class="fas fa-exclamation-circle mr-1"></i>Reason is required
          </span>
        </div>
        <div class="flex justify-end gap-3 pt-2">
          <button onclick="closeRejectModal()"
            class="px-4 py-2 text-sm bg-white/5 hover:bg-white/10 text-gray-300 border border-white/10 rounded-xl transition">
            Cancel
          </button>
          <button onclick="submitReject()"
            class="px-5 py-2 text-sm bg-red-600 hover:bg-red-700 text-white rounded-xl font-semibold transition">
            <i class="fas fa-xmark mr-1.5"></i>Reject Return
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- ── Pickup Modal ── -->
  <div id="pickupModal" class="fixed inset-0 bg-black/70 backdrop-blur-sm hidden z-50 flex items-center justify-center p-4">
    <div class="bg-[#0b1220] w-full max-w-sm rounded-2xl border border-white/10 shadow-2xl overflow-hidden">
      <div class="flex items-center justify-between px-6 py-4 border-b border-white/10 bg-white/5">
        <div class="flex items-center gap-2">
          <div class="w-7 h-7 rounded-full bg-purple-500/20 flex items-center justify-center">
            <i class="fas fa-truck text-purple-400 text-xs"></i>
          </div>
          <h3 class="text-white font-bold text-sm">Schedule Pickup</h3>
        </div>
        <button onclick="closePickupModal()" class="text-gray-500 hover:text-white transition">
          <i class="fas fa-times"></i>
        </button>
      </div>
      <div class="p-6 space-y-4">
        <input type="hidden" id="pickupItemId">
        <div>
          <label class="text-xs text-gray-400 uppercase tracking-widest mb-2 block">
            Pickup Date <span class="text-red-400">*</span>
          </label>
          <input type="date" id="pickupDate"
            min="<%= new Date().toISOString().split('T')[0] %>"
            class="w-full bg-[#0f172a] border border-white/10 text-gray-200 text-sm rounded-xl px-4 py-3 focus:outline-none focus:border-purple-500 transition">
          <span id="pickupDateError" class="text-red-400 text-xs mt-1 hidden block">
            <i class="fas fa-exclamation-circle mr-1"></i>Date is required
          </span>
        </div>
        <p class="text-xs text-gray-500">
          <i class="fas fa-info-circle mr-1 text-gray-600"></i>
          The customer will be notified about the scheduled pickup date.
        </p>
        <div class="flex justify-end gap-3 pt-2">
          <button onclick="closePickupModal()"
            class="px-4 py-2 text-sm bg-white/5 hover:bg-white/10 text-gray-300 border border-white/10 rounded-xl transition">
            Cancel
          </button>
          <button onclick="submitPickup()"
            class="px-5 py-2 text-sm bg-purple-600 hover:bg-purple-700 text-white rounded-xl font-semibold transition">
            <i class="fas fa-truck mr-1.5"></i>Schedule
          </button>
        </div>
      </div>
    </div>
  </div>

  <script type="module">
    import { showToast } from "../../partials/errorMsg.utils.js";
    import { confirmAction } from "../../partials/confirm.util.js";

    // ── Reject Modal ──────────────────────────────────────────────────────────
    function openRejectModal(itemId) {
      document.getElementById('rejectItemId').value = itemId;
      document.getElementById('rejectReason').value = '';
      document.getElementById('rejectReasonError').classList.add('hidden');
      document.getElementById('rejectModal').classList.remove('hidden');
    }
    window.openRejectModal = openRejectModal;

    function closeRejectModal() {
      document.getElementById('rejectModal').classList.add('hidden');
    }
    window.closeRejectModal = closeRejectModal;

    async function submitReject() {
      const itemId = document.getElementById('rejectItemId').value;
      const reason = document.getElementById('rejectReason').value.trim();
      if (!reason) {
        document.getElementById('rejectReasonError').classList.remove('hidden');
        return;
      }
      try {
        const res  = await fetch(`/admin/returns/${itemId}`, {
          method:  'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body:    JSON.stringify({ action: 'reject', rejectReason: reason }),
        });
        const data = await res.json();
        if (!data.success) throw new Error(data.message);
        showToast('Return request rejected', 'success');
        closeRejectModal();
        setTimeout(() => location.reload(), 800);
      } catch (err) {
        showToast(err.message || 'Something went wrong', 'error');
      }
    }
    window.submitReject = submitReject;

    // ── Approve ───────────────────────────────────────────────────────────────
    async function handleReturn(itemId, action) {
      const confirmed = await confirmAction(
        action === 'approve'
          ? 'Approve this return request?'
          : 'Reject this return request?'
      );
      if (!confirmed) return;
      try {
        const res  = await fetch(`/admin/returns/${itemId}`, {
          method:  'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body:    JSON.stringify({ action }),
        });
        const data = await res.json();
        if (!data.success) throw new Error(data.message);
        showToast(`Return ${action}d successfully`, 'success');
        setTimeout(() => location.reload(), 800);
      } catch (err) {
        showToast(err.message || 'Something went wrong', 'error');
      }
    }
    window.handleReturn = handleReturn;

    // ── Pickup Modal ──────────────────────────────────────────────────────────
    function openPickupModal(itemId) {
      document.getElementById('pickupItemId').value = itemId;
      document.getElementById('pickupDate').value   = '';
      document.getElementById('pickupDateError').classList.add('hidden');
      document.getElementById('pickupModal').classList.remove('hidden');
    }
    window.openPickupModal = openPickupModal;

    function closePickupModal() {
      document.getElementById('pickupModal').classList.add('hidden');
    }
    window.closePickupModal = closePickupModal;

    async function submitPickup() {
      const itemId     = document.getElementById('pickupItemId').value;
      const pickupDate = document.getElementById('pickupDate').value;
      if (!pickupDate) {
        document.getElementById('pickupDateError').classList.remove('hidden');
        return;
      }
      try {
        const res  = await fetch(`/admin/returns/pickup/${itemId}`, {
          method:  'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body:    JSON.stringify({ pickupDate }),
        });
        const data = await res.json();
        if (!data.success) throw new Error(data.message);
        showToast('Pickup scheduled successfully', 'success');
        closePickupModal();
        setTimeout(() => location.reload(), 800);
      } catch (err) {
        showToast(err.message || 'Something went wrong', 'error');
      }
    }
    window.submitPickup = submitPickup;

    // ── Complete Return ───────────────────────────────────────────────────────
    async function completeReturn(itemId) {
      const confirmed = await confirmAction(
        'Mark this item as returned? This will automatically process the refund to the customer.'
      );
      if (!confirmed) return;
      try {
        const res  = await fetch(`/admin/returns/complete/${itemId}`, {
          method:  'PATCH',
          headers: { 'Content-Type': 'application/json' },
        });
        const data = await res.json();
        if (!data.success) throw new Error(data.message);
        showToast('Return completed — refund processed to customer wallet', 'success');
        setTimeout(() => location.reload(), 1000);
      } catch (err) {
        showToast(err.message || 'Something went wrong', 'error');
      }
    }
    window.completeReturn = completeReturn;

    // ── Close modals on backdrop click ────────────────────────────────────────
    ['rejectModal', 'pickupModal'].forEach(id => {
      document.getElementById(id)?.addEventListener('click', function(e) {
        if (e.target === this) this.classList.add('hidden');
      });
    });
  </script>

</body>
</html>
