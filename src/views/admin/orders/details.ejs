 <!-- REJECT Return MODAL -->
  <div id="rejectModal" class="fixed inset-0 hidden items-center justify-center bg-black/60 z-50">
  <div class="bg-[#0b1220] border border-white/10 rounded-xl w-[90%] max-w-md p-6 shadow-2xl">
    <h2 class="text-white font-semibold text-lg mb-4">Reject Return</h2>

