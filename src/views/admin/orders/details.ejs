<script type="module">
  import { showToast } from "/partials/errorMsg.utils.js";
  import { confirmAction } from "/partials/confirm.util.js";

  // ── Copy any ID to clipboard ──────────────────────────────────────────────
  window.copyId = async (id) => {
    try {
      await navigator.clipboard.writeText(id);
      showToast('Copied!', 'success');
    } catch {
      showToast('Copy failed', 'error');
    }
  };

  // ── Item-level status update ──────────────────────────────────────────────
  let _pendingCancelItemId = null;

  window.updateItemStatus = async (itemId) => {
    const select = document.getElementById(`item-status-${itemId}`);
    const status = select?.value;
    if (!status) return;

    // Intercept cancel — show reason modal
    if (status === 'cancelled') {
      _pendingCancelItemId = itemId;
      openItemCancelModal();
      return;
    }

    try {
      const res  = await fetch(`/admin/orders/items/${itemId}/status`, {
        method:  'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({ status }),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.message);
      showToast(`Item status updated to "${status.replace(/_/g,' ')}"`, 'success');
      setTimeout(() => location.reload(), 600);
    } catch (err) {
      showToast(err.message || 'Update failed', 'error');
    }
  };

  // ── Item cancel modal ─────────────────────────────────────────────────────
  const isPaid = '<%= ["paid","pending"].includes(order.payment?.status) && order.payment?.method !== "cod" ? "true" : "false" %>' === 'true';

  function openItemCancelModal() {
    document.getElementById('itemCancelReason').value  = '';
    document.getElementById('itemCancelComment').value = '';
    const note = document.getElementById('itemCancelRefundNote');
    note.classList.toggle('hidden', !isPaid);
    const m = document.getElementById('itemCancelModal');
    m.classList.remove('hidden'); m.classList.add('flex');
  }

  window.closeItemCancelModal = () => {
    const m = document.getElementById('itemCancelModal');
    m.classList.add('hidden'); m.classList.remove('flex');
    _pendingCancelItemId = null;
    // Reset dropdown back to previous value
    if (_pendingCancelItemId) {
      const sel = document.getElementById(`item-status-${_pendingCancelItemId}`);
      if (sel) sel.value = sel.dataset.original || 'placed';
    }
  };

  window.submitItemCancel = async () => {
    const reason  = document.getElementById('itemCancelReason').value;
    const comment = document.getElementById('itemCancelComment').value.trim();

    if (!reason) { showToast('Please select a cancellation reason', 'error'); return; }

    const btn = document.getElementById('itemCancelSubmitBtn');
    btn.disabled = true; btn.textContent = 'Cancelling...';

    try {
      // Step 1: update status to cancelled with reason
      const res = await fetch(`/admin/orders/items/${_pendingCancelItemId}/status`, {
        method:  'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({ status: 'cancelled', reason, comment }),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.message);

      // Step 2: auto-refund if order was paid (non-COD)
      if (isPaid) {
        const refundRes = await fetch(`/admin/orders/items/${_pendingCancelItemId}/refund`, {
          method:  'POST',
          headers: { 'Content-Type': 'application/json' },
          body:    JSON.stringify({ orderId: '<%= order._id %>' }),
        });
        const refundData = await refundRes.json();
        if (refundRes.ok && refundData.refundAmount) {
          showToast(`Item cancelled & ₹${refundData.refundAmount.toLocaleString('en-IN')} refunded to wallet`, 'success');
        } else {
          showToast('Item cancelled (refund skipped)', 'success');
        }
      } else {
        showToast('Item cancelled successfully', 'success');
      }

      setTimeout(() => location.reload(), 800);
    } catch (err) {
      showToast(err.message || 'Cancel failed', 'error');
      btn.disabled = false; btn.textContent = 'Cancel Item';
    }
  };

  // ── Manual refund trigger ─────────────────────────────────────────────────
  window.processRefund = async (itemId, orderId) => {
    const confirmed = await confirmAction('Process wallet refund for this item?');
    if (!confirmed) return;

    try {
      const res  = await fetch(`/admin/orders/items/${itemId}/refund`, {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({ orderId }),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.message);
      showToast(`Refunded ₹${data.refundAmount?.toLocaleString('en-IN')} to wallet`, 'success');
      setTimeout(() => location.reload(), 700);
    } catch (err) {
      showToast(err.message || 'Refund failed', 'error');
    }
  };

  const orderId = '<%= order._id %>';
  let currentItemId = null;

  // =============================
  // 🔹 MODAL HELPERS
  // =============================
  const openModal = (id) => {
    const m = document.getElementById(id);
    m?.classList.remove('hidden');
    m?.classList.add('flex');
  };

  const closeModal = (id) => {
    const m = document.getElementById(id);
    m?.classList.add('hidden');
    m?.classList.remove('flex');
  };

  // =============================
  // 🔹 ORDER STATUS UPDATE
  // =============================
  async function submitStatusUpdate() {
    const status = document.getElementById('statusSelect').value;

    try {
      const res = await fetch(`/admin/orders/${orderId}/status`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ status })
      });

      const data = await res.json();

      if (!res.ok) throw new Error(data.message);

      showToast("Order status updated successfully", "success");
      closeModal('updateModal');
      setTimeout(() => location.reload(), 600);

    } catch (err) {
      showToast(err.message || "Failed to update status", "error");
    }
  }

  // ── Smart cancel modal logic ──────────────────────────────────────────────
  const PAY_METHOD = '<%= order.payment.method %>';
  const PAY_STATUS = '<%= order.payment.status %>';

  function onReasonChange() {
    const reason = document.getElementById('cancelReason').value;
    const panel  = document.getElementById('refundPanel');
    const hint   = document.getElementById('cancelModalHint');

    // hide all sub-panels
    ['refundRequired','refundNotRequired','refundFraudHold','refundAlreadyDone']
      .forEach(id => document.getElementById(id).classList.add('hidden'));

    if (!reason) { panel.classList.add('hidden'); hint.textContent = ''; return; }

    panel.classList.remove('hidden');
    panel.className = panel.className.replace(/border-\S+/, '');

    if (PAY_METHOD === 'cod') {
      show('refundNotRequired');
      document.getElementById('noRefundReason').textContent = 'COD — nothing was paid online';
      hint.textContent = 'Order will be cancelled. No refund needed.';
      panel.classList.add('border-gray-500/20');

    } else if (PAY_STATUS === 'failed' || PAY_STATUS === 'pending') {
      show('refundNotRequired');
      document.getElementById('noRefundReason').textContent = `Payment ${PAY_STATUS}`;
      hint.textContent = 'Order will be cancelled. Payment was never completed.';
      panel.classList.add('border-gray-500/20');

    } else if (PAY_STATUS === 'refunded') {
      show('refundAlreadyDone');
      hint.textContent = 'Refund was already processed. Order will be cancelled only.';
      panel.classList.add('border-emerald-500/20');

    } else if (PAY_STATUS === 'paid') {
      if (reason === 'fraud_suspected') {
        show('refundFraudHold');
        hint.textContent = 'Refund will be held for manual review.';
        panel.classList.add('border-amber-500/20');
      } else {
        show('refundRequired');
        selectRefundMethod('wallet'); // default
        hint.textContent = 'Refund will be credited to customer wallet immediately.';
        panel.classList.add('border-emerald-500/20');
      }
    }
  }

  function show(id) { document.getElementById(id).classList.remove('hidden'); }

  let _selectedRefundMethod = 'wallet';
  function selectRefundMethod(method) {
    _selectedRefundMethod = method;
    document.querySelectorAll('.refund-method-btn').forEach(btn => {
      const active = btn.dataset.method === method;
      btn.classList.toggle('border-cyan-500',     active);
      btn.classList.toggle('text-cyan-400',        active);
      btn.classList.toggle('bg-cyan-500/10',       active);
      btn.classList.toggle('border-white/10',      !active);
      btn.classList.toggle('text-gray-400',        !active);
    });
    const hint = document.getElementById('cancelModalHint');
    const msgs = {
      wallet:   'Refund will be credited to customer wallet immediately.',
      original: 'Refund will be initiated to original payment source (may take 5–7 days).',
      manual:   'Refund marked for manual processing by finance team.',
    };
    hint.textContent = msgs[method] || '';
  }

  // ── Cancel submit ─────────────────────────────────────────────────────────
  async function submitCancel() {
    const reason      = document.getElementById('cancelReason').value;
    const comments    = document.getElementById('cancelComments').value.trim();
    const internalNote = document.getElementById('internalNote').value.trim();

    if (!reason) { showToast('Please select a cancel reason', 'error'); return; }

    const confirmed = await confirmAction('Cancel this order? This cannot be undone.');
    if (!confirmed) return;

    const btn = document.getElementById('cancelSubmitBtn');
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin text-xs"></i> Cancelling...';

    try {
      const res = await fetch(`/admin/orders/${orderId}/cancel`, {
        method:  'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({
          reason,
          comments,
          refundMethod: _selectedRefundMethod,
          internalNote,
        }),
      });

      const data = await res.json();
      if (!res.ok) throw new Error(data.message);

      closeModal('cancelModal');

      if (data.refundRequired && data.refundStatus === 'completed') {
        showToast(`Order cancelled. ₹${data.refundAmount?.toLocaleString('en-IN')} refunded to wallet.`, 'success');
      } else if (data.refundRequired && data.refundStatus === 'on_hold') {
        showToast('Order cancelled. Refund held for manual review.', 'warning');
      } else {
        showToast('Order cancelled successfully.', 'success');
      }

      setTimeout(() => location.reload(), 800);
    } catch (err) {
      showToast(err.message || 'Cancel failed', 'error');
      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-ban text-xs"></i> Confirm Cancel';
    }
  }

  // =============================
  // 🔹 RETURN APPROVE / REJECT
  // =============================
  async function handleReturnAction(itemId, action, rejectReason = '') {
    try {
      const res = await fetch(`/admin/orders/returns/${itemId}`, {
        method: "PATCH",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ action, rejectReason })
      });

      const data = await res.json();

      if (!res.ok) throw new Error(data.message);

      showToast(
        action === "approve" ? "Return approved" : "Return rejected",
        "success"
      );

      setTimeout(() => location.reload(), 600);

    } catch (err) {
      showToast(err.message || "Action failed", "error");
    }
  }

  // =============================
  // 🔹 REJECT MODAL
  // =============================
  function openRejectModal(itemId) {
    currentItemId = itemId;
    openModal('rejectModal');
  }

  function closeRejectModal() {
    closeModal('rejectModal');
  }

  function submitReject() {
    const reason = document.getElementById("rejectReasonInput").value;

    if (!reason) {
      showToast("Enter reject reason", "error");
      return;
    }

    handleReturnAction(currentItemId, "reject", reason);
  }

  // =============================
  // 🔹 PICKUP SCHEDULING
  // =============================
  function openPickupModal(itemId) {
    currentItemId = itemId;
    openModal("pickupModal");
  }

  function closePickupModal() {
    closeModal("pickupModal");
  }

  async function submitPickup() {
    const pickupDate = document.getElementById("pickupDate").value;

    if (!pickupDate) {
      showToast("Please select pickup date", "error");
      return;
    }

    try {
      const res = await fetch(`/admin/orders/returns/pickup/${currentItemId}`, {
        method: "PATCH",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ pickupDate }),
      });

      const data = await res.json();

      if (!res.ok) throw new Error(data.message);

      showToast("Pickup scheduled successfully", "success");
      closePickupModal();
      setTimeout(() => location.reload(), 600);

    } catch (err) {
      showToast(err.message || "Pickup failed", "error");
    }
  }

  // =============================
  // 🔹 MARK RETURNED
  // =============================
  async function markReturned(itemId) {
    const confirm = await confirmAction("Confirm item received?");

    if (!confirm) return;

    try {
      const res = await fetch(`/admin/orders/returns/complete/${itemId}`, {
        method: "PATCH",
      });

      const data = await res.json();

      if (!res.ok) throw new Error(data.message);

      showToast("Item marked as returned", "success");
      setTimeout(() => location.reload(), 600);

    } catch (err) {
      showToast(err.message || "Update failed", "error");
    }
  }

  // =============================
  // 🔹 OUTSIDE CLICK CLOSE
  // =============================
  ['updateModal','cancelModal','rejectModal','pickupModal'].forEach(id => {
    document.getElementById(id)?.addEventListener('click', function(e) {
      if (e.target === this) closeModal(id);
    });
  });

  // =============================
  // 🔹 GLOBAL ACCESS (EJS onclick)
  // =============================
  window.openUpdateModal  = () => openModal('updateModal');
  window.closeUpdateModal = () => closeModal('updateModal');
  window.openCancelModal  = () => {
    // reset modal state on open
    document.getElementById('cancelReason').value = '';
    document.getElementById('cancelComments').value = '';
    document.getElementById('internalNote').value = '';
    document.getElementById('refundPanel').classList.add('hidden');
    document.getElementById('cancelModalHint').textContent = '';
    const btn = document.getElementById('cancelSubmitBtn');
    btn.disabled = false;
    btn.innerHTML = '<i class="fas fa-ban text-xs"></i> Confirm Cancel';
    openModal('cancelModal');
  };
  window.closeCancelModal = () => closeModal('cancelModal');
  window.onReasonChange   = onReasonChange;
  window.selectRefundMethod = selectRefundMethod;

  window.openRejectModal  = openRejectModal;
  window.closeRejectModal = closeRejectModal;
  window.submitReject     = submitReject;
  window.handleReturnAction = handleReturnAction;

  window.openPickupModal = openPickupModal;
  window.closePickupModal = closePickupModal;
  window.submitPickup = submitPickup;

  window.markReturned = markReturned;

  window.submitStatusUpdate = submitStatusUpdate;
  window.submitCancel = submitCancel;
</script>

</body>
</html>
