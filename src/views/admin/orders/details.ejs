  <!-- CANCEL ORDER MODAL — Smart Refund System -->
  <div id="cancelModal" class="fixed inset-0 hidden items-center justify-center bg-black/70 backdrop-blur-sm z-50">
    <div class="bg-[#0b1220] border border-white/10 rounded-2xl w-[95%] max-w-lg shadow-2xl overflow-hidden">

      <!-- Header -->
      <div class="flex items-center justify-between px-6 py-4 border-b border-white/10 bg-white/5">
        <div class="flex items-center gap-2">
          <div class="w-7 h-7 rounded-full bg-red-500/20 flex items-center justify-center">
            <i class="fas fa-ban text-red-400 text-xs"></i>
          </div>
          <h2 class="text-white font-bold text-base">Cancel Order</h2>
        </div>
        <button onclick="closeCancelModal()" class="text-gray-500 hover:text-white transition">
          <i class="fas fa-times"></i>
        </button>
      </div>

      <!-- Order snapshot -->
      <div class="px-6 py-3 bg-[#0f172a] border-b border-white/5 flex items-center justify-between text-xs">
        <span class="text-gray-400">Order <span class="text-white font-mono font-semibold">#<%= order.orderNumber %></span></span>
        <div class="flex items-center gap-3">
          <span class="text-gray-400">Method: <span class="text-white font-semibold uppercase"><%= order.payment.method %></span></span>
          <span id="payStatusPill" class="px-2 py-0.5 rounded-full font-bold uppercase text-[10px]
            <%= order.payment.status === 'paid'    ? 'bg-emerald-500/20 text-emerald-400' :
                order.payment.status === 'failed'  ? 'bg-red-500/20 text-red-400' :
                'bg-yellow-500/20 text-yellow-400' %>">
            <%= order.payment.status %>
          </span>
        </div>
      </div>

      <div class="px-6 py-5 space-y-4">

        <!-- Cancel Reason -->
        <div>
          <label class="block text-xs text-gray-400 font-semibold mb-1.5 uppercase tracking-wider">Cancel Reason <span class="text-red-400">*</span></label>
          <select id="cancelReason" onchange="onReasonChange()"
            class="w-full bg-[#0f172a] border border-white/10 text-gray-200 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:border-red-500 transition">
            <option value="">— Select reason —</option>
            <option value="out_of_stock">Out of Stock</option>
            <option value="customer_request">Customer Request</option>
            <option value="payment_failed">Payment Failed</option>
            <option value="fraud_suspected">Fraud Suspected</option>
            <option value="other">Other</option>
          </select>
        </div>

        <!-- Comments -->
        <div>
          <label class="block text-xs text-gray-400 font-semibold mb-1.5 uppercase tracking-wider">Comments</label>
          <textarea id="cancelComments" rows="2" placeholder="Additional details..."
            class="w-full bg-[#0f172a] border border-white/10 text-gray-200 rounded-lg px-3 py-2.5 text-sm resize-none focus:outline-none focus:border-white/30 placeholder-gray-600"></textarea>
        </div>

        <!-- Smart Refund Panel — shown/hidden by JS -->
        <div id="refundPanel" class="hidden rounded-xl border overflow-hidden">

          <!-- Refund Required -->
          <div id="refundRequired" class="hidden">
            <div class="bg-emerald-500/10 border-b border-emerald-500/20 px-4 py-2.5 flex items-center gap-2">
              <i class="fas fa-rotate-left text-emerald-400 text-xs"></i>
              <span class="text-emerald-400 text-xs font-bold uppercase tracking-wider">Refund Required</span>
              <span class="ml-auto text-emerald-300 font-black text-sm">₹<%= order.pricing.finalAmount?.toLocaleString('en-IN') %></span>
            </div>
            <div class="bg-[#0f172a] px-4 py-3">
              <label class="block text-xs text-gray-400 font-semibold mb-2 uppercase tracking-wider">Refund Method</label>
              <div class="grid grid-cols-3 gap-2" id="refundMethodBtns">
                <button type="button" onclick="selectRefundMethod('wallet')"
                  data-method="wallet"
                  class="refund-method-btn flex flex-col items-center gap-1 p-2.5 rounded-lg border border-white/10 hover:border-cyan-500/50 transition text-xs text-gray-400 hover:text-cyan-400">
                  <i class="fas fa-wallet text-base"></i>
                  <span>Wallet</span>
                </button>
                <button type="button" onclick="selectRefundMethod('original')"
                  data-method="original"
                  class="refund-method-btn flex flex-col items-center gap-1 p-2.5 rounded-lg border border-white/10 hover:border-cyan-500/50 transition text-xs text-gray-400 hover:text-cyan-400">
                  <i class="fas fa-credit-card text-base"></i>
                  <span>Original</span>
                </button>
                <button type="button" onclick="selectRefundMethod('manual')"
                  data-method="manual"
                  class="refund-method-btn flex flex-col items-center gap-1 p-2.5 rounded-lg border border-white/10 hover:border-cyan-500/50 transition text-xs text-gray-400 hover:text-cyan-400">
                  <i class="fas fa-user-tie text-base"></i>
                  <span>Manual</span>
                </button>
              </div>
            </div>
          </div>

          <!-- No Refund -->
          <div id="refundNotRequired" class="hidden bg-gray-500/10 border-gray-500/20 px-4 py-2.5 flex items-center gap-2">
            <i class="fas fa-circle-xmark text-gray-400 text-xs"></i>
            <span class="text-gray-400 text-xs font-semibold">No refund required</span>
            <span id="noRefundReason" class="ml-auto text-gray-500 text-xs"></span>
          </div>

          <!-- Fraud Hold -->
          <div id="refundFraudHold" class="hidden bg-amber-500/10 border-amber-500/20 px-4 py-2.5 flex items-center gap-2">
            <i class="fas fa-shield-halved text-amber-400 text-xs"></i>
            <span class="text-amber-400 text-xs font-bold">Refund on hold — manual review required</span>
          </div>

          <!-- Already Refunded -->
          <div id="refundAlreadyDone" class="hidden bg-emerald-500/10 border-emerald-500/20 px-4 py-2.5 flex items-center gap-2">
            <i class="fas fa-circle-check text-emerald-400 text-xs"></i>
            <span class="text-emerald-400 text-xs font-bold">Refund already completed — no action needed</span>
          </div>

        </div>

        <!-- Internal Note -->
        <div>
          <label class="block text-xs text-gray-400 font-semibold mb-1.5 uppercase tracking-wider">Internal Note</label>
          <input id="internalNote" type="text" placeholder="Admin note (not shown to customer)"
            class="w-full bg-[#0f172a] border border-white/10 text-gray-200 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:border-white/30 placeholder-gray-600">
        </div>

      </div>

      <!-- Footer -->
      <div class="px-6 py-4 border-t border-white/10 bg-white/5 flex items-center justify-between gap-3">
        <p id="cancelModalHint" class="text-xs text-gray-500 flex-1"></p>
        <div class="flex gap-3">
          <button onclick="closeCancelModal()" class="px-4 py-2 bg-gray-700 hover:bg-gray-600 text-white rounded-lg text-sm transition">Back</button>
          <button onclick="submitCancel()" id="cancelSubmitBtn"
            class="px-5 py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg text-sm font-bold transition flex items-center gap-2">
            <i class="fas fa-ban text-xs"></i> Confirm Cancel
          </button>
