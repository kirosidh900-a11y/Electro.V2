  <div id="updateModal" class="fixed inset-0 hidden items-center justify-center bg-black/60 z-50">
    <div class="bg-[#0b1220] border border-white/10 rounded-xl w-[90%] max-w-md p-6 shadow-2xl">
      <div class="flex justify-between items-center mb-4">
        <h2 class="text-white font-semibold text-lg">Update Order Status</h2>
        <button onclick="closeUpdateModal()" class="text-gray-400 hover:text-white"><i class="fas fa-times"></i></button>
      </div>
      
      <% if(isSingleItem) { %>
        <p class="text-gray-400 text-sm mb-4">
          <i class="fas fa-info-circle text-blue-400 mr-1"></i>
          Single item order - updating order status will also update the item status.
        </p>
      <% } else { %>
        <p class="text-amber-400 text-sm mb-4">
          <i class="fas fa-exclamation-triangle mr-1"></i>
          Multi-item order - manage individual items separately. Order status will auto-calculate.
        </p>
      <% } %>
      
      <select id="statusSelect" class="w-full bg-[#0f172a] border border-white/10 text-gray-200 rounded-lg px-3 py-2.5 text-sm mb-5 focus:outline-none focus:border-cyan-500">
        <% ['placed','confirmed','shipped','out_for_delivery','delivered'].forEach(s => { %>
          <option value="<%= s %>" <%= order.orderStatus === s ? 'selected' : '' %>><%= s.replace(/_/g,' ').replace(/\b\w/g, c => c.toUpperCase()) %></option>
        <% }) %>
