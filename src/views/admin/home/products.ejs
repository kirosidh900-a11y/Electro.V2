<!DOCTYPE html>
<html lang="en" class="dark">

<head>
        <%- include('../../partials/head') %>
</head>

<body class="min-h-screen flex">

        <%- include('../../partials/admin/sidebar') %>

                <div id="mainContent" class="flex-1 flex flex-col min-w-0 transition-all duration-300">

                        <%- include('../../partials/admin/header') %>

                                <main class="flex-1 p-4 sm:p-6 lg:p-8 w-full">

                                        <%- include("./partials/header",{ title }) %>

                                                <!-- ================= TABLE ================= -->

                                                <div
                                                        class="w-full bg-[#0b1220] border border-white/5 rounded-3xl shadow-xl overflow-x-auto">

                                                        <table class="w-full text-sm text-left text-gray-300">

                                                                <thead
                                                                        class="border-b border-white/10 text-gray-400 uppercase text-xs">

                                                                        <tr>

                                                                                <th class="px-6 py-4">#</th>
                                                                                <th class="px-6 py-4">Product</th>
                                                                                <th class="px-6 py-4">Category</th>
                                                                                <th class="px-6 py-4">Brand</th>
                                                                                <th class="px-6 py-4">Status</th>
                                                                                <th class="px-6 py-4 text-right">Actions
                                                                                </th>

                                                                        </tr>

                                                                </thead>

                                                                <tbody id="productsTableBody">
                                                                        <%- include("./partials/productRows", {
                                                                                products, currentPage }) %>
                                                                </tbody>

                                                        </table>

                                                </div>

                                                <!-- ================= PAGINATION ================= -->

                                                <div id="pagination" class="flex flex-wrap justify-center gap-2 mt-8">

                                                        <%- include("./partials/pagination",{ currentPage,totalPages })
                                                                %>

                                                </div>

                                </main>

                </div>

                <!-- ================= PRODUCT MODAL ================= -->

                <div id="productsTableBody"
                        class="fixed inset-0 bg-black/60 hidden z-50 flex items-center justify-center">

                        <div class="bg-[#0b1220] w-[550px] rounded-xl border border-white/10 p-6">

                                <div class="flex justify-between items-center mb-4">

                                        <h2 id="productModalTitle" class="text-lg font-semibold text-white">

                                                Add Product

                                        </h2>

                                        <button onclick="closeModal()" class="text-gray-400 hover:text-white">

                                                <i class="fas fa-times"></i>

                                        </button>

                                </div>

                                <form id="productForm" class="flex flex-col gap-4">

                                        <input type="hidden" id="product-id">

                                        <!-- Product Name -->

                                        <div>

                                                <label class="text-sm text-gray-400">Product Name</label>

                                                <input type="text" id="product-name"
                                                        class="w-full mt-1 bg-[#0f172a] border border-white/10 px-3 py-2 rounded-lg text-sm">

                                        </div>

                                        <!-- Category -->

                                        <div>

                                                <label class="text-sm text-gray-400">Category</label>

                                                <select id="product-category"
                                                        class="w-full mt-1 bg-[#0f172a] border border-white/10 px-3 py-2 rounded-lg text-sm">

                                                        <option value="">Select category</option>

                                                        <% categories.forEach(c=>{ %>

                                                                <option value="<%= c._id %>">

                                                                        <%= c.title %>

                                                                </option>

                                                                <% }) %>

                                                </select>

                                        </div>

                                        <!-- Brand -->

                                        <div>

                                                <label class="text-sm text-gray-400">Brand</label>

                                                <select id="product-brand" name="brand"
                                                        class="w-full mt-1 bg-[#0f172a] border border-white/10 px-3 py-2 rounded-lg text-sm">

                                                        <option value="">Select brand</option>

                                                        <% brands.forEach(b=> { %>

                                                                <option value="<%= b._id %>">
                                                                        <%= b.title %>
                                                                </option>

                                                                <% }) %>

                                                </select>

                                        </div>

                                        <!-- Attributes -->

                                        <div>

                                                <label class="text-sm text-gray-400">Attributes</label>

                                                <div id="productAttributes" class="flex flex-col gap-2"></div>

                                        </div>

                                        <!-- Status -->

                                        <div>

                                                <label class="text-sm text-gray-400">Status</label>

                                                <select id="product-status"
                                                        class="w-full mt-1 bg-[#0f172a] border border-white/10 px-3 py-2 rounded-lg text-sm">

                                                        <option value="unlisted">Unlisted</option>
                                                        <option value="listed">Listed</option>

                                                </select>

                                        </div>

                                        <!-- Buttons -->

                                        <div class="flex justify-center gap-3 mt-4">

                                                <button type="button" onclick="closeModal()"
                                                        class="px-4 py-2 bg-gray-600 hover:bg-gray-700 text-white rounded-lg text-sm">

                                                        Cancel

                                                </button>

                                                <button type="submit" id="product-submit-btn"
                                                        class="px-4 py-2 bg-cyan-600 hover:bg-cyan-700 text-white rounded-lg text-sm">

                                                        Create Product

                                                </button>

                                        </div>

                                </form>

                        </div>

                </div>

                <!-- ================= SCRIPTS ================= -->
                <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

                <script>

                        const swalDark = {
                                background: "#1a1a1a",
                                color: "#ffffff",
                                confirmButtonColor: "#fa5252"
                        };

                        let editingAttributes = {};


                        // OPEN ADD MODAL
                        function openAddModal() {

                                document.getElementById("product-id").value = "";
                                document.getElementById("product-name").value = "";
                                document.getElementById("product-category").value = "";
                                document.getElementById("product-brand").value = "";
                                document.getElementById("product-status").value = "unlisted";

                                document.getElementById("productAttributes").innerHTML = "";

                                editingAttributes = {};

                                document.getElementById("product-submit-btn").textContent = "Create Product";

                                const title = document.getElementById("productModalTitle");
                                if (title) title.textContent = "Add Product";

                                document.getElementById("productModal").classList.remove("hidden");
                        }


                        // CLOSE MODAL
                        function closeModal() {
                                document.getElementById("productModal").classList.add("hidden");
                        }


                        // ADD BUTTON AUTO DETECT
                        const pageTitle = document.querySelector("h1")?.textContent || "";
                        const moduleName = pageTitle.replace("Management", "").trim().toLowerCase();
                        const addBtn = document.getElementById(`add-${moduleName}`);

                        if (addBtn) {
                                addBtn.addEventListener("click", openAddModal);
                        }


                        // ================= LOAD CATEGORY ATTRIBUTES =================

                        async function loadCategoryAttributes(categoryId, existingAttributes = {}) {

                                const container = document.getElementById("productAttributes");
                                container.innerHTML = "";

                                if (!categoryId) return;

                                try {

                                        const res = await fetch(`/admin/category/${categoryId}/attributes`);
                                        const data = await res.json();

                                        data.productAttributes.forEach(attr => {

                                                const input = document.createElement("input");

                                                input.placeholder = attr.label;
                                                input.name = attr.key;
                                                input.value = existingAttributes[attr.key] || "";

                                                input.className =
                                                        "bg-[#0f172a] border border-white/10 px-3 py-2 rounded-lg text-sm";

                                                container.appendChild(input);

                                        });

                                }
                                catch (err) {

                                        Swal.fire({
                                                ...swalDark,
                                                icon: "error",
                                                text: "Failed to load attributes"
                                        });

                                }

                        }


                        // CATEGORY CHANGE
                        const categorySelect = document.getElementById("product-category");

                        categorySelect?.addEventListener("change", function () {

                                loadCategoryAttributes(this.value, editingAttributes);

                        });



                        // ================= EDIT PRODUCT =================

                        function editProduct(id, name, category, brand, status, attributes = {}) {

                                document.getElementById("product-id").value = id;
                                document.getElementById("product-name").value = name;
                                document.getElementById("product-category").value = category || "";
                                document.getElementById("product-brand").value = brand || "";
                                document.getElementById("product-status").value = status;

                                editingAttributes = attributes || {};

                                document.getElementById("product-submit-btn").textContent = "Update Product";

                                const title = document.getElementById("productModalTitle");
                                if (title) title.textContent = "Edit Product";

                                loadCategoryAttributes(category, editingAttributes);

                                document.getElementById("productModal").classList.remove("hidden");
                        }

                        // ================= FORM SUBMIT =================

                        const productForm = document.getElementById("productForm");

                        productForm?.addEventListener("submit", async (e) => {

                                e.preventDefault();

                                const id = document.getElementById("product-id").value;
                                const name = document.getElementById("product-name").value.trim();
                                const category = document.getElementById("product-category").value;
                                const brand = document.getElementById("product-brand").value;
                                const status = document.getElementById("product-status").value;

                                const productNamePattern = /^[A-Za-z0-9]+(?:[ _-][A-Za-z0-9]+)*$/;

                                if (!name)
                                        return Swal.fire({ ...swalDark, icon: "warning", text: "Product name required" });

                                if (!productNamePattern.test(name))
                                        return Swal.fire({ ...swalDark, icon: "warning", text: "Invalid product name" });

                                if (!category)
                                        return Swal.fire({ ...swalDark, icon: "warning", text: "Select category" });

                                if (!brand)
                                        return Swal.fire({ ...swalDark, icon: "warning", text: "Select brand" });


                                // COLLECT ATTRIBUTES
                                const attributes = {};
                                const inputs = document.querySelectorAll("#productAttributes input");

                                for (const input of inputs) {

                                        const key = input.name;
                                        const value = input.value.trim();

                                        if (!value)
                                                return Swal.fire({ ...swalDark, icon: "warning", text: `${key} is required` });

                                        attributes[key] = value;

                                }


                                let url = "/admin/products";
                                let method = "POST";

                                if (id) {
                                        url = `/admin/products/${id}`;
                                        method = "PATCH";
                                }

                                try {

                                        const res = await fetch(url, {
                                                method,
                                                headers: { "Content-Type": "application/json" },
                                                body: JSON.stringify({
                                                        name,
                                                        category,
                                                        brand,
                                                        status,
                                                        attributes
                                                })
                                        });

                                        const data = await res.json();

                                        if (!data.success)
                                                return Swal.fire({ ...swalDark, icon: "error", text: data.message });


                                        await Swal.fire({
                                                ...swalDark,
                                                icon: "success",
                                                text: data.message,
                                                timer: 1500,
                                                showConfirmButton: false
                                        });


                                        // ================= UPDATE TABLE =================

                                        if (id) {

                                                const row = document.getElementById(`row-${id}`);

                                                if (row) {

                                                        const titleCell = document.getElementById(`title-${id}`);
                                                        const categoryCell = document.getElementById(`category-${id}`);
                                                        const brandCell = document.getElementById(`brand-${id}`);
                                                        const badge = document.getElementById(`badge-${id}`);

                                                        if (titleCell) titleCell.textContent = name;

                                                        const categoryText =
                                                                document.querySelector("#product-category option:checked")?.textContent.trim() || "-";

                                                        const brandText =
                                                                document.querySelector("#product-brand option:checked")?.textContent.trim() || "-";

                                                        if (categoryCell) categoryCell.textContent = categoryText;
                                                        if (brandCell) brandCell.textContent = brandText;

                                                        if (badge) {

                                                                badge.textContent = status;

                                                                badge.className =
                                                                        status === "listed"
                                                                                ? "px-3 py-1 rounded-full text-xs bg-emerald-500/20 text-emerald-400"
                                                                                : "px-3 py-1 rounded-full text-xs bg-red-500/20 text-red-400";

                                                        }

                                                }

                                        }
                                        else {

                                                location.reload();

                                        }

                                        closeModal();

                                }
                                catch (err) {

                                        Swal.fire({
                                                ...swalDark,
                                                icon: "error",
                                                text: "Something went wrong"
                                        });

                                }

                        });




                        // ================= DELETE PRODUCT =================

                        async function deleteProduct(product_id) {

                                const result = await Swal.fire({
                                        title: "Delete Product?",
                                        text: "This cannot be undone!",
                                        icon: "warning",
                                        ...swalDark,
                                        showCancelButton: true,
                                        confirmButtonText: "Delete"
                                });

                                if (!result.isConfirmed) return;

                                try {

                                        const res = await fetch(`/admin/products/${product_id}`, {
                                                method: "DELETE"
                                        });

                                        const data = await res.json();

                                        if (!data.success)
                                                return Swal.fire({ ...swalDark, icon: "error", text: data.message });

                                        const row = document.getElementById(`row-${product_id}`);

                                        if (row) {

                                                row.style.opacity = "0";
                                                setTimeout(() => row.remove(), 300);

                                        }

                                }
                                catch (err) {

                                        Swal.fire({ ...swalDark, icon: "error", text: "Server error" });

                                }

                        }


                        async function toggleProductStatus(product_id, status) {

                                const action = status === "listed" ? "unlist" : "list";

                                const result = await Swal.fire({
                                        title: "Are you sure?",
                                        text: `Do you want to ${action} this brand?`,
                                        icon: "warning",
                                        ...swalDark,
                                        showCancelButton: true,
                                        confirmButtonText: `Yes, ${action}!`,
                                        cancelButtonText: "Cancel"
                                });

                                if (!result.isConfirmed) return;

                                try {

                                        const res = await fetch(`/admin/products/${product_id}/status/`, {
                                                method: "PATCH"
                                        });

                                        const data = await res.json();

                                        if (!data.success) {
                                                return Swal.fire({
                                                        icon: "error",
                                                        ...swalDark,
                                                        text: data.message
                                                });
                                        }

                                        const btn = document.getElementById(`status-${product_id}`);
                                        const badge = document.getElementById(`badge-${product_id}`);

                                        const newStatus = data.status;

                                        // update badge
                                        badge.textContent = newStatus;

                                        if (newStatus === "listed") {
                                                badge.className = "px-3 py-1 rounded-full text-xs bg-emerald-500/20 text-emerald-400";
                                        } else {
                                                badge.className = "px-3 py-1 rounded-full text-xs bg-red-500/20 text-red-400";
                                        }

                                        // update button text
                                        btn.textContent = newStatus === "listed" ? "Unlist" : "List";

                                        btn.className =
                                                `px-3 py-1 text-xs rounded-md font-semibold ${newStatus === "listed"
                                                        ? "bg-yellow-500/20 text-yellow-400 hover:bg-yellow-500/30"
                                                        : "bg-emerald-500/20 text-emerald-400 hover:bg-emerald-500/30"
                                                }`;

                                        btn.setAttribute(
                                                "onclick",
                                                `toggleProductStatus('${product_id}','${newStatus}')`
                                        );

                                        Swal.fire({
                                                toast: true,
                                                position: "top-end",
                                                icon: "success",
                                                title: `Brand ${action}ed successfully`,
                                                showConfirmButton: false,
                                                timer: 2000
                                        });

                                } catch (error) {

                                        console.error(error);

                                        Swal.fire({
                                                icon: "error",
                                                ...swalDark,
                                                text: "Something went wrong"
                                        });

                                }

                        }

                </script>


                <script>

                        const filter = document.getElementById("filter");

                        function debounce(func, delay) {

                                let timer;

                                return function (...args) {
                                        clearTimeout(timer);

                                        timer = setTimeout(() => {
                                                func.apply(this, args);
                                        }, delay);

                                };
                        }



                        async function searchData() {

                                console.log(moduleName)

                                const value = searchInput?.value.trim() || "";
                                const filterValue = filter?.value.trim() || "";

                                try {

                                        const res = await fetch(
                                                `/admin/${moduleName}?search=${encodeURIComponent(value)}&status=${encodeURIComponent(filterValue)}`,
                                                {
                                                        headers: {
                                                                "X-Requested-With": "XMLHttpRequest",
                                                        }
                                                }
                                        );

                                        const data = await res.json();

                                        // dynamic table body update
                                        document.getElementById(`${moduleName}TableBody`).innerHTML = data.rows;

                                        // update pagination
                                        document.getElementById("pagination").innerHTML = data.pagination;

                                } catch (error) {
                                        console.error("Search error:", error);
                                }

                        }

                        const debouncedSearch = debounce(searchData, 400);

                        if (searchInput) {
                                searchInput.addEventListener("input", debouncedSearch);
                        }

                        if (filter) {
                                filter.addEventListener("change", searchData);
                        }

                        async function toggleCategoryStatus(category_id, status) {

                                const action = status === "listed" ? "unlist" : "list";

                                const result = await Swal.fire({
                                        title: `Are you sure?`,
                                        text: `Do you want to ${action} this product?`,
                                        icon: "warning",
                                        background: "#0b1220",
                                        color: "#e5e7eb",
                                        showCancelButton: true,
                                        confirmButtonText: `Yes, ${action}!`,
                                        cancelButtonText: "Cancel"
                                });

                                if (!result.isConfirmed) return;

                                try {

                                        const res = await fetch(`/admin/category/${category_id}/status`, {
                                                method: "PATCH",
                                                headers: {
                                                        "Content-Type": "application/json"
                                                }
                                        });

                                        const data = await res.json();

                                        if (!data.success) {

                                                Swal.fire({
                                                        icon: "error",
                                                        title: "Error",
                                                        text: data.message || "Failed to update product status",
                                                        background: "#0b1220",
                                                        color: "#e5e7eb"
                                                });

                                                return;

                                        }


                                        const btn = document.getElementById(`status-${category_id}`);
                                        const badge = document.getElementById(`badge-${category_id}`);

                                        const newStatus = data.status;

                                        // update badge
                                        badge.textContent = newStatus;

                                        if (newStatus === "listed") {
                                                badge.className = "px-3 py-1 rounded-full text-xs bg-emerald-500/20 text-emerald-400";
                                        } else {
                                                badge.className = "px-3 py-1 rounded-full text-xs bg-red-500/20 text-red-400";
                                        }

                                        // update button
                                        btn.textContent = newStatus === "listed" ? "Unlist" : "List";

                                        btn.className =
                                                `px-3 py-1 text-xs rounded-md font-semibold ${newStatus === "listed"
                                                        ? "bg-yellow-500/20 text-yellow-400 hover:bg-yellow-500/30"
                                                        : "bg-emerald-500/20 text-emerald-400 hover:bg-emerald-500/30"
                                                }`;

                                        // update onclick status parameter
                                        btn.setAttribute(
                                                "onclick",
                                                `toggleCategoryStatus('${category_id}','${newStatus}')`
                                        );

                                        Swal.fire({
                                                toast: true,
                                                position: "top-end",
                                                icon: "success",
                                                title: `Category ${action}ed successfully`,
                                                showConfirmButton: false,
                                                timer: 2000
                                        });

                                } catch (error) {
                                        console.error(error);
                                }

                        }

                        async function editCategory(category_id) {

                                const { value: title } = await Swal.fire({
                                        title: "Edit Category",
                                        background: "#0b1220",
                                        color: "#e5e7eb",
                                        input: "text",
                                        inputPlaceholder: "Enter category title",
                                        showCancelButton: true,
                                        confirmButtonText: "Update",
                                        cancelButtonText: "Cancel",
                                        inputValidator: (value) => {

                                                const pattern = /^[A-Za-z]+(?: [A-Za-z]+)*$/;

                                                if (!value.trim()) {
                                                        return "Category title is required";
                                                }

                                                if (!pattern.test(value.trim())) {
                                                        return "Only letters allowed with single space between words";
                                                }

                                        }
                                });

                                if (!title) return;

                                try {

                                        const res = await fetch(`/admin/category/${category_id}`, {
                                                method: "PATCH",
                                                headers: {
                                                        "Content-Type": "application/json"
                                                },
                                                body: JSON.stringify({ title })
                                        });

                                        const data = await res.json();

                                        if (!data.success) {
                                                Swal.fire("Error", data.message, "error");
                                                return;
                                        }

                                        Swal.fire({
                                                toast: true,
                                                position: "top-end",
                                                icon: "success",
                                                title: "Category updated successfully",
                                                showConfirmButton: false,
                                                timer: 2000
                                        });

                                        // update title in table without reload
                                        const titleCell = document.getElementById(`title-${category_id}`);
                                        if (titleCell) {
                                                titleCell.textContent = title.toUpperCase();
                                        }

                                } catch (error) {
                                        console.error(error);
                                        Swal.fire("Error", "Something went wrong", "error");
                                }
                        }

                        async function deleteCategory(category_id) {

                                const result = await Swal.fire({
                                        title: "Delete Category?",
                                        text: "This action cannot be undone!",
                                        icon: "warning",
                                        background: "#0b1220",
                                        color: "#e5e7eb",
                                        showCancelButton: true,
                                        confirmButtonText: "Yes, delete it!",
                                        cancelButtonText: "Cancel",
                                        confirmButtonColor: "#ef4444"
                                });

                                if (!result.isConfirmed) return;

                                try {

                                        const res = await fetch(`/admin/category/${category_id}`, {
                                                method: "DELETE"
                                        });

                                        const data = await res.json();

                                        if (!data.success) {

                                                Swal.fire({
                                                        icon: "error",
                                                        title: "Error",
                                                        text: data.message || "Failed to delete category",
                                                        background: "#0b1220",
                                                        color: "#e5e7eb"
                                                });

                                                return;
                                        }

                                        Swal.fire({
                                                toast: true,
                                                position: "top-end",
                                                icon: "success",
                                                title: "Category deleted successfully",
                                                showConfirmButton: false,
                                                timer: 2000
                                        });

                                        // remove row from table
                                        const row = document.getElementById(`row-${category_id}`);
                                        if (row) {
                                                row.remove();
                                        }

                                } catch (error) {

                                        console.error(error);

                                        Swal.fire({
                                                icon: "error",
                                                title: "Error",
                                                text: "Something went wrong",
                                                background: "#0b1220",
                                                color: "#e5e7eb"
                                        });

                                }

                        }


                        let currentCategory = null;

                        function openAttributeModal(categoryId) {
                                currentCategory = categoryId;
                                document.getElementById("attributeModal").classList.remove("hidden");
                                document.getElementById("attributeModal").classList.add("flex");
                        }

                        function closeAttributeModal() {
                                document.getElementById("attributeModal").classList.add("hidden");
                        }


                        async function saveAttribute() {
                                const label = document.getElementById("attrLabel").value.trim();
                                const data_type = document.getElementById("attrType").value;
                                const unit = document.getElementById("attrUnit").value.trim();

                                const key = document
                                        .getElementById("attrKey")
                                        .value
                                        .trim()
                                        .toLowerCase()
                                        .replace(/\s+/g, "_");

                                const allowed_values = document
                                        .getElementById("attrValues")
                                        .value
                                        .split(",")
                                        .map(v => v.trim())
                                        .filter(v => v !== "");

                                const is_required = document.getElementById("attrRequired").checked;
                                const is_variant_level = document.getElementById("attrVariant").checked;



                                /* ======================
                                   VALIDATIONS
                                ====================== */

                                const keyPattern = /^[a-z]+(_[a-z]+)*$/;
                                const labelPattern = /^[A-Za-z]+(?: [A-Za-z]+)*$/;

                                // key validation
                                if (!key) {

                                        await Swal.fire({
                                                icon: "warning",
                                                title: "Missing Key",
                                                text: "Attribute key is required",
                                                background: "#0b1220",
                                                color: "#e5e7eb"
                                        });

                                        return;
                                }

                                if (!keyPattern.test(key)) {

                                        await Swal.fire({
                                                icon: "warning",
                                                title: "Invalid Key",
                                                text: "Key must contain lowercase letters and underscore only (example: ram_size)",
                                                background: "#0b1220",
                                                color: "#e5e7eb"
                                        });

                                        return;
                                }


                                // label validation
                                if (!label) {

                                        await Swal.fire({
                                                icon: "warning",
                                                title: "Missing Label",
                                                text: "Display label is required",
                                                background: "#0b1220",
                                                color: "#e5e7eb"
                                        });

                                        return;
                                }

                                if (!labelPattern.test(label)) {

                                        await Swal.fire({
                                                icon: "warning",
                                                title: "Invalid Label",
                                                text: "Label should contain only letters and single spaces",
                                                background: "#0b1220",
                                                color: "#e5e7eb"
                                        });

                                        return;
                                }


                                // select type validation
                                if (data_type === "select" && allowed_values.length === 0) {

                                        await Swal.fire({
                                                icon: "warning",
                                                title: "Missing Values",
                                                text: "Allowed values required for select type",
                                                background: "#0b1220",
                                                color: "#e5e7eb"
                                        });

                                        return;
                                }


                                // unit validation (optional)
                                const unitPattern = /^[A-Za-z]+$/;

                                if (unit && !unitPattern.test(unit)) {

                                        await Swal.fire({
                                                icon: "warning",
                                                title: "Invalid Unit",
                                                text: "Unit must contain only letters (GB, Inch, Hz)",
                                                background: "#0b1220",
                                                color: "#e5e7eb"
                                        });

                                        return;
                                }



                                /* ======================
                                   API CALL
                                ====================== */

                                try {

                                        const res = await fetch(`/admin/category/${currentCategory}`, {
                                                method: "POST",
                                                headers: {
                                                        "Content-Type": "application/json"
                                                },
                                                body: JSON.stringify({
                                                        key,
                                                        label,
                                                        data_type,
                                                        unit,
                                                        allowed_values,
                                                        is_required,
                                                        is_variant_level
                                                })
                                        });

                                        const data = await res.json();

                                        if (!data.success) {

                                                await Swal.fire({
                                                        icon: "error",
                                                        title: "Error",
                                                        text: data.message,
                                                        background: "#0b1220",
                                                        color: "#e5e7eb"
                                                });

                                                return;
                                        }


                                        // success toast
                                        Swal.fire({
                                                toast: true,
                                                position: "top-end",
                                                icon: "success",
                                                title: "Attribute added successfully",
                                                background: "#0b1220",
                                                color: "#e5e7eb",
                                                showConfirmButton: false,
                                                timer: 2000
                                        });


                                        closeAttributeModal();
                                        location.reload();

                                }
                                catch (error) {

                                        console.error(error);

                                        Swal.fire({
                                                icon: "error",
                                                title: "Server Error",
                                                text: "Something went wrong",
                                                background: "#0b1220",
                                                color: "#e5e7eb"
                                        });

                                }

                        }
                </script>


                <!-- pagenation -->
                <script>

                        const paginationContainer = document.getElementById("pagination");

                        let currentPage = 1;


                        paginationContainer.addEventListener("click", async (e) => {

                                const link = e.target.closest(".pagination-link");
                                if (!link) return;

                                e.preventDefault();

                                currentPage = Number(link.dataset.page);

                                const search = searchInput?.value.trim() || "";
                                const filterValue = filter?.value || "";

                                try {

                                        const res = await fetch(
                                                `/admin/${moduleName}?page=${currentPage}&search=${encodeURIComponent(search)}&status=${encodeURIComponent(filterValue)}`,
                                                {
                                                        headers: {
                                                                "X-Requested-With": "XMLHttpRequest",
                                                                "Accept": "application/json"
                                                        }
                                                }
                                        );

                                        const data = await res.json();

                                        document.getElementById(`${moduleName}TableBody`).innerHTML = data.rows;
                                        document.getElementById("pagination").innerHTML = data.pagination;

                                } catch (err) {

                                        console.error("Pagination error:", err);

                                }

                        });

                </script>


</body>

