<!DOCTYPE html>
<html lang="en" class="dark">

<head>
        <%- include('../../partials/head') %>
</head>

<body class="min-h-screen flex">

        <%- include('../../partials/admin/sidebar') %>

                <div id="mainContent" class="flex-1 flex flex-col min-w-0 transition-all duration-300">

                        <%- include('../../partials/admin/header') %>

                                <main class="flex-1 p-4 sm:p-6 lg:p-8 w-full">

                                        <%- include("./partials/header",{ title }) %>

                                                <!-- ===== Table Card ===== -->
                                                <div
                                                        class="w-full bg-[#0b1220] border border-white/5 rounded-3xl shadow-xl">

                                                        <div class="overflow-x-auto w-full">

                                                                <table class="w-full text-sm text-left">

                                                                        <!-- Table Head -->
                                                                        <thead
                                                                                class="bg-white/5 text-gray-400 uppercase text-xs tracking-widest">
                                                                                <tr>
                                                                                        <th class="px-6 py-4">#</th>
                                                                                        <th class="px-6 py-4">Category
                                                                                        </th>
                                                                                        <th class="px-6 py-4">Attributes
                                                                                        </th>
                                                                                        <th class="px-6 py-4">Status
                                                                                        </th>
                                                                                        <th
                                                                                                class="px-6 py-4 text-right">
                                                                                                Actions</th>
                                                                                </tr>
                                                                        </thead>

                                                                        <!-- Table Body -->
                                                                        <tbody id="categoryTableBody"
                                                                                class="text-gray-300">

                                                                                <%- include("./partials/categoryRows", {
                                                                                        categories, currentPage }) %>

                                                                        </tbody>

                                                                </table>

                                                        </div>

                                                </div>

                                                <!-- ===== Pagination ===== -->
                                                <div id="pagination"
                                                        class="flex flex-wrap justify-center items-center gap-2 mt-8">

                                                        <%- include("./partials/pagination", { currentPage, totalPages
                                                                }) %>

                                                </div>

                                </main>



                </div>

                <!-- Category Modal -->
                <div id="categoryModal" class="fixed inset-0 bg-black/60 hidden z-50 flex items-center justify-center">

                        <div class="bg-[#0b1220] w-[500px] rounded-xl border border-white/10 p-6">

                                <div class="flex justify-between items-center mb-4">
                                        <h2 id="categoryModalTitle" class="text-lg font-semibold text-white">
                                                Add Category
                                        </h2>

                                        <button onclick="closeCategoryModal()" class="text-gray-400 hover:text-white">
                                                <i class="fas fa-times"></i>
                                        </button>
                                </div>

                                <form id="categoryForm" class="flex flex-col gap-4">

                                        <input type="hidden" id="category-id">

                                        <label class="text-sm text-gray-400">Category Name</label>

                                        <input id="category-title"
                                                class="bg-[#0f172a] border border-white/10 px-3 py-2 rounded-lg text-sm">

                                        <label class="text-sm text-gray-400">Status</label>

                                        <select id="category-status"
                                                class="bg-[#0f172a] border border-white/10 px-3 py-2 rounded-lg text-sm">

                                                <option value="unlisted">Unlisted</option>
                                                <option value="listed">Listed</option>

                                        </select>

                                        <div class="flex justify-end gap-3 mt-4">

                                                <button type="button" onclick="closeCategoryModal()"
                                                        class="px-4 py-2 bg-gray-600 hover:bg-gray-700 rounded-lg">
                                                        Cancel
                                                </button>

                                                <button type="submit" id="category-submit-btn"
                                                        class="px-4 py-2 bg-cyan-600 hover:bg-cyan-700 rounded-lg">
                                                        Create Category
                                                </button>

                                        </div>

                                </form>

                        </div>
                </div>

                <!-- Attribute Modal -->
                <div id="attributeModal" class="fixed inset-0 bg-black/60 hidden z-50 flex items-center justify-center">

                        <div class="bg-[#0b1220] w-[700px] rounded-xl border border-white/10 p-6">

                                <div class="flex justify-between items-center mb-4">

                                        <h2 class="text-lg font-semibold text-white">
                                                Add Category Attributes
                                        </h2>

                                        <button onclick="closeAttributeModal()" class="text-gray-400 hover:text-white">
                                                <i class="fas fa-times"></i>
                                        </button>

                                </div>

                                <p class="text-sm text-gray-400 mb-6">
                                        Define attributes used for products and variants
                                </p>

                                <div class="grid grid-cols-2 gap-4">

                                        <div>
                                                <label class="text-sm text-gray-400">Attribute Key
                                                        *</label>
                                                <input id="attrKey"
                                                        class="w-full mt-1 bg-[#0f172a] border border-white/10 px-3 py-2 rounded-lg text-sm"
                                                        placeholder="ram, storage">
                                        </div>

                                        <div>
                                                <label class="text-sm text-gray-400">Display Label
                                                        *</label>
                                                <input id="attrLabel"
                                                        class="w-full mt-1 bg-[#0f172a] border border-white/10 px-3 py-2 rounded-lg text-sm"
                                                        placeholder="RAM, Storage">
                                        </div>

                                        <div>
                                                <label class="text-sm text-gray-400">Data Type *</label>
                                                <select id="attrType"
                                                        class="w-full mt-1 bg-[#0f172a] border border-white/10 px-3 py-2 rounded-lg text-sm">

                                                        <option value="text">Text</option>
                                                        <option value="number">Number</option>
                                                        <option value="select">Select</option>

                                                </select>
                                        </div>

                                        <div>
                                                <label class="text-sm text-gray-400">Unit
                                                        (Optional)</label>
                                                <input id="attrUnit"
                                                        class="w-full mt-1 bg-[#0f172a] border border-white/10 px-3 py-2 rounded-lg text-sm"
                                                        placeholder="GB, inch, Hz">
                                        </div>

                                        <div class="col-span-2">
                                                <label class="text-sm text-gray-400">Allowed
                                                        Values</label>

                                                <input id="attrValues"
                                                        class="w-full mt-1 bg-[#0f172a] border border-white/10 px-3 py-2 rounded-lg text-sm"
                                                        placeholder="Black, Blue, Red">
                                        </div>

                                        <div class="col-span-2 flex items-center justify-between mt-2">

                                                <!-- Required Toggle -->
                                                <div class="flex items-center gap-3">

                                                        <span class="text-sm text-gray-400">Required</span>

                                                        <label class="relative inline-flex items-center cursor-pointer">

                                                                <input type="checkbox" id="attrRequired"
                                                                        class="sr-only peer">

                                                                <div class="w-11 h-6 bg-gray-700 rounded-full peer 
peer-checked:bg-cyan-600
after:content-[''] after:absolute after:top-[2px] after:left-[2px]
after:bg-white after:h-5 after:w-5 after:rounded-full
after:transition-all peer-checked:after:translate-x-full">
                                                                </div>

                                                        </label>

                                                </div>


                                                <!-- Variant Level Toggle -->
                                                <div class="flex items-center gap-3">

                                                        <span class="text-sm text-gray-400">Varies by Variant</span>

                                                        <label class="relative inline-flex items-center cursor-pointer">

                                                                <input type="checkbox" id="attrVariant"
                                                                        class="sr-only peer">

                                                                <div class="w-11 h-6 bg-gray-700 rounded-full peer 
peer-checked:bg-cyan-600
after:content-[''] after:absolute after:top-[2px] after:left-[2px]
after:bg-white after:h-5 after:w-5 after:rounded-full
after:transition-all peer-checked:after:translate-x-full">
                                                                </div>

                                                        </label>

                                                </div>


                                                <!-- Delete Attribute Button -->
                                                <button onclick="removeAttributeField()"
                                                        class="text-red-400 hover:text-red-300">

                                                        <i class="fas fa-trash"></i>

                                                </button>

                                        </div>

                                </div>

                                <div class="flex justify-end gap-3 mt-6">

                                        <button onclick="closeAttributeModal()"
                                                class="px-4 py-2 bg-gray-600 hover:bg-gray-700 text-white rounded-lg text-sm">
                                                Cancel
                                        </button>

                                        <button onclick="saveAttribute()"
                                                class="px-4 py-2 bg-cyan-600 hover:bg-cyan-700 text-white rounded-lg text-sm">
                                                Save Attributes
                                        </button>

                                </div>

                        </div>
                </div>



                <script type="module">

                        import { showToast } from "../../partials/errorMsg.utils.js";
                        import { confirmAction } from "../../partials/confirm.util.js";


                        /* ================= REMOVE ATTRIBUTE ================= */

                        const addCategoryBtn = document.getElementById("add-category");

                        if (addCategoryBtn) {
                                addCategoryBtn.addEventListener("click", openAddCategoryModal);
                        }

                        document.addEventListener("click", (e) => {

                                const btn = e.target.closest(".remove-attr");
                                if (!btn) return;

                                const categoryId = btn.dataset.category;
                                const key = btn.dataset.key;

                                removeAttribute(categoryId, key);

                        });


                        async function removeAttribute(category_Id, attribute_key) {

                                const confirmed = await confirmAction("Do you want to delete this attribute?");
                                if (!confirmed) return;

                                try {

                                        const res = await fetch(
                                                `/admin/category/${category_Id}/attribute/${encodeURIComponent(attribute_key)}`,
                                                { method: "DELETE" }
                                        );

                                        const result = await res.json();

                                        if (!result.success) {
                                                return showToast(result.message, "error");
                                        }

                                        showToast("Attribute removed successfully", "success");

                                        const chip = document.getElementById(`attr-${category_Id}-${attribute_key}`);
                                        if (chip) chip.remove();

                                } catch (error) {

                                        console.error(error);
                                        showToast("Something went wrong", "error");

                                }
                        }


                        /* ================= CATEGORY MODAL ================= */

                        const categoryModal = document.getElementById("categoryModal");
                        const categoryForm = document.getElementById("categoryForm");

                        function openAddCategoryModal() {

                                document.getElementById("category-id").value = "";
                                document.getElementById("category-title").value = "";
                                document.getElementById("category-status").value = "unlisted";

                                document.getElementById("categoryModalTitle").textContent = "Add Category";
                                document.getElementById("category-submit-btn").textContent = "Create Category";

                                categoryModal.classList.remove("hidden");

                        }
                        window.openAddCategoryModal = openAddCategoryModal;


                        function closeCategoryModal() {
                                categoryModal.classList.add("hidden");
                        }
                        window.closeCategoryModal = closeCategoryModal;


                        /* ================= EDIT CATEGORY ================= */

                        function editCategory(id) {

                                const titleCell = document.getElementById(`title-${id}`);
                                const badge = document.getElementById(`badge-${id}`);

                                if (!titleCell || !badge) return;

                                document.getElementById("category-id").value = id;
                                document.getElementById("category-title").value = titleCell.textContent.trim();
                                document.getElementById("category-status").value = badge.textContent.trim();

                                document.getElementById("categoryModalTitle").textContent = "Edit Category";
                                document.getElementById("category-submit-btn").textContent = "Update Category";

                                categoryModal.classList.remove("hidden");

                        }
                        window.editCategory = editCategory;


                        /* ================= CREATE / UPDATE CATEGORY ================= */

                        categoryForm?.addEventListener("submit", async (e) => {

                                e.preventDefault();

                                const id = document.getElementById("category-id").value;
                                const title = document.getElementById("category-title").value.trim();
                                const status = document.getElementById("category-status").value;

                                const pattern = /^[A-Za-z&-]+(?: [A-Za-z&-]+)*$/;

                                if (!title)
                                        return showToast("Category name required", "warning");

                                if (!pattern.test(title))
                                        return showToast("Only letters allowed", "warning");

                                try {

                                        let url = "/admin/category";
                                        let method = "POST";

                                        if (id) {
                                                url = `/admin/category/${id}`;
                                                method = "PATCH";
                                        }

                                        const res = await fetch(url, {
                                                method,
                                                headers: { "Content-Type": "application/json" },
                                                body: JSON.stringify({ title, status })
                                        });

                                        const data = await res.json();

                                        if (!data.success)
                                                return showToast(data.message, "error");

                                        showToast(
                                                id ? "Category updated successfully" : "Category created successfully",
                                                "success"
                                        );

                                        /* ===== Update UI without reload (Edit) ===== */

                                        if (id) {

                                                const titleCell = document.getElementById(`title-${id}`);
                                                const badge = document.getElementById(`badge-${id}`);

                                                if (titleCell) titleCell.textContent = title;

                                                if (badge) {

                                                        badge.textContent = status;

                                                        badge.className =
                                                                status === "listed"
                                                                        ? "px-3 py-1 rounded-full text-xs bg-emerald-500/20 text-emerald-400"
                                                                        : "px-3 py-1 rounded-full text-xs bg-red-500/20 text-red-400";

                                                }

                                        } else {

                                                location.reload();

                                        }

                                        closeCategoryModal();

                                } catch (error) {

                                        console.error(error);
                                        showToast("Something went wrong", "error");

                                }

                        });


                        /* ================= TOGGLE CATEGORY STATUS ================= */

                        async function toggleCategoryStatus(category_id) {

                                const badge = document.getElementById(`badge-${category_id}`);
                                const btn = document.getElementById(`status-${category_id}`);

                                if (!badge || !btn) return;

                                const currentStatus = badge.textContent.trim();
                                const action = currentStatus === "listed" ? "unlist" : "list";

                                const confirmed = await confirmAction(`Do you want to ${action} this category?`);
                                if (!confirmed) return;

                                try {

                                        const res = await fetch(`/admin/category/${category_id}/status`, {
                                                method: "PATCH"
                                        });

                                        const data = await res.json();

                                        if (!data.success)
                                                return showToast(data.message, "error");

                                        const newStatus = data.data.status;

                                        badge.textContent = newStatus;

                                        badge.className =
                                                newStatus === "listed"
                                                        ? "px-3 py-1 rounded-full text-xs bg-emerald-500/20 text-emerald-400"
                                                        : "px-3 py-1 rounded-full text-xs bg-red-500/20 text-red-400";

                                        btn.textContent = newStatus === "listed" ? "Unlist" : "List";

                                        btn.className =
                                                `px-3 py-1 text-xs rounded-md font-semibold ${newStatus === "listed"
                                                        ? "bg-yellow-500/20 text-yellow-400 hover:bg-yellow-500/30"
                                                        : "bg-emerald-500/20 text-emerald-400 hover:bg-emerald-500/30"
                                                }`;

                                        showToast(`Category ${action}ed successfully`, "success");

                                } catch (error) {

                                        console.error(error);
                                        showToast("Something went wrong", "error");

                                }

                        }
                        window.toggleCategoryStatus = toggleCategoryStatus;


                        /* ================= DELETE CATEGORY ================= */

                        async function deleteCategory(category_id) {

                                const confirmed = await confirmAction("Delete this category?");
                                if (!confirmed) return;

                                try {

                                        const res = await fetch(`/admin/category/${category_id}`, {
                                                method: "DELETE"
                                        });

                                        const data = await res.json();

                                        if (!data.success)
                                                return showToast(data.message, "error");

                                        showToast("Category deleted successfully", "success");

                                        const row = document.getElementById(`row-${category_id}`);
                                        if (row) row.remove();

                                } catch (error) {

                                        console.error(error);
                                        showToast("Something went wrong", "error");

                                }

                        }
                        window.deleteCategory = deleteCategory;


                        /* ================= ATTRIBUTE MODAL ================= */

                        let currentCategory = null;

                        function openAttributeModal(categoryId) {

                                currentCategory = categoryId;

                                document.getElementById("attributeModal").classList.remove("hidden");
                                document.getElementById("attributeModal").classList.add("flex");

                        }
                        window.openAttributeModal = openAttributeModal;


                        function closeAttributeModal() {
                                document.getElementById("attributeModal").classList.add("hidden");
                        }
                        window.closeAttributeModal = closeAttributeModal;


                        /* ================= SAVE ATTRIBUTE ================= */

                        async function saveAttribute() {

                                const label = document.getElementById("attrLabel").value.trim();
                                const data_type = document.getElementById("attrType").value;
                                const unit = document.getElementById("attrUnit").value.trim();

                                const key = document
                                        .getElementById("attrKey")
                                        .value
                                        .trim()
                                        .toLowerCase()
                                        .replace(/\s+/g, "_");

                                const allowed_values = document
                                        .getElementById("attrValues")
                                        .value
                                        .split(",")
                                        .map(v => v.trim())
                                        .filter(v => v !== "");

                                const is_required = document.getElementById("attrRequired").checked;
                                const is_variant_level = document.getElementById("attrVariant").checked;

                                if (!key || !label)
                                        return showToast("Key and label required", "warning");

                                try {

                                        const res = await fetch(`/admin/category/${currentCategory}`, {
                                                method: "POST",
                                                headers: { "Content-Type": "application/json" },
                                                body: JSON.stringify({
                                                        key,
                                                        label,
                                                        data_type,
                                                        unit,
                                                        allowed_values,
                                                        is_required,
                                                        is_variant_level
                                                })
                                        });

                                        const data = await res.json();

                                        if (!data.success)
                                                return showToast(data.message, "error");

                                        showToast("Attribute added successfully", "success");

                                        closeAttributeModal();
                                        location.reload();

                                } catch (error) {

                                        console.error(error);
                                        showToast("Server error", "error");

                                }

                        }
                        window.saveAttribute = saveAttribute;

                </script>


                <script>

                        const filter = document.getElementById("filter");

                        function debounce(func, delay) {

                                let timer;

                                return function (...args) {
                                        clearTimeout(timer);

                                        timer = setTimeout(() => {
                                                func.apply(this, args);
                                        }, delay);

                                };
                        }



                        async function searchData() {

                                const value = searchInput?.value.trim() || "";
                                const filterValue = filter?.value.trim() || "";

                                try {

                                        const res = await fetch(
                                                `/admin/${moduleName}?search=${encodeURIComponent(value)}&status=${encodeURIComponent(filterValue)}`,
                                                {
                                                        headers: {
                                                                "X-Requested-With": "XMLHttpRequest",
                                                        }
                                                }
                                        );

                                        const data = await res.json();

                                        // dynamic table body update
                                        document.getElementById(`${moduleName}TableBody`).innerHTML = data.rows;

                                        // update pagination
                                        document.getElementById("pagination").innerHTML = data.pagination;

                                } catch (error) {
                                        console.error("Search error:", error);
                                }

                        }

                        const debouncedSearch = debounce(searchData, 400);

                        if (searchInput) {
                                searchInput.addEventListener("input", debouncedSearch);
                        }

                        if (filter) {
                                filter.addEventListener("change", searchData);
                        }

                </script>


                <!-- pagenation -->
                <script>

                        const paginationContainer = document.getElementById("pagination");

                        let currentPage = 1;

                        // detect module from page title
                        const pageTitle =
                                document.querySelector("h1")?.textContent || "";

                        const moduleName =
                                pageTitle
                                        .replace("Management", "")
                                        .trim()
                                        .toLowerCase();


                        paginationContainer.addEventListener("click", async (e) => {

                                const link = e.target.closest(".pagination-link");
                                if (!link) return;

                                e.preventDefault();

                                currentPage = Number(link.dataset.page);

                                const search = searchInput?.value.trim() || "";
                                const filterValue = filter?.value || "";

                                try {

                                        const res = await fetch(
                                                `/admin/${moduleName}?page=${currentPage}&search=${encodeURIComponent(search)}&status=${encodeURIComponent(filterValue)}`,
                                                {
                                                        headers: {
                                                                "X-Requested-With": "XMLHttpRequest"
                                                        }
                                                }
                                        );

                                        const data = await res.json();

                                        document.getElementById(`${moduleName}TableBody`).innerHTML = data.rows;
                                        document.getElementById("pagination").innerHTML = data.pagination;

                                } catch (err) {

                                        console.error("Pagination error:", err);

                                }

                        });

                </script>

</body>

</html>