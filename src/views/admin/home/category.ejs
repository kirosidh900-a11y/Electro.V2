<!DOCTYPE html>
<html lang="en" class="dark">

<head>
        <%- include('../../partials/head') %>
</head>

<body class="min-h-screen flex">

        <%- include('../../partials/admin/sidebar') %>

                <div id="mainContent" class="flex-1 flex flex-col min-w-0 transition-all duration-300">

                        <%- include('../../partials/admin/header') %>

                                <main class="flex-1 p-4 sm:p-6 lg:p-8 w-full">

                                        <%- include("./partials/header",{ title }) %>

                                                <!-- ===== Table Card ===== -->
                                                <div
                                                        class="w-full bg-[#0b1220] border border-white/5 rounded-3xl shadow-xl">

                                                        <div class="overflow-x-auto w-full">

                                                                <table class="w-full text-sm text-left">

                                                                        <!-- Table Head -->
                                                                        <thead
                                                                                class="bg-white/5 text-gray-400 uppercase text-xs tracking-widest">
                                                                                <tr>
                                                                                        <th class="px-6 py-4">#</th>
                                                                                        <th class="px-6 py-4">Category
                                                                                        </th>
                                                                                        <th class="px-6 py-4">Attributes
                                                                                        </th>
                                                                                        <th class="px-6 py-4">Status
                                                                                        </th>
                                                                                        <th
                                                                                                class="px-6 py-4 text-right">
                                                                                                Actions</th>
                                                                                </tr>
                                                                        </thead>

                                                                        <!-- Table Body -->
                                                                        <tbody id="categoryTableBody"
                                                                                class="text-gray-300">

                                                                                <%- include("./partials/categoryRows", {
                                                                                        categories, currentPage }) %>

                                                                        </tbody>

                                                                </table>

                                                        </div>

                                                </div>

                                                <!-- ===== Pagination ===== -->
                                                <div id="pagination"
                                                        class="flex flex-wrap justify-center items-center gap-2 mt-8">

                                                        <%- include("./partials/pagination", { currentPage, totalPages
                                                                }) %>

                                                </div>

                                </main>



                </div>

                <!-- Attribute Modal -->
                <div id="attributeModal" class="fixed inset-0 bg-black/60 hidden z-50 flex items-center justify-center">

                        <div class="bg-[#0b1220] w-[700px] rounded-xl border border-white/10 p-6">

                                <div class="flex justify-between items-center mb-4">

                                        <h2 class="text-lg font-semibold text-white">
                                                Add Category Attributes
                                        </h2>

                                        <button onclick="closeAttributeModal()" class="text-gray-400 hover:text-white">
                                                <i class="fas fa-times"></i>
                                        </button>

                                </div>

                                <p class="text-sm text-gray-400 mb-6">
                                        Define attributes used for products and variants
                                </p>

                                <div class="grid grid-cols-2 gap-4">

                                        <div>
                                                <label class="text-sm text-gray-400">Attribute Key
                                                        *</label>
                                                <input id="attrKey"
                                                        class="w-full mt-1 bg-[#0f172a] border border-white/10 px-3 py-2 rounded-lg text-sm"
                                                        placeholder="ram, storage">
                                        </div>

                                        <div>
                                                <label class="text-sm text-gray-400">Display Label
                                                        *</label>
                                                <input id="attrLabel"
                                                        class="w-full mt-1 bg-[#0f172a] border border-white/10 px-3 py-2 rounded-lg text-sm"
                                                        placeholder="RAM, Storage">
                                        </div>

                                        <div>
                                                <label class="text-sm text-gray-400">Data Type *</label>
                                                <select id="attrType"
                                                        class="w-full mt-1 bg-[#0f172a] border border-white/10 px-3 py-2 rounded-lg text-sm">

                                                        <option value="text">Text</option>
                                                        <option value="number">Number</option>
                                                        <option value="select">Select</option>

                                                </select>
                                        </div>

                                        <div>
                                                <label class="text-sm text-gray-400">Unit
                                                        (Optional)</label>
                                                <input id="attrUnit"
                                                        class="w-full mt-1 bg-[#0f172a] border border-white/10 px-3 py-2 rounded-lg text-sm"
                                                        placeholder="GB, inch, Hz">
                                        </div>

                                        <div class="col-span-2">
                                                <label class="text-sm text-gray-400">Allowed
                                                        Values</label>

                                                <input id="attrValues"
                                                        class="w-full mt-1 bg-[#0f172a] border border-white/10 px-3 py-2 rounded-lg text-sm"
                                                        placeholder="Black, Blue, Red">
                                        </div>

                                        <div class="col-span-2 flex items-center justify-between mt-2">

                                                <!-- Required Toggle -->
                                                <div class="flex items-center gap-3">

                                                        <span class="text-sm text-gray-400">Required</span>

                                                        <label class="relative inline-flex items-center cursor-pointer">

                                                                <input type="checkbox" id="attrRequired"
                                                                        class="sr-only peer">

                                                                <div class="w-11 h-6 bg-gray-700 rounded-full peer 
peer-checked:bg-cyan-600
after:content-[''] after:absolute after:top-[2px] after:left-[2px]
after:bg-white after:h-5 after:w-5 after:rounded-full
after:transition-all peer-checked:after:translate-x-full">
                                                                </div>

                                                        </label>

                                                </div>


                                                <!-- Variant Level Toggle -->
                                                <div class="flex items-center gap-3">

                                                        <span class="text-sm text-gray-400">Varies by Variant</span>

                                                        <label class="relative inline-flex items-center cursor-pointer">

                                                                <input type="checkbox" id="attrVariant"
                                                                        class="sr-only peer">

                                                                <div class="w-11 h-6 bg-gray-700 rounded-full peer 
peer-checked:bg-cyan-600
after:content-[''] after:absolute after:top-[2px] after:left-[2px]
after:bg-white after:h-5 after:w-5 after:rounded-full
after:transition-all peer-checked:after:translate-x-full">
                                                                </div>

                                                        </label>

                                                </div>


                                                <!-- Delete Attribute Button -->
                                                <button onclick="removeAttributeField()"
                                                        class="text-red-400 hover:text-red-300">

                                                        <i class="fas fa-trash"></i>

                                                </button>

                                        </div>

                                </div>

                                <div class="flex justify-end gap-3 mt-6">

                                        <button onclick="closeAttributeModal()"
                                                class="px-4 py-2 bg-gray-600 hover:bg-gray-700 text-white rounded-lg text-sm">
                                                Cancel
                                        </button>

                                        <button onclick="saveAttribute()"
                                                class="px-4 py-2 bg-cyan-600 hover:bg-cyan-700 text-white rounded-lg text-sm">
                                                Save Attributes
                                        </button>

                                </div>

                        </div>
                </div>



                <script>

                        const swalDark = {
                                background: "#1a1a1a",
                                color: "#ffffff",
                                confirmButtonColor: "#fa5252",
                        };

                        document.addEventListener("click", (e) => {

                                const btn = e.target.closest(".remove-attr");
                                if (!btn) return;

                                const categoryId = btn.dataset.category;
                                const key = btn.dataset.key;

                                removeAttribute(categoryId, key);

                        });


                        async function removeAttribute(category_Id, attribute_key) {

                                console.log("Category:", category_Id);
                                console.log("Attribute:", attribute_key);

                                const confirm = await Swal.fire({
                                        ...swalDark,
                                        icon: "warning",
                                        title: "Confirmation",
                                        text: "Do you want to delete this attribute?",
                                        showCancelButton: true,
                                        confirmButtonText: "Yes, Delete",
                                        cancelButtonText: "Cancel"
                                });

                                if (!confirm.isConfirmed) return;

                                try {

                                        const res = await fetch(
                                                `/admin/category/${category_Id}/attribute/${encodeURIComponent(attribute_key)}`,
                                                {
                                                        method: "DELETE"
                                                }
                                        );

                                        const result = await res.json();

                                        if (result.success) {

                                                Swal.fire({
                                                        toast: true,
                                                        position: "top-end",
                                                        icon: "success",
                                                        title: "Attribute removed successfully",
                                                        background: "#0b1220",
                                                        color: "#e5e7eb",
                                                        showConfirmButton: false,
                                                        timer: 2000
                                                });

                                                const chip = document.getElementById(
                                                        `attr-${category_Id}-${attribute_key}`
                                                );

                                                if (chip) chip.remove();

                                        } else {

                                                Swal.fire({
                                                        ...swalDark,
                                                        icon: "error",
                                                        title: "Error",
                                                        text: result.message
                                                });

                                        }
                                } catch (error) {

                                        console.error(error);

                                        Swal.fire({
                                                ...swalDark,
                                                icon: "error",
                                                title: "Server Error",
                                                text: "Something went wrong"
                                        });

                                }
                        }



                        const addCategoryBtn = document.getElementById("add-category");

                        if (addCategoryBtn) {

                                addCategoryBtn.addEventListener("click", async (e) => {

                                        e.preventDefault();

                                        const { value: formValues } = await Swal.fire({

                                                title: "Add Category",
                                                background: "#0b1220",
                                                color: "#e5e7eb",
                                                showCancelButton: true,
                                                confirmButtonText: "Create Category",
                                                cancelButtonText: "Cancel",
                                                focusConfirm: false,
                                                buttonsStyling: false,

                                                customClass: {
                                                        confirmButton:
                                                                "px-4 py-2 bg-cyan-600 hover:bg-cyan-700 text-white rounded-lg text-sm",
                                                        cancelButton:
                                                                "px-4 py-2 bg-gray-600 hover:bg-gray-700 text-white rounded-lg text-sm"
                                                },

                                                html: `
<div class="flex flex-col gap-4 text-left mt-4">

<label class="text-sm text-gray-400">Category Name</label>

<input id="category-title"
type="text"
placeholder="Enter category name"
class="w-full bg-[#0f172a] border border-white/10 
px-3 py-2 rounded-lg text-sm focus:outline-none 
focus:ring-2 focus:ring-cyan-500">

<label class="text-sm text-gray-400">Status</label>

<select id="category-status"
class="w-full bg-[#0f172a] border border-white/10 
px-3 py-2 rounded-lg text-sm focus:outline-none 
focus:ring-2 focus:ring-cyan-500">

<option value="unlisted" selected>Unlisted</option>
<option value="listed">Listed</option>

</select>

</div>
`,

                                                preConfirm: () => {

                                                        const title = document
                                                                .getElementById("category-title")
                                                                .value
                                                                .trim();

                                                        const status = document
                                                                .getElementById("category-status")
                                                                .value;

                                                        if (!title) {

                                                                Swal.showValidationMessage("Category name is required");
                                                                return false;

                                                        }

                                                        return { title, status };

                                                }

                                        });

                                        if (!formValues) return;
                                        if (!formValues) return;

                                        try {

                                                const res = await fetch("/admin/category", {

                                                        method: "POST",

                                                        headers: {
                                                                "Content-Type": "application/json"
                                                        },

                                                        body: JSON.stringify(formValues)

                                                });

                                                const data = await res.json();

                                                if (data.success) {

                                                        Swal.fire({
                                                                icon: "success",
                                                                title: "Category created",
                                                                toast: true,
                                                                position: "top-end",
                                                                showConfirmButton: false,
                                                                timer: 2000
                                                        });

                                                        location.reload();

                                                } else {

                                                        Swal.fire({
                                                                ...swalDark,
                                                                icon: "error",
                                                                text: data.message
                                                        });

                                                }

                                        } catch (error) {

                                                console.error(error);

                                                Swal.fire({
                                                        icon: "error",
                                                        text: "Something went wrong"
                                                });

                                        }

                                });

                        }

                </script>


                <script>

                        const filter = document.getElementById("filter");

                        function debounce(func, delay) {

                                let timer;

                                return function (...args) {
                                        clearTimeout(timer);

                                        timer = setTimeout(() => {
                                                func.apply(this, args);
                                        }, delay);

                                };
                        }



                        async function searchData() {

                                const value = searchInput?.value.trim() || "";
                                const filterValue = filter?.value.trim() || "";

                                try {

                                        const res = await fetch(
                                                `/admin/${moduleName}?search=${encodeURIComponent(value)}&status=${encodeURIComponent(filterValue)}`,
                                                {
                                                        headers: {
                                                                "X-Requested-With": "XMLHttpRequest",
                                                        }
                                                }
                                        );

                                        const data = await res.json();

                                        // dynamic table body update
                                        document.getElementById(`${moduleName}TableBody`).innerHTML = data.rows;

                                        // update pagination
                                        document.getElementById("pagination").innerHTML = data.pagination;

                                } catch (error) {
                                        console.error("Search error:", error);
                                }

                        }

                        const debouncedSearch = debounce(searchData, 400);

                        if (searchInput) {
                                searchInput.addEventListener("input", debouncedSearch);
                        }

                        if (filter) {
                                filter.addEventListener("change", searchData);
                        }

                        async function toggleCategoryStatus(category_id, status) {

                                const action = status === "listed" ? "unlist" : "list";

                                const result = await Swal.fire({
                                        title: `Are you sure?`,
                                        text: `Do you want to ${action} this category?`,
                                        icon: "warning",
                                        background: "#0b1220",
                                        color: "#e5e7eb",
                                        showCancelButton: true,
                                        confirmButtonText: `Yes, ${action}!`,
                                        cancelButtonText: "Cancel"
                                });

                                if (!result.isConfirmed) return;

                                try {

                                        const res = await fetch(`/admin/category/${category_id}/status`, {
                                                method: "PATCH",
                                                headers: {
                                                        "Content-Type": "application/json"
                                                }
                                        });

                                        const data = await res.json();

                                        if (!data.success) {

                                                Swal.fire({
                                                        icon: "error",
                                                        title: "Error",
                                                        text: data.message || "Failed to update category status",
                                                        background: "#0b1220",
                                                        color: "#e5e7eb"
                                                });

                                                return;

                                        }


                                        const btn = document.getElementById(`status-${category_id}`);
                                        const badge = document.getElementById(`badge-${category_id}`);

                                        const newStatus = data.status;

                                        // update badge
                                        badge.textContent = newStatus;

                                        if (newStatus === "listed") {
                                                badge.className = "px-3 py-1 rounded-full text-xs bg-emerald-500/20 text-emerald-400";
                                        } else {
                                                badge.className = "px-3 py-1 rounded-full text-xs bg-red-500/20 text-red-400";
                                        }

                                        // update button
                                        btn.textContent = newStatus === "listed" ? "Unlist" : "List";

                                        btn.className =
                                                `px-3 py-1 text-xs rounded-md font-semibold ${newStatus === "listed"
                                                        ? "bg-yellow-500/20 text-yellow-400 hover:bg-yellow-500/30"
                                                        : "bg-emerald-500/20 text-emerald-400 hover:bg-emerald-500/30"
                                                }`;

                                        // update onclick status parameter
                                        btn.setAttribute(
                                                "onclick",
                                                `toggleCategoryStatus('${category_id}','${newStatus}')`
                                        );

                                        Swal.fire({
                                                toast: true,
                                                position: "top-end",
                                                icon: "success",
                                                title: `Category ${action}ed successfully`,
                                                showConfirmButton: false,
                                                timer: 2000
                                        });

                                } catch (error) {
                                        console.error(error);
                                }

                        }

                        async function editCategory(category_id) {

                                const { value: title } = await Swal.fire({
                                        title: "Edit Category",
                                        background: "#0b1220",
                                        color: "#e5e7eb",
                                        input: "text",
                                        inputPlaceholder: "Enter category title",
                                        showCancelButton: true,
                                        confirmButtonText: "Update",
                                        cancelButtonText: "Cancel",
                                        inputValidator: (value) => {

                                                const pattern = /^[A-Za-z]+(?: [A-Za-z]+)*$/;

                                                if (!value.trim()) {
                                                        return "Category title is required";
                                                }

                                                if (!pattern.test(value.trim())) {
                                                        return "Only letters allowed with single space between words";
                                                }

                                        }
                                });

                                if (!title) return;

                                try {

                                        const res = await fetch(`/admin/category/${category_id}`, {
                                                method: "PATCH",
                                                headers: {
                                                        "Content-Type": "application/json"
                                                },
                                                body: JSON.stringify({ title })
                                        });

                                        const data = await res.json();

                                        if (!data.success) {
                                                Swal.fire("Error", data.message, "error");
                                                return;
                                        }

                                        Swal.fire({
                                                toast: true,
                                                position: "top-end",
                                                icon: "success",
                                                title: "Category updated successfully",
                                                showConfirmButton: false,
                                                timer: 2000
                                        });

                                        // update title in table without reload
                                        const titleCell = document.getElementById(`title-${category_id}`);
                                        if (titleCell) {
                                                titleCell.textContent = title.toUpperCase();
                                        }

                                } catch (error) {
                                        console.error(error);
                                        Swal.fire("Error", "Something went wrong", "error");
                                }
                        }

                        async function deleteCategory(category_id) {

                                const result = await Swal.fire({
                                        title: "Delete Category?",
                                        text: "This action cannot be undone!",
                                        icon: "warning",
                                        background: "#0b1220",
                                        color: "#e5e7eb",
                                        showCancelButton: true,
                                        confirmButtonText: "Yes, delete it!",
                                        cancelButtonText: "Cancel",
                                        confirmButtonColor: "#ef4444"
                                });

                                if (!result.isConfirmed) return;

                                try {

                                        const res = await fetch(`/admin/category/${category_id}`, {
                                                method: "DELETE"
                                        });

                                        const data = await res.json();

                                        if (!data.success) {

                                                Swal.fire({
                                                        icon: "error",
                                                        title: "Error",
                                                        text: data.message || "Failed to delete category",
                                                        background: "#0b1220",
                                                        color: "#e5e7eb"
                                                });

                                                return;
                                        }

                                        Swal.fire({
                                                toast: true,
                                                position: "top-end",
                                                icon: "success",
                                                title: "Category deleted successfully",
                                                showConfirmButton: false,
                                                timer: 2000
                                        });

                                        // remove row from table
                                        const row = document.getElementById(`row-${category_id}`);
                                        if (row) {
                                                row.remove();
                                        }

                                } catch (error) {

                                        console.error(error);

                                        Swal.fire({
                                                icon: "error",
                                                title: "Error",
                                                text: "Something went wrong",
                                                background: "#0b1220",
                                                color: "#e5e7eb"
                                        });

                                }

                        }


                        let currentCategory = null;

                        function openAttributeModal(categoryId) {
                                currentCategory = categoryId;
                                document.getElementById("attributeModal").classList.remove("hidden");
                                document.getElementById("attributeModal").classList.add("flex");
                        }

                        function closeAttributeModal() {
                                document.getElementById("attributeModal").classList.add("hidden");
                        }


                        async function saveAttribute() {
                                const label = document.getElementById("attrLabel").value.trim();
                                const data_type = document.getElementById("attrType").value;
                                const unit = document.getElementById("attrUnit").value.trim();

                                const key = document
                                        .getElementById("attrKey")
                                        .value
                                        .trim()
                                        .toLowerCase()
                                        .replace(/\s+/g, "_");

                                const allowed_values = document
                                        .getElementById("attrValues")
                                        .value
                                        .split(",")
                                        .map(v => v.trim())
                                        .filter(v => v !== "");

                                const is_required = document.getElementById("attrRequired").checked;
                                const is_variant_level = document.getElementById("attrVariant").checked;



                                /* ======================
                                   VALIDATIONS
                                ====================== */

                                const keyPattern = /^[a-z]+(_[a-z]+)*$/;
                                const labelPattern = /^[A-Za-z]+(?: [A-Za-z]+)*$/;

                                // key validation
                                if (!key) {

                                        await Swal.fire({
                                                icon: "warning",
                                                title: "Missing Key",
                                                text: "Attribute key is required",
                                                background: "#0b1220",
                                                color: "#e5e7eb"
                                        });

                                        return;
                                }

                                if (!keyPattern.test(key)) {

                                        await Swal.fire({
                                                icon: "warning",
                                                title: "Invalid Key",
                                                text: "Key must contain lowercase letters and underscore only (example: ram_size)",
                                                background: "#0b1220",
                                                color: "#e5e7eb"
                                        });

                                        return;
                                }


                                // label validation
                                if (!label) {

                                        await Swal.fire({
                                                icon: "warning",
                                                title: "Missing Label",
                                                text: "Display label is required",
                                                background: "#0b1220",
                                                color: "#e5e7eb"
                                        });

                                        return;
                                }

                                if (!labelPattern.test(label)) {

                                        await Swal.fire({
                                                icon: "warning",
                                                title: "Invalid Label",
                                                text: "Label should contain only letters and single spaces",
                                                background: "#0b1220",
                                                color: "#e5e7eb"
                                        });

                                        return;
                                }


                                // select type validation
                                if (data_type === "select" && allowed_values.length === 0) {

                                        await Swal.fire({
                                                icon: "warning",
                                                title: "Missing Values",
                                                text: "Allowed values required for select type",
                                                background: "#0b1220",
                                                color: "#e5e7eb"
                                        });

                                        return;
                                }


                                // unit validation (optional)
                                const unitPattern = /^[A-Za-z]+$/;

                                if (unit && !unitPattern.test(unit)) {

                                        await Swal.fire({
                                                icon: "warning",
                                                title: "Invalid Unit",
                                                text: "Unit must contain only letters (GB, Inch, Hz)",
                                                background: "#0b1220",
                                                color: "#e5e7eb"
                                        });

                                        return;
                                }



                                /* ======================
                                   API CALL
                                ====================== */

                                try {

                                        const res = await fetch(`/admin/category/${currentCategory}`, {
                                                method: "POST",
                                                headers: {
                                                        "Content-Type": "application/json"
                                                },
                                                body: JSON.stringify({
                                                        key,
                                                        label,
                                                        data_type,
                                                        unit,
                                                        allowed_values,
                                                        is_required,
                                                        is_variant_level
                                                })
                                        });

                                        const data = await res.json();

                                        if (!data.success) {

                                                await Swal.fire({
                                                        icon: "error",
                                                        title: "Error",
                                                        text: data.message,
                                                        background: "#0b1220",
                                                        color: "#e5e7eb"
                                                });

                                                return;
                                        }


                                        // success toast
                                        Swal.fire({
                                                toast: true,
                                                position: "top-end",
                                                icon: "success",
                                                title: "Attribute added successfully",
                                                background: "#0b1220",
                                                color: "#e5e7eb",
                                                showConfirmButton: false,
                                                timer: 2000
                                        });


                                        closeAttributeModal();
                                        location.reload();

                                }
                                catch (error) {

                                        console.error(error);

                                        Swal.fire({
                                                icon: "error",
                                                title: "Server Error",
                                                text: "Something went wrong",
                                                background: "#0b1220",
                                                color: "#e5e7eb"
                                        });

                                }

                        }
                </script>


                <!-- pagenation -->
                <script>

                        const paginationContainer = document.getElementById("pagination");

                        let currentPage = 1;

                        // detect module from page title
                        const pageTitle =
                                document.querySelector("h1")?.textContent || "";

                        const moduleName =
                                pageTitle
                                        .replace("Management", "")
                                        .trim()
                                        .toLowerCase();


                        paginationContainer.addEventListener("click", async (e) => {

                                const link = e.target.closest(".pagination-link");
                                if (!link) return;

                                e.preventDefault();

                                currentPage = Number(link.dataset.page);

                                const search = searchInput?.value.trim() || "";
                                const filterValue = filter?.value || "";

                                try {

                                        const res = await fetch(
                                                `/admin/${moduleName}?page=${currentPage}&search=${encodeURIComponent(search)}&status=${encodeURIComponent(filterValue)}`,
                                                {
                                                        headers: {
                                                                "X-Requested-With": "XMLHttpRequest"
                                                        }
                                                }
                                        );

                                        const data = await res.json();

                                        document.getElementById(`${moduleName}TableBody`).innerHTML = data.rows;
                                        document.getElementById("pagination").innerHTML = data.pagination;

                                } catch (err) {

                                        console.error("Pagination error:", err);

                                }

                        });

                </script>

</body>

</html>