<!DOCTYPE html>
<html lang="en" class="dark">

<head>
        <%- include('../../partials/head') %>
</head>

<body class="min-h-screen flex">

        <%- include('../../partials/admin/sidebar') %>

                <div id="mainContent" class="flex-1 flex flex-col min-w-0 transition-all duration-300">

                        <%- include('../../partials/admin/header') %>

                                <main class="flex-1 p-6">

                                        <!-- ================= HEADER ================= -->

                                        <div class="flex items-center justify-between mb-6">

                                                <button onclick="history.back()"
                                                        class="text-sm text-blue-400 hover:text-white transition">
                                                        ← Back To Products
                                                </button>

                                                <h1 class="text-xl font-semibold text-white">
                                                        Product Details
                                                </h1>

                                        </div>


                                        <!-- ================= PRODUCT INFO ================= -->

                                        <div class="grid grid-cols-2 gap-6 mb-6">

                                                <!-- LEFT CARD -->

                                                <div class="bg-[#0b1220] border border-white/10 rounded-xl p-6">

                                                        <h3 class="text-white font-semibold mb-4">
                                                                Product Information
                                                        </h3>

                                                        <div class="space-y-2 text-sm text-gray-300">

                                                                <p>
                                                                        <span class="text-gray-400">Name:</span>
                                                                        <%= product.name %>
                                                                </p>

                                                                <p>
                                                                        <span class="text-gray-400">Brand:</span>
                                                                        <%= product.brand.title %>
                                                                </p>

                                                                <p>
                                                                        <span class="text-gray-400">Category:</span>
                                                                        <%= product.category.title %>
                                                                </p>

                                                                <p>
                                                                        <span class="text-gray-400">Status:</span>

                                                                        <span class="px-2 py-1 rounded-full text-xs
<%= product.status === " listed" ? "bg-emerald-500/20 text-emerald-400" : "bg-red-500/20 text-red-400" %>">

                                                                                <%= product.status==="listed" ? "Listed"
                                                                                        : "Unlisted" %>

                                                                        </span>
                                                                </p>

                                                                <p>
                                                                        <span class="text-gray-400">Created:</span>
                                                                        <%= product.createdAt.toDateString() %>
                                                                </p>

                                                                <p>
                                                                        <span class="text-gray-400">Updated:</span>
                                                                        <%= product.updatedAt.toDateString() %>
                                                                </p>

                                                        </div>

                                                </div>


                                                <!-- RIGHT CARD -->

                                                <div class="bg-[#0b1220] border border-white/10 rounded-xl p-6">

                                                        <h3 class="text-white font-semibold mb-4">
                                                                Product Metrics
                                                        </h3>

                                                        <div class="grid grid-cols-2 gap-4">

                                                                <div class="bg-[#0f172a] p-4 rounded-lg text-center">
                                                                        <p class="text-gray-400 text-sm">Total Variants
                                                                        </p>
                                                                        <p class="text-xl text-white font-semibold">
                                                                                <%= totalVariants %>
                                                                        </p>
                                                                </div>

                                                                <div class="bg-[#0f172a] p-4 rounded-lg text-center">
                                                                        <p class="text-gray-400 text-sm">Minimum Price
                                                                        </p>
                                                                        <p class="text-xl text-white font-semibold">$<%=
                                                                                        minPrice %>
                                                                        </p>
                                                                </div>

                                                                <div class="bg-[#0f172a] p-4 rounded-lg text-center">
                                                                        <p class="text-gray-400 text-sm">Total Stock</p>
                                                                        <p class="text-xl text-white font-semibold">
                                                                                <%= totalStock %>
                                                                        </p>
                                                                </div>

                                                                <div class="bg-[#0f172a] p-4 rounded-lg text-center">
                                                                        <p class="text-gray-400 text-sm">In Stock</p>
                                                                        <p class="text-xl text-white font-semibold">
                                                                                <%= totalStock> 0 ? "Yes" : "No" %>
                                                                        </p>
                                                                </div>

                                                        </div>

                                                </div>

                                        </div>


                                        <!-- ================= VARIANTS ================= -->

                                        <div class="bg-[#0b1220] border border-white/10 rounded-xl p-6">

                                                <div class="flex items-center justify-between mb-4">

                                                        <h3 class="text-white font-semibold">
                                                                Variants (<%= variants.length %>)
                                                        </h3>

                                                        <button onclick="openVariantModal()"
                                                                class="bg-blue-600 hover:bg-blue-700 text-white text-sm px-4 py-2 rounded-lg">
                                                                + Add Variant
                                                        </button>

                                                </div>

                                                <% let attributeKeys=[]; variants.forEach(function(v){ const
                                                        attrs=v.attributes instanceof Map ?
                                                        Object.fromEntries(v.attributes) : (v.attributes || {});
                                                        Object.keys(attrs).forEach(function(key){
                                                        if(!attributeKeys.includes(key)){ attributeKeys.push(key) } })
                                                        }) %>


                                                        <% if(variants.length===0){ %>

                                                                <div class="text-center text-gray-400 py-10">

                                                                        <p>No variants added yet</p>

                                                                        <button onclick="openVariantModal()"
                                                                                class="mt-3 bg-blue-600 px-4 py-2 rounded-lg text-sm text-white">
                                                                                Add First Variant
                                                                        </button>

                                                                </div>

                                                                <% } else { %>


                                                                        <table class="w-full text-sm text-gray-300">

                                                                                <thead
                                                                                        class="border-b border-white/10 text-gray-400">
                                                                                        <tr>

                                                                                                <th
                                                                                                        class="py-3 text-left">
                                                                                                        SKU</th>

                                                                                                <%
                                                                                                        attributeKeys.forEach(key=>
                                                                                                        { %>
                                                                                                        <th
                                                                                                                class="py-3 text-left">
                                                                                                                <%= key.toUpperCase()
                                                                                                                        %>
                                                                                                        </th>
                                                                                                        <% }) %>

                                                                                                                <th
                                                                                                                        class="py-3 text-left">
                                                                                                                        Price
                                                                                                                </th>
                                                                                                                <th
                                                                                                                        class="py-3 text-left">
                                                                                                                        Stock
                                                                                                                </th>
                                                                                                                <th
                                                                                                                        class="py-3 text-left">
                                                                                                                        Images
                                                                                                                </th>
                                                                                                                <th
                                                                                                                        class="py-3 text-right">
                                                                                                                        Actions
                                                                                                                </th>

                                                                                        </tr>
                                                                                </thead>

                                                                                <tbody>

                                                                                        <% variants.forEach(v=> { %>

                                                                                                <tr
                                                                                                        class="border-b border-white/5">

                                                                                                        <td
                                                                                                                class="py-3">
                                                                                                                <%= v.sku
                                                                                                                        %>
                                                                                                        </td>

                                                                                                        <%
                                                                                                                attributeKeys.forEach(key=>
                                                                                                                { %>

                                                                                                                <td
                                                                                                                        class="py-3">
                                                                                                                        <%= v.attributes?.get
                                                                                                                                ?
                                                                                                                                v.attributes.get(key)
                                                                                                                                :
                                                                                                                                v.attributes?.[key]
                                                                                                                                || "-"
                                                                                                                                %>
                                                                                                                </td>

                                                                                                                <% }) %>

                                                                                                                        <td>$<%= v.price
                                                                                                                                        %>
                                                                                                                        </td>
                                                                                                                        <td>
                                                                                                                                <%= v.stock
                                                                                                                                        %>
                                                                                                                        </td>


                                                                                                                        <!-- IMAGES COLUMN -->

                                                                                                                        <td
                                                                                                                                class="py-3">

                                                                                                                                <div
                                                                                                                                        class="flex flex-col items-center gap-2">

                                                                                                                                        <% if(v.product_image
                                                                                                                                                &&
                                                                                                                                                v.product_image.length){
                                                                                                                                                %>

                                                                                                                                                <%
                                                                                                                                                        v.product_image.forEach(img=>
                                                                                                                                                        {
                                                                                                                                                        %>

                                                                                                                                                        <div
                                                                                                                                                                class="relative group">

                                                                                                                                                                <img src="<%= img %>"
                                                                                                                                                                        class="w-12 h-12 object-cover rounded border border-white/10" />

                                                                                                                                                                <button onclick="deleteVariantImage('<%= v._id %>','<%= img %>')"
                                                                                                                                                                        class="absolute -top-2 -right-2 bg-red-500 text-white rounded-full w-4 h-4 text-[10px] hidden group-hover:flex items-center justify-center">
                                                                                                                                                                        ×
                                                                                                                                                                </button>

                                                                                                                                                        </div>

                                                                                                                                                        <% })
                                                                                                                                                                %>

                                                                                                                                                                <% }
                                                                                                                                                                        %>


                                                                                                                                                                        <!-- ADD IMAGE BOX -->

                                                                                                                                                                        <div onclick="openImageUpload('<%= v._id %>')"
                                                                                                                                                                                class="w-12 h-12 border-2 border-dashed border-gray-500 rounded flex flex-col items-center justify-center cursor-pointer hover:border-blue-500">

                                                                                                                                                                                <i
                                                                                                                                                                                        class="fas fa-plus text-xs"></i>
                                                                                                                                                                                <span
                                                                                                                                                                                        class="text-[9px]">Add</span>

                                                                                                                                                                        </div>

                                                                                                                                </div>

                                                                                                                        </td>


                                                                                                                        <td
                                                                                                                                class="text-right">

                                                                                                                                <button onclick="deleteVariant('<%= v._id %>')"
                                                                                                                                        class="text-red-400 text-xs hover:text-red-300">
                                                                                                                                        Delete
                                                                                                                                </button>

                                                                                                                        </td>
                                                                                                                        <input type="file"
                                                                                                                                id="variantImageInput"
                                                                                                                                class="hidden"
                                                                                                                                accept="image/*">
                                                                                                </tr>

                                                                                                <% }) %>

                                                                                </tbody>

                                                                        </table>

                                                                        <% } %>

                                        </div>

                                </main>

                </div>

                <div id="variantModal" class="fixed inset-0 bg-black/60 hidden z-50 flex items-center justify-center">

                        <div class="bg-[#0b1220] w-[550px] rounded-xl border border-white/10 p-6">

                                <div class="flex justify-between items-center mb-4">

                                        <h2 id="variantModalTitle" class="text-lg font-semibold text-white">
                                                Add Variant
                                        </h2>

                                        <button onclick="closeVariantModal()" class="text-gray-400 hover:text-white">

                                                <i class="fas fa-times"></i>

                                        </button>

                                </div>


                                <form id="variantForm" class="flex flex-col gap-4">

                                        <input type="hidden" id="variant-id">


                                        <!-- SKU -->

                                        <div>

                                                <label class="text-sm text-gray-400">SKU</label>

                                                <input type="text" id="variant-sku"
                                                        class="w-full mt-1 bg-[#0f172a] border border-white/10 px-3 py-2 rounded-lg text-sm">

                                        </div>


                                        <!-- PRICE -->

                                        <div>

                                                <label class="text-sm text-gray-400">Price</label>

                                                <input type="number" id="variant-price"
                                                        class="w-full mt-1 bg-[#0f172a] border border-white/10 px-3 py-2 rounded-lg text-sm">

                                        </div>


                                        <!-- STOCK -->

                                        <div>

                                                <label class="text-sm text-gray-400">Stock</label>

                                                <input type="number" id="variant-stock"
                                                        class="w-full mt-1 bg-[#0f172a] border border-white/10 px-3 py-2 rounded-lg text-sm">

                                        </div>


                                        <!-- VARIANT ATTRIBUTES (Dynamic) -->

                                        <div>

                                                <label class="text-sm text-gray-400">
                                                        Variant Attributes
                                                </label>

                                                <div id="variantAttributes" class="flex flex-col gap-2"></div>

                                        </div>


                                        <!-- BUTTONS -->

                                        <div class="flex justify-center gap-3 mt-4">

                                                <button type="button" onclick="closeVariantModal()"
                                                        class="px-4 py-2 bg-gray-600 hover:bg-gray-700 text-white rounded-lg text-sm">

                                                        Cancel

                                                </button>


                                                <button type="submit"
                                                        class="px-4 py-2 bg-cyan-600 hover:bg-cyan-700 text-white rounded-lg text-sm">

                                                        Save Variant

                                                </button>

                                        </div>

                                </form>

                        </div>

                </div>

                <script>

                        let editingVariantAttributes = {}

                        function openVariantModal() {

                                document.getElementById("variant-id").value = ""
                                document.getElementById("variant-sku").value = ""
                                document.getElementById("variant-price").value = ""
                                document.getElementById("variant-stock").value = ""

                                editingVariantAttributes = {}

                                document.getElementById("variantModalTitle").textContent = "Add Variant"

                                loadVariantAttributes()

                                document.getElementById("variantModal").classList.remove("hidden")

                        }

                        function closeVariantModal() {
                                document.getElementById("variantModal").classList.add("hidden")
                        }


                        async function loadVariantAttributes(existingAttributes = {}) {

                                const categoryId = "<%= product.category._id %>"

                                const container = document.getElementById("variantAttributes")

                                container.innerHTML = ""

                                try {

                                        const res = await fetch(`/admin/category/${categoryId}/attributes`)

                                        const data = await res.json()

                                        data.variantAttributes.forEach(attr => {

                                                const input = document.createElement("input")

                                                input.placeholder = attr.label
                                                input.name = attr.key
                                                input.value = existingAttributes[attr.key] || ""

                                                input.className =
                                                        "bg-[#0f172a] border border-white/10 px-3 py-2 rounded-lg text-sm"

                                                container.appendChild(input)

                                        })

                                } catch (err) {

                                        alert("Failed to load variant attributes")

                                }

                        }



                        function editVariant(id, sku, price, stock, attributes = {}) {

                                document.getElementById("variant-id").value = id
                                document.getElementById("variant-sku").value = sku
                                document.getElementById("variant-price").value = price
                                document.getElementById("variant-stock").value = stock

                                editingVariantAttributes = attributes || {}

                                document.getElementById("variantModalTitle").textContent = "Edit Variant"

                                loadVariantAttributes(editingVariantAttributes)

                                document.getElementById("variantModal").classList.remove("hidden")

                        }



                        const variantForm = document.getElementById("variantForm")

                        variantForm.addEventListener("submit", async (e) => {

                                e.preventDefault()

                                const variantId = document.getElementById("variant-id").value

                                const sku = document.getElementById("variant-sku").value.trim()
                                const price = document.getElementById("variant-price").value
                                const stock = document.getElementById("variant-stock").value

                                const attributes = {}

                                document.querySelectorAll("#variantAttributes input")
                                        .forEach(input => {
                                                attributes[input.name] = input.value.trim()
                                        })


                                let url = `/admin/products/<%= product._id %>/variants`
                                let method = "POST"

                                if (variantId) {

                                        url = `/admin/products/<%= product._id %>/variants/${variantId}`
                                        method = "PATCH"

                                }

                                const res = await fetch(url, {
                                        method,
                                        headers: {
                                                "Content-Type": "application/json"
                                        },
                                        body: JSON.stringify({
                                                sku,
                                                price,
                                                stock,
                                                attributes
                                        })
                                })

                                const data = await res.json()

                                if (!data.success) {
                                        alert(data.message)
                                        return
                                }

                                location.reload()

                        })



                        async function deleteVariant(id) {

                                if (!confirm("Delete variant?")) return

                                await fetch(`/admin/products/<%= product._id %>/variants/${id}`, {
                                        method: "DELETE"
                                })

                                location.reload()

                        }


                        let currentVariantId = null

                        function openImageUpload(variantId) {

                                currentVariantId = variantId

                                document.getElementById("variantImageInput").click()

                        }

                        document.getElementById("variantImageInput").addEventListener("change", async function () {

                                const file = this.files[0]

                                if (!file) return

                                const formData = new FormData()

                                formData.append("image", file)

                                const res = await fetch(
                                        `/admin/products/<%= product._id %>/variants/${currentVariantId}/image`,
                                        {
                                                method: "POST",
                                                body: formData
                                        }
                                )

                                const data = await res.json()

                                if (!data.success) {
                                        alert(data.message)
                                        return
                                }

                                location.reload()

                        })


                        async function deleteVariantImage(variantId, image) {

                                if (!confirm("Delete image?")) return

                                await fetch(
                                        `/admin/products/<%= product._id %>/variants/${variantId}/image`,
                                        {
                                                method: "DELETE",
                                                headers: {
                                                        "Content-Type": "application/json"
                                                },
                                                body: JSON.stringify({ image })
                                        }
                                )

                                location.reload()

                        }

                </script>
</body>

</html>