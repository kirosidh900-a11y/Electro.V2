<!DOCTYPE html>
<html lang="en" class="dark">

<head>
  <%- include('../../partials/head') %>
    <link rel="stylesheet" href="https://unpkg.com/cropperjs@1.6.2/dist/cropper.min.css">
    <script src="https://unpkg.com/cropperjs@1.6.2/dist/cropper.min.js"></script>
    <style>
      @keyframes scaleIn {
        0% {
          opacity: 0;
          transform: scale(0.9);
        }

        100% {
          opacity: 1;
          transform: scale(1);
        }
      }

      .animate-scaleIn {
        animation: scaleIn 0.2s ease-out;
      }

      @keyframes fadeIn {
        from {
          opacity: 0;
          transform: translateY(-10px);
        }

        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      .animate-fadeIn {
        animation: fadeIn 0.3s ease;
      }
    </style>

</head>

<body class="min-h-screen flex">

  <%- include('../../partials/admin/sidebar') %>

    <div id="mainContent" class="flex-1 flex flex-col min-w-0 transition-all duration-300">
      <%- include('../../partials/admin/header') %>


        <main class="flex-1 p-6">

          <!-- ================= HEADER ================= -->

          <div class="flex items-center justify-between mb-6">

            <button onclick="history.back()" class="text-sm text-blue-400 hover:text-white transition">
              ← Back To Products
            </button>

            <h1 class="text-xl font-semibold text-white">
              Product Details
            </h1>

            <!-- ACTION DROPDOWN -->
            <div class="relative">

              <button onclick="toggleActionMenu()"
                class="bg-gray-700 hover:bg-gray-600 text-white text-sm px-4 py-2 rounded-lg flex items-center gap-2">

                Action
                <i class="fas fa-chevron-down text-xs"></i>

              </button>

              <!-- DROPDOWN -->
              <div id="actionDropdown"
                class="absolute right-0 mt-2 w-44 bg-[#0f172a] border border-white/10 rounded-lg shadow-lg hidden">

                <!-- EDIT PRODUCT -->
                <!-- <button 
                                                                        class="w-full text-left px-4 py-2 text-sm text-gray-300 hover:bg-white/10">
                                                                        Edit Product
                                                                </button> -->

                <!-- LIST / UNLIST -->
                <button id="status-<%= product._id %>"
                  onclick="handleProductAction('<%= product._id %>', '<%= product.status %>')" class="w-full text-left px-4 py-2 text-sm
                                                                        <%= product.status==='listed'
                                                                                ? 'text-yellow-400 hover:bg-white/10'
                                                                                : 'text-green-400 hover:bg-white/10' %>
                                                                                ">

                  <%= product.status==="listed" ? "Unlist Product" : "List Product" %>

                </button>

                <!-- DELETE PRODUCT -->
                <button onclick="handleProductAction('<%= product._id %>','delete')"
                  class="w-full text-left px-4 py-2 text-sm text-red-400 hover:bg-white/10">
                  Delete Product
                </button>

              </div>

            </div>

          </div>


          <!-- ================= PRODUCT INFO ================= -->

          <div class="grid grid-cols-2 gap-6 mb-6">

            <!-- LEFT CARD -->

            <div class="bg-[#0b1220] border border-white/10 rounded-xl p-6">

              <h3 class="text-white font-semibold mb-4">
                Product Information
              </h3>

              <div class="space-y-2 text-sm text-gray-300">

                <p>
                  <span class="text-gray-400">Name:</span>
                  <%= product.name %>
                </p>

                <p>
                  <span class="text-gray-400">Brand:</span>
                  <%= product.brand.title %>
                </p>

                <p>
                  <span class="text-gray-400">Category:</span>
                  <%= product.category.title %>
                </p>

                <p>
                  <span class="text-gray-400">Status:</span>

                  <span id="badge-<%= product._id %>" class="px-2 py-1 rounded-full text-xs
                                                              <%= product.status === 'listed'
                                                                                ? 'bg-emerald-500/20 text-emerald-400'
                                                                                : 'bg-red-500/20 text-red-400' %>">

                    <%= product.status==="listed" ? "Listed" : "Unlisted" %>

                  </span>
                </p>

                <p>
                  <span class="text-gray-400">Created:</span>
                  <%= product.createdAt.toDateString() %>
                </p>

                <p>
                  <span class="text-gray-400">Updated:</span>
                  <%= product.updatedAt.toDateString() %>
                </p>

                <!-- Copyable Product ID -->
                <div class="flex items-center gap-2 pt-1 border-t border-white/5 mt-2">
                  <span class="text-gray-400">Product ID:</span>
                  <span class="font-mono text-xs text-gray-500 truncate flex-1"><%= product._id %></span>
                  <button onclick="copyId('<%= product._id %>')"
                    class="text-gray-600 hover:text-cyan-400 transition shrink-0" title="Copy Product ID">
                    <i class="fas fa-copy text-xs"></i>
                  </button>
                </div>

              </div>

            </div>


            <!-- RIGHT CARD -->

            <div class="bg-[#0b1220] border border-white/10 rounded-xl p-6">

              <h3 class="text-white font-semibold mb-4">
                Product Metrics
              </h3>

              <div class="grid grid-cols-2 gap-4">

                <div class="bg-[#0f172a] p-4 rounded-lg text-center">
                  <p class="text-gray-400 text-sm">Total Variants
                  </p>
                  <p class="text-xl text-white font-semibold">
                    <%= totalVariants %>
                  </p>
                </div>

                <div class="bg-[#0f172a] p-4 rounded-lg text-center">
                  <p class="text-gray-400 text-sm">Minimum Price
                  </p>
                  <p class="text-xl text-white font-semibold">₹<%= minPrice %>
                  </p>
                </div>

                <div class="bg-[#0f172a] p-4 rounded-lg text-center">
                  <p class="text-gray-400 text-sm">Total Stock</p>
                  <p class="text-xl text-white font-semibold">
                    <%= totalStock %>
                  </p>
                </div>

                <div class="bg-[#0f172a] p-4 rounded-lg text-center">
                  <p class="text-gray-400 text-sm">In Stock</p>
                  <p class="text-xl text-white font-semibold">
                    <%= totalStock> 0 ? "Yes" : "No" %>
                  </p>
                </div>

              </div>

            </div>

          </div>


          <!--=================VARIANTS=================-->

          <div class="bg-[#0b1220] border border-white/10 rounded-xl p-6">

            <div class="flex items-center justify-between mb-5">
              <h3 class="text-white font-semibold text-lg">
                Variants (<%= variants.length %>)
              </h3>

              <button onclick="openVariantModal()"
                class="bg-blue-600 hover:bg-blue-700 text-white text-sm px-4 py-2 rounded-lg">
                + Add Variant
              </button>
            </div>

            <% if (variants.length===0) { %>

              <div class="text-center text-gray-400 py-10">
                <p>No variants added yet</p>
              </div>

              <% } else { %>

                <div class="w-full overflow-x-auto">

                  <table class="min-w-[1000px] w-full text-sm text-gray-300">

                    <!-- HEADER -->
                    <thead class="sticky top-0 bg-[#0b1220] border-b border-white/10 text-gray-400">
                      <tr>
                        <th class="py-3 px-4 text-left">
                          SKU</th>
                        <th class="py-3 px-4 text-left">
                          Attributes</th>
                        <th class="py-3 px-4 text-left">
                          Price</th>
                        <th class="py-3 px-4 text-left">
                          Stock</th>
                        <th class="py-3 px-4 text-left">
                          Description</th>
                        <th class="py-3 px-4 text-left">
                          Images</th>
                        <th class="py-3 px-4 text-right">
                          Actions</th>
                      </tr>
                    </thead>

                    <tbody>

                      <% variants.forEach(function(v, index) { const attrs=v.attributes instanceof Map ?
                        Object.fromEntries(v.attributes) : (v.attributes || {}); %>

                        <tr class="border-b border-white/5 hover:bg-[#141a25] hover:rounded-full transition">

                          <!-- SKU -->
                          <td class="py-3 px-4 text-white font-medium">
                            <div class="flex items-center gap-1.5 group">
                              <span><%= v.sku %></span>
                              <button onclick="copyId('<%= v.sku %>')"
                                class="opacity-0 group-hover:opacity-100 text-gray-600 hover:text-cyan-400 transition"
                                title="Copy SKU">
                                <i class="fas fa-copy text-[10px]"></i>
                              </button>
                            </div>
                            <div class="flex items-center gap-1.5 mt-0.5 group">
                              <span class="font-mono text-[10px] text-gray-600 truncate max-w-[100px]"><%= v._id %></span>
                              <button onclick="copyId('<%= v._id %>')"
                                class="opacity-0 group-hover:opacity-100 text-gray-600 hover:text-cyan-400 transition"
                                title="Copy Variant ID">
                                <i class="fas fa-copy text-[10px]"></i>
                              </button>
                            </div>
                          </td>

                          <!-- ATTRIBUTES -->
                          <td class="py-3 px-4">
                            <div class="flex flex-wrap gap-1">
                              <% Object.keys(attrs).forEach(function(key) { %>
                                <span class="bg-blue-500/10 text-blue-300 text-[11px] px-2 py-1 rounded">
                                  <%= key %>
                                    :
                                    <%= attrs[key] %>
                                </span>
                                <% }) %>
                            </div>
                          </td>

                          <!-- PRICE -->
                          <td class="py-3 px-4">
                            <div class="flex flex-col">

                              <span class="text-green-400 font-semibold">
                                ₹<%= v.price %>
                              </span>

                              <% if (v.regular_price && v.regular_price> v.price) { %>
                                <span class="text-xs text-gray-400 line-through">
                                  ₹<%= v.regular_price %>
                                </span>
                                <% } %>

                                  <% if (v.max_discount_amount) { %>
                                    <span class="text-[10px] text-yellow-400">
                                      Max Disc: ₹<%= v.max_discount_amount %>
                                    </span>
                                    <% } %>

                            </div>
                          </td>

                          <!-- STOCK -->
                          <td class="py-3 px-4">
                            <span class="<%= v.stock > 0 ? 'text-emerald-400' : 'text-red-400' %>">
                              <%= v.stock %>
                            </span>
                          </td>

                          <!-- DESCRIPTION -->
                          <td class="py-3 px-4 max-w-[250px] text-xs text-gray-400">
                            <div class="max-h-[60px] overflow-hidden">
                              <%= v.description %>
                            </div>
                          </td>

                          <!-- IMAGES -->
                          <td class="py-3 px-4">
                            <div class="flex flex-wrap gap-2 max-w-[140px]">

                              <% if (v.product_images && v.product_images.length) { %>

                                <% v.product_images.forEach(function(img) { %>

                                  <div class="relative group">
                                    <img src="<%= img.url %>"
                                      class="w-12 h-12 object-cover rounded border border-white/10" />

                                    <!-- DELETE -->
                                    <button onclick="deleteVariantImage('<%= v._id %>', '<%= img.imageId %>')"
                                      class="absolute -top-2 -right-2 bg-red-500 text-white rounded-full w-4 h-4 text-[10px] hidden group-hover:flex items-center justify-center">
                                      ×
                                    </button>

                                    <!-- 🔥 REPLACE BUTTON -->
                                    <button onclick="replaceVariantImage('<%= v._id %>', '<%= img.imageId %>')"
                                      class="absolute bottom-0 left-0 right-0 bg-black/60 text-white text-[10px] py-[2px] hidden group-hover:block">
                                      Replace
                                    </button>
                                  </div>

                                  <% }) %>

                                    <% } %>

                                      <!-- ADD IMAGE -->
                                      <% if (v.product_images.length < 5) { %>
                                        <div onclick="openImageUpload('<%= v._id %>')"
                                          class="w-12 h-12 border-2 border-dashed border-gray-500 rounded flex items-center justify-center cursor-pointer hover:border-blue-500">
                                          <i class="fas fa-plus text-xs"></i>
                                        </div>
                                        <%}%>


                            </div>
                          </td>

                          <!-- ACTIONS -->
                          <td class="py-3 px-4 text-right">
                            <div class="flex justify-end gap-2">

                              <button onclick="editVariant(
                                '<%= v._id %>'
                            )" class="text-blue-400 text-xs hover:text-blue-300">
                                Edit
                              </button>

                              <button onclick="deleteVariant('<%= v._id %>')"
                                class="text-red-400 text-xs hover:text-red-300">
                                Delete
                              </button>

                            </div>
                          </td>

                        </tr>

                        <% }) %>

                    </tbody>

                  </table>

                </div>

                <% } %>

          </div>

        </main>

    </div>

    <div id="variantModal"
      class="fixed inset-0 bg-black/60 backdrop-blur-sm hidden z-50 flex items-center justify-center">

      <!-- MODAL BOX -->
      <div class="bg-[#0b1220] w-full max-w-lg sm:max-w-xl md:max-w-2xl lg:max-w-3xl 
    max-h-[90vh] overflow-y-auto rounded-xl border border-white/10 p-6 
    shadow-xl animate-scaleIn">

        <!-- HEADER -->
        <div class="flex justify-between items-center mb-4">
          <h2 id="variantModalTitle" class="text-lg font-semibold text-white">
            Add Variant
          </h2>

          <button onclick="closeVariantModal()" class="text-gray-400 hover:text-white text-lg">
            ✕
          </button>
        </div>

        <!-- FORM -->
        <form id="variantForm" class="flex flex-col gap-4">

          <input type="hidden" id="variant-id">

          <!-- SKU -->
          <div>
            <label class="text-sm text-gray-400">SKU</label>
            <div class="flex gap-2 mt-1">
              <input type="text" id="variant-sku"
                class="flex-1 bg-[#0f172a] border border-white/10 px-3 py-2 rounded-lg text-sm uppercase"
                placeholder="e.g. SKU001">
              <button type="button" id="generateSkuBtn"
                title="Auto-generate SKU"
                class="px-3 py-2 bg-white/5 hover:bg-cyan-500/20 text-gray-400 hover:text-cyan-400 rounded-lg text-xs transition">
                <i class="fas fa-wand-magic-sparkles"></i>
              </button>
            </div>
            <p id="skuStatus" class="text-xs mt-1"></p>
            <span id="variantSkuError" class="text-red-400 text-xs mt-1 hidden block"></span>
          </div>

          <!-- PRICE -->
          <div>
            <label class="text-sm text-gray-400">Price</label>
            <input type="number" id="variant-price"
              class="w-full mt-1 bg-[#0f172a] border border-white/10 px-3 py-2 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 outline-none">
            <span id="variantPriceError" class="text-red-400 text-xs mt-1 hidden block"></span>
          </div>

          <!-- REGULAR PRICE -->
          <div>
            <label class="text-sm text-gray-400">Regular Price (MRP)</label>
            <input type="number" id="variant-regular-price"
              class="w-full mt-1 bg-[#0f172a] border border-white/10 px-3 py-2 rounded-lg text-sm">
            <span id="variantRegularPriceError" class="text-red-400 text-xs mt-1 hidden block"></span>
          </div>

          <!-- MAX DISCOUNT -->
          <div>
            <label class="text-sm text-gray-400">Max Discount Amount</label>
            <input type="number" id="variant-max-discount"
              class="w-full mt-1 bg-[#0f172a] border border-white/10 px-3 py-2 rounded-lg text-sm">
            <span id="variantMaxDiscountError" class="text-red-400 text-xs mt-1 hidden block"></span>
          </div>

          <!-- STOCK -->
          <div>
            <label class="text-sm text-gray-400">Stock</label>
            <input type="number" id="variant-stock"
              class="w-full mt-1 bg-[#0f172a] border border-white/10 px-3 py-2 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 outline-none">
            <span id="variantStockError" class="text-red-400 text-xs mt-1 hidden block"></span>
          </div>

          <!-- DESCRIPTION -->
          <div>
            <label class="text-sm text-gray-400">Description</label>
            <textarea id="variant-description"
              class="w-full mt-1 bg-[#0f172a] border border-white/10 px-3 py-2 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 outline-none"
              rows="3"></textarea>
            <span id="variantDescriptionError" class="text-red-400 text-xs mt-1 hidden block"></span>
          </div>

          <!-- IMAGES -->
          <div>
            <label class="text-sm text-gray-400">Images</label>

            <input type="file" id="variantImageInput" class="hidden" accept="image/*" multiple>

            <div id="variantImagePreview"
              class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 gap-3 mt-2 overflow-visible">
            </div>

            <button type="button" onclick="openImageUploadForForm()"
              class="mt-3 px-3 py-1 bg-blue-600 hover:bg-blue-700 text-white text-xs rounded">
              + Add Images
            </button>
            <span id="variantImagesError" class="text-red-400 text-xs mt-1 hidden block"></span>
          </div>

          <!-- ATTRIBUTES -->
          <div>
            <label class="text-sm text-gray-400">Variant Attributes</label>
            <div id="variantAttributes" class="flex flex-col gap-2 mt-2"></div>
            <span id="variantAttributesError" class="text-red-400 text-xs mt-1 hidden block"></span>
          </div>

          <!-- BUTTONS -->
          <div class="flex justify-end gap-3 mt-4">
            <button type="button" onclick="closeVariantModal()"
              class="px-4 py-2 bg-gray-600 hover:bg-gray-700 text-white rounded-lg text-sm">
              Cancel
            </button>

            <button type="submit" class="px-4 py-2 bg-cyan-600 hover:bg-cyan-700 text-white rounded-lg text-sm">
              Save Variant
            </button>
          </div>

        </form>

      </div>
    </div>

    <!-- croper modal -->
    <div id="variantCropModal" class="fixed inset-0 bg-black/70 hidden z-50 flex items-center justify-center">

      <div class="bg-[#0b1220] p-6 rounded-xl w-[600px]">

        <h2 class="text-white mb-4">Crop Image</h2>

        <div class="max-h-[400px]">
          <img id="variantCropImage" class="max-w-full">
        </div>

        <div class="flex justify-end gap-3 mt-4">
          <button onclick="closeVariantCrop()" class="px-4 py-2 bg-gray-600 rounded">
            Cancel
          </button>

          <button onclick="handleCrop()" class="px-4 py-2 bg-cyan-600 rounded">
            Crop
          </button>
        </div>

      </div>

    </div>

    <script type="module">

      import { showToast } from "../../partials/errorMsg.utils.js";
      import { confirmAction } from "../../partials/confirm.util.js";

      // ── Copy any ID to clipboard ──────────────────────────────────────────
      window.copyId = async (id) => {
        try {
          await navigator.clipboard.writeText(id);
          showToast('Copied: ' + id.slice(0, 16) + (id.length > 16 ? '…' : ''), 'success');
        } catch {
          showToast('Copy failed', 'error');
        }
      };

      let editingVariantAttributes = {};
      let currentVariantId = null;
      const MAX_IMAGES = 5;

      // Cropper variables
      let variantCropper;
      let variantCroppedBlob;
      let variantImages = []; //  store cropped blobs
      let cropMode = "single"; // "single" | "multi"
      let imagesToDelete = []; // store imageIds to delete on save
      let replacedImages = []; // store {imageId, blob} for replaced images
      let replaceVariantId = null;
      let replaceIndex = null;
      let newImagesInEdit = []; //store new img in editing variant time



      const variantImageInput = document.getElementById("variantImageInput");
      const variantCropModal = document.getElementById("variantCropModal");
      const variantCropImage = document.getElementById("variantCropImage");

      function getTotalImages() {
        const existing = document.querySelectorAll("#variantImagePreview > div[data-image-id]").length;
        const newImgs = newImagesInEdit.length;
        const addImgs = variantImages.length;

        return existing + newImgs + addImgs;
      }

      function updateAddButtonVisibility() {
        const btn = document.querySelector("#variantForm button[onclick='openImageUploadForForm()']");

        if (getTotalImages() >= MAX_IMAGES) {
          btn.style.display = "none"; // ❌ hide
        } else {
          btn.style.display = "inline-block"; // ✅ show
        }
      }




      /* ================= ACTION MENU ================= */

      window.toggleActionMenu = function () {
        const menu = document.getElementById("actionDropdown");
        menu.classList.toggle("hidden");
      };

      document.addEventListener("click", function (e) {
        const menu = document.getElementById("actionDropdown");
        if (!e.target.closest(".relative")) {
          menu?.classList.add("hidden");
        }
      });

      /* ================= VARIANT MODAL ================= */

      window.openVariantModal = function () {
        document.getElementById("variant-id").value = "";
        document.getElementById("variant-sku").value = "";
        document.getElementById("variant-price").value = "";
        document.getElementById("variant-stock").value = "";

        document.getElementById("variant-regular-price").value = "";
        document.getElementById("variant-max-discount").value = "";

        variantImages = [];
        imagesToDelete = [];

        document.getElementById("variantImagePreview").innerHTML = "";
        document.getElementById("variant-description").value = "";

        editingVariantAttributes = {};

        document.getElementById("variantModalTitle").textContent = "Add Variant";

        // Clear all inline errors
        document.getElementById("variantSkuError").textContent = "";
        document.getElementById("variantSkuError").classList.add("hidden");
        document.getElementById("variantPriceError").textContent = "";
        document.getElementById("variantPriceError").classList.add("hidden");
        document.getElementById("variantRegularPriceError").textContent = "";
        document.getElementById("variantRegularPriceError").classList.add("hidden");
        document.getElementById("variantMaxDiscountError").textContent = "";
        document.getElementById("variantMaxDiscountError").classList.add("hidden");
        document.getElementById("variantStockError").textContent = "";
        document.getElementById("variantStockError").classList.add("hidden");
        document.getElementById("variantDescriptionError").textContent = "";
        document.getElementById("variantDescriptionError").classList.add("hidden");
        document.getElementById("variantImagesError").textContent = "";
        document.getElementById("variantImagesError").classList.add("hidden");
        document.getElementById("variantAttributesError").textContent = "";
        document.getElementById("variantAttributesError").classList.add("hidden");

        loadVariantAttributes();
        skuStatus.textContent = ''


        document.getElementById("variantModal").classList.remove("hidden");
        document.body.style.overflow = "hidden"; // 🔥 prevent background scroll

      };

      window.closeVariantModal = function () {
        // Clear all inline errors
        document.getElementById("variantSkuError").textContent = "";
        document.getElementById("variantSkuError").classList.add("hidden");
        document.getElementById("variantPriceError").textContent = "";
        document.getElementById("variantPriceError").classList.add("hidden");
        document.getElementById("variantRegularPriceError").textContent = "";
        document.getElementById("variantRegularPriceError").classList.add("hidden");
        document.getElementById("variantMaxDiscountError").textContent = "";
        document.getElementById("variantMaxDiscountError").classList.add("hidden");
        document.getElementById("variantStockError").textContent = "";
        document.getElementById("variantStockError").classList.add("hidden");
        document.getElementById("variantDescriptionError").textContent = "";
        document.getElementById("variantDescriptionError").classList.add("hidden");
        document.getElementById("variantImagesError").textContent = "";
        document.getElementById("variantImagesError").classList.add("hidden");
        document.getElementById("variantAttributesError").textContent = "";
        document.getElementById("variantAttributesError").classList.add("hidden");
        
        document.getElementById("variantModal").classList.add("hidden");
        document.body.style.overflow = "auto"; // restore scroll
        skuStatus.textContent = ''
        imagesToDelete = [];
        newImagesInEdit = [];
        replacedImages = [];
      };

      /* ================= LOAD ATTRIBUTES ================= */

      async function loadVariantAttributes(existingAttributes = {}) {
        const categoryId = "<%= product.category._id %>";
        const container = document.getElementById("variantAttributes");

        container.innerHTML = "";

        try {
          const res = await fetch(`/admin/category/${categoryId}/attributes`);
          const result = await res.json();

          result.data.variantAttributes.forEach(attr => {
            const input = document.createElement("input");

            input.placeholder = attr.label;
            input.name = attr.key;
            input.value = existingAttributes[attr.key] || "";

            input.className =
              "bg-[#0f172a] border border-white/10 px-3 py-2 rounded-lg text-sm";

            container.appendChild(input);
          });

        } catch {
          showToast("Failed to load attributes", "error");
        }
      }

      /* ================= EDIT VARIANT ================= */

      window.editVariant = async function (variantId) {
        imagesToDelete = [];
        newImagesInEdit = [];//for Backend
        replacedImages = [];
        variantImages = [];  // for UI


        try {

          const res = await fetch(
            `/admin/products/<%= product._id %>/variants/${variantId}`
          );

          const data = await res.json();

          if (!data.success) {
            return showToast(data.message, "error");
          }

          const variant = data.data.variant;

          console.log("FETCHED VARIANT:", variant);

          // ================= SET BASIC FIELDS =================

          document.getElementById("variant-id").value = variant._id;
          document.getElementById("variant-sku").value = variant.sku || "";
          document.getElementById("variant-price").value = variant.price || "";
          document.getElementById("variant-stock").value = variant.stock || "";
          document.getElementById("variant-description").value = variant.description || "";
          document.getElementById("variant-regular-price").value =
            variant.regular_price || "";

          document.getElementById("variant-max-discount").value =
            variant.max_discount_amount || "";

          // ================= ATTRIBUTES =================

          editingVariantAttributes = variant.attributes || {};
          await loadVariantAttributes(editingVariantAttributes);

          // ================= IMAGES =================

          const preview = document.getElementById("variantImagePreview");
          preview.innerHTML = "";

          if (variant.product_images?.length) {
            variant.product_images.forEach(img => {
              const wrapper = document.createElement("div");
              wrapper.className = "relative group w-16 h-16";

              // store imageId for delete/replace actions
              wrapper.dataset.imageId = img.imageId;


              const image = document.createElement("img");
              image.src = img.url;
              image.className = "w-full h-full object-cover rounded";

              const removeBtn = document.createElement("button");
              removeBtn.innerHTML = "×";

              // ❌ REMOVE BUTTON
              removeBtn.className =
                "absolute -top-2 -right-2 bg-red-500 text-white rounded-full w-4 h-4 text-[10px] hidden group-hover:flex items-center justify-center z-10";

              // REMOVE HANDLER
              removeBtn.onclick = () => {
                imagesToDelete.push(img.imageId);
                wrapper.remove();
                updateAddButtonVisibility();
              };

              const replaceBtn = document.createElement("button");
              replaceBtn.type = "button";
              replaceBtn.innerText = "Replace";

              // 🔁 REPLACE BUTTO
              replaceBtn.className =
                "absolute bottom-0 left-0 right-0 bg-black/60 text-white text-[10px] py-[2px] hidden group-hover:block";

              // click replace (EDIT MODE ONLY)
              replaceBtn.onclick = () => {
                replaceVariantId = img.imageId;
                cropMode = "replace-edit";
                variantImageInput.click();
              };

              wrapper.appendChild(image);
              wrapper.appendChild(removeBtn);
              wrapper.appendChild(replaceBtn);


              preview.appendChild(wrapper);
            });
          }

          // reset new images
          variantImages = [];

          document.getElementById("variantModalTitle").textContent = "Edit Variant";

          document.getElementById("variantModal").classList.remove("hidden");

        } catch (error) {
          console.error(error);
          showToast("Failed to load variant", "error");
        }
      };

      /* ================= SUBMIT VARIANT ================= */

      const variantForm = document.getElementById("variantForm");

      variantForm.addEventListener("submit", async (e) => {
        e.preventDefault();

        const submitBtn = variantForm.querySelector("button[type='submit']");

        if (submitBtn.disabled) return;

        // Get all error elements
        const skuError = document.getElementById("variantSkuError");
        const priceError = document.getElementById("variantPriceError");
        const regularPriceError = document.getElementById("variantRegularPriceError");
        const maxDiscountError = document.getElementById("variantMaxDiscountError");
        const stockError = document.getElementById("variantStockError");
        const descriptionError = document.getElementById("variantDescriptionError");
        const imagesError = document.getElementById("variantImagesError");
        const attributesError = document.getElementById("variantAttributesError");

        // Clear all previous errors
        skuError.textContent = "";
        skuError.classList.add("hidden");
        priceError.textContent = "";
        priceError.classList.add("hidden");
        regularPriceError.textContent = "";
        regularPriceError.classList.add("hidden");
        maxDiscountError.textContent = "";
        maxDiscountError.classList.add("hidden");
        stockError.textContent = "";
        stockError.classList.add("hidden");
        descriptionError.textContent = "";
        descriptionError.classList.add("hidden");
        imagesError.textContent = "";
        imagesError.classList.add("hidden");
        attributesError.textContent = "";
        attributesError.classList.add("hidden");

        try {
          submitBtn.disabled = true;
          submitBtn.textContent = "Saving...";
          submitBtn.classList.add("opacity-50", "cursor-not-allowed");

          const variantId = document.getElementById("variant-id").value;
          const sku = document.getElementById("variant-sku").value.trim();

          const priceInput = document.getElementById("variant-price").value;
          const stockInput = document.getElementById("variant-stock").value;
          const regularPriceInput = document.getElementById("variant-regular-price").value;
          const maxDiscountInput = document.getElementById("variant-max-discount").value;

          const regular_price =
            regularPriceInput === "" ? undefined : parseFloat(regularPriceInput);

          const max_discount_amount =
            maxDiscountInput === "" ? undefined : parseFloat(maxDiscountInput);

          const price = priceInput === "" ? NaN : parseFloat(priceInput);
          const stock = stockInput === "" ? NaN : parseInt(stockInput);

          const description = document.getElementById("variant-description").value.trim();

          let hasError = false;

          // SKU validation
          if (skuStatus.textContent.includes("exists")) {
            skuError.textContent = "SKU already exists!";
            skuError.classList.remove("hidden");
            hasError = true;
          } else if (!sku) {
            skuError.textContent = "SKU is required";
            skuError.classList.remove("hidden");
            hasError = true;
          } else if (sku.length < 3) {
            skuError.textContent = "SKU must be at least 3 characters";
            skuError.classList.remove("hidden");
            hasError = true;
          }

          // Price validation
          if (isNaN(price) || price < 0) {
            priceError.textContent = "Price must be 0 or greater";
            priceError.classList.remove("hidden");
            hasError = true;
          }

          // Stock validation
          if (isNaN(stock) || stock < 0) {
            stockError.textContent = "Stock must be 0 or greater";
            stockError.classList.remove("hidden");
            hasError = true;
          }

          // Regular price validation
          if (regular_price !== undefined && regular_price < price) {
            regularPriceError.textContent = "Regular price must be greater than or equal to price";
            regularPriceError.classList.remove("hidden");
            hasError = true;
          }

          // Max discount validation
          if (max_discount_amount !== undefined && max_discount_amount < 0) {
            maxDiscountError.textContent = "Max discount must be 0 or greater";
            maxDiscountError.classList.remove("hidden");
            hasError = true;
          }

          // Max discount must be less than the selling price
          if (max_discount_amount !== undefined && max_discount_amount > 0 && !isNaN(price) && max_discount_amount >= price) {
            maxDiscountError.textContent = "Max discount must be less than the selling price";
            maxDiscountError.classList.remove("hidden");
            hasError = true;
          }

          // ATTRIBUTES - Pattern allows letters, numbers, spaces, -, _, and /
          const attributePattern = /^[A-Za-z0-9/]+(?:[ _-][A-Za-z0-9/]+)*$/;
          const attributes = {};
          const attrInputs = document.querySelectorAll("#variantAttributes input");
          
          for (const input of attrInputs) {
            const value = input.value.trim();
            if (!value) {
              attributesError.textContent = `${input.placeholder} is required`;
              attributesError.classList.remove("hidden");
              hasError = true;
              break;
            }
            if (!attributePattern.test(value)) {
              attributesError.textContent = `${input.placeholder} can only contain letters, numbers, spaces, -, _, and /`;
              attributesError.classList.remove("hidden");
              hasError = true;
              break;
            }
            attributes[input.name] = value;
          }

          // DESCRIPTION
          if (!description || description.length < 5) {
            descriptionError.textContent = "Description must be at least 5 characters";
            descriptionError.classList.remove("hidden");
            hasError = true;
          }

          // IMAGES
          if (!variantId && variantImages.length < 3) {
            imagesError.textContent = "At least 3 images are required";
            imagesError.classList.remove("hidden");
            hasError = true;
          }

          if (hasError) {
            submitBtn.disabled = false;
            submitBtn.textContent = "Save Variant";
            submitBtn.classList.remove("opacity-50", "cursor-not-allowed");
            return;
          }

          // FORM DATA
          const formData = new FormData();
          formData.append("sku", sku);
          formData.append("price", price);
          formData.append("stock", stock);
          formData.append("description", description);
          formData.append("attributes", JSON.stringify(attributes));

          variantImages.forEach((img, i) => {
            if (img.file) {
              formData.append("images", img.file, `variant-${i}.png`);
            }
          });

          if (imagesToDelete.length > 0) {
            formData.append("deleteImages", JSON.stringify(imagesToDelete));
          }

          if (replacedImages.length > 0) {
            replacedImages.forEach((item, i) => {
              if (item.file && item.imageId) {
                formData.append("images", item.file);
                formData.append("replaceImageIds", item.imageId);
              }
            });
          }

          newImagesInEdit.forEach((img) => {
            if (img.file) {
              formData.append("images", img.file);
            }
          });

          if (regular_price !== undefined) {
            formData.append("regular_price", regular_price);
          }

          if (max_discount_amount !== undefined) {
            formData.append("max_discount_amount", max_discount_amount);
          }

          let url = `/admin/products/<%= product._id %>/variants`;
          let method = "POST";

          if (variantId) {
            url = `/admin/products/<%= product._id %>/variants/${variantId}`;
            method = "PATCH";
          }

          const res = await fetch(url, {
            method,
            body: formData
          });

          const data = await res.json();

          if (!data.success) {
            showToast(data.message, "error");
            return;
          }

          showToast(data.message, "success");

          setTimeout(() => location.reload(), 1200);

        } catch (err) {
          showToast(err.message || "Something went wrong", "error");
        } finally {
          setTimeout(() => {
            submitBtn.disabled = false;
            submitBtn.textContent = "Save Variant";
            submitBtn.classList.remove("opacity-50", "cursor-not-allowed");
          }, 1000);
        }
      });

      /* ================= DELETE VARIANT ================= */

      window.deleteVariant = async function (id) {
        const confirmed = await confirmAction("Delete Variant?");
        if (!confirmed) return;

        try {
          const res = await fetch(
            `/admin/products/<%= product._id %>/variants/${id}`,
            { method: "DELETE" }
          );

          const data = await res.json();

          if (!data.success)
            return showToast(data.message, "error");

          showToast("Variant deleted successfully", "success");

          setTimeout(() => location.reload(), 1200);

        } catch {
          showToast("Delete failed", "error");
        }
      };

      /* ================= IMAGE UPLOAD (WITH CROPPER) ================= */

      window.openImageUpload = function (variantId) {
        currentVariantId = variantId;
        cropMode = "single";
        variantImageInput.click();
      };

      variantImageInput.addEventListener("change", function () {
        const file = this.files[0];
        if (!file) return;

        if (!file.type.startsWith("image/"))
          return showToast("Only image files allowed", "warning");

        const reader = new FileReader();

        reader.onload = function (e) {
          variantCropImage.src = e.target.result;
          variantCropModal.classList.remove("hidden");

          setTimeout(() => {
            if (variantCropper) variantCropper.destroy();

            variantCropper = new Cropper(variantCropImage, {
              viewMode: 1,
              autoCropArea: 1,
            });
          }, 100);
        };

        reader.readAsDataURL(file);
      });

      function handleNextImage(files) {
        const file = files.shift();
        if (!file) return;

        if (!file.type.startsWith("image/"))
          return showToast("Only image files allowed", "warning");

        const reader = new FileReader();

        reader.onload = function (e) {
          variantCropImage.src = e.target.result;
          variantCropModal.classList.remove("hidden");

          setTimeout(() => {
            if (variantCropper) variantCropper.destroy();

            variantCropper = new Cropper(variantCropImage, {
              aspectRatio: 1,
              viewMode: 1,
              autoCropArea: 1,
            });

            // store remaining files
            variantCropModal.dataset.remaining = JSON.stringify(files);
          }, 100);
        };

        reader.readAsDataURL(file);
      }

      /* ================= CROP & UPLOAD ================= */

      window.cropSingleVariantImage = async function () {
        if (!variantCropper) return;

        const canvas = variantCropper.getCroppedCanvas({
          width: 400,
          height: 400,
          viewMode: 1,
          responsive: true,

          // ✅ Full control to user
          movable: true,
          zoomable: true,
        });

        canvas.toBlob(async (blob) => {

          const formData = new FormData();
          formData.append("image", blob, "variant.png");

          try {
            const res = await fetch(
              `/admin/products/<%= product._id %>/variants/${currentVariantId}/image`,
              {
                method: "POST",
                body: formData
              }
            );

            const data = await res.json();

            if (!data.success)
              return showToast(data.message, "error");

            showToast("Image uploaded successfully", "success");

            closeVariantCrop();
            setTimeout(() => location.reload(), 800);

          } catch {
            showToast("Upload failed", "error");
          }

        }, "image/png");
      };

      window.cropMultiVariantImage = function () {
        if (!variantCropper) return;

        const canvas = variantCropper.getCroppedCanvas({
          width: 400,
          height: 400,
          viewMode: 1,
          responsive: true,

          // ✅ Full control to user
          movable: true,
          zoomable: true,
        });

        canvas.toBlob((blob) => {

          variantImages.push({
            file: blob,
            preview: URL.createObjectURL(blob),
          });

          renderImages();

          closeVariantCrop();

        }, "image/png");
      };

      window.handleCrop = function () {
        if (cropMode === "single") {
          cropSingleVariantImage();
        } else if (cropMode === "multi") {
          cropMultiVariantImage();
        } else if (cropMode === "multi-edit") {
          cropMultiVariantImageEdit(); // NEW
        } else if (cropMode === "replace") {
          replaceVariantImageUpload(); // existing (table)
        } else if (cropMode === "replace-edit") {
          replaceImageInEdit(); // edit modal
        } else if (cropMode === "replace-add") {
          replaceImageInAdd(); // add modal 
        } else if (cropMode === "replace-edit-new") {
          replaceNewImageInEdit();
        }
      };

      async function replaceVariantImageUpload() {
        if (!variantCropper) return;

        const canvas = variantCropper.getCroppedCanvas({
          width: 400,
          height: 400,
        });

        canvas.toBlob(async (blob) => {
          const formData = new FormData();
          formData.append("image", blob, "variant.png");
          formData.append("imageId", replaceImageId);

          try {
            const res = await fetch(
              `/admin/products/<%= product._id %>/variants/${replaceVariantId}/image/replace`,
              {
                method: "PATCH",
                body: formData
              }
            );

            const data = await res.json();

            if (!data.success)
              return showToast(data.message, "error");

            showToast("Image replaced successfully", "success");

            closeVariantCrop();
            setTimeout(() => location.reload(), 800);

          } catch {
            showToast("Replace failed", "error");
          }

        }, "image/png");
      }


      function replaceImageInEdit() {
        if (!variantCropper) return;

        const canvas = variantCropper.getCroppedCanvas({
          width: 400,
          height: 400,
        });

        canvas.toBlob((blob) => {

          // store for backend
          replacedImages.push({
            imageId: replaceVariantId,
            file: blob,
          });

          // update UI preview
          const preview = document.getElementById("variantImagePreview");

          [...preview.children].forEach((wrapper) => {
            const img = wrapper.querySelector("img");

            if (img && img.src.includes(replaceVariantId)) {
              img.src = URL.createObjectURL(blob);
            }
          });

          closeVariantCrop();
        }, "image/png");
      }

      /* ================= CLOSE CROP ================= */

      window.closeVariantCrop = function () {
        variantCropModal.classList.add("hidden");

        if (variantCropper) {
          variantCropper.destroy();
          variantCropper = null;
        }

        variantImageInput.value = "";
      };

      /* ================= DELETE IMAGE ================= */

      window.deleteVariantImage = async function (variantId, imageId) {
        console.log(imageId)
        const confirmed = await confirmAction("Delete image?");
        if (!confirmed) return;

        try {
          const res = await fetch(
            `/admin/products/<%= product._id %>/variants/${variantId}/image`,
            {
              method: "DELETE",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ imageId })
            }
          );

          const data = await res.json();

          if (!data.success)
            return showToast(data.message, "error");

          showToast("Image removed", "success");

          setTimeout(() => location.reload(), 1200);

        } catch {
          showToast("Delete failed", "error");
        }
      };

      window.openImageUploadForForm = function () {
        const variantId = document.getElementById("variant-id").value;

        const totalImages =
          variantImages.length + newImagesInEdit.length + document.querySelectorAll("#variantImagePreview > div[data-image-id]").length;

        if (totalImages >= MAX_IMAGES) {
          showToast("Maximum 5 images allowed", "warning");
          return;
        }

        if (variantId) {
          // EDIT MODE
          cropMode = "multi-edit";
        } else {
          // ADD MODE
          cropMode = "multi";
        }

        variantImageInput.click();
      };

      // Product togglestatus update and delete product code 
      window.handleProductAction = async function (productId, action) {

        // close dropdown
        document.getElementById("actionDropdown").classList.add("hidden");

        let confirmText = "";

        if (action === "delete") confirmText = "Delete this product?";
        if (action === "listed") confirmText = "Unlist this product?";
        if (action === "unlisted") confirmText = "List this product?";

        const confirmed = await confirmAction(confirmText);
        if (!confirmed) return;

        try {
          let url = "";
          let method = "PATCH";

          if (action === "delete") {
            url = `/admin/products/${productId}`;
            method = "DELETE";
          } else {
            url = `/admin/products/${productId}/status`;
          }

          const res = await fetch(url, { method });
          const result = await res.json();

          if (!result.success) {
            return showToast(data.message, "error");
          }

          // DELETE CASE
          if (action === "delete") {
            showToast("Product deleted successfully", "success");
            setTimeout(() => location.reload(), 500); // optional
            return;
          }

          // TOGGLE CASE (NO RELOAD)
          const btn = document.getElementById(`status-${productId}`);


          if (!btn) return;

          // determine new state
          const newAction = result.data.action;

          // update button text
          btn.textContent = newAction === "listed"
            ? "Unlist Product"
            : "List Product";

          // update button color
          btn.className = `w-full text-left px-4 py-2 text-sm ${newAction === "listed"
            ? "text-yellow-400 hover:bg-white/10"
            : "text-green-400 hover:bg-white/10"
            }`;


          const badge = document.getElementById(`badge-${productId}`);

          badge.textContent = newAction === "listed"
            ? "Listed"
            : "Unlisted";

          // update button color
          badge.className = `px-2 py-1 rounded-full text-xs ${newAction === "listed"
            ? 'bg-emerald-500/20 text-emerald-400'
            : 'bg-red-500/20 text-red-400'
            }`;

          // update onclick
          btn.setAttribute(
            "onclick",
            `handleProductAction('${productId}','${newAction}')`
          );

          showToast(`Product ${action}ed successfully`, "success");

        } catch (err) {
          showToast("Something went wrong", "error");
        }
      };

      // Disable scroll on number inputs (GLOBAL FIX)
      document.addEventListener("wheel", function (e) {
        if (e.target.type === "number") {
          e.preventDefault();
          e.target.blur();
        }
      }, { passive: false });

      let replaceImageId = null;
      replaceVariantId = null;

      // OPEN FILE SELECT FOR REPLACE
      window.replaceVariantImage = function (variantId, imageId) {
        replaceVariantId = variantId;
        replaceImageId = imageId;

        cropMode = "replace"; // new mode
        variantImageInput.click();
      };

      function addVariantImages(files) {
        const preview = document.getElementById("variantImagePreview");

        [...files].forEach(file => {
          const url = URL.createObjectURL(file);

          variantImages.push({ file, preview: url });

          renderImages();
          updateAddButtonVisibility();
        });
      }

      function replaceImageInAdd() {
        if (!variantCropper) return;

        const canvas = variantCropper.getCroppedCanvas({
          width: 400,
          height: 400,
        });

        canvas.toBlob((blob) => {
          if (!blob) return; // safety

          const url = URL.createObjectURL(blob);

          variantImages[replaceIndex] = {
            file: blob,
            preview: url,
          };

          renderImages();
          closeVariantCrop();
        }, "image/png");
      }

      function renderImages() {
        const preview = document.getElementById("variantImagePreview");
        preview.innerHTML = "";

        variantImages.forEach((img, index) => {
          const wrapper = document.createElement("div");
          wrapper.className = "relative group w-20 h-20"; // 🔥 bigger hit area

          const image = document.createElement("img");
          image.src = img.preview;
          image.className = "w-full h-full object-cover rounded pointer-events-none";

          // ❌ REMOVE
          const removeBtn = document.createElement("button");
          removeBtn.type = "button";
          removeBtn.innerHTML = "×";
          removeBtn.className =
            "absolute -top-2 -right-2 bg-red-500 text-white rounded-full w-5 h-5 text-[10px] hidden group-hover:flex items-center justify-center z-20";

          removeBtn.onclick = () => {
            variantImages.splice(index, 1);
            // ALSO REMOVE FROM newImagesInEdit
            newImagesInEdit.splice(index, 1);
            renderImages();
            updateAddButtonVisibility();

          };

          // 🔁 REPLACE
          const replaceBtn = document.createElement("button");
          replaceBtn.type = "button";
          replaceBtn.innerText = "Replace";
          replaceBtn.className =
            "absolute bottom-0 left-0 right-0 bg-black/70 text-white text-[10px] py-[2px] hidden group-hover:block z-20";

          replaceBtn.onclick = () => {
            replaceIndex = index;
            cropMode = "replace-add"; // 
            variantImageInput.click();
          };

          wrapper.appendChild(image);
          wrapper.appendChild(removeBtn);
          wrapper.appendChild(replaceBtn);

          preview.appendChild(wrapper);
        });
      }

      function cropMultiVariantImageEdit() {
        if (!variantCropper) return;

        const canvas = variantCropper.getCroppedCanvas({
          width: 400,
          height: 400,
        });

        canvas.toBlob((blob) => {
          if (!blob) return;

          // store like replacedImages OR new images
          newImagesInEdit.push({
            file: blob,
            preview: URL.createObjectURL(blob),
          });

          //  ONLY APPEND 
          appendNewImagePreview(blob);
          updateAddButtonVisibility();

          closeVariantCrop();

        }, "image/png");
      }

      function appendNewImagePreview(blob) {
        const preview = document.getElementById("variantImagePreview");



        const wrapper = document.createElement("div");
        wrapper.className = "relative group w-20 h-20";

        wrapper.dataset.type = "new";
        wrapper.dataset.index = newImagesInEdit.length - 1;

        const img = document.createElement("img");
        img.src = URL.createObjectURL(blob);
        img.className = "w-full h-full object-cover rounded";

        // ❌ REMOVE
        const removeBtn = document.createElement("button");
        removeBtn.type = "button";
        removeBtn.innerHTML = "×";
        removeBtn.className =
          "absolute -top-2 -right-2 bg-red-500 text-white rounded-full w-5 h-5 text-[10px] hidden group-hover:flex items-center justify-center z-20";

        removeBtn.onclick = () => {
          const index = Number(wrapper.dataset.index);

          newImagesInEdit.splice(index, 1);
          wrapper.remove();
          updateAddButtonVisibility(); // ✅ ADD
        };

        // 🔁 REPLACE (NEW IMAGE)
        const replaceBtn = document.createElement("button");
        replaceBtn.innerText = "Replace";
        replaceBtn.type = "button";
        replaceBtn.className =
          "absolute bottom-0 left-0 right-0 bg-black/70 text-white text-[10px] py-[2px] hidden group-hover:block z-20";

        replaceBtn.onclick = () => {
          replaceIndex = Number(wrapper.dataset.index);
          cropMode = "replace-edit-new";
          variantImageInput.click();
        };

        wrapper.appendChild(img);
        wrapper.appendChild(removeBtn);
        wrapper.appendChild(replaceBtn);

        preview.appendChild(wrapper);
      }


      function replaceNewImageInEdit() {
        if (!variantCropper) return;

        const canvas = variantCropper.getCroppedCanvas({
          width: 400,
          height: 400,
        });

        canvas.toBlob((blob) => {
          if (!blob) return;

          const url = URL.createObjectURL(blob);

          newImagesInEdit[replaceIndex] = {
            file: blob,
            preview: url,
          };

          const preview = document.getElementById("variantImagePreview");

          const wrapper = [...preview.children].find(
            (w) => w.dataset.index == replaceIndex && w.dataset.type === "new"
          );

          if (wrapper) {
            const img = wrapper.querySelector("img");
            img.src = url;
          }

          closeVariantCrop();
        }, "image/png");
      }

    </script>



    <script>

      function debounce(fn, delay) {
        let timeout;

        return function (...args) {
          clearTimeout(timeout);
          timeout = setTimeout(() => fn.apply(this, args), delay);
        };
      }

      const skuInput = document.getElementById("variant-sku");
      const skuStatus = document.getElementById("skuStatus");

      const checkSku = debounce(async function () {
        const sku = skuInput.value.trim();

        if (!sku) {
          skuStatus.textContent = "";
          return;
        }

        skuStatus.textContent = "Checking...";
        skuStatus.className = "text-xs mt-1 text-gray-400";

        try {
          const res = await fetch(`/admin/products/check-sku?sku=${sku}`);
          const result = await res.json();

          console.log(result)

          if (result.data.available) {
            skuStatus.textContent = "✅ SKU available";
            skuStatus.className = "text-xs mt-1 text-emerald-400";
          } else {
            skuStatus.textContent = "❌ SKU already exists";
            skuStatus.className = "text-xs mt-1 text-red-400";
          }

        } catch (err) {
          skuStatus.textContent = "Error checking SKU";
          skuStatus.className = "text-xs mt-1 text-red-400";
        }

      }, 500);

      skuInput.addEventListener("input", checkSku);

      // Auto-generate SKU — format: SKU + 6 alphanumeric chars, unique check
      document.getElementById('generateSkuBtn').addEventListener('click', async () => {
        const btn = document.getElementById('generateSkuBtn');
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';

        const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789';

        try {
          for (let i = 0; i < 10; i++) {
            const suffix = Array.from({ length: 6 }, () => chars[Math.floor(Math.random() * chars.length)]).join('');
            const sku    = 'SKU' + suffix;

            const res    = await fetch(`/admin/products/check-sku?sku=${sku}`);
            const result = await res.json();

            if (result.data?.available) {
              skuInput.value          = sku;
              skuStatus.textContent   = '✅ SKU available';
              skuStatus.className     = 'text-xs mt-1 text-emerald-400';
              break;
            }
          }
        } catch (err) {
          skuStatus.textContent = 'Error generating SKU';
          skuStatus.className   = 'text-xs mt-1 text-red-400';
        } finally {
          btn.disabled = false;
          btn.innerHTML = '<i class="fas fa-wand-magic-sparkles"></i>';
        }
      });

    </script>


</body>

