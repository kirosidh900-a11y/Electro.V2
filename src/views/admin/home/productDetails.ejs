<!DOCTYPE html>
<html lang="en" class="dark">

<head>
        <%- include('../../partials/head') %>
</head>

<body class="min-h-screen flex">

        <%- include('../../partials/admin/sidebar') %>

                <div id="mainContent" class="flex-1 flex flex-col min-w-0 transition-all duration-300">

                        <%- include('../../partials/admin/header') %>

                                <main class="flex-1 p-6">

                                        <!-- ================= HEADER ================= -->

                                        <div class="flex items-center justify-between mb-6">

                                                <a href="/admin/products" class="text-sm text-blue-400 hover:underline">
                                                        ← Back to Products
                                                </a>

                                                <h1 class="text-xl font-semibold text-white">
                                                        Product Details
                                                </h1>

                                                <div class="relative">

                                                        <button
                                                                class="bg-gray-700 text-white px-4 py-2 rounded-lg text-sm">
                                                                Actions
                                                        </button>

                                                </div>

                                        </div>


                                        <!-- ================= PRODUCT INFO ================= -->

                                        <div class="grid grid-cols-2 gap-6 mb-6">

                                                <!-- LEFT CARD -->

                                                <div class="bg-[#0b1220] border border-white/10 rounded-xl p-6">

                                                        <h3 class="text-white font-semibold mb-4">
                                                                Product Information
                                                        </h3>

                                                        <div class="space-y-2 text-sm text-gray-300">

                                                                <p><span class="text-gray-400">Name:</span>
                                                                        <%= product.name %>
                                                                </p>

                                                                <p><span class="text-gray-400">Brand:</span>
                                                                        <%= product.brand.title %>
                                                                </p>

                                                                <p><span class="text-gray-400">Category:</span>
                                                                        <%= product.category.title %>
                                                                </p>

                                                                <p>

                                                                        <span class="text-gray-400">Status:</span>

                                                                        <span class="px-2 py-1 rounded-full text-xs 
<%= product.status === " listed" ? "bg-emerald-500/20 text-emerald-400" : "bg-red-500/20 text-red-400" %>">

                                                                                <%= product.status==="listed"
                                                                                        ? "In Stock" : "Unlisted" %>

                                                                        </span>

                                                                </p>

                                                                <p><span class="text-gray-400">Created At:</span>
                                                                        <%= product.createdAt.toDateString() %>
                                                                </p>

                                                                <p><span class="text-gray-400">Last Updated:</span>
                                                                        <%= product.updatedAt.toDateString() %>
                                                                </p>

                                                        </div>

                                                </div>


                                                <!-- RIGHT CARD -->

                                                <div class="bg-[#0b1220] border border-white/10 rounded-xl p-6">

                                                        <h3 class="text-white font-semibold mb-4">
                                                                Product Metrics
                                                        </h3>

                                                        <div class="grid grid-cols-2 gap-4">

                                                                <div class="bg-[#0f172a] p-4 rounded-lg text-center">
                                                                        <p class="text-gray-400 text-sm">Total Variants
                                                                        </p>
                                                                        <p class="text-xl text-white font-semibold">
                                                                                <%= variants.length %>
                                                                        </p>
                                                                </div>

                                                                <div class="bg-[#0f172a] p-4 rounded-lg text-center">
                                                                        <p class="text-gray-400 text-sm">Minimum Price
                                                                        </p>
                                                                        <p class="text-xl text-white font-semibold">
                                                                                $<%= minPrice || 0 %>
                                                                        </p>
                                                                </div>

                                                                <div class="bg-[#0f172a] p-4 rounded-lg text-center">
                                                                        <p class="text-gray-400 text-sm">Total Stock</p>
                                                                        <p class="text-xl text-white font-semibold">
                                                                                <%= totalStock || 0 %>
                                                                        </p>
                                                                </div>

                                                                <div class="bg-[#0f172a] p-4 rounded-lg text-center">
                                                                        <p class="text-gray-400 text-sm">In Stock</p>
                                                                        <p class="text-xl text-white font-semibold">
                                                                                <%= totalStock> 0 ? "Yes" : "No" %>
                                                                        </p>
                                                                </div>

                                                        </div>

                                                </div>

                                        </div>


                                        <!-- ================= VARIANTS ================= -->

                                        <div class="bg-[#0b1220] border border-white/10 rounded-xl p-6">

                                                <div class="flex items-center justify-between mb-4">

                                                        <h3 class="text-white font-semibold">
                                                                Variants (<%= variants.length %>)
                                                        </h3>

                                                        <button onclick="openVariantModal()"
                                                                class="bg-blue-600 hover:bg-blue-700 text-white text-sm px-4 py-2 rounded-lg">

                                                                + Add Variant

                                                        </button>

                                                </div>

                                                <% if(variants.length===0){ %>

                                                        <div class="text-center text-gray-400 py-10">

                                                                <p>No variants added yet</p>

                                                                <button onclick="openVariantModal()"
                                                                        class="mt-3 bg-blue-600 px-4 py-2 rounded-lg text-sm text-white">

                                                                        Add First Variant

                                                                </button>

                                                        </div>

                                                        <% } %>


                                                                <% if(variants.length> 0){ %>

                                                                        <table class="w-full text-sm text-gray-300">

                                                                                <thead
                                                                                        class="border-b border-white/10 text-gray-400">

                                                                                        <tr>
                                                                                                <th
                                                                                                        class="py-3 text-left">
                                                                                                        SKU</th>
                                                                                                <th
                                                                                                        class="py-3 text-left">
                                                                                                        Price</th>
                                                                                                <th
                                                                                                        class="py-3 text-left">
                                                                                                        Stock</th>
                                                                                                <th
                                                                                                        class="py-3 text-right">
                                                                                                        Actions</th>
                                                                                        </tr>

                                                                                </thead>

                                                                                <tbody>

                                                                                        <% variants.forEach(v=>{ %>

                                                                                                <tr
                                                                                                        class="border-b border-white/5">

                                                                                                        <td
                                                                                                                class="py-3">
                                                                                                                <%= v.sku
                                                                                                                        %>
                                                                                                        </td>

                                                                                                        <td>$<%= v.price
                                                                                                                        %>
                                                                                                        </td>

                                                                                                        <td>
                                                                                                                <%= v.stock
                                                                                                                        %>
                                                                                                        </td>

                                                                                                        <td
                                                                                                                class="text-right">

                                                                                                                <button onclick="deleteVariant('<%= v._id %>')"
                                                                                                                        class="text-red-400 text-xs">

                                                                                                                        Delete

                                                                                                                </button>

                                                                                                        </td>

                                                                                                </tr>

                                                                                                <% }) %>

                                                                                </tbody>

                                                                        </table>

                                                                        <% } %>

                                        </div>

                                </main>

                </div>

                <!-- ================= VARIANT MODAL ================= -->

                <div id="variantModal" class="fixed inset-0 bg-black/60 hidden z-50 flex items-center justify-center">

                        <div class="bg-[#0b1220] w-[550px] rounded-xl border border-white/10 p-6">

                                <div class="flex justify-between items-center mb-4">

                                        <h2 id="variantModalTitle" class="text-lg font-semibold text-white">
                                                Add Variant
                                        </h2>

                                        <button onclick="closeVariantModal()" class="text-gray-400 hover:text-white">
                                                <i class="fas fa-times"></i>
                                        </button>

                                </div>

                                <form id="variantForm" class="flex flex-col gap-4">

                                        <input type="hidden" id="variant-id">

                                        <!-- SKU -->

                                        <div>
                                                <label class="text-sm text-gray-400">SKU</label>
                                                <input type="text" id="variant-sku"
                                                        class="w-full mt-1 bg-[#0f172a] border border-white/10 px-3 py-2 rounded-lg text-sm">
                                        </div>

                                        <!-- PRICE -->

                                        <div>
                                                <label class="text-sm text-gray-400">Price</label>
                                                <input type="number" id="variant-price"
                                                        class="w-full mt-1 bg-[#0f172a] border border-white/10 px-3 py-2 rounded-lg text-sm">
                                        </div>

                                        <!-- STOCK -->

                                        <div>
                                                <label class="text-sm text-gray-400">Stock</label>
                                                <input type="number" id="variant-stock"
                                                        class="w-full mt-1 bg-[#0f172a] border border-white/10 px-3 py-2 rounded-lg text-sm">
                                        </div>

                                        <!-- VARIANT ATTRIBUTES -->

                                        <div>
                                                <label class="text-sm text-gray-400">Variant Attributes</label>
                                                <div id="variantAttributes" class="flex flex-col gap-2"></div>
                                        </div>

                                        <!-- BUTTONS -->

                                        <div class="flex justify-center gap-3 mt-4">

                                                <button type="button" onclick="closeVariantModal()"
                                                        class="px-4 py-2 bg-gray-600 hover:bg-gray-700 text-white rounded-lg text-sm">
                                                        Cancel
                                                </button>

                                                <button type="submit"
                                                        class="px-4 py-2 bg-cyan-600 hover:bg-cyan-700 text-white rounded-lg text-sm">
                                                        Save Variant
                                                </button>

                                        </div>

                                </form>

                        </div>
                </div>


                <script>

                        function openVariantModal() {

                                document.getElementById("variant-id").value = ""
                                document.getElementById("variant-sku").value = ""
                                document.getElementById("variant-price").value = ""
                                document.getElementById("variant-stock").value = ""

                                document.getElementById("variantModalTitle").textContent = "Add Variant"

                                loadVariantAttributes()

                                document.getElementById("variantModal").classList.remove("hidden")

                        }

                        function closeVariantModal() {
                                document.getElementById("variantModal").classList.add("hidden")
                        }


                        async function loadVariantAttributes() {

                                const categoryId = "<%= product.category._id %>"

                                const container = document.getElementById("variantAttributes")

                                container.innerHTML = ""

                                const res = await fetch(`/admin/category/${categoryId}/attributes?status=true`)

                                const data = await res.json()

                                data.variantAttributes
                                        .forEach(attr => {

                                                const input = document.createElement("input")

                                                input.placeholder = attr.label
                                                input.name = attr.key

                                                input.className =
                                                        "bg-[#0f172a] border border-white/10 px-3 py-2 rounded-lg text-sm"

                                                container.appendChild(input)

                                        })

                        }
                </script>

</body>

</html>