<% if(products.length===0){ %>

        <tr>
                <td colspan="6" class="text-center py-12 text-gray-500">
                        <i class="fas fa-box text-2xl mb-2 block"></i>
                        <p>No products found</p>
                </td>
        </tr>

        <% } else { %>

                <% products.forEach((product,index)=>{ %>

                        <tr id="row-<%= product._id %>" class="border-b border-white/5 hover:bg-white/5">

                                <td class="px-6 py-4">
                                        <%= (currentPage-1)*10 + index +1 %>
                                </td>

                                <td id="title-<%= product._id %>" class="px-6 py-4 font-semibold text-white">
                                        <%= product.name %>
                                </td>

                                <td id="category-<%= product._id %>" class="px-6 py-4">
                                        <%= product.category?.title || "-" %>
                                </td>

                                <td id="brand-<%= product._id %>" class="px-6 py-4">
                                        <%= product.brand?.title || "-" %>
                                </td>

                                <td class="px-6 py-4">

                                        <span id="badge-<%= product._id %>" class="px-3 py-1 rounded-full text-xs
<%= product.status==='listed'
? 'bg-emerald-500/20 text-emerald-400'
: 'bg-red-500/20 text-red-400' %>">

                                                <%= product.status %>

                                        </span>

                                </td>

                                <td class="px-6 py-4 text-right">

                                        <div class="flex justify-end gap-3">

                                                <button onclick='editProduct(
"<%= product._id %>",
<%- JSON.stringify(product.name) %>,
"<%= product.category?._id || '' %>",
"<%= product.brand?._id || '' %>",
"<%= product.status %>",
<%- JSON.stringify(product.attributes || {}) %>
)' class="text-cyan-400 hover:text-cyan-300">

                                                        <i class="fas fa-edit"></i>

                                                </button>

                                                <button onclick="toggleProductStatus('<%= product._id %>','<%= product.status %>')"
                                                        id="status-<%= product._id %>" class="px-3 py-1 text-xs rounded-md font-semibold
<%= product.status==='listed'
? 'bg-yellow-500/20 text-yellow-400'
: 'bg-emerald-500/20 text-emerald-400' %>">

                                                        <%= product.status==='listed' ? "Unlist" : "List" %>

                                                </button>

                                                <button onclick="deleteProduct('<%= product._id %>')"
                                                        class="text-red-400 hover:text-red-300">

                                                        <i class="fas fa-trash"></i>

                                                </button>

                                        </div>

                                </td>

                        </tr>

                        <% }) %>

                                <% } %>