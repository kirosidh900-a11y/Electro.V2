<!DOCTYPE html>
<html lang="en" class="dark">

<head>
        <%- include('../../partials/head') %>
</head>

<body class="min-h-screen flex">

        <%- include('../../partials/admin/sidebar') %>

                <div id="mainContent" class="flex-1 flex flex-col min-w-0 transition-all duration-300">

                        <%- include('../../partials/admin/header') %>

                                <main class="flex-1 p-4 sm:p-6 lg:p-8 w-full">

                                        <%- include("./partials/header",{ title }) %>

                                                <!-- ===== Table Card ===== -->
                                                <div
                                                        class="w-full bg-[#0b1220] border border-white/5 rounded-3xl shadow-xl overflow-x-auto">

                                                        <table class="w-full text-sm text-left text-gray-300">

                                                                <thead
                                                                        class="border-b border-white/10 text-gray-400 uppercase text-xs">

                                                                        <tr>

                                                                                <th class="px-6 py-4">#</th>

                                                                                <th class="px-6 py-4">Logo</th>

                                                                                <th class="px-6 py-4">Brand Name</th>

                                                                                <th class="px-6 py-4">Status</th>

                                                                                <th class="px-6 py-4 text-right">Actions
                                                                                </th>

                                                                        </tr>

                                                                </thead>

                                                                <tbody id="brandTableBody">

                                                                        <%- include("./partials/brandRows", { brands,
                                                                                currentPage }) %>

                                                                </tbody>

                                                        </table>

                                                </div>

                                                <!-- ===== Pagination ===== -->
                                                <div id="pagination"
                                                        class="flex flex-wrap justify-center items-center gap-2 mt-8">

                                                        <%- include("./partials/pagination", { currentPage, totalPages
                                                                }) %>

                                                </div>

                                </main>



                </div>

                <!-- Add / Edit Brand Modal -->
                <div id="brandModal" class="fixed inset-0 bg-black/60 hidden z-50 flex items-center justify-center">

                        <div class="bg-[#0b1220] w-[500px] rounded-xl border border-white/10 p-6">

                                <div class="flex justify-between items-center mb-4">

                                        <h2 class="text-lg font-semibold text-white">
                                                Add Brand
                                        </h2>

                                        <button onclick="closeModal()" class="text-gray-400 hover:text-white">
                                                <i class="fas fa-times"></i>
                                        </button>

                                </div>

                                <form id="brandForm" class="flex flex-col gap-4">

                                        <input type="hidden" id="brand-id">

                                        <!-- Brand Name -->
                                        <div>
                                                <label class="text-sm text-gray-400">Brand Name</label>

                                                <input type="text" name="title" id="brand-title"
                                                        class="w-full mt-1 bg-[#0f172a] border border-white/10 px-3 py-2 rounded-lg text-sm">
                                                <span id="brandTitleError" class="text-red-400 text-xs mt-1 hidden block"></span>
                                        </div>

                                        <!-- Brand Logo -->
                                        <div>
                                                <label class="text-sm text-gray-400">Brand Logo</label>

                                                <input type="file" name="logo" id="brand-logo"
                                                        accept="image/png,image/jpeg,image/webp,image/svg+xml"
                                                        class="w-full mt-1 bg-[#0f172a] border border-white/10 px-3 py-2 rounded-lg text-sm">
                                                <span id="brandLogoError" class="text-red-400 text-xs mt-1 hidden block"></span>
                                                <!-- Preview -->
                                                <img id="brand-logo-preview"
                                                        class="mt-3 w-20 h-20 object-contain rounded-2xl bg-white hidden">
                                        </div>

                                        <!-- Status -->
                                        <div>
                                                <label class="text-sm text-gray-400">Status</label>

                                                <select name="status" id="brand-status"
                                                        class="w-full mt-1 bg-[#0f172a] border border-white/10 px-3 py-2 rounded-lg text-sm">

                                                        <option value="unlisted">Unlisted</option>
                                                        <option value="listed">Listed</option>

                                                </select>
                                        </div>

                                        <!-- Buttons -->
                                        <div class="flex justify-center gap-3 mt-4">

                                                <button type="button" onclick="closeModal()"
                                                        class="px-4 py-2 bg-gray-600 hover:bg-gray-700 text-white rounded-lg text-sm">

                                                        Cancel

                                                </button>

                                                <button type="submit" id="brand-submit-btn"
                                                        class="px-4 py-2 bg-cyan-600 hover:bg-cyan-700 text-white rounded-lg text-sm">

                                                        Create Brand

                                                </button>

                                        </div>

                                </form>

                        </div>

                </div>

                <!-- Image Crop Modal -->
                <div id="cropModal" class="fixed inset-0 bg-black/80 hidden z-50 flex items-center justify-center p-4">

                        <div class="bg-[#0b1220] p-6 rounded-xl w-full max-w-[800px] border border-white/10">

                                <h2 class="text-white text-xl font-semibold mb-4">Crop Logo</h2>

                                <div class="relative bg-[#1a1a2e] rounded-lg overflow-hidden flex items-center justify-center" style="height: 500px;">
                                        <canvas id="cropCanvas" class="cursor-move"></canvas>
                                </div>

                                <div class="flex flex-col sm:flex-row justify-between items-center gap-4 mt-6">
                                        <div class="flex gap-2 flex-wrap">
                                                <button onclick="zoomIn()" class="px-3 py-2 bg-gray-700 hover:bg-gray-600 text-white rounded-lg text-sm transition-colors">
                                                        <i class="fas fa-search-plus"></i> Zoom In
                                                </button>
                                                <button onclick="zoomOut()" class="px-3 py-2 bg-gray-700 hover:bg-gray-600 text-white rounded-lg text-sm transition-colors">
                                                        <i class="fas fa-search-minus"></i> Zoom Out
                                                </button>
                                                <button onclick="resetCrop()" class="px-3 py-2 bg-gray-700 hover:bg-gray-600 text-white rounded-lg text-sm transition-colors">
                                                        <i class="fas fa-redo"></i> Reset
                                                </button>
                                        </div>
                                        <div class="flex gap-3">
                                                <button onclick="closeCrop()" class="px-5 py-2 bg-gray-600 hover:bg-gray-700 text-white rounded-lg transition-colors">
                                                        Cancel
                                                </button>
                                                <button onclick="cropImage()" class="px-5 py-2 bg-cyan-600 hover:bg-cyan-700 text-white rounded-lg transition-colors">
                                                        Crop & Save
                                                </button>
                                        </div>
                                </div>

                        </div>

                </div>

                <script type="module">

                        import { showToast } from "../../partials/errorMsg.utils.js";
                        import { confirmAction } from "../../partials/confirm.util.js";

                        let croppedBlob;
                        let cropState = {
                                image: null,
                                scale: 1,
                                offsetX: 0,
                                offsetY: 0,
                                isDragging: false,
                                startX: 0,
                                startY: 0,
                                cropSize: 300
                        };

                        const logoInput = document.getElementById("brand-logo");
                        const cropModal = document.getElementById("cropModal");
                        const canvas = document.getElementById("cropCanvas");
                        const ctx = canvas.getContext("2d");
                        const preview = document.getElementById("brand-logo-preview");
                        const brandForm = document.getElementById("brandForm");

                        const addBtn = document.getElementById(`add-${moduleName}`);

                        if (addBtn) addBtn.addEventListener("click", openAddModal);



                        /* ================= MODAL ================= */

                        function openAddModal() {

                                const submitBtn = document.getElementById("brand-submit-btn");

                                croppedBlob = null;

                                submitBtn.disabled = false;
                                submitBtn.textContent = "Create Brand";

                                document.getElementById("brand-id").value = "";
                                document.getElementById("brand-title").value = "";
                                document.getElementById("brand-status").value = "unlisted";
                                document.getElementById("brand-logo").value = "";

                                preview.src = "";
                                preview.classList.add("hidden");

                                // Clear inline errors
                                document.getElementById("brandTitleError").textContent = "";
                                document.getElementById("brandTitleError").classList.add("hidden");
                                document.getElementById("brandLogoError").textContent = "";
                                document.getElementById("brandLogoError").classList.add("hidden");

                                document.getElementById("brandModal").classList.remove("hidden");

                        }
                        window.openAddModal = openAddModal;



                        function closeModal() {
                                // Clear inline errors
                                document.getElementById("brandTitleError").textContent = "";
                                document.getElementById("brandTitleError").classList.add("hidden");
                                document.getElementById("brandLogoError").textContent = "";
                                document.getElementById("brandLogoError").classList.add("hidden");
                                
                                document.getElementById("brandModal").classList.add("hidden");
                        }
                        window.closeModal = closeModal;



                        function editBrand(id, title, status, logo) {

                                const submitBtn = document.getElementById("brand-submit-btn");

                                submitBtn.disabled = false;
                                submitBtn.textContent = "Update Brand";

                                document.getElementById("brand-id").value = id;
                                document.getElementById("brand-title").value = title;
                                document.getElementById("brand-status").value = status;

                                if (logo) {
                                        preview.src = logo;
                                        preview.classList.remove("hidden");
                                }

                                // Clear inline errors
                                document.getElementById("brandTitleError").textContent = "";
                                document.getElementById("brandTitleError").classList.add("hidden");
                                document.getElementById("brandLogoError").textContent = "";
                                document.getElementById("brandLogoError").classList.add("hidden");

                                document.getElementById("brandModal").classList.remove("hidden");

                        }
                        window.editBrand = editBrand;



                        /* ================= IMAGE CROP ================= */

                        logoInput.addEventListener("change", function () {

                                const file = this.files[0];
                                if (!file) return;

                                const reader = new FileReader();

                                reader.onload = function (e) {

                                        const img = new Image();
                                        img.onload = function () {
                                                cropState.image = img;
                                                
                                                // Show modal first
                                                cropModal.classList.remove("hidden");
                                                
                                                // Wait for modal to render, then set canvas size
                                                setTimeout(() => {
                                                        const container = canvas.parentElement;
                                                        canvas.width = container.clientWidth;
                                                        canvas.height = container.clientHeight;
                                                        
                                                        // Calculate initial scale to fit image
                                                        const scaleX = canvas.width / img.width;
                                                        const scaleY = canvas.height / img.height;
                                                        cropState.scale = Math.min(scaleX, scaleY) * 0.7;
                                                        
                                                        // Center the image
                                                        cropState.offsetX = 0;
                                                        cropState.offsetY = 0;
                                                        
                                                        // Set crop size (smaller of canvas dimensions)
                                                        cropState.cropSize = Math.min(canvas.width, canvas.height) * 0.6;
                                                        
                                                        drawCanvas();
                                                }, 100);
                                        };
                                        img.src = e.target.result;

                                };

                                reader.readAsDataURL(file);

                        });

                        // Canvas drawing function
                        function drawCanvas() {
                                if (!cropState.image || !canvas.width) return;

                                // Clear canvas
                                ctx.fillStyle = '#1a1a2e';
                                ctx.fillRect(0, 0, canvas.width, canvas.height);
                                
                                // Calculate image position
                                const imgWidth = cropState.image.width * cropState.scale;
                                const imgHeight = cropState.image.height * cropState.scale;
                                const x = (canvas.width - imgWidth) / 2 + cropState.offsetX;
                                const y = (canvas.height - imgHeight) / 2 + cropState.offsetY;
                                
                                // Draw image
                                ctx.drawImage(cropState.image, x, y, imgWidth, imgHeight);
                                
                                // Draw dark overlay
                                ctx.fillStyle = 'rgba(0, 0, 0, 0.6)';
                                ctx.fillRect(0, 0, canvas.width, canvas.height);
                                
                                // Calculate crop area
                                const cropX = (canvas.width - cropState.cropSize) / 2;
                                const cropY = (canvas.height - cropState.cropSize) / 2;
                                
                                // Clear and redraw image in crop area
                                ctx.save();
                                ctx.beginPath();
                                ctx.rect(cropX, cropY, cropState.cropSize, cropState.cropSize);
                                ctx.clip();
                                
                                // Clear the crop area
                                ctx.clearRect(cropX, cropY, cropState.cropSize, cropState.cropSize);
                                
                                // Redraw image in crop area
                                ctx.drawImage(cropState.image, x, y, imgWidth, imgHeight);
                                ctx.restore();
                                
                                // Draw crop border and grid
                                ctx.strokeStyle = '#00bcd4';
                                ctx.lineWidth = 3;
                                ctx.strokeRect(cropX, cropY, cropState.cropSize, cropState.cropSize);
                                
                                // Draw grid lines (rule of thirds)
                                ctx.strokeStyle = 'rgba(0, 188, 212, 0.3)';
                                ctx.lineWidth = 1;
                                ctx.setLineDash([5, 5]);
                                
                                // Vertical lines
                                ctx.beginPath();
                                ctx.moveTo(cropX + cropState.cropSize / 3, cropY);
                                ctx.lineTo(cropX + cropState.cropSize / 3, cropY + cropState.cropSize);
                                ctx.moveTo(cropX + (cropState.cropSize * 2) / 3, cropY);
                                ctx.lineTo(cropX + (cropState.cropSize * 2) / 3, cropY + cropState.cropSize);
                                ctx.stroke();
                                
                                // Horizontal lines
                                ctx.beginPath();
                                ctx.moveTo(cropX, cropY + cropState.cropSize / 3);
                                ctx.lineTo(cropX + cropState.cropSize, cropY + cropState.cropSize / 3);
                                ctx.moveTo(cropX, cropY + (cropState.cropSize * 2) / 3);
                                ctx.lineTo(cropX + cropState.cropSize, cropY + (cropState.cropSize * 2) / 3);
                                ctx.stroke();
                                
                                ctx.setLineDash([]);
                                
                                // Draw corner handles
                                const handleSize = 12;
                                ctx.fillStyle = '#00bcd4';
                                
                                // Top-left
                                ctx.fillRect(cropX - handleSize/2, cropY - handleSize/2, handleSize, handleSize);
                                // Top-right
                                ctx.fillRect(cropX + cropState.cropSize - handleSize/2, cropY - handleSize/2, handleSize, handleSize);
                                // Bottom-left
                                ctx.fillRect(cropX - handleSize/2, cropY + cropState.cropSize - handleSize/2, handleSize, handleSize);
                                // Bottom-right
                                ctx.fillRect(cropX + cropState.cropSize - handleSize/2, cropY + cropState.cropSize - handleSize/2, handleSize, handleSize);
                        }

                        // Mouse events for dragging
                        canvas.addEventListener('mousedown', (e) => {
                                cropState.isDragging = true;
                                const rect = canvas.getBoundingClientRect();
                                cropState.startX = e.clientX - rect.left;
                                cropState.startY = e.clientY - rect.top;
                        });

                        canvas.addEventListener('mousemove', (e) => {
                                if (!cropState.isDragging) return;
                                
                                const rect = canvas.getBoundingClientRect();
                                const currentX = e.clientX - rect.left;
                                const currentY = e.clientY - rect.top;
                                
                                const dx = currentX - cropState.startX;
                                const dy = currentY - cropState.startY;
                                
                                cropState.offsetX += dx;
                                cropState.offsetY += dy;
                                
                                cropState.startX = currentX;
                                cropState.startY = currentY;
                                
                                drawCanvas();
                        });

                        canvas.addEventListener('mouseup', () => {
                                cropState.isDragging = false;
                        });

                        canvas.addEventListener('mouseleave', () => {
                                cropState.isDragging = false;
                        });

                        // Touch events for mobile
                        canvas.addEventListener('touchstart', (e) => {
                                e.preventDefault();
                                cropState.isDragging = true;
                                const rect = canvas.getBoundingClientRect();
                                const touch = e.touches[0];
                                cropState.startX = touch.clientX - rect.left;
                                cropState.startY = touch.clientY - rect.top;
                        });

                        canvas.addEventListener('touchmove', (e) => {
                                e.preventDefault();
                                if (!cropState.isDragging) return;
                                
                                const rect = canvas.getBoundingClientRect();
                                const touch = e.touches[0];
                                const currentX = touch.clientX - rect.left;
                                const currentY = touch.clientY - rect.top;
                                
                                const dx = currentX - cropState.startX;
                                const dy = currentY - cropState.startY;
                                
                                cropState.offsetX += dx;
                                cropState.offsetY += dy;
                                
                                cropState.startX = currentX;
                                cropState.startY = currentY;
                                
                                drawCanvas();
                        });

                        canvas.addEventListener('touchend', () => {
                                cropState.isDragging = false;
                        });

                        // Zoom functions
                        function zoomIn() {
                                cropState.scale *= 1.2;
                                drawCanvas();
                        }
                        window.zoomIn = zoomIn;

                        function zoomOut() {
                                cropState.scale *= 0.8;
                                drawCanvas();
                        }
                        window.zoomOut = zoomOut;

                        function resetCrop() {
                                if (!cropState.image) return;
                                const scaleX = canvas.width / cropState.image.width;
                                const scaleY = canvas.height / cropState.image.height;
                                cropState.scale = Math.min(scaleX, scaleY) * 0.7;
                                cropState.offsetX = 0;
                                cropState.offsetY = 0;
                                drawCanvas();
                        }
                        window.resetCrop = resetCrop;


                        function cropImage() {

                                if (!cropState.image) return;

                                // Create a temporary canvas for the cropped image
                                const tempCanvas = document.createElement('canvas');
                                const outputSize = 400; // Output size for the cropped image
                                tempCanvas.width = outputSize;
                                tempCanvas.height = outputSize;
                                const tempCtx = tempCanvas.getContext('2d');
                                
                                // Calculate source coordinates
                                const imgWidth = cropState.image.width * cropState.scale;
                                const imgHeight = cropState.image.height * cropState.scale;
                                const x = (canvas.width - imgWidth) / 2 + cropState.offsetX;
                                const y = (canvas.height - imgHeight) / 2 + cropState.offsetY;
                                
                                const cropX = (canvas.width - cropState.cropSize) / 2;
                                const cropY = (canvas.height - cropState.cropSize) / 2;
                                
                                // Calculate the portion of the original image to crop
                                const sourceX = (cropX - x) / cropState.scale;
                                const sourceY = (cropY - y) / cropState.scale;
                                const sourceWidth = cropState.cropSize / cropState.scale;
                                const sourceHeight = cropState.cropSize / cropState.scale;
                                
                                // Draw the cropped portion
                                tempCtx.drawImage(
                                        cropState.image,
                                        sourceX,
                                        sourceY,
                                        sourceWidth,
                                        sourceHeight,
                                        0,
                                        0,
                                        outputSize,
                                        outputSize
                                );

                                tempCanvas.toBlob((blob) => {

                                        croppedBlob = blob;

                                        preview.src = URL.createObjectURL(blob);
                                        preview.classList.remove("hidden");

                                        closeCrop();

                                }, "image/png");

                        }
                        window.cropImage = cropImage;



                        function closeCrop() {

                                cropModal.classList.add("hidden");
                                cropState.image = null;
                                cropState.scale = 1;
                                cropState.offsetX = 0;
                                cropState.offsetY = 0;

                        }
                        window.closeCrop = closeCrop;



                        /* ================= BRAND SUBMIT ================= */

                        brandForm?.addEventListener("submit", async (e) => {

                                e.preventDefault();

                                const submitBtn = document.getElementById("brand-submit-btn");
                                if (submitBtn.disabled) return;

                                const brandId = document.getElementById("brand-id").value;
                                const title = document.getElementById("brand-title").value.trim();
                                const status = document.getElementById("brand-status").value;

                                const logoFile = croppedBlob || logoInput.files[0];

                                const titlePattern = /^[A-Za-z]+(?: [A-Za-z]+)*$/;

                                // Get error elements
                                const titleError = document.getElementById("brandTitleError");
                                const logoError = document.getElementById("brandLogoError");

                                // Clear previous errors
                                titleError.textContent = "";
                                titleError.classList.add("hidden");
                                logoError.textContent = "";
                                logoError.classList.add("hidden");

                                // Validate
                                let hasError = false;

                                if (!title) {
                                        titleError.textContent = "Brand name is required";
                                        titleError.classList.remove("hidden");
                                        hasError = true;
                                } else if (!titlePattern.test(title)) {
                                        titleError.textContent = "Brand name must contain letters only";
                                        titleError.classList.remove("hidden");
                                        hasError = true;
                                }

                                if (!brandId && !logoFile) {
                                        logoError.textContent = "Brand logo is required";
                                        logoError.classList.remove("hidden");
                                        hasError = true;
                                }

                                if (hasError) return;

                                submitBtn.disabled = true;
                                submitBtn.textContent = "Processing...";

                                try {

                                        const formData = new FormData();

                                        formData.append("title", title);
                                        formData.append("status", status);

                                        if (logoFile) {
                                                formData.append("logo", logoFile, "logo.png");
                                        }


                                        let url = "/admin/brand";
                                        let method = "POST";

                                        if (brandId) {
                                                url = `/admin/brand/${brandId}`;
                                                method = "PATCH";
                                        }

                                        const res = await fetch(url, { method, body: formData });

                                        const data = await res.json();

                                        if (!data.success) {
                                                showToast(data.message, "error");
                                                return;
                                        }


                                        showToast(
                                                brandId ? "Brand updated successfully" : "Brand created successfully",
                                                "success"
                                        );


                                        closeModal();


                                        if (brandId) {

                                                const titleCell = document.getElementById(`title-${brandId}`);
                                                const badge = document.getElementById(`badge-${brandId}`);
                                                const row = document.getElementById(`row-${brandId}`);

                                                if (titleCell) titleCell.textContent = title.toUpperCase();

                                                if (badge) {

                                                        badge.textContent = status;

                                                        badge.className =
                                                                status === "listed"
                                                                        ? "px-3 py-1 rounded-full text-xs bg-emerald-500/20 text-emerald-400"
                                                                        : "px-3 py-1 rounded-full text-xs bg-red-500/20 text-red-400";

                                                }

                                                if (logoFile && row) {

                                                        const img = row.querySelector("img");
                                                        if (img) img.src = URL.createObjectURL(logoFile);

                                                }

                                        } else {
                                                setTimeout(() => {
                                                        location.reload()
                                                }, 1000);
                                        }

                                }
                                catch (error) {

                                        showToast(error.message || "Something went wrong", "error");

                                }
                                finally {

                                        submitBtn.disabled = false;
                                        submitBtn.textContent = brandId ? "Update Brand" : "Create Brand";

                                }

                        });



                        /* ================= DELETE BRAND ================= */

                        async function deleteBrand(brand_id) {

                                const confirmed = await confirmAction("Delete Brand?");

                                if (!confirmed) return;

                                try {

                                        const res = await fetch(`/admin/brand/${brand_id}`, {
                                                method: "DELETE"
                                        });

                                        const data = await res.json();

                                        if (!data.success) throw new Error(data.message);

                                        showToast("Brand deleted successfully", "success");

                                        const row = document.getElementById(`row-${brand_id}`);

                                        row.classList.add("opacity-0");

                                        setTimeout(() => row.remove(), 300);

                                }
                                catch (error) {

                                        showToast(error.message || "Something went wrong", "error");

                                }

                        }
                        window.deleteBrand = deleteBrand;



                        /* ================= TOGGLE STATUS ================= */

                        async function toggleBrandStatus(brand_id, status) {

                                const action = status === "listed" ? "unlist" : "list";

                                const confirmed = await confirmAction(`Do you want to ${action} this brand?`);

                                if (!confirmed) return;

                                try {

                                        const res = await fetch(`/admin/brand/status/${brand_id}`, {
                                                method: "PATCH"
                                        });

                                        const result = await res.json();

                                        if (!result.success) throw new Error(result.message);

                                        const badge = document.getElementById(`badge-${brand_id}`);
                                        const btn = document.getElementById(`status-${brand_id}`);

                                        // Get the new status from the response
                                        const newStatus = result.data.status;

                                        // Update badge text with proper capitalization
                                        badge.textContent = newStatus.charAt(0).toUpperCase() + newStatus.slice(1);

                                        // Update badge styling
                                        badge.className =
                                                newStatus === "listed"
                                                        ? "px-3 py-1 rounded-full text-xs bg-emerald-500/20 text-emerald-400"
                                                        : "px-3 py-1 rounded-full text-xs bg-red-500/20 text-red-400";

                                        // Update button text
                                        btn.textContent = newStatus === "listed" ? "Unlist" : "List";

                                        // Update button styling
                                        btn.className =
                                                `px-3 py-1 text-xs rounded-md font-semibold ${newStatus === "listed"
                                                        ? "bg-yellow-500/20 text-yellow-400 hover:bg-yellow-500/30"
                                                        : "bg-emerald-500/20 text-emerald-400 hover:bg-emerald-500/30"
                                                }`;

                                        // Update onclick handler with new status
                                        btn.setAttribute(
                                                "onclick",
                                                `toggleBrandStatus('${brand_id}','${newStatus}')`
                                        );

                                        showToast(`Brand ${action}ed successfully`, "success");

                                }
                                catch (error) {

                                        showToast(error.message || "Something went wrong", "error");

                                }

                        }
                        window.toggleBrandStatus = toggleBrandStatus;

                </script>

                <script>

                        const filter = document.getElementById("filter");

                        function debounce(func, delay) {

                                let timer;

                                return function (...args) {
                                        clearTimeout(timer);

                                        timer = setTimeout(() => {
                                                func.apply(this, args);
                                        }, delay);

                                };
                        }



                        async function searchData() {

                                console.log(moduleName)

                                const value = searchInput?.value.trim() || "";
                                const filterValue = filter?.value.trim() || "";

                                try {

                                        const res = await fetch(
                                                `/admin/${moduleName}?search=${encodeURIComponent(value)}&status=${encodeURIComponent(filterValue)}`,
                                                {
                                                        headers: {
                                                                "X-Requested-With": "XMLHttpRequest",
                                                        }
                                                }
                                        );

                                        const data = await res.json();

                                        // dynamic table body update
                                        document.getElementById(`${moduleName}TableBody`).innerHTML = data.rows;

                                        // update pagination
                                        document.getElementById("pagination").innerHTML = data.pagination;

                                } catch (error) {
                                        console.error("Search error:", error);
                                }

                        }

                        const debouncedSearch = debounce(searchData, 400);

                        if (searchInput) {
                                searchInput.addEventListener("input", debouncedSearch);
                        }

                        if (filter) {
                                filter.addEventListener("change", searchData);
                        }

                        async function toggleCategoryStatus(category_id, status) {

                                const action = status === "listed" ? "unlist" : "list";

                                const result = await Swal.fire({
                                        title: `Are you sure?`,
                                        text: `Do you want to ${action} this category?`,
                                        icon: "warning",
                                        background: "#0b1220",
                                        color: "#e5e7eb",
                                        showCancelButton: true,
                                        confirmButtonText: `Yes, ${action}!`,
                                        cancelButtonText: "Cancel"
                                });

                                if (!result.isConfirmed) return;

                                try {

                                        const res = await fetch(`/admin/category/${category_id}/status`, {
                                                method: "PATCH",
                                                headers: {
                                                        "Content-Type": "application/json"
                                                }
                                        });

                                        const { data, message, success } = await res.json();
                                        console.log(data, message, success)
                                        if (!success) {

                                                Swal.fire({
                                                        icon: "error",
                                                        title: "Error",
                                                        text: message || "Failed to update category status",
                                                        background: "#0b1220",
                                                        color: "#e5e7eb"
                                                });

                                                return;

                                        }


                                        const btn = document.getElementById(`status-${category_id}`);
                                        const badge = document.getElementById(`badge-${category_id}`);

                                        const newStatus = data.status;

                                        // update badge
                                        badge.textContent = newStatus;

                                        if (newStatus === "listed") {
                                                badge.className = "px-3 py-1 rounded-full text-xs bg-emerald-500/20 text-emerald-400";
                                        } else {
                                                badge.className = "px-3 py-1 rounded-full text-xs bg-red-500/20 text-red-400";
                                        }

                                        // update button
                                        btn.textContent = newStatus === "listed" ? "Unlist" : "List";

                                        btn.className =
                                                `px-3 py-1 text-xs rounded-md font-semibold ${newStatus === "listed"
                                                        ? "bg-yellow-500/20 text-yellow-400 hover:bg-yellow-500/30"
                                                        : "bg-emerald-500/20 text-emerald-400 hover:bg-emerald-500/30"
                                                }`;

                                        // update onclick status parameter
                                        btn.setAttribute(
                                                "onclick",
                                                `toggleCategoryStatus('${category_id}','${newStatus}')`
                                        );

                                        Swal.fire({
                                                toast: true,
                                                position: "top-end",
                                                icon: "success",
                                                title: `Category ${action}ed successfully`,
                                                showConfirmButton: false,
                                                timer: 2000
                                        });

                                } catch (error) {
                                        console.error(error);
                                }

                        }

                        async function editCategory(category_id) {

                                const { value: title } = await Swal.fire({
                                        title: "Edit Category",
                                        background: "#0b1220",
                                        color: "#e5e7eb",
                                        input: "text",
                                        inputPlaceholder: "Enter category title",
                                        showCancelButton: true,
                                        confirmButtonText: "Update",
                                        cancelButtonText: "Cancel",
                                        inputValidator: (value) => {

                                                const pattern = /^[A-Za-z]+(?: [A-Za-z]+)*$/;

                                                if (!value.trim()) {
                                                        return "Category title is required";
                                                }

                                                if (!pattern.test(value.trim())) {
                                                        return "Only letters allowed with single space between words";
                                                }

                                        }
                                });

                                if (!title) return;

                                try {

                                        const res = await fetch(`/admin/category/${category_id}`, {
                                                method: "PATCH",
                                                headers: {
                                                        "Content-Type": "application/json"
                                                },
                                                body: JSON.stringify({ title })
                                        });

                                        const data = await res.json();

                                        if (!data.success) {
                                                Swal.fire("Error", data.message, "error");
                                                return;
                                        }

                                        Swal.fire({
                                                toast: true,
                                                position: "top-end",
                                                icon: "success",
                                                title: "Category updated successfully",
                                                showConfirmButton: false,
                                                timer: 2000
                                        });

                                        // update title in table without reload
                                        const titleCell = document.getElementById(`title-${category_id}`);
                                        if (titleCell) {
                                                titleCell.textContent = title.toUpperCase();
                                        }

                                } catch (error) {
                                        console.error(error);
                                        Swal.fire("Error", "Something went wrong", "error");
                                }
                        }

                        async function deleteCategory(category_id) {

                                const result = await Swal.fire({
                                        title: "Delete Category?",
                                        text: "This action cannot be undone!",
                                        icon: "warning",
                                        background: "#0b1220",
                                        color: "#e5e7eb",
                                        showCancelButton: true,
                                        confirmButtonText: "Yes, delete it!",
                                        cancelButtonText: "Cancel",
                                        confirmButtonColor: "#ef4444"
                                });

                                if (!result.isConfirmed) return;

                                try {

                                        const res = await fetch(`/admin/category/${category_id}`, {
                                                method: "DELETE"
                                        });

                                        const data = await res.json();

                                        if (!data.success) {

                                                Swal.fire({
                                                        icon: "error",
                                                        title: "Error",
                                                        text: data.message || "Failed to delete category",
                                                        background: "#0b1220",
                                                        color: "#e5e7eb"
                                                });

                                                return;
                                        }

                                        Swal.fire({
                                                toast: true,
                                                position: "top-end",
                                                icon: "success",
                                                title: "Category deleted successfully",
                                                showConfirmButton: false,
                                                timer: 2000
                                        });

                                        // remove row from table
                                        const row = document.getElementById(`row-${category_id}`);
                                        if (row) {
                                                row.remove();
                                        }

                                } catch (error) {

                                        console.error(error);

                                        Swal.fire({
                                                icon: "error",
                                                title: "Error",
                                                text: "Something went wrong",
                                                background: "#0b1220",
                                                color: "#e5e7eb"
                                        });

                                }

                        }


                        let currentCategory = null;

                        function openAttributeModal(categoryId) {
                                currentCategory = categoryId;
                                document.getElementById("attributeModal").classList.remove("hidden");
                                document.getElementById("attributeModal").classList.add("flex");
                        }

                        function closeAttributeModal() {
                                document.getElementById("attributeModal").classList.add("hidden");
                        }


                        async function saveAttribute() {
                                const label = document.getElementById("attrLabel").value.trim();
                                const data_type = document.getElementById("attrType").value;
                                const unit = document.getElementById("attrUnit").value.trim();

                                const key = document
                                        .getElementById("attrKey")
                                        .value
                                        .trim()
                                        .toLowerCase()
                                        .replace(/\s+/g, "_");

                                const allowed_values = document
                                        .getElementById("attrValues")
                                        .value
                                        .split(",")
                                        .map(v => v.trim())
                                        .filter(v => v !== "");

                                const is_required = document.getElementById("attrRequired").checked;
                                const is_variant_level = document.getElementById("attrVariant").checked;



                                /* ======================
                                   VALIDATIONS
                                ====================== */

                                const keyPattern = /^[a-z]+(_[a-z]+)*$/;
                                const labelPattern = /^[A-Za-z]+(?: [A-Za-z]+)*$/;

                                // key validation
                                if (!key) {

                                        await Swal.fire({
                                                icon: "warning",
                                                title: "Missing Key",
                                                text: "Attribute key is required",
                                                background: "#0b1220",
                                                color: "#e5e7eb"
                                        });

                                        return;
                                }

                                if (!keyPattern.test(key)) {

                                        await Swal.fire({
                                                icon: "warning",
                                                title: "Invalid Key",
                                                text: "Key must contain lowercase letters and underscore only (example: ram_size)",
                                                background: "#0b1220",
                                                color: "#e5e7eb"
                                        });

                                        return;
                                }


                                // label validation
                                if (!label) {

                                        await Swal.fire({
                                                icon: "warning",
                                                title: "Missing Label",
                                                text: "Display label is required",
                                                background: "#0b1220",
                                                color: "#e5e7eb"
                                        });

                                        return;
                                }

                                if (!labelPattern.test(label)) {

                                        await Swal.fire({
                                                icon: "warning",
                                                title: "Invalid Label",
                                                text: "Label should contain only letters and single spaces",
                                                background: "#0b1220",
                                                color: "#e5e7eb"
                                        });

                                        return;
                                }


                                // select type validation
                                if (data_type === "select" && allowed_values.length === 0) {

                                        await Swal.fire({
                                                icon: "warning",
                                                title: "Missing Values",
                                                text: "Allowed values required for select type",
                                                background: "#0b1220",
                                                color: "#e5e7eb"
                                        });

                                        return;
                                }


                                // unit validation (optional)
                                const unitPattern = /^[A-Za-z]+$/;

                                if (unit && !unitPattern.test(unit)) {

                                        await Swal.fire({
                                                icon: "warning",
                                                title: "Invalid Unit",
                                                text: "Unit must contain only letters (GB, Inch, Hz)",
                                                background: "#0b1220",
                                                color: "#e5e7eb"
                                        });

                                        return;
                                }



                                /* ======================
                                   API CALL
                                ====================== */

                                try {

                                        const res = await fetch(`/admin/category/${currentCategory}`, {
                                                method: "POST",
                                                headers: {
                                                        "Content-Type": "application/json"
                                                },
                                                body: JSON.stringify({
                                                        key,
                                                        label,
                                                        data_type,
                                                        unit,
                                                        allowed_values,
                                                        is_required,
                                                        is_variant_level
                                                })
                                        });

                                        const data = await res.json();

                                        if (!data.success) {

                                                await Swal.fire({
                                                        icon: "error",
                                                        title: "Error",
                                                        text: data.message,
                                                        background: "#0b1220",
                                                        color: "#e5e7eb"
                                                });

                                                return;
                                        }


                                        // success toast
                                        Swal.fire({
                                                toast: true,
                                                position: "top-end",
                                                icon: "success",
                                                title: "Attribute added successfully",
                                                background: "#0b1220",
                                                color: "#e5e7eb",
                                                showConfirmButton: false,
                                                timer: 2000
                                        });


                                        closeAttributeModal();
                                        location.reload();

                                }
                                catch (error) {

                                        console.error(error);

                                        Swal.fire({
                                                icon: "error",
                                                title: "Server Error",
                                                text: "Something went wrong",
                                                background: "#0b1220",
                                                color: "#e5e7eb"
                                        });

                                }

                        }
                </script>


                <!-- pagenation -->
                <script>

                        const paginationContainer = document.getElementById("pagination");

                        let currentPage = 1;

                        // detect module from page title
                        const pageTitle =
                                document.querySelector("h1")?.textContent || "";

                        const moduleName =
                                pageTitle
                                        .replace("Management", "")
                                        .trim()
                                        .toLowerCase();


                        paginationContainer.addEventListener("click", async (e) => {

                                const link = e.target.closest(".pagination-link");
                                if (!link) return;

                                e.preventDefault();

                                currentPage = Number(link.dataset.page);

                                const search = searchInput?.value.trim() || "";
                                const filterValue = filter?.value || "";

                                try {

                                        const res = await fetch(
                                                `/admin/${moduleName}?page=${currentPage}&search=${encodeURIComponent(search)}&status=${encodeURIComponent(filterValue)}`,
                                                {
                                                        headers: {
                                                                "X-Requested-With": "XMLHttpRequest"
                                                        }
                                                }
                                        );

                                        const data = await res.json();

                                        document.getElementById(`${moduleName}TableBody`).innerHTML = data.rows;
                                        document.getElementById("pagination").innerHTML = data.pagination;

                                } catch (err) {

                                        console.error("Pagination error:", err);

                                }

                        });

                </script>

</body>

</html>