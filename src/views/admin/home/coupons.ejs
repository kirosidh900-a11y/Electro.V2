<!DOCTYPE html>
<html lang="en" class="dark">

<head>
  <%- include('../../partials/head') %>
</head>

<body class="min-h-screen flex">

  <%- include('../../partials/admin/sidebar') %>

    <div id="mainContent" class="flex-1 flex flex-col min-w-0 transition-all duration-300">
      <%- include('../../partials/admin/header') %>

        <main class="flex-1 p-4 sm:p-6 lg:p-8 w-full">

          <!-- Page Header -->
          <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6 mb-8 w-full">
            <h1 class="text-xl sm:text-2xl font-bold text-white">Coupon Management</h1>

            <div class="flex flex-col sm:flex-row gap-3 w-full lg:w-auto">
              <!-- Search -->
              <div class="relative w-full sm:w-64">
                <input id="searchInput" type="text" placeholder="Search coupons..."
                  class="w-full bg-[#0f172a] border border-white/10 pl-10 pr-10 py-2 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-cyan-500 text-gray-200 placeholder-gray-600" />
                <i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm"></i>
                <button id="clearBtn" type="button"
                  class="hidden absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-white">
                  <i class="fas fa-times"></i>
                </button>
              </div>

              <!-- Filter -->
              <select id="statusFilter"
                class="w-full sm:w-40 bg-[#0f172a] border border-white/10 px-4 py-2 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-cyan-500 text-gray-200">
                <option value="">All</option>
                <option value="active">Active</option>
                <option value="inactive">Inactive</option>
                <option value="expired">Expired</option>
                <option value="upcoming">Upcoming</option>
              </select>

              <!-- Add Button -->
              <button onclick="openCouponModal()"
                class="flex items-center gap-2 px-4 py-2 bg-cyan-600 hover:bg-cyan-700 text-white text-sm font-semibold rounded-lg transition shadow-md">
                <i class="fas fa-plus"></i> Add Coupon
              </button>
            </div>
          </div>

          <!-- Stats Row -->
          <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
            <div class="bg-[#0b1220] border border-white/5 rounded-2xl p-5">
              <p class="text-xs text-gray-500 uppercase tracking-widest mb-1">Total Coupons</p>
              <p class="text-2xl font-black text-white">
                <%= coupons?.length || 0 %>
              </p>
            </div>
            <div class="bg-[#0b1220] border border-white/5 rounded-2xl p-5">
              <p class="text-xs text-gray-500 uppercase tracking-widest mb-1">Active</p>
              <p class="text-2xl font-black text-emerald-400">
                <%= coupons?.filter(c=> c.isActive && new Date(c.expiryDate) >= new Date()).length || 0 %>
              </p>
            </div>
            <div class="bg-[#0b1220] border border-white/5 rounded-2xl p-5">
              <p class="text-xs text-gray-500 uppercase tracking-widest mb-1">Expired</p>
              <p class="text-2xl font-black text-red-400">
                <%= coupons?.filter(c=> new Date(c.expiryDate) < new Date()).length || 0 %>
              </p>
            </div>
            <div class="bg-[#0b1220] border border-white/5 rounded-2xl p-5">
              <p class="text-xs text-gray-500 uppercase tracking-widest mb-1">Total Uses</p>
              <p class="text-2xl font-black text-cyan-400">
                <%= coupons?.reduce((sum, c)=> sum + (c.usedCount || 0), 0) || 0 %>
              </p>
            </div>
          </div>

          <!-- Table -->
          <div class="w-full bg-[#0b1220] border border-white/5 rounded-3xl shadow-xl overflow-x-auto">
            <table class="w-full text-sm text-left text-gray-300">
              <thead class="bg-white/5 text-gray-400 uppercase text-xs tracking-widest border-b border-white/5">
                <tr>
                  <th class="px-6 py-4">#</th>
                  <th class="px-6 py-4">Code</th>
                  <th class="px-6 py-4">Discount</th>
                  <th class="px-6 py-4">Min Order</th>
                  <th class="px-6 py-4">Usage</th>
                  <th class="px-6 py-4">Validity</th>
                  <th class="px-6 py-4">Status</th>
                  <th class="px-6 py-4 text-right">Actions</th>
                </tr>
              </thead>
              <tbody id="couponsTableBody">
                <% if (!coupons || coupons.length===0) { %>
                  <tr>
                    <td colspan="8" class="px-6 py-20 text-center">
                      <div class="flex flex-col items-center gap-3 text-gray-600">
                        <i class="fas fa-ticket text-4xl"></i>
                        <p class="text-sm">No coupons found</p>
                        <button onclick="openCouponModal()" class="text-xs text-cyan-500 hover:underline">Create your
                          first coupon</button>
                      </div>
                    </td>
                  </tr>
                  <% } else { %>
                    <% coupons.forEach((coupon, i)=> { %>
                      <% const now=new Date(); const expiry=new Date(coupon.expiryDate); const start=new
                        Date(coupon.startDate); let statusLabel, statusClass; if (!coupon.isActive) {
                        statusLabel='Inactive' ; statusClass='bg-gray-500/20 text-gray-400' ; } else if (expiry < now) {
                        statusLabel='Expired' ; statusClass='bg-red-500/20 text-red-400' ; } else if (start> now) {
                        statusLabel = 'Upcoming'; statusClass = 'bg-yellow-500/20 text-yellow-400';
                        } else {
                        statusLabel = 'Active'; statusClass = 'bg-emerald-500/20 text-emerald-400';
                        }
                        const usagePercent = coupon.usageLimit ? Math.min((coupon.usedCount / coupon.usageLimit) * 100,
                        100) : 0;
                        %>
                        <tr id="row-<%= coupon._id %>" class="border-t border-white/5 hover:bg-white/[0.02] transition">
                          <td class="px-6 py-4 text-gray-500">
                            <%= (currentPage - 1) * 10 + i + 1 %>
                          </td>

                          <!-- Code -->
                          <td class="px-6 py-4">
                            <div class="flex items-center gap-2">
                              <span
                                class="font-mono font-bold text-cyan-400 bg-cyan-500/10 px-2.5 py-1 rounded-lg tracking-widest text-xs">
                                <%= coupon.code %>
                              </span>
                              <button onclick="copyCode('<%= coupon.code %>')"
                                class="text-gray-600 hover:text-gray-300 transition" title="Copy">
                                <i class="fas fa-copy text-xs"></i>
                              </button>
                            </div>
                            <p class="text-xs text-gray-500 mt-1 truncate max-w-[160px]">
                              <%= coupon.description || '—' %>
                            </p>
                          </td>

                          <!-- Discount -->
                          <td class="px-6 py-4">
                            <span class="font-bold text-white">
                              <% if (coupon.discountType==='percentage' ) { %>
                                <%= coupon.discountValue %>%
                                  <% if (coupon.maxDiscount) { %><span class="text-xs text-gray-500 font-normal"> (max ₹
                                      <%= coupon.maxDiscount %>)</span>
                                    <% } %>
                                      <% } else { %>
                                        ₹<%= coupon.discountValue %>
                                          <% } %>
                            </span>
                            <p class="text-[10px] text-gray-500 capitalize mt-0.5">
                              <%= coupon.discountType %>
                            </p>
                          </td>

                          <!-- Min Order -->
                          <td class="px-6 py-4 text-gray-300">
                            ₹<%= coupon.minOrderAmount || 0 %>
                          </td>

                          <!-- Usage -->
                          <td class="px-6 py-4">
                            <div class="flex items-center gap-2">
                              <span class="text-sm text-gray-300">
                                <%= coupon.usedCount || 0 %>
                                  <% if (coupon.usageLimit) { %>/<%= coupon.usageLimit %>
                                      <% } %>
                              </span>
                            </div>
                            <% if (coupon.usageLimit) { %>
                              <div class="w-20 h-1 bg-white/10 rounded-full mt-1.5">
                                <div class="h-1 rounded-full <%= usagePercent >= 90 ? 'bg-red-500' : 'bg-cyan-500' %>"
                                  style="width: <%= usagePercent %>%"></div>
                              </div>
                              <% } else { %>
                                <p class="text-[10px] text-gray-600 mt-0.5">Unlimited</p>
                                <% } %>
                          </td>

                          <!-- Validity -->
                          <td class="px-6 py-4 text-xs text-gray-400">
                            <p>
                              <%= new Date(coupon.startDate).toLocaleDateString('en-IN', { day:'numeric', month:'short',
                                year:'numeric' }) %>
                            </p>
                            <p class="text-gray-600">→ <%= new Date(coupon.expiryDate).toLocaleDateString('en-IN', {
                                day:'numeric', month:'short', year:'numeric' }) %>
                            </p>
                          </td>

                          <!-- Status -->
                          <td class="px-6 py-4">
                            <span id="badge-<%= coupon._id %>"
                              class="px-3 py-1 rounded-full text-xs font-semibold <%= statusClass %>">
                              <%= statusLabel %>
                            </span>
                          </td>

                          <!-- Actions -->
                          <td class="px-6 py-4 text-right">
                            <div class="flex items-center justify-end gap-2">
                              <button onclick="editCoupon('<%= coupon._id %>')"
                                class="p-2 rounded-lg bg-white/5 hover:bg-cyan-500/20 text-gray-400 hover:text-cyan-400 transition"
                                title="Edit">
                                <i class="fas fa-pen text-xs"></i>
                              </button>
                              <button onclick="toggleCouponStatus('<%= coupon._id %>')" id="toggle-<%= coupon._id %>"
                                class="p-2 rounded-lg bg-white/5 hover:bg-yellow-500/20 text-gray-400 hover:text-yellow-400 transition"
                                title="<%= coupon.isActive ? 'Deactivate' : 'Activate' %>">
                                <i class="fas <%= coupon.isActive ? 'fa-toggle-on' : 'fa-toggle-off' %> text-xs"></i>
                              </button>
                              <button onclick="deleteCoupon('<%= coupon._id %>')"
                                class="p-2 rounded-lg bg-white/5 hover:bg-red-500/20 text-gray-400 hover:text-red-400 transition"
                                title="Delete">
                                <i class="fas fa-trash text-xs"></i>
                              </button>
                            </div>
                          </td>
                        </tr>
                        <% }) %>
                          <% } %>
              </tbody>
            </table>
          </div>

          <!-- Pagination -->
          <div id="pagination" class="flex flex-wrap justify-center items-center gap-2 mt-8">
            <% if (totalPages> 1) { %>
              <% for (let p=1; p <=totalPages; p++) { %>
                <a href="?page=<%= p %>" class="px-3 py-1.5 text-xs rounded-lg border transition
                <%= p === currentPage
                  ? 'bg-cyan-600 border-cyan-600 text-white'
                  : 'border-white/10 text-gray-400 hover:bg-white/5' %>">
                  <%= p %>
                </a>
                <% } %>
                  <% } %>
          </div>

        </main>
    </div>

    <!-- ===== COUPON MODAL ===== -->
    <div id="couponModal"
      class="fixed inset-0 bg-black/60 backdrop-blur-sm hidden z-50 flex items-center justify-center p-4">
      <div class="bg-[#0b1220] w-full max-w-xl rounded-2xl border border-white/10 p-6 max-h-[90vh] overflow-y-auto">

        <!-- Modal Header -->
        <div class="flex justify-between items-center mb-6">
          <h2 id="couponModalTitle" class="text-lg font-bold text-white">Add Coupon</h2>
          <button onclick="closeCouponModal()" class="text-gray-400 hover:text-white transition">
            <i class="fas fa-times"></i>
          </button>
        </div>

        <!-- Form -->
        <form id="couponForm" class="space-y-4">
          <input type="hidden" id="coupon-id">

          <!-- Code + Description -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="text-xs text-gray-400 uppercase tracking-widest mb-1.5 block">Coupon Code *</label>
              <div class="flex gap-2">
                <input type="text" id="coupon-code" placeholder="e.g. SAVE20"
                  class="flex-1 bg-[#0f172a] border border-white/10 px-3 py-2.5 rounded-lg text-sm text-gray-200 placeholder-gray-600 focus:outline-none focus:ring-2 focus:ring-cyan-500 uppercase">
                <button type="button" onclick="generateCode()"
                  class="px-3 py-2 bg-white/5 hover:bg-white/10 text-gray-400 hover:text-white rounded-lg text-xs transition"
                  title="Auto-generate">
                  <i class="fas fa-wand-magic-sparkles"></i>
                </button>
              </div>
              <span id="couponCodeError" class="text-red-400 text-xs mt-1 hidden block"></span>
            </div>
            <div>
              <label class="text-xs text-gray-400 uppercase tracking-widest mb-1.5 block">Description</label>
              <input type="text" id="coupon-description" placeholder="Short description..."
                class="w-full bg-[#0f172a] border border-white/10 px-3 py-2.5 rounded-lg text-sm text-gray-200 placeholder-gray-600 focus:outline-none focus:ring-2 focus:ring-cyan-500">
              <span id="couponDescriptionError" class="text-red-400 text-xs mt-1 hidden block"></span>
            </div>
          </div>

          <!-- Discount Type + Value -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="text-xs text-gray-400 uppercase tracking-widest mb-1.5 block">Discount Type *</label>
              <select id="coupon-discount-type" onchange="toggleMaxDiscount()"
                class="w-full bg-[#0f172a] border border-white/10 px-3 py-2.5 rounded-lg text-sm text-gray-200 focus:outline-none focus:ring-2 focus:ring-cyan-500">
                <option value="">Select type</option>
                <option value="percentage">Percentage (%)</option>
                <option value="fixed">Fixed Amount (₹)</option>
              </select>
              <span id="couponDiscountTypeError" class="text-red-400 text-xs mt-1 hidden block"></span>
            </div>
            <div>
              <label class="text-xs text-gray-400 uppercase tracking-widest mb-1.5 block">Discount Value *</label>
              <div class="relative">
                <span id="discountPrefix"
                  class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-500 text-sm">%</span>
                <input type="number" id="coupon-discount-value" placeholder="0"
                  class="w-full bg-[#0f172a] border border-white/10 pl-8 pr-3 py-2.5 rounded-lg text-sm text-gray-200 placeholder-gray-600 focus:outline-none focus:ring-2 focus:ring-cyan-500">
              </div>
              <span id="couponDiscountValueError" class="text-red-400 text-xs mt-1 hidden block"></span>
            </div>
          </div>

          <!-- Max Discount (percentage only) -->
          <div id="maxDiscountRow" class="hidden">
            <label class="text-xs text-gray-400 uppercase tracking-widest mb-1.5 block">Max Discount Cap (₹)</label>
            <input type="number" id="coupon-max-discount" placeholder="e.g. 500"
              class="w-full bg-[#0f172a] border border-white/10 px-3 py-2.5 rounded-lg text-sm text-gray-200 placeholder-gray-600 focus:outline-none focus:ring-2 focus:ring-cyan-500">
            <span id="couponMaxDiscountError" class="text-red-400 text-xs mt-1 hidden block"></span>
          </div>

          <!-- Min Order + Usage Limit -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="text-xs text-gray-400 uppercase tracking-widest mb-1.5 block">Min Order Amount (₹)</label>
              <input type="number" id="coupon-min-order" placeholder="0"
                class="w-full bg-[#0f172a] border border-white/10 px-3 py-2.5 rounded-lg text-sm text-gray-200 placeholder-gray-600 focus:outline-none focus:ring-2 focus:ring-cyan-500">
              <span id="couponMinOrderError" class="text-red-400 text-xs mt-1 hidden block"></span>
            </div>
            <div>
              <label class="text-xs text-gray-400 uppercase tracking-widest mb-1.5 block">Usage Limit <span
                  class="text-gray-600 normal-case">(blank = unlimited)</span></label>
              <input type="number" id="coupon-usage-limit" placeholder="e.g. 100"
                class="w-full bg-[#0f172a] border border-white/10 px-3 py-2.5 rounded-lg text-sm text-gray-200 placeholder-gray-600 focus:outline-none focus:ring-2 focus:ring-cyan-500">
              <span id="couponUsageLimitError" class="text-red-400 text-xs mt-1 hidden block"></span>
            </div>
          </div>

          <!-- Per User Limit -->
          <div>
            <label class="text-xs text-gray-400 uppercase tracking-widest mb-1.5 block">Per User Limit <span
                class="text-gray-600 normal-case">(blank = unlimited)</span></label>
            <input type="number" id="coupon-per-user" placeholder="e.g. 1"
              class="w-full bg-[#0f172a] border border-white/10 px-3 py-2.5 rounded-lg text-sm text-gray-200 placeholder-gray-600 focus:outline-none focus:ring-2 focus:ring-cyan-500">
            <span id="couponPerUserError" class="text-red-400 text-xs mt-1 hidden block"></span>
          </div>

          <!-- Start + Expiry Date -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="text-xs text-gray-400 uppercase tracking-widest mb-1.5 block">Start Date *</label>
              <input type="date" id="coupon-start"
                class="w-full bg-[#0f172a] border border-white/10 px-3 py-2.5 rounded-lg text-sm text-gray-200 focus:outline-none focus:ring-2 focus:ring-cyan-500 [color-scheme:dark]">
              <span id="couponStartError" class="text-red-400 text-xs mt-1 hidden block"></span>
            </div>
            <div>
              <label class="text-xs text-gray-400 uppercase tracking-widest mb-1.5 block">Expiry Date *</label>
              <input type="date" id="coupon-expiry"
                class="w-full bg-[#0f172a] border border-white/10 px-3 py-2.5 rounded-lg text-sm text-gray-200 focus:outline-none focus:ring-2 focus:ring-cyan-500 [color-scheme:dark]">
              <span id="couponExpiryError" class="text-red-400 text-xs mt-1 hidden block"></span>
            </div>
          </div>

          <!-- Status -->
          <div>
            <label class="text-xs text-gray-400 uppercase tracking-widest mb-1.5 block">Status</label>
            <select id="coupon-status"
              class="w-full bg-[#0f172a] border border-white/10 px-3 py-2.5 rounded-lg text-sm text-gray-200 focus:outline-none focus:ring-2 focus:ring-cyan-500">
              <option value="true">Active</option>
              <option value="false">Inactive</option>
            </select>
          </div>

          <!-- Buttons -->
          <div class="flex justify-end gap-3 pt-2 border-t border-white/5">
            <button type="button" onclick="closeCouponModal()"
              class="px-5 py-2 bg-white/5 hover:bg-white/10 text-gray-300 rounded-lg text-sm transition">
              Cancel
            </button>
            <button type="submit" id="coupon-submit-btn"
              class="px-5 py-2 bg-cyan-600 hover:bg-cyan-700 text-white font-semibold rounded-lg text-sm transition">
              Create Coupon
            </button>
          </div>
        </form>
      </div>
    </div>

    <!-- ===== SCRIPTS ===== -->
    <script>
      // Search + filter
      let debounceTimer;
      const searchInput = document.getElementById('searchInput');
      const clearBtn = document.getElementById('clearBtn');

      searchInput.addEventListener('input', () => {
        clearBtn.classList.toggle('hidden', searchInput.value.trim().length === 0);
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(filterCoupons, 400);
      });

      clearBtn.addEventListener('click', () => {
        searchInput.value = '';
        clearBtn.classList.add('hidden');
        filterCoupons();
      });

      document.getElementById('statusFilter').addEventListener('change', filterCoupons);

      function filterCoupons() {
        const q = searchInput.value.trim().toLowerCase();
        const status = document.getElementById('statusFilter').value;
        const rows = document.querySelectorAll('#couponsTableBody tr[id^="row-"]');

        rows.forEach(row => {
          const code = row.querySelector('span.font-mono')?.textContent?.toLowerCase() || '';
          const badge = row.querySelector('[id^="badge-"]')?.textContent?.trim().toLowerCase() || '';
          const matchQ = !q || code.includes(q);
          const matchS = !status || badge === status;
          row.style.display = matchQ && matchS ? '' : 'none';
        });
      }

      // Modal
      function openCouponModal(data = null) {
        const isEdit = !!data;
        document.getElementById('coupon-id').value = data?._id || '';
        document.getElementById('coupon-code').value = data?.code || '';
        document.getElementById('coupon-description').value = data?.description || '';
        document.getElementById('coupon-discount-type').value = data?.discountType || '';
        document.getElementById('coupon-discount-value').value = data?.discountValue || '';
        document.getElementById('coupon-max-discount').value = data?.maxDiscount || '';
        document.getElementById('coupon-min-order').value = data?.minOrderAmount || '';
        document.getElementById('coupon-usage-limit').value = data?.usageLimit || '';
        document.getElementById('coupon-per-user').value = data?.perUserLimit || '';
        document.getElementById('coupon-start').value = data?.startDate ? data.startDate.slice(0, 10) : '';
        document.getElementById('coupon-expiry').value = data?.expiryDate ? data.expiryDate.slice(0, 10) : '';
        document.getElementById('coupon-status').value = data ? String(data.isActive) : 'true';

        document.getElementById('couponModalTitle').textContent = isEdit ? 'Edit Coupon' : 'Add Coupon';
        document.getElementById('coupon-submit-btn').textContent = isEdit ? 'Update Coupon' : 'Create Coupon';

        // Clear all inline errors
        clearCouponErrors();

        toggleMaxDiscount();
        document.getElementById('couponModal').classList.remove('hidden');
      }

      function closeCouponModal() {
        // Clear all inline errors
        clearCouponErrors();
        document.getElementById('couponModal').classList.add('hidden');
        document.getElementById('couponForm').reset();
      }

      function clearCouponErrors() {
        document.getElementById('couponCodeError').textContent = '';
        document.getElementById('couponCodeError').classList.add('hidden');
        document.getElementById('couponDescriptionError').textContent = '';
        document.getElementById('couponDescriptionError').classList.add('hidden');
        document.getElementById('couponDiscountTypeError').textContent = '';
        document.getElementById('couponDiscountTypeError').classList.add('hidden');
        document.getElementById('couponDiscountValueError').textContent = '';
        document.getElementById('couponDiscountValueError').classList.add('hidden');
        document.getElementById('couponMaxDiscountError').textContent = '';
        document.getElementById('couponMaxDiscountError').classList.add('hidden');
        document.getElementById('couponMinOrderError').textContent = '';
        document.getElementById('couponMinOrderError').classList.add('hidden');
        document.getElementById('couponUsageLimitError').textContent = '';
        document.getElementById('couponUsageLimitError').classList.add('hidden');
        document.getElementById('couponPerUserError').textContent = '';
        document.getElementById('couponPerUserError').classList.add('hidden');
        document.getElementById('couponStartError').textContent = '';
        document.getElementById('couponStartError').classList.add('hidden');
        document.getElementById('couponExpiryError').textContent = '';
        document.getElementById('couponExpiryError').classList.add('hidden');
      }

      function toggleMaxDiscount() {
        const type = document.getElementById('coupon-discount-type').value;
        document.getElementById('maxDiscountRow').classList.toggle('hidden', type !== 'percentage');
        document.getElementById('discountPrefix').textContent = type === 'fixed' ? '₹' : '%';
      }

      async function generateCode() {
        const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789';
        const btn = document.querySelector('[onclick="generateCode()"]');
        if (btn) { btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>'; }

        try {
          // Try up to 5 codes — stop immediately on first available
          for (let i = 0; i < 5; i++) {
            const code = Array.from({ length: 8 }, () => chars[Math.floor(Math.random() * chars.length)]).join('');
            const res = await fetch(`/admin/coupons/check-code?code=${code}`);
            const data = await res.json();

            if (res.status === 429) {
              window._showAdminToast?.(data.message, 'error');
              return;
            }

            if (data.available) {
              document.getElementById('coupon-code').value = code;
              return;
            }
          }
          window._showAdminToast?.('Could not generate a unique code. Try manually.', 'warning');
        } catch (e) {
          window._showAdminToast?.('Network error generating code', 'error');
        } finally {
          if (btn) { btn.disabled = false; btn.innerHTML = '<i class="fas fa-wand-magic-sparkles"></i>'; }
        }
      }

      function copyCode(code) {
        navigator.clipboard.writeText(code).then(() => {
          // visual feedback handled by toast in module below
          window._copyToast && window._copyToast(code);
        });
      }

      function editCoupon(id) {
        fetch(`/admin/coupons/${id}`)
          .then(r => r.json())
          .then(res => {
            if (res.success) openCouponModal(res.data);
          });
      }

      function toggleCouponStatus(id) {
        fetch(`/admin/coupons/${id}/status`, { method: 'PATCH' })
          .then(r => r.json())
          .then(res => {
            if (res.success) location.reload();
          });
      }

      function deleteCoupon(id) {
        if (!confirm('Delete this coupon?')) return;
        fetch(`/admin/coupons/${id}`, { method: 'DELETE' })
          .then(r => r.json())
          .then(res => {
            if (res.success) document.getElementById(`row-${id}`)?.remove();
          });
      }
    </script>

    <script type="module">
      import { showToast } from "../../partials/errorMsg.utils.js";
      import { confirmAction } from "../../partials/confirm.util.js";

      window._copyToast = (code) => showToast(`Copied: ${code}`, 'success');
      window._showAdminToast = (msg, type) => showToast(msg, type);

      // ── Frontend validation ──────────────────────────────────────────
      function validateForm() {
        // Clear all errors first
        clearCouponErrors();

        const code = document.getElementById('coupon-code').value.trim();
        const type = document.getElementById('coupon-discount-type').value;
        const value = parseFloat(document.getElementById('coupon-discount-value').value);
        const maxDiscount = parseFloat(document.getElementById('coupon-max-discount').value);
        const minOrder = parseFloat(document.getElementById('coupon-min-order').value);
        const usageLimit = document.getElementById('coupon-usage-limit').value;
        const perUser = document.getElementById('coupon-per-user').value;
        const startDate = document.getElementById('coupon-start').value;
        const expiryDate = document.getElementById('coupon-expiry').value;
        const isEdit = !!document.getElementById('coupon-id').value;

        const showInline = (elementId, msg) => {
          const errorEl = document.getElementById(elementId);
          errorEl.textContent = msg;
          errorEl.classList.remove('hidden');
          return false;
        };

        if (!code) return showInline('couponCodeError', 'Coupon code is required');
        if (!/^[A-Z0-9]{3,20}$/.test(code)) return showInline('couponCodeError', 'Code must be 3–20 alphanumeric characters');
        if (!type) return showInline('couponDiscountTypeError', 'Discount type is required');
        if (!value || isNaN(value)) return showInline('couponDiscountValueError', 'Discount value is required');
        if (type === 'percentage' && (value < 1 || value > 100))
          return showInline('couponDiscountValueError', 'Percentage must be between 1% and 100%');
        if (type === 'fixed' && value <= 0) return showInline('couponDiscountValueError', 'Fixed discount must be greater than 0');
        if (type === 'percentage' && document.getElementById('coupon-max-discount').value && (isNaN(maxDiscount) || maxDiscount <= 0))
          return showInline('couponMaxDiscountError', 'Max discount cap must be greater than 0');
        if (minOrder && (isNaN(minOrder) || minOrder < 0))
          return showInline('couponMinOrderError', 'Min order amount must be 0 or greater');

        // Min order must be strictly greater than the discount amount
        if (type === 'fixed' && minOrder && !isNaN(minOrder) && !isNaN(value)) {
          if (minOrder <= value)
            return showInline('couponMinOrderError', 'Min order amount must be greater than the discount value');
        }
        if (type === 'percentage' && minOrder && !isNaN(minOrder) && document.getElementById('coupon-max-discount').value && !isNaN(maxDiscount) && maxDiscount > 0) {
          if (minOrder <= maxDiscount)
            return showInline('couponMinOrderError', 'Min order amount must be greater than the max discount cap');
        }
        if (usageLimit && (isNaN(parseInt(usageLimit)) || parseInt(usageLimit) < 1))
          return showInline('couponUsageLimitError', 'Usage limit must be at least 1');
        if (perUser && (isNaN(parseInt(perUser)) || parseInt(perUser) < 1))
          return showInline('couponPerUserError', 'Per user limit must be at least 1');
        if (!startDate) return showInline('couponStartError', 'Start date is required');
        
        const today = new Date();
        today.setHours(0, 0, 0, 0);

        if (new Date(startDate) < today) {
          return showInline('couponStartError', 'Start date must be from today onwards');
        }

        if (!expiryDate) return showInline('couponExpiryError', 'Expiry date is required');
        if (new Date(expiryDate) <= new Date(startDate))
          return showInline('couponExpiryError', 'Expiry date must be after start date');
        return true;
      }

      // ── Submit ───────────────────────────────────────────────────────
      document.getElementById('couponForm').addEventListener('submit', async (e) => {
        e.preventDefault();

        const isValid = validateForm();
        if (!isValid) return;

        const id = document.getElementById('coupon-id').value;
        const isEdit = !!id;
        const btn = document.getElementById('coupon-submit-btn');

        btn.disabled = true;
        btn.textContent = isEdit ? 'Updating...' : 'Creating...';

        const maxDiscountVal = document.getElementById('coupon-max-discount').value;
        const usageLimitVal = document.getElementById('coupon-usage-limit').value;
        const perUserVal = document.getElementById('coupon-per-user').value;

        const payload = {
          code: document.getElementById('coupon-code').value.trim().toUpperCase(),
          description: document.getElementById('coupon-description').value.trim(),
          discountType: document.getElementById('coupon-discount-type').value,
          discountValue: parseFloat(document.getElementById('coupon-discount-value').value),
          maxDiscount: maxDiscountVal ? parseFloat(maxDiscountVal) : null,
          minOrderAmount: parseFloat(document.getElementById('coupon-min-order').value) || 0,
          usageLimit: usageLimitVal ? parseInt(usageLimitVal) : null,
          perUserLimit: perUserVal ? parseInt(perUserVal) : null,
          startDate: document.getElementById('coupon-start').value,
          expiryDate: document.getElementById('coupon-expiry').value,
          isActive: document.getElementById('coupon-status').value === 'true',
        };

        try {
          const res = await fetch(isEdit ? `/admin/coupons/${id}` : '/admin/coupons', {
            method: isEdit ? 'PATCH' : 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });

          const data = await res.json();

          if (!res.ok) {
            showToast(data.message || 'Something went wrong', 'error');
            return;
          }

          showToast(data.message, 'success');
          closeCouponModal();
          setTimeout(() => location.reload(), 700);

        } catch (err) {
          showToast(err.message || 'Request failed', 'error');
        } finally {
          btn.disabled = false;
          btn.textContent = isEdit ? 'Update Coupon' : 'Create Coupon';
        }
      });

      // ── Delete with confirm ──────────────────────────────────────────
      window.deleteCoupon = async (id) => {
        const confirmed = await confirmAction('Delete this coupon? This cannot be undone.');
        if (!confirmed) return;

        const res = await fetch(`/admin/coupons/${id}`, { method: 'DELETE' });
        const data = await res.json();

        if (data.success) {
          showToast(data.message, 'success');
          document.getElementById(`row-${id}`)?.remove();
        } else {
          showToast(data.message, 'error');
        }
      };

      // ── Toggle status ────────────────────────────────────────────────
      window.toggleCouponStatus = async (id) => {
        const res = await fetch(`/admin/coupons/${id}/status`, { method: 'PATCH' });
        const data = await res.json();

        if (data.success) {
          showToast(data.message, 'success');
          setTimeout(() => location.reload(), 500);
        } else {
          showToast(data.message, 'error');
        }
      };

    </script>
    <script>
      // Prevent mouse wheel from changing number input values
      document.querySelectorAll('input[type="number"]').forEach((el) => {
        el.addEventListener('wheel', (e) => { e.preventDefault(); }, { passive: false });
      });
    </script>

</body>

</html>