<% if (!orders || orders.length === 0) { %>
  <div class="bg-white p-10 text-center rounded-xl shadow-sm">
    <p class="text-gray-500 text-sm font-medium">No orders found</p>
  </div>
<% } %>

<% orders.forEach(order => { %>

<a href="/order/details/<%= order._id %>"
  class="block bg-white border border-gray-200 rounded-xl shadow-sm hover:shadow-md transition-all duration-200 p-4">

  <div class="flex gap-4 items-center">

    <!-- ✅ IMAGE (IMPORTANT FIX) -->
    <div class="flex gap-2 min-w-[90px]">
      <% if(order.previewImages?.length) { %>
        <% order.previewImages.forEach(img => { %>
          <img src="<%= img %>"
            class="w-16 h-16 object-contain bg-gray-100 rounded border p-1">
        <% }) %>
      <% } else { %>
        <div class="w-16 h-16 bg-gray-100 rounded flex items-center justify-center text-xs text-gray-400">
          No Image
        </div>
      <% } %>
    </div>

    <!-- ✅ CENTER CONTENT -->
    <div class="flex-1">

      <h2 class="text-sm font-semibold text-gray-800">
        <%= order.orderNumber %>
      </h2>

      <p class="text-xs text-gray-500 mt-1">
        <%= new Date(order.createdAt).toDateString() %>
      </p>

      <p class="text-xs text-gray-600 mt-1">
        <%= order.itemCount || 0 %> item(s)
      </p>

      <!-- STATUS -->
      <div class="mt-2">
        <% let statusClass = "bg-gray-100 text-gray-600"; %>

        <% if(order.orderStatus === "placed") statusClass = "bg-yellow-100 text-yellow-700"; %>
        <% if(order.orderStatus === "shipped") statusClass = "bg-blue-100 text-blue-700"; %>
        <% if(order.orderStatus === "delivered") statusClass = "bg-green-100 text-green-700"; %>
        <% if(order.orderStatus === "cancelled") statusClass = "bg-red-100 text-red-600"; %>

        <span class="px-2 py-1 text-xs font-medium rounded <%= statusClass %>">
          <%= order.orderStatus %>
        </span>
      </div>

    </div>

    <!-- ✅ RIGHT SIDE -->
    <div class="text-right min-w-[120px]">

      <p class="text-sm font-semibold text-gray-900">
        ₹<%= order.pricing.finalAmount %>
      </p>

      <div class="mt-2">
  <span class="inline-flex items-center gap-1 text-blue-600 text-sm font-medium hover:gap-2 transition-all">
    View Details
    <span>→</span>
  </span>
</div>

    </div>

  </div>

</a>

<% }) %>