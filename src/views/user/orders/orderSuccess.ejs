<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<script src="https://cdn.tailwindcss.com"></script>

<%- include("../../partials/user/header.ejs") %>

    <style>
        body {
            font-family: 'Outfit', sans-serif;
            background-color: #f9fafb;
        }

        /* Ambient Background Blobs Animation */
        @keyframes blob {
            0% {
                transform: translate(0px, 0px) scale(1);
            }

            33% {
                transform: translate(30px, -50px) scale(1.1);
            }

            66% {
                transform: translate(-20px, 20px) scale(0.9);
            }

            100% {
                transform: translate(0px, 0px) scale(1);
            }
        }

        .animate-blob {
            animation: blob 7s infinite alternate;
        }

        .animation-delay-2000 {
            animation-delay: 2s;
        }

        .animation-delay-4000 {
            animation-delay: 4s;
        }

        /* SVG Checkmark Drawing Animation */
        @keyframes drawCheck {
            0% {
                stroke-dashoffset: 50;
                opacity: 0;
            }

            100% {
                stroke-dashoffset: 0;
                opacity: 1;
            }
        }

        .check-path {
            stroke-dasharray: 50;
            stroke-dashoffset: 50;
            animation: drawCheck 0.8s cubic-bezier(0.65, 0, 0.45, 1) forwards;
            animation-delay: 0.3s;
        }

        /* Tooltip utility */
        .tooltip-caret::after {
            content: '';
            position: absolute;
            bottom: -5px;
            left: 50%;
            transform: translateX(-50%);
            border-width: 5px 5px 0;
            border-style: solid;
            border-color: #111827 transparent transparent transparent;
        }

        /* Card entrance */
        @keyframes cardEntrance {
            0%   { opacity: 0; transform: translateY(40px) scale(0.96); }
            100% { opacity: 1; transform: translateY(0)   scale(1); }
        }
        .card-enter { animation: cardEntrance 0.7s cubic-bezier(0.22,1,0.36,1) forwards; }

        /* Icon pop */
        @keyframes iconPop {
            0%   { transform: scale(0) rotate(-20deg); opacity: 0; }
            60%  { transform: scale(1.15) rotate(5deg); opacity: 1; }
            100% { transform: scale(1) rotate(0deg); opacity: 1; }
        }
        .icon-pop { animation: iconPop 0.6s cubic-bezier(0.34,1.56,0.64,1) 0.2s both; }

        /* Confetti piece */
        @keyframes confettiFall {
            0%   { transform: translateY(-20px) rotate(0deg);   opacity: 1; }
            100% { transform: translateY(120px) rotate(720deg); opacity: 0; }
        }
        .confetti-piece {
            position: absolute;
            width: 8px; height: 8px;
            border-radius: 2px;
            animation: confettiFall 1.4s ease-in forwards;
        }

        /* Shimmer on receipt */
        @keyframes shimmer {
            0%   { background-position: -400px 0; }
            100% { background-position: 400px 0; }
        }
        .shimmer-line {
            background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
            background-size: 400px 100%;
            animation: shimmer 1.5s infinite;
        }
    </style>

    <main class="min-h-[90vh] relative flex justify-center items-center py-20 px-4 sm:px-6 overflow-hidden z-0">

        <!-- Animated Ambient Color Background -->
        <div class="absolute top-0 left-0 w-full h-[60vh] bg-gradient-to-b from-green-50 to-transparent -z-20"></div>
        <div
            class="absolute top-10 left-1/4 w-[300px] h-[300px] sm:w-[400px] sm:h-[400px] bg-green-200/40 rounded-full mix-blend-multiply filter blur-[80px] animate-blob -z-10 pointer-events-none">
        </div>
        <div
            class="absolute top-20 right-1/4 w-[300px] h-[300px] sm:w-[400px] sm:h-[400px] bg-emerald-100/50 rounded-full mix-blend-multiply filter blur-[80px] animate-blob animation-delay-2000 -z-10 pointer-events-none">
        </div>

        <div class="w-full max-w-[600px] relative">

            <!-- Confetti container -->
            <div id="confettiContainer" class="absolute inset-0 pointer-events-none overflow-hidden z-20"></div>

            <!-- Background pulse ring behind the check icon -->
            <div
                class="absolute -top-14 left-1/2 -translate-x-1/2 w-40 h-40 bg-green-400/20 rounded-full blur-[30px] -z-10 animate-pulse pointer-events-none">
            </div>

            <!-- Start of Card Context -->
            <div
                class="card-enter bg-white/95 backdrop-blur-2xl rounded-[2rem] shadow-2xl shadow-green-900/5 border border-white p-6 sm:p-10 pt-16 mt-12 relative text-center">

                <!-- Break-out Floating Avatar Checkmark -->
                <div class="absolute -top-14 left-1/2 -translate-x-1/2 group">
                    <!-- Drop shadow glow -->
                    <div
                        class="absolute inset-0 bg-green-400 rounded-full blur-[15px] opacity-20 group-hover:opacity-40 transition-opacity duration-300">
                    </div>

                    <div
                        class="icon-pop relative w-28 h-28 bg-gradient-to-tr from-green-500 to-emerald-400 rounded-full border-[6px] border-white shadow-xl flex items-center justify-center transform group-hover:scale-105 transition-transform duration-500">
                        <svg class="w-12 h-12 text-white drop-shadow-md" fill="none" stroke="currentColor"
                            stroke-width="4" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                            <path class="check-path" d="M20 6L9 17l-5-5"></path>
                        </svg>
                    </div>

                    <!-- Floating geometric particles -->
                    <i class="fa-solid fa-star absolute top-1 -right-4 text-yellow-400 text-xl animate-bounce"
                        style="animation-duration: 2.5s;"></i>
                    <i class="fa-solid fa-certificate absolute bottom-3 -left-5 text-blue-300 text-lg animate-pulse"
                        style="animation-duration: 3s;"></i>
                </div>

                <!-- Header Titles -->
                <h1 class="text-3xl sm:text-4xl font-extrabold text-gray-900 tracking-tight mt-2 mb-2">Order Placed!
                </h1>
                <p class="text-[15px] sm:text-base text-gray-500 mb-10 max-w-[90%] mx-auto leading-relaxed">
                    Thank you for shopping with us! We have received your order and will send a confirmation email with
                    your shipping details.
                </p>

                <!-- Digital Receipt Box -->
                <div
                    class="bg-[#f9fafb] rounded-[1.25rem] border border-gray-100 p-5 sm:p-6 text-left mb-10 shadow-inner relative overflow-hidden group">
                    <!-- Background decoration icon -->
                    <i
                        class="fa-brands fa-slack absolute -right-6 -bottom-6 text-[120px] text-gray-100 opacity-40 rotate-[15deg] pointer-events-none group-hover:scale-110 transition-transform duration-700"></i>

                    <!-- Order Number Block -->
                    <div class="flex items-center justify-between border-b border-gray-200/80 pb-4 mb-4 relative z-10">
                        <div>
                            <span
                                class="flex items-center gap-1.5 text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1.5">
                                <i class="fa-solid fa-receipt text-gray-300"></i> Order Number
                            </span>
                            <span
                                class="text-base sm:text-lg font-bold text-gray-900 font-mono tracking-tight bg-white px-2 py-0.5 rounded border border-gray-100 inline-block shadow-sm">
                                <%= typeof orderNumber !=='undefined' ? orderNumber : 'ORD-8947231' %>
                            </span>
                        </div>

                        <!-- Copy Button -->
                        <button
                            onclick="copyToClipboard('<%= typeof orderNumber !== 'undefined' ? orderNumber : 'ORD-8947231' %>')"
                            class="w-10 h-10 rounded-xl bg-white border border-gray-200 text-gray-500 flex items-center justify-center shadow-sm hover:bg-black hover:text-white hover:border-black transition-all group/btn relative">
                            <i class="fa-regular fa-copy group-hover/btn:scale-110 transition-transform"></i>

                            <!-- Tooltip popup -->
                            <div id="copyTooltip"
                                class="absolute -top-10 left-1/2 -translate-x-1/2 bg-gray-900 text-white text-[11px] font-medium px-3 py-1.5 rounded opacity-0 transition-opacity duration-200 pointer-events-none shadow-xl tooltip-caret whitespace-nowrap z-50">
                                Copied!
                            </div>
                        </button>
                    </div>

                    <!-- Date Context Block -->
                    <div class="grid grid-cols-2 gap-4 relative z-10">
                        <div>
                            <span
                                class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1.5">Date
                                Placed</span>
                            <span class="text-xs sm:text-sm font-semibold text-gray-800">
                                <%= new Date().toLocaleDateString('en-US', { day: 'numeric' , month: 'long' ,
                                    year: 'numeric' }) %>
                            </span>
                        </div>
                        <div>
                            <span
                                class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1.5 text-blue-600">Expected
                                Delivery</span>
                            <span
                                class="text-xs sm:text-sm font-extrabold text-gray-900 inline-flex items-center gap-1.5">
                                <i class="fa-regular fa-calendar-check text-blue-500 text-[10px]"></i>
                                <%= new Date(expectedDelivery).toLocaleDateString('en-US', { day: 'numeric' ,
                                    month: 'long' }) %>
                            </span>
                        </div>

                        <div class="grid grid-cols-2 gap-4 mt-4 relative z-10">

    <!-- PAYMENT METHOD -->
    <div>
        <span class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1.5">
            Payment Method
        </span>
        <span class="text-xs sm:text-sm font-semibold text-gray-800 flex items-center gap-1.5">
            <% if (paymentMethod === "razorpay") { %>
                <i class="fa-solid fa-credit-card text-blue-500 text-xs"></i> Online (Razorpay)
            <% } else if (paymentMethod === "wallet") { %>
                <i class="fa-solid fa-wallet text-blue-500 text-xs"></i> Wallet
            <% } else { %>
                <i class="fa-solid fa-money-bill-wave text-green-500 text-xs"></i> Cash on Delivery
            <% } %>
        </span>
    </div>

    <!-- PAYMENT ID -->
    <div>
        <span class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1.5">
            Payment ID
        </span>
        <span class="text-xs sm:text-sm font-mono text-gray-900">
            <% if (paymentMethod === "razorpay" && paymentId) { %>
                <%= paymentId %>
            <% } else if (paymentMethod === "wallet") { %>
                <span class="text-green-600 font-semibold text-xs">Paid via Wallet ✓</span>
            <% } else { %>
                --
            <% } %>
        </span>
    </div>

</div>
                    </div>
                </div>

                <!-- Call to Action Buttons -->
                <div class="flex flex-col sm:flex-row items-center gap-3">
                    <a href="/orders"
                        class="w-full sm:flex-1 relative overflow-hidden group/btn2 flex items-center justify-center gap-2.5 px-8 py-4 bg-gray-900 text-white text-sm font-semibold rounded-2xl hover:bg-black transition-colors shadow-lg hover:shadow-xl">
                        <span
                            class="absolute inset-0 w-full h-full bg-white/20 scale-x-0 group-hover/btn2:scale-x-100 origin-left transition-transform duration-500 ease-out z-0"></span>
                        <i class="fa-solid fa-list-check z-10 opacity-70"></i>
                        <span class="relative z-10">Track / View Order</span>
                        <i
                            class="fa-solid fa-arrow-right-long text-xs z-10 opacity-70 group-hover/btn2:opacity-100 group-hover/btn2:translate-x-1.5 transition-all"></i>
                    </a>

                    <a href="/shop"
                        class="w-full sm:flex-1 flex items-center justify-center gap-2 px-8 py-4 bg-white text-gray-700 text-sm font-semibold rounded-2xl border-2 border-gray-200 hover:border-gray-900 hover:text-black transition-all group hover:bg-gray-50">
                        <i
                            class="fa-solid fa-bag-shopping text-xs text-gray-400 group-hover:text-black transition-colors"></i>
                        Continue Shopping
                    </a>
                </div>

            </div>
        </div>
    </main>

    <script>
        // Copy to Clipboard Utility
        function copyToClipboard(text) {
            if (!navigator.clipboard) return;
            navigator.clipboard.writeText(text).then(() => {
                const tooltip = document.getElementById('copyTooltip');
                tooltip.classList.remove('opacity-0');
                tooltip.classList.add('opacity-100');
                setTimeout(() => {
                    tooltip.classList.remove('opacity-100');
                    tooltip.classList.add('opacity-0');
                }, 2000);
            });
        }

        // Confetti burst on load
        (function spawnConfetti() {
            const container = document.getElementById('confettiContainer');
            if (!container) return;
            const colors = ['#22c55e','#3b82f6','#f59e0b','#ec4899','#8b5cf6','#06b6d4'];
            for (let i = 0; i < 36; i++) {
                const el = document.createElement('div');
                el.className = 'confetti-piece';
                el.style.cssText = `
                    left: ${Math.random() * 100}%;
                    top: ${Math.random() * 30}%;
                    background: ${colors[Math.floor(Math.random() * colors.length)]};
                    animation-delay: ${Math.random() * 0.8}s;
                    animation-duration: ${1.2 + Math.random() * 0.8}s;
                    width: ${6 + Math.random() * 6}px;
                    height: ${6 + Math.random() * 6}px;
                    border-radius: ${Math.random() > 0.5 ? '50%' : '2px'};
                `;
                container.appendChild(el);
            }
            // Clean up after animation
            setTimeout(() => container.innerHTML = '', 3000);
        })();
    </script>

    <%- include("../../partials/user/footer.ejs") %>