<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Order Details</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    body { font-family: 'Inter', sans-serif; }
    .modal { transition: opacity 0.2s ease; }
    body.modal-active { overflow: hidden; }
  </style>
</head>
<body class="bg-[#F1F3F6] min-h-screen">

<%- include("../../partials/user/header.ejs") %>

<div class="max-w-[1280px] mx-auto px-4 py-5 pb-12">

  <!-- Breadcrumb -->
  <div class="text-xs text-gray-500 mb-4 flex items-center gap-1 flex-wrap">
    <a href="/" class="hover:text-blue-600 transition">Home</a>
    <span>&rsaquo;</span>
    <a href="/myProfile" class="hover:text-blue-600 transition">My Account</a>
    <span>&rsaquo;</span>
    <a href="/orders" class="hover:text-blue-600 transition">My Orders</a>
    <span>&rsaquo;</span>
    <span class="text-gray-800 font-medium"><%= order.orderNumber %></span>
  </div>

  <!-- Page Title -->
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 mb-5">
    <div>
      <h1 class="text-xl font-bold text-gray-900">Order #<%= order.orderNumber %></h1>
      <p class="text-xs text-gray-500 mt-0.5">
        Placed on <%= new Date(order.createdAt).toLocaleString('en-IN', { day:'numeric', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit' }) %>
      </p>
    </div>
    <span class="self-start sm:self-auto px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wide
      <%= order.orderStatus === 'delivered'        ? 'bg-green-100 text-green-700' :
          order.orderStatus === 'cancelled'        ? 'bg-red-100 text-red-600' :
          order.orderStatus === 'shipped' || order.orderStatus === 'out_for_delivery' ? 'bg-blue-100 text-blue-700' :
          'bg-yellow-100 text-yellow-700' %>">
      <%= order.orderStatus.replace(/_/g,' ') %>
    </span>
  </div>

  <div class="flex flex-col lg:flex-row gap-6 items-start">

    <!-- LEFT -->
    <div class="w-full lg:flex-1 space-y-5">

      <!-- Order Tracking -->
      <div class="bg-white border rounded-xl shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b">
          <h2 class="text-sm font-bold text-gray-800">Order Status</h2>
        </div>
        <div class="px-6 py-8">
          <% const currentStatus = order.orderStatus.toLowerCase(); %>

          <% if(currentStatus === 'cancelled') { %>
            <div class="flex items-center justify-center gap-4 max-w-xs mx-auto">
              <div class="flex flex-col items-center">
                <div class="w-11 h-11 rounded-full bg-green-500 text-white flex items-center justify-center shadow">
                  <i class="fa-solid fa-check"></i>
                </div>
                <p class="mt-2 text-xs font-semibold text-gray-700">Confirmed</p>
              </div>
              <div class="flex-1 h-1 bg-red-400 rounded"></div>
              <div class="flex flex-col items-center">
                <div class="w-11 h-11 rounded-full bg-red-500 text-white flex items-center justify-center shadow">
                  <i class="fa-solid fa-xmark"></i>
                </div>
                <p class="mt-2 text-xs font-bold text-red-600">Cancelled</p>
              </div>
            </div>
            <p class="text-center text-sm text-red-500 font-medium mt-4">
              Cancelled on <%= new Date(order.cancelledAt || order.updatedAt).toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' }) %>
            </p>
          <% } else { %>
            <%
              const steps = [
                { key: 'placed',           label: 'Placed',          icon: 'fa-bag-shopping' },
                { key: 'confirmed',        label: 'Confirmed',       icon: 'fa-circle-check' },
                { key: 'shipped',          label: 'Shipped',         icon: 'fa-box' },
                { key: 'out_for_delivery', label: 'Out for Delivery',icon: 'fa-truck' },
                { key: 'delivered',        label: 'Delivered',       icon: 'fa-house' },
              ];
              const statusOrder = ['placed','confirmed','shipped','out_for_delivery','delivered'];
              const currentIdx = statusOrder.indexOf(currentStatus);
            %>
            <div class="relative flex justify-between items-start max-w-2xl mx-auto">
              <div class="absolute top-5 left-0 w-full h-0.5 bg-gray-200"></div>
              <div class="absolute top-5 left-0 h-0.5 bg-green-500"
                   style="width: <%= currentIdx >= 0 ? (currentIdx / (steps.length - 1)) * 100 : 0 %>%"></div>
              <% steps.forEach((step, idx) => { %>
                <% const done = idx <= currentIdx; %>
                <div class="flex flex-col items-center z-10 flex-1">
                  <div class="w-10 h-10 rounded-full flex items-center justify-center border-4 shadow-sm
                    <%= done ? 'bg-green-500 text-white border-green-100' : 'bg-white text-gray-300 border-gray-200' %>">
                    <i class="fa-solid <%= step.icon %> text-xs"></i>
                  </div>
                  <p class="text-[10px] mt-2 text-center leading-tight font-medium
                    <%= done ? 'text-gray-800' : 'text-gray-400' %>"><%= step.label %></p>
                </div>
              <% }) %>
            </div>
            <% if(order.delivery?.expectedDate && currentStatus !== 'delivered') { %>
              <p class="text-center text-xs text-gray-500 mt-5">
                Expected by <span class="font-semibold text-gray-700">
                  <%= new Date(order.delivery.expectedDate).toLocaleDateString('en-IN', { weekday:'short', day:'numeric', month:'short' }) %>
                </span>
              </p>
            <% } %>
            <% if(order.delivery?.deliveredAt) { %>
              <p class="text-center text-xs text-green-600 font-semibold mt-5">
                <i class="fa-solid fa-circle-check mr-1"></i>
                Delivered on <%= new Date(order.delivery.deliveredAt).toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' }) %>
              </p>
            <% } %>
          <% } %>
        </div>
      </div>

      <!-- Order Items -->
      <div class="bg-white border rounded-xl shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b flex items-center justify-between">
          <h2 class="text-sm font-bold text-gray-800">Order Items (<%= items.length %>)</h2>
          <% if(['placed','confirmed'].includes(order.orderStatus) && !order.isCancelled) { %>
            <button onclick="openCancelModal(false)"
              class="text-xs text-red-600 border border-red-200 px-3 py-1.5 rounded-lg hover:bg-red-50 font-semibold transition flex items-center gap-1.5">
              <i class="fa-solid fa-ban text-[10px]"></i> Cancel Order
            </button>
          <% } %>
        </div>

        <div class="divide-y divide-gray-100">
          <% items.forEach(item => { %>
            <div class="p-5 flex gap-4 items-start">
              <!-- Image -->
              <a href="/product/<%= item.productId %>"
                class="w-20 h-20 border rounded-lg p-1.5 bg-gray-50 flex-shrink-0 hover:opacity-80 transition">
                <img src="<%= item.images?.[0] || 'https://via.placeholder.com/150' %>"
                     class="w-full h-full object-contain mix-blend-multiply" alt="<%= item.name %>">
              </a>

              <!-- Info -->
              <div class="flex-1 min-w-0">
                <a href="/product/<%= item.productId %>"
                  class="text-sm font-semibold text-gray-900 leading-tight hover:text-blue-600 transition">
                  <%= item.name %>
                </a>
                <% if(item.brand) { %><p class="text-xs text-gray-400 mt-0.5"><%= item.brand %></p><% } %>

                <div class="flex flex-wrap gap-1.5 mt-1.5">
                  <span class="bg-gray-100 text-gray-600 text-xs px-2 py-0.5 rounded">Qty: <%= item.quantity %></span>
                  <% if(item.attributes && Object.keys(item.attributes).length > 0) { %>
                    <% Object.entries(item.attributes).forEach(([k,v]) => { %>
                      <span class="bg-gray-100 text-gray-600 text-xs px-2 py-0.5 rounded capitalize"><%= k %>: <%= v %></span>
                    <% }) %>
                  <% } %>
                  <span class="text-xs px-2 py-0.5 rounded font-semibold
  <%= item.itemStatus === 'cancelled'        ? 'bg-red-100 text-red-600' :
      item.itemStatus === 'returned'         ? 'bg-purple-100 text-purple-600' :
      item.itemStatus === 'return_requested' ? 'bg-yellow-100 text-yellow-700' :
      item.itemStatus === 'return_approved'  ? 'bg-blue-100 text-blue-700' :
      item.itemStatus === 'return_rejected'  ? 'bg-red-100 text-red-600' :
      item.itemStatus === 'delivered'        ? 'bg-green-100 text-green-700' :
      'bg-gray-100 text-gray-600' %>">
                    <%= item.itemStatus %>
                  </span>
                </div>

                <div class="mt-1.5 text-xs text-gray-500">
                  ₹<%= item.pricing?.finalPrice?.toLocaleString('en-IN') %> × <%= item.quantity %>
                  <% if(item.pricing?.discountAmount > 0) { %>
                    <span class="text-green-600 ml-1">(-₹<%= item.pricing.discountAmount.toLocaleString('en-IN') %>)</span>
                  <% } %>

                  <% if(item.itemStatus.includes('return') && item.return) { %>
  <div class="mt-2 border rounded-lg p-2 text-xs
    <%= item.itemStatus === 'return_rejected' ? 'bg-red-50 border-red-100' :
        item.itemStatus === 'return_approved' ? 'bg-blue-50 border-blue-100' :
        'bg-yellow-50 border-yellow-100' %>">

    <!-- STATUS TITLE -->
    <p class="font-semibold
      <%= item.itemStatus === 'return_rejected' ? 'text-red-600' :
          item.itemStatus === 'return_approved' ? 'text-blue-600' :
          'text-yellow-700' %>">

      <%= item.itemStatus.replace(/_/g, ' ') %>
    </p>

    <!-- USER REASON -->
    <% if(item.return.reason) { %>
      <p class="text-gray-600 mt-1">
        Reason: <%= item.return.reason.replace(/_/g, ' ') %>
      </p>
    <% } %>

    <!-- USER COMMENT -->
    <% if(item.return.comments) { %>
      <p class="text-gray-500 mt-1">
        Comment: <%= item.return.comments %>
      </p>
    <% } %>

    <!-- ❌ REJECT REASON -->
    <% if(item.itemStatus === 'return_rejected' && item.return.rejectReason) { %>
  <p class="text-red-500 mt-1 font-medium">
    Reject Reason: <%= item.return.rejectReason %>
  </p>

  <!-- 🔥 CONTACT SUPPORT BUTTON -->
  <div class="mt-2 inline-flex items-center gap-1 text-xs bg-blue-600 text-white px-3 py-1 rounded hover:bg-blue-700 transition">
      <i class="fa-solid fa-headset"></i>
      Contact Support
  </div>
<% } %>
  </div>
<% } %>

<!-- 📦 PICKUP STATUS -->
<% if(item.itemStatus === 'pickup_scheduled' && item.return?.pickupDate) { %>
  <p class="text-xs text-yellow-400 mt-1">
    Pickup Scheduled: <%= new Date(item.return.pickupDate).toLocaleDateString('en-IN') %>
  </p>
<% } %>

<!-- PICKUP COMPLETED -->
<% if(item.itemStatus === 'returned' && item.return?.pickupCompletedAt) { %>
  <p class="text-xs text-green-400 mt-1">
    Pickup Completed: <%= new Date(item.return.pickupCompletedAt).toLocaleDateString('en-IN') %>
  </p>
<% } %>
                </div>
              </div>

              <!-- Price + Action -->
              <div class="text-right shrink-0 flex flex-col items-end gap-2">
                <p class="text-sm font-bold text-gray-900">₹<%= item.pricing?.total?.toLocaleString('en-IN') %></p>
                <% if(item.itemStatus === 'delivered') { %>
                  <button onclick="openReturnModal('<%= item._id %>')"
                    class="text-xs text-blue-600 border border-blue-200 px-2.5 py-1 rounded-lg hover:bg-blue-50 font-medium transition">
                    Return
                  </button>
                 
                <% } %>
                <% if(['placed','confirmed'].includes(order.orderStatus) && item.itemStatus !=='cancelled' && items.length > 1) { %>
                  <button onclick="openCancelModal(true, '<%= item._id %>')"
                    class="text-xs text-red-600 border border-red-200 px-2.5 py-1 rounded-lg hover:bg-red-50 font-medium transition">
                    Cancel Item
                  </button>
                  <% } %>     </div>
            </div>
          <% }) %>
        </div>
      </div>

      <!-- Cancellation Details -->
      <% if(order.isCancelled && order.cancelReason) { %>
        <div class="bg-white border border-red-100 rounded-xl p-5 shadow-sm">
          <h3 class="text-sm font-bold text-red-600 mb-3 flex items-center gap-2">
            <i class="fa-solid fa-ban"></i> Cancellation Details
          </h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
            <div>
              <p class="text-xs text-gray-400 mb-1">Reason</p>
              <p class="text-gray-700 font-medium capitalize"><%= order.cancelReason?.replace(/_/g,' ') %></p>
            </div>
            <% if(order.cancelComments) { %>
              <div>
                <p class="text-xs text-gray-400 mb-1">Comments</p>
                <p class="text-gray-700"><%= order.cancelComments %></p>
              </div>
            <% } %>
          </div>
        </div>
      <% } %>

    </div>

    <!-- RIGHT Sidebar -->
    <div class="w-full lg:w-[360px] space-y-5">

      <!-- Delivery Address -->
      <div class="bg-white border rounded-xl p-5 shadow-sm">
        <h2 class="font-bold text-gray-900 mb-4 flex items-center gap-2 text-sm">
          <i class="fa-solid fa-location-dot text-blue-600"></i> Delivery Address
        </h2>
        <p class="font-bold text-gray-800 text-sm"><%= order.shippingAddress.name %></p>
        <p class="text-sm text-gray-500 leading-relaxed mt-1">
          <%= order.shippingAddress.address %>,<br>
          <%= order.shippingAddress.city %>, <%= order.shippingAddress.state %> —
          <span class="font-semibold text-gray-700"><%= order.shippingAddress.pincode %></span>
        </p>
        <div class="mt-3 flex items-center gap-2 text-sm">
          <i class="fa-solid fa-phone text-gray-400 text-xs"></i>
          <span class="text-gray-700 font-medium"><%= order.shippingAddress.phone %></span>
        </div>
        <% if(order.shippingAddress.altPhone) { %>
          <div class="mt-1 flex items-center gap-2 text-sm">
            <i class="fa-solid fa-phone text-gray-300 text-xs"></i>
            <span class="text-gray-500"><%= order.shippingAddress.altPhone %> <span class="text-xs">(Alt)</span></span>
          </div>
        <% } %>
        <% if(order.shippingAddress.landmark) { %>
          <p class="text-xs text-gray-400 mt-2">Near: <%= order.shippingAddress.landmark %></p>
        <% } %>
      </div>

      <!-- Price Details -->
      <div class="bg-white border rounded-xl p-5 shadow-sm">
        <h2 class="font-bold text-gray-900 mb-4 text-sm">Price Details</h2>
        <div class="space-y-2.5 text-sm border-b pb-4">
          <div class="flex justify-between text-gray-600">
            <span>Subtotal</span>
            <span>₹<%= order.pricing.subtotal?.toLocaleString('en-IN') %></span>
          </div>
          <% if(order.pricing.productDiscount > 0) { %>
            <div class="flex justify-between text-green-600">
              <span>Product Discount</span>
              <span>-₹<%= order.pricing.productDiscount?.toLocaleString('en-IN') %></span>
            </div>
          <% } %>
          <% if(order.pricing.couponDiscount > 0) { %>
            <div class="flex justify-between text-green-600">
              <span>Coupon Discount</span>
              <span>-₹<%= order.pricing.couponDiscount?.toLocaleString('en-IN') %></span>
            </div>
          <% } %>
          <div class="flex justify-between text-gray-600">
            <span>GST</span>
            <span>₹<%= order.pricing.gstTotal?.toLocaleString('en-IN') %></span>
          </div>
          <div class="flex justify-between text-gray-600">
            <span>Delivery</span>
            <% if(order.pricing.deliveryCharge > 0) { %>
              <span>₹<%= order.pricing.deliveryCharge?.toLocaleString('en-IN') %></span>
            <% } else { %>
              <span class="text-green-600 font-semibold text-xs uppercase">Free</span>
            <% } %>
          </div>
        </div>
        <div class="flex justify-between items-center pt-4">
          <span class="font-bold text-gray-900">Grand Total</span>
          <span class="text-lg font-black text-gray-900">₹<%= order.pricing.finalAmount?.toLocaleString('en-IN') %></span>
        </div>
        <div class="mt-4 bg-blue-50 rounded-lg p-3 flex items-center justify-between">
          <span class="text-xs text-blue-700 font-medium">Payment</span>
          <div class="flex items-center gap-2">
            <span class="bg-white px-2 py-0.5 rounded border border-blue-200 font-bold text-blue-800 uppercase text-xs">
              <%= order.payment.method %>
            </span>
            <span class="text-xs font-semibold
              <%= order.payment.status === 'paid' ? 'text-green-600' : order.payment.status === 'failed' ? 'text-red-500' : 'text-yellow-600' %>">
              <%= order.payment.status %>
            </span>
          </div>
        </div>
      </div>

      <!-- Order Info -->
      <div class="bg-white border rounded-xl p-5 shadow-sm">
        <h2 class="font-bold text-gray-900 mb-4 text-sm">Order Info</h2>
        <div class="space-y-2.5 text-sm">
          <div class="flex justify-between">
            <span class="text-gray-500">Order ID</span>
            <span class="text-gray-800 font-mono text-xs font-semibold"><%= order.orderNumber %></span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-500">Placed On</span>
            <span class="text-gray-700"><%= new Date(order.createdAt).toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' }) %></span>
          </div>
          <% if(order.delivery?.expectedDate && order.orderStatus !== 'delivered' && order.orderStatus !== 'cancelled') { %>
            <div class="flex justify-between">
              <span class="text-gray-500">Expected By</span>
              <span class="text-gray-700 font-medium"><%= new Date(order.delivery.expectedDate).toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' }) %></span>
            </div>
          <% } %>
          <% if(order.delivery?.deliveredAt) { %>
            <div class="flex justify-between">
              <span class="text-gray-500">Delivered On</span>
              <span class="text-green-600 font-semibold"><%= new Date(order.delivery.deliveredAt).toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' }) %></span>
            </div>
          <% } %>
        </div>
      </div>

    </div>
  </div>
</div>

<!-- CANCEL MODAL -->
<% if(['placed','confirmed'].includes(order.orderStatus) && !order.isCancelled) { %>
<div id="cancelModal" class="modal opacity-0 pointer-events-none fixed inset-0 flex items-center justify-center z-[100]">
  <div class="absolute inset-0 bg-black/50" onclick="toggleModal('cancelModal')"></div>
  <div class="relative bg-white w-11/12 max-w-md rounded-xl shadow-2xl z-10 p-6">
    <div class="flex justify-between items-center mb-5">
      <h3 class="text-base font-bold text-gray-800">Cancel Order</h3>
      <button onclick="toggleModal('cancelModal')" class="text-gray-400 hover:text-gray-600"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <form onsubmit="submitCancel(event, '<%= order._id %>')">
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 mb-1.5">Reason <span class="text-red-500">*</span></label>
        <select required name="cancelReason" class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:border-blue-500">
          <option value="" disabled selected>Choose a reason...</option>
          <option value="changed_mind">I changed my mind</option>
          <option value="price_cheaper_elsewhere">Found a cheaper alternative</option>
          <option value="ordered_by_mistake">Ordered by mistake</option>
          <option value="delivery_taking_too_long">Delivery is taking too long</option>
          <option value="other">Other</option>
        </select>
      </div>
      <div class="mb-5">
        <label class="block text-sm font-medium text-gray-700 mb-1.5">Comments <span class="text-red-500">*</span></label>
        <textarea required name="cancelComments" rows="3" placeholder="Please provide details..."
          class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm resize-none focus:outline-none focus:border-blue-500"></textarea>
      </div>
      <div class="flex gap-3 justify-end border-t pt-4">
        <button type="button" onclick="toggleModal('cancelModal')" class="px-4 py-2 text-sm text-gray-600 hover:bg-gray-100 rounded-lg">Close</button>
        <button type="submit" id="cancel-submit-btn" class="px-5 py-2 bg-red-600 text-white text-sm font-semibold rounded-lg hover:bg-red-700 transition">
          Confirm Cancellation
        </button>
      </div>
    </form>
  </div>
</div>
<% } %>

<!-- RETURN MODAL -->
<div id="returnModal" class="modal opacity-0 pointer-events-none fixed inset-0 flex items-center justify-center z-[100]">
  <div class="absolute inset-0 bg-black/50" onclick="toggleModal('returnModal')"></div>
  <div class="relative bg-white w-11/12 max-w-md rounded-xl shadow-2xl z-10 p-6">
    <div class="flex justify-between items-center mb-5">
      <h3 class="text-base font-bold text-gray-800">Return Item</h3>
      <button onclick="toggleModal('returnModal')" class="text-gray-400 hover:text-gray-600"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <div class="bg-blue-50 text-blue-700 p-3 rounded-lg text-xs mb-4 flex gap-2">
      <i class="fa-solid fa-circle-info mt-0.5 shrink-0"></i>
      <p>Your return request will be evaluated based on item condition and reason.</p>
    </div>
    <form onsubmit="submitReturn(event)">
      <input type="hidden" id="returnItemId">
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 mb-1.5">Return Reason <span class="text-red-500">*</span></label>
        <select required name="returnReason" class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:border-blue-500">
          <option value="" disabled selected>Why are you returning this?</option>
          <option value="defective">Item is defective or doesn't work</option>
          <option value="missing_parts">Missing accessories or parts</option>
          <option value="wrong_item">Received wrong item</option>
          <option value="damaged">Item damaged during shipping</option>
          <option value="not_needed">No longer needed</option>
        </select>
      </div>
      <div class="mb-5">
        <label class="block text-sm font-medium text-gray-700 mb-1.5">Comments</label>
        <textarea name="returnComments" rows="3" placeholder="Please explain the issue..."
          class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm resize-none focus:outline-none focus:border-blue-500"></textarea>
      </div>
      <div class="flex gap-3 justify-end border-t pt-4">
        <button type="button" onclick="toggleModal('returnModal')" class="px-4 py-2 text-sm text-gray-600 hover:bg-gray-100 rounded-lg">Close</button>
        <button type="submit" id="return-submit-btn" class="px-5 py-2 bg-[#2874F0] text-white text-sm font-semibold rounded-lg hover:bg-blue-700 transition">
          Confirm Return
        </button>
      </div>
    </form>
  </div>
</div>

<script type="module">
  import { showToast } from "/partials/errorMsg.utils.js";
  window.showToast = showToast;
</script>

<script>
  function toggleModal(id) {
    const modal = document.getElementById(id);
    if (!modal) return;
    modal.classList.toggle('opacity-0');
    modal.classList.toggle('pointer-events-none');
    document.body.classList.toggle('modal-active');
  }

  let cancelContext = {
  isSingle: false,
  itemId: null
};

function openCancelModal(isSingle = false, itemId = null) {
  cancelContext.isSingle = isSingle;
  cancelContext.itemId = itemId;

  //  update modal title
  const title = document.querySelector("#cancelModal h3");
    const form = document.querySelector("#cancelModal form");
    form.reset(); // 🔥 clear old values

  if (title) {
    title.innerText = isSingle ? "Cancel Item" : "Cancel Order";
  }

  toggleModal('cancelModal');
}
  function openReturnModal(itemId) {
    document.getElementById('returnItemId').value = itemId;
    toggleModal('returnModal');
  }

  async function submitCancel(e, orderId) {
  e.preventDefault();

  const form = e.target;
  const btn = document.getElementById('cancel-submit-btn');

  btn.textContent = 'Cancelling...';
  btn.disabled = true;

  try {
    let url = "";
    let body = {
      reason: form.cancelReason.value,
      comments: form.cancelComments.value
    };

    if (cancelContext.isSingle) {
      // ITEM CANCEL
      url = `/orders/${orderId}/item/${cancelContext.itemId}/cancel`;
    } else {
      // ORDER CANCEL
      url = `/orders/${orderId}/cancel`;
    }

    const res = await fetch(url, {
      method: 'PATCH',
      headers: {
        'Content-Type': 'application/json',
        'Accept': 'application/json'
      },
      body: JSON.stringify(body),
      credentials: 'include'
    });

    const data = await res.json();

    if (!res.ok) throw new Error(data.message || 'Cancel failed');

    toggleModal('cancelModal');
    setTimeout(() => location.reload(), 600);

  } catch (err) {
    btn.textContent = 'Confirm Cancellation';
    btn.disabled = false;
    showToast(err.message, 'error');
  }
}

  async function submitReturn(e) {
    e.preventDefault();
    const form = e.target;
    const itemId = document.getElementById('returnItemId').value;
    const btn = document.getElementById('return-submit-btn');
    btn.textContent = 'Submitting...';
    btn.disabled = true;
    try {
      const res = await fetch(`/orders/${itemId}/return`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ returnReason: form.returnReason.value, returnComments: form.returnComments.value }),
        credentials: 'include'
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.message || 'Return failed');
      toggleModal('returnModal');
      window.showToast ? showToast('Return request submitted', 'success') : null;
      setTimeout(() => location.reload(), 800);
    } catch (err) {
      btn.textContent = 'Confirm Return';
      btn.disabled = false;
      window.showToast ? showToast(err.message, 'error') : alert(err.message);
    }
  }
</script>

<%- include("../../partials/user/footer.ejs") %>
</body>
</html>
