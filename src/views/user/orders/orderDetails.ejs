<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<script src="https://cdn.tailwindcss.com"></script>

<%- include("../../partials/user/header.ejs") %>

    <style>
        body {
            font-family: 'Inter', sans-serif;
        }

        /* Timeline tracking CSS */
        .timeline-node {
            position: relative;
        }

        .timeline-node::before {
            content: '';
            position: absolute;
            top: 24px;
            left: 11px;
            bottom: -24px;
            width: 2px;
            background-color: #22c55e;
            z-index: 0;
        }

        .timeline-node-inactive::before {
            background-color: #e5e7eb;
        }

        .timeline-node:last-child::before {
            display: none;
        }

        .modal {
            transition: opacity 0.25s ease;
        }

        body.modal-active {
            overflow-x: hidden;
            overflow-y: hidden !important;
        }
    </style>

    <div class="max-w-[1280px] mx-auto px-4 flex flex-col lg:flex-row gap-6 items-start pb-10">

        <div class="w-full lg:flex-1 space-y-6">

            <div class="bg-white border rounded-xl shadow-sm overflow-hidden">
                <div class="p-6 md:p-8 flex flex-col md:flex-row justify-between gap-6">
                    <div class="flex gap-6">
                        <div class="w-24 h-24 md:w-32 md:h-32 border rounded-lg p-2 bg-gray-50 flex-shrink-0">
                            <img src="<%= product.images?.[0] || 'https://via.placeholder.com/150' %>"
                                class="w-full h-full object-contain mix-blend-multiply">
                        </div>
                        <div class="flex-1">
                            <h1 class="text-lg md:text-xl font-bold text-gray-900 mb-2 leading-tight">
                                <%= product.name %>
                            </h1>
                            <p class="text-sm text-gray-500 flex items-center gap-2 mb-4">
                                <span class="bg-gray-100 px-2 py-0.5 rounded">Qty: <%= product.quantity %></span>
                                <% if(product.attributes && Object.keys(product.attributes).length> 0) { %>
                                    <span class="text-gray-300">|</span>
                                    <span class="text-gray-600">
                                        <%= Object.values(product.attributes).join(', ') %></span>
                            <% } %>
                        </p>
                        <div class="text-2xl font-bold text-gray-900">
                            ₹<%= product.pricing.finalPrice %>
                        </div>
                    </div>
                </div>

                <div class="flex flex-col gap-3 min-w-[180px]">
                    <% if(['placed','processing'].includes(order.orderStatus.toLowerCase()) && !order.isCancelled) { %>
                        <button onclick="toggleModal('cancelModal')"
                            class="w-full py-2.5 px-4 bg-white border border-red-200 text-red-600 rounded-lg hover:bg-red-50 font-semibold transition flex items-center justify-center gap-2 shadow-sm">
                            <i class="fa-solid fa-ban"></i> Cancel Order
                        </button>
                        <% } %>
                
                            <% if(order.orderStatus==='delivered' ) { %>
                                <button onclick="toggleModal('returnModal')"
                                    class="w-full py-2.5 px-4 bg-[#2874F0] text-white rounded-lg hover:bg-blue-700 font-semibold transition shadow-md flex items-center justify-center gap-2">
                                    <i class="fa-solid fa-rotate-left"></i> Return Item
                                </button>
                                <% } %>
                
                                    <button
                                        class="w-full py-2.5 px-4 bg-gray-50 text-gray-700 border rounded-lg hover:bg-gray-100 font-medium transition flex items-center justify-center gap-2">
                                        <i class="fa-solid fa-file-invoice"></i> Invoice
                                    </button>
                </div>
                </div>

                    <div class="border-t bg-gray-50/50 p-6 md:p-10">

  <% const status = order.orderStatus.toLowerCase(); %>

  <% if(status === "cancelled") { %>

    <!-- 🔴 CANCELLED UI -->
    <div class="flex items-center justify-center gap-10">

      <!-- Confirmed -->
      <div class="flex flex-col items-center">
        <div class="w-12 h-12 rounded-full bg-green-500 text-white flex items-center justify-center">
          <i class="fa-solid fa-check"></i>
        </div>
        <p class="mt-2 text-sm font-bold text-gray-800">Confirmed</p>
      </div>

      <!-- Line -->
      <div class="flex-1 h-1 bg-red-400"></div>

      <!-- Cancelled -->
      <div class="flex flex-col items-center">
        <div class="w-12 h-12 rounded-full bg-red-500 text-white flex items-center justify-center">
          <i class="fa-solid fa-xmark"></i>
        </div>
        <p class="mt-2 text-sm font-bold text-red-600">Cancelled</p>
      </div>

    </div>

    <div class="mt-6 text-center">
      <p class="text-red-600 font-semibold">
        Order was cancelled on 
        <%= new Date(order.cancelledAt || order.updatedAt).toLocaleDateString('en-IN') %>
      </p>
    </div>

  <% } else { %>

    <!-- 🟢 NORMAL TIMELINE -->
    <% const lifecycle = ['confirmed','shipped','out for delivery','delivered']; %>
    <% const currentIndex = lifecycle.indexOf(status); %>

    <div class="relative flex justify-between items-center max-w-3xl mx-auto">

      <div class="absolute top-1/2 left-0 w-full h-1 bg-gray-200 -translate-y-1/2"></div>

      <div class="absolute top-1/2 left-0 h-1 bg-green-500 -translate-y-1/2"
        style="width: <%= currentIndex >= 0 ? (currentIndex / (lifecycle.length - 1)) * 100 : 0 %>%">
      </div>

      <% lifecycle.forEach((step, index) => { %>
        <% const isCompleted = index <= currentIndex; %>

        <div class="flex flex-col items-center z-10">
          <div class="w-10 h-10 rounded-full flex items-center justify-center border-4
            <%= isCompleted ? 'bg-green-500 text-white border-green-100' : 'bg-white text-gray-400 border-gray-200' %>">

            <% if(isCompleted) { %>
              <i class="fa-solid fa-check"></i>
            <% } else { %>
              <span><%= index + 1 %></span>
            <% } %>

          </div>

          <p class="text-xs mt-2 uppercase <%= isCompleted ? 'text-black' : 'text-gray-400' %>">
            <%= step %>
          </p>
        </div>

      <% }) %>

    </div>

  <% } %>

</div>
                </div>
            </div>

            <div class="w-full lg:w-[380px] space-y-6">
                <div class="bg-white border rounded-xl p-6 shadow-sm">
                    <h2 class="font-bold text-gray-900 mb-4 flex items-center gap-2">
                        <i class="fa-solid fa-location-dot text-blue-600"></i> Delivery Address
                    </h2>
                    <div class="space-y-1">
                        <p class="font-bold text-gray-800">
                            <%= order.shippingAddress.name %>
                        </p>
                        <p class="text-sm text-gray-600 leading-relaxed">
                            <%= order.shippingAddress.address %>,<br>
                                <%= order.shippingAddress.city %>, <%= order.shippingAddress.state %> - <span
                                            class="font-semibold">
                                            <%= order.shippingAddress.pincode %>
                                        </span>
                        </p>
                        <div class="pt-3 flex items-center gap-2 text-sm text-gray-800">
                            <span class="text-gray-500 text-xs">Phone:</span>
                            <span class="font-medium">
                                <%= order.shippingAddress.phone %>
                            </span>
                        </div>
                    </div>
                </div>

                <div class="bg-white border rounded-xl p-6 shadow-sm">
                    <h2 class="font-bold text-gray-900 mb-4">Price Details</h2>
                    <div class="space-y-3 border-b pb-4">
                        <div class="flex justify-between text-sm text-gray-600 font-medium">
                            <span>Base Price</span>
                            <span>₹<%= product.pricing.basePrice %></span>
                        </div>
                        <div class="flex justify-between text-sm text-gray-600 font-medium">
                            <span>GST (<%= product.pricing.gstRate %>%)</span>
                            <span>₹<%= product.pricing.gstAmount %></span>
                        </div>
                        <div class="flex justify-between text-sm">
                            <span class="text-gray-600">Delivery Fee</span>
                            <span class="text-green-600 font-bold uppercase text-xs">Free</span>
                        </div>
                    </div>
                    <div class="flex justify-between items-center pt-4">
                        <span class="text-lg font-bold text-gray-900">Total Amount</span>
                        <span class="text-xl font-black text-gray-900">₹<%= product.pricing.finalPrice %></span>
                    </div>
                    <div class="mt-4 bg-blue-50 p-3 rounded-lg flex items-center justify-between text-xs">
                        <span class="text-blue-700 font-medium">Payment Mode</span>
                        <span
                            class="bg-white px-2 py-1 rounded border border-blue-200 font-bold text-blue-800 uppercase tracking-tight">
                            <%= order.payment.method %>
                        </span>
                    </div>
                </div>
            </div>
    </div>

        <!-- ================= MODALS ================= -->

        <% if((order.orderStatus==='placed' || order.orderStatus==='processing' ) && !order.isCancelled) { %>
            <!-- Cancel Order Modal -->
            <div class="modal opacity-0 pointer-events-none fixed w-full h-full top-0 left-0 flex items-center justify-center z-[100]"
                id="cancelModal">
                <div class="absolute w-full h-full bg-gray-900 opacity-50 block" onclick="toggleModal('cancelModal')">
                </div>
                <div class="bg-white w-11/12 md:max-w-md mx-auto rounded shadow-lg z-50 overflow-y-auto">
                    <div class="py-4 text-left px-6">
                        <!--Title-->
                        <div class="flex justify-between items-center pb-3 border-b mb-4">
                            <p class="text-lg font-semibold text-gray-800">Reason for Cancellation</p>
                            <div class="cursor-pointer z-50 p-2 hover:bg-gray-100 rounded-full transition"
                                onclick="toggleModal('cancelModal')">
                                <i class="fa fa-times text-gray-500"></i>
                            </div>
                        </div>

                        <!--Body-->
                        <form onsubmit="submitCancel(event, '<%= order._id %>')">
                            <div class="mb-4">
                                <label class="block text-gray-700 text-sm font-medium mb-2">Select Reason *</label>
                                <select required name="cancelReason"
                                    class="block w-full border border-gray-300 rounded px-3 py-2 text-sm">
                                    <option value="" disabled selected>Choose a reason...</option>
                                    <option value="changed_mind">I changed my mind</option>
                                    <option value="price_cheaper_elsewhere">Found a cheaper alternative</option>
                                    <option value="ordered_by_mistake">Ordered by mistake</option>
                                    <option value="delivery_taking_too_long">Delivery is taking too long</option>
                                    <option value="other">Other</option>
                                </select>
                            </div>

                            <div class="mb-4">
                                <label class="block text-gray-700 text-sm font-medium mb-2">Comments *</label>
                                <textarea required name="cancelComments" rows="3"
                                    class="block w-full border border-gray-300 rounded px-3 py-2 text-sm"
                                    placeholder="Please provide details..."></textarea>
                            </div>

                            <div class="flex justify-end pt-4 gap-3 border-t">
                                <button type="button" onclick="toggleModal('cancelModal')"
                                    class="px-4 py-2 text-gray-600 hover:bg-gray-100 rounded">
                                    Close
                                </button>

                                <button type="submit" id="cancel-submit-btn"
                                    class="px-4 py-2 bg-red-600 text-white rounded hover:bg-red-700">
                                    Confirm Cancellation
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
            <% } %>

                <% if(order.orderStatus==='delivered' ) { %>
                    <!-- Return Order Modal -->
                    <div class="modal opacity-0 pointer-events-none fixed w-full h-full top-0 left-0 flex items-center justify-center z-[100]"
                        id="returnModal">
                        <div class="absolute w-full h-full bg-gray-900 opacity-50 block"
                            onclick="toggleModal('returnModal')"></div>
                        <div class="bg-white w-11/12 md:max-w-md mx-auto rounded shadow-lg z-50 overflow-y-auto">
                            <div class="py-4 text-left px-6">
                                <!--Title-->
                                <div class="flex justify-between items-center pb-3 border-b mb-4">
                                    <p class="text-lg font-semibold text-gray-800">Reason for Return</p>
                                    <div class="cursor-pointer z-50 p-2 hover:bg-gray-100 rounded-full transition"
                                        onclick="toggleModal('returnModal')">
                                        <i class="fa fa-times text-gray-500"></i>
                                    </div>
                                </div>

                                <!--Body-->
                                <form action="/order/return/<%= order._id %>" method="POST">
                                    <div class="bg-blue-50 text-blue-800 p-3 rounded text-xs mb-4 flex gap-2">
                                        <i class="fa fa-info-circle mt-0.5"></i>
                                        <p>Depending on the condition of the item and reason, your return request will
                                            be
                                            evaluated for a refund or replacement.</p>
                                    </div>

                                    <div class="mb-4">
                                        <label class="block text-gray-700 text-sm font-medium mb-2">Select Return Reason
                                            *</label>
                                        <select required name="returnReason"
                                            class="block w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 text-gray-700 bg-white">
                                            <option value="" disabled selected>Why are you returning this?</option>
                                            <option value="defective">Item is defective or doesn't work</option>
                                            <option value="missing_parts">Missing accessories or parts</option>
                                            <option value="wrong_item">Received wrong item</option>
                                            <option value="damaged">Item/Packaging damaged strictly during shipping
                                            </option>
                                            <option value="not_needed">No longer needed</option>
                                        </select>
                                    </div>

                                    <div class="mb-4">
                                        <label class="block text-gray-700 text-sm font-medium mb-2">Detailed Comments
                                            *</label>
                                        <textarea required name="returnComments" rows="3"
                                            class="block w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 text-gray-700 resize-none transition"
                                            placeholder="Please thoroughly explain the issue..."></textarea>
                                    </div>

                                    <!--Footer-->
                                    <div class="flex justify-end pt-2 gap-3 mt-4 border-t pt-4">
                                        <button type="button"
                                            class="px-4 p-2 bg-transparent rounded text-gray-600 hover:bg-gray-100 hover:text-gray-800 font-medium text-sm transition"
                                            onclick="toggleModal('returnModal')">Close</button>
                                        <button type="submit"
                                            class="px-4 p-2 bg-[#2874F0] text-white rounded hover:bg-blue-700 font-medium text-sm transition shadow-sm">Confirm
                                            Return</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                    <% } %>

                    <script type="module" >
                               import { showToast } from "/partials/errorMsg.utils.js";
                import { confirmAction } from "/partials/confirm.util.js";
window.showToast = showToast
                    </script>
                        <script>
                            function toggleModal(modalID) {
                                const modal = document.getElementById(modalID);
                                if (modal) {
                                    modal.classList.toggle('opacity-0');
                                    modal.classList.toggle('pointer-events-none');
                                    document.body.classList.toggle('modal-active');
                                }
                            }

                            const submitCancel = async (e, orderId) => {
                                e.preventDefault();

                                const form = e.target;
                                const reason = form.cancelReason.value;
                                const comments = form.cancelComments.value;
                                const btn = document.getElementById("cancel-submit-btn");

                                if (!reason || !comments) {
                                    alert("Please fill all fields");
                                    return;
                                }

                                btn.innerText = "Cancelling...";
                                btn.disabled = true;

                                try {
                                    const res = await fetch(`/orders/${orderId}/cancel`, {
                                        method: "PATCH",
                                        headers: {
                                            "Content-Type": "application/json",
                                            'Accept':'application/json'
                                        },
                                        body: JSON.stringify({ reason, comments }),
                                        credentials: "include"
                                    });

                                    const data = await res.json();

                                    if (!res.ok) {
                                        throw new Error(data.message || "Cancel failed");
                                    }

                                    btn.innerText = "Cancelled ✅";

                                    // Close modal
                                    toggleModal("cancelModal");

                                    // Refresh page
                                    setTimeout(() => location.reload(), 800);

                                } catch (err) {
                                    console.error(err);
                                    btn.innerText = "Confirm Cancellation";
                                    btn.disabled = false;
                                    showToast(err.message,'error');
                                }
                            };

                        </script>

                        <%- include("../../partials/user/footer.ejs") %>