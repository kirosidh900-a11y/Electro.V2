        <script>
            const container = document.getElementById("orderContainer");

            function showSkeletons() {
                container.innerHTML = "";

                for (let i = 0; i < 5; i++) {
                    container.innerHTML += `
        <div class="bg-white p-4 rounded shadow animate-pulse">
            <div class="flex gap-4">
                <div class="w-20 h-20 bg-gray-200"></div>
                <div class="flex-1">
                    <div class="h-4 bg-gray-200 mb-2"></div>
                    <div class="h-4 bg-gray-200 w-1/2"></div>
                </div>
            </div>
        </div>`;
                }
            }

            async function loadOrders(page = 1) {
                try {
                    showSkeletons();

                    const search = document.getElementById("searchInput").value || "";

                    const params = new URLSearchParams({
                        page,
                        search
                    });

                    const res = await fetch(`/orders?${params.toString()}`, {
                        headers: { "Accept": "application/json" }
                    });

                    const data = await res.json();

                    if (!data.success) throw new Error();

                    // 🔥 inject cards
                    const temp = document.createElement("div");
                    temp.innerHTML = data.cards;
                    container.replaceChildren(...temp.children);

                    // 🔥 pagination
                    document.getElementById("pagination").innerHTML = data.pagination;

                    // 🔥 empty state
                    if (data.currentCount === 0) {
                        container.innerHTML = `
                <div class="bg-white p-6 text-center rounded">
                    No orders found
                </div>`;
                    }

                } catch (err) {
                    container.innerHTML = `
            <p class="text-center text-red-500">
                Failed to load orders
            </p>`;
                }
            }

            // 🔥 SEARCH (debounce)
            let timer;
            document.getElementById("searchInput").addEventListener("input", () => {
                clearTimeout(timer);
                timer = setTimeout(() => loadOrders(1), 400);
            });

            // 🔥 PAGINATION
            document.getElementById("pagination").addEventListener("click", (e) => {
                const btn = e.target.closest(".pagination-link");
                if (btn) loadOrders(btn.dataset.page);
            });

            // INIT
            document.addEventListener("DOMContentLoaded", () => {
                loadOrders(1);
            });
        </script>