<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
<script src="https://cdn.tailwindcss.com"></script>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
<script defer src="https://cdn.jsdelivr.net/npm/toastify-js"></script>

<%- include("../../partials/user/header") %>

    <main class="bg-gray-100 flex items-center justify-center py-6 px-4 sm:px-6 lg:px-8 min-h-screen">
        <div
            class="max-w-5xl w-full bg-[#111111] rounded-xl shadow-2xl overflow-hidden flex flex-col md:flex-row min-h-[600px]">

            <!-- ══════════════ LEFT PANEL ══════════════ -->
            <div
                class="w-full md:w-1/2 p-6 md:p-12 flex flex-col justify-center relative min-h-[500px] md:min-h-[600px]">

                <!-- STEP 1 — Enter Email -->
                <div id="step-1"
                    class="step-container w-full absolute inset-0 p-8 flex flex-col justify-center bg-[#111111] z-30 transition-all duration-500">
                    <div class="flex items-center gap-3 mb-2">
                        <i class="fas fa-lock text-white text-3xl"></i>
                        <h2 class="text-white text-2xl font-bold">Forgot Password</h2>
                    </div>
                    <p class="text-gray-400 mb-8">Enter your email to continue.</p>

                    <!-- novalidate prevents browser-native GET submit fallback -->
                    <form id="form-step-1" class="space-y-6" novalidate autocomplete="off">
                        <input type="email" id="email" name="email" placeholder="Enter your Email" autocomplete="off"
                            class="w-full bg-[#050505] text-white border border-[#2a2a2a] rounded-lg px-5 py-4 focus:outline-none focus:border-[#fa5252]">
                        <button type="submit" id="btn-step-1"
                            class="w-full bg-[#fa5252] text-white font-bold rounded-lg py-4 hover:bg-[#e03131] transition">
                            Next
                        </button>
                    </form>
                </div>

                <!-- STEP 2 — Verify OTP -->
                <div id="step-2"
                    class="step-container w-full absolute inset-0 p-8 opacity-0 pointer-events-none flex flex-col justify-center bg-[#111111] z-20 transition-all duration-500">
                    <h2 class="text-[#fa5252] text-2xl font-bold mb-4 text-center">Verify OTP</h2>

                    <form id="form-step-2" class="space-y-6" novalidate>
                        <input type="text" id="otp" name="otp" maxlength="6" placeholder="Enter OTP"
                            autocomplete="one-time-code"
                            class="w-full bg-transparent text-white border-b border-gray-600 py-3 text-center tracking-[1rem] text-2xl focus:outline-none focus:border-[#fa5252]">

                        <button type="submit" id="btn-step-2"
                            class="w-full bg-gradient-to-r from-[#fa5252] to-[#c2255c] text-white font-bold py-4 rounded-xl hover:opacity-90 transition">
                            Verify OTP
                        </button>

                        <div class="text-center mt-4">
                            <p id="otp-timer-wrapper" class="text-gray-500 text-sm">
                                Resend OTP in <span id="timer" class="text-[#fa5252] font-bold">50</span>s
                            </p>
                            <button type="button" id="resend-btn"
                                class="hidden text-[#fa5252] hover:underline font-medium text-sm">
                                Resend OTP
                            </button>
                        </div>
                    </form>
                </div>

                <!-- STEP 3 — New Password -->
                <div id="step-3"
                    class="step-container w-full absolute inset-0 p-8 opacity-0 pointer-events-none flex flex-col justify-center bg-[#111111] z-10 transition-all duration-500">
                    <h2 class="text-white text-2xl font-bold mb-4">Create New Password</h2>

                    <form id="form-step-3" class="space-y-6" novalidate>
                        <div class="relative">
                            <input type="password" id="password" placeholder="New Password"
                                class="w-full bg-[#16191f] text-gray-200 border border-[#2c313a] rounded-lg px-5 py-4 pr-12 focus:outline-none focus:border-[#fa5252]">
                            <!-- wire onclick directly so it works regardless of module scope -->
                            <button type="button" class="absolute right-5 top-4 text-gray-500"
                                onclick="togglePassword('password', this)">
                                <i class="fas fa-eye"></i>
                            </button>
                            <span id="passwordError" class="hidden text-red-400 text-xs mt-2 block"></span>
                        </div>
                        <div class="relative">
                            <input type="password" id="cPassword" placeholder="Confirm Password"
                                class="w-full bg-[#16191f] text-gray-200 border border-[#2c313a] rounded-lg px-5 py-4 pr-12 focus:outline-none focus:border-[#fa5252]">
                            <button type="button" class="absolute right-5 top-4 text-gray-500"
                                onclick="togglePassword('cPassword', this)">
                                <i class="fas fa-eye"></i>
                            </button>
                            <span id="cPasswordError" class="hidden text-red-400 text-xs mt-2 block"></span>
                        </div>
                        <button type="submit" id="btn-step-3"
                            class="w-full bg-[#fa5252] text-white font-bold py-4 rounded-lg hover:bg-[#e03131] transition">
                            Update Password
                        </button>
                    </form>
                </div>
            </div>

            <!-- ══════════════ RIGHT PANEL ══════════════ -->
            <div id="right-panel"
                class="w-full md:w-1/2 flex items-center justify-center bg-gradient-to-br from-[#ff4d6d] to-[#fa5252] text-white text-center p-8 md:p-10">
                <div class="max-w-xs">
                    <h2 id="rp-title" class="text-2xl md:text-3xl font-bold mb-4">Secure Access</h2>
                    <p id="rp-desc" class="mb-6 text-sm md:text-base">Verify your identity to regain access to your
                        dashboard.</p>
                    <img id="rp-img" src="https://placehold.co/400x400/ffffff/fa5252?text=Security"
                        class="rounded-xl shadow-xl w-full h-auto mx-auto" alt="Security">
                </div>
            </div>

        </div>
    </main>

    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <!-- togglePassword must be globally available BEFORE the module loads -->
    <script>
        function togglePassword(id, el) {
            const input = document.getElementById(id);
            const icon = el.querySelector('i');
            if (!input) return;
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.replace('fa-eye', 'fa-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.replace('fa-eye-slash', 'fa-eye');
            }
        }
    </script>

    <!-- Main forgot-password logic -->
    <script type="module" src="/user/js/auth/forgot.js" defer></script>

    <%- include("../../partials/user/footer") %>