<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<script src="https://cdn.tailwindcss.com"></script>

<%- include("../../partials/user/header.ejs") %>

        <style>
                body {
                        font-family: 'Inter', sans-serif;
                }

                img {
                        display: block;
                }

                .custom-scrollbar::-webkit-scrollbar {
                        width: 4px;
                }

                .custom-scrollbar::-webkit-scrollbar-thumb {
                        background: #d1d5db;
                        border-radius: 4px;
                }

                .loading {
                        pointer-events: none;
                        opacity: 0.6;
                }
        </style>

        <!-- MOBILE FILTER BUTTON -->
        <button onclick="toggleSidebar()"
                class="lg:hidden fixed top-4 left-4 z-[60] bg-blue-600 text-white p-2 rounded shadow"> <i
                        class="fa fa-filter"></i>
        </button>

        <!-- OVERLAY -->
        <div id="sidebarOverlay" class="fixed inset-0 bg-black/40 hidden z-40" onclick="toggleSidebar()"></div>

        <main class="bg-[#F1F3F6] min-h-screen py-6">
                <div class="max-w-[1280px] mx-auto px-4 flex flex-col lg:flex-row gap-4">


                        <%- include("./partials/productSidebar") %>


                                <!-- PRODUCTS -->
                                <div class="flex-grow">

                                        <!-- TOP BAR -->
                                        <div
                                                class="bg-white border p-4 mb-4 flex flex-col sm:flex-row sm:justify-between sm:items-center gap-3 rounded shadow-sm">

                                                <!-- LEFT: RESULT INFO -->
                                                <p class="text-sm text-gray-600">
                                                        Showing
                                                        <span id="currentCount"
                                                                class="font-semibold text-gray-900">0</span>
                                                        of
                                                        <span id="totalProduct"
                                                                class="font-semibold text-gray-900">0</span>
                                                        products
                                                        <span id="activeFilters"
                                                                class="ml-2 text-blue-600 text-xs font-medium"></span>
                                                </p>

                                                <!-- RIGHT: CONTROLS -->
                                                <div class="flex items-center gap-2">

                                                        <!-- SORT -->
                                                        <select id="sortSelect"
                                                                class="border px-3 py-2 text-sm rounded focus:outline-none focus:ring-2 focus:ring-blue-500 cursor-pointer">
                                                                <option value="newest">Relevance</option>
                                                                <option value="priceLow">Price: Low → High</option>
                                                                <option value="priceHigh">Price: High → Low</option>
                                                                <option value="nameAsc">Name A → Z</option>
                                                                <option value="nameDesc">Name Z → A</option>
                                                        </select>

                                                        <!-- CLEAR FILTER -->
                                                        <button id="clearFiltersBtn"
                                                                class="text-xs px-3 py-2 border rounded hover:bg-gray-100 transition">
                                                                Clear
                                                        </button>

                                                </div>

                                        </div>

                                        <!-- GRID -->
                                        <div id="productContainer" class="grid gap-4"
                                                style="grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));">
                                        </div>

                                        <!-- PAGINATION -->
                                        <div id="pagination" class="flex justify-center mt-10"></div>

                                </div>


                </div>
        </main>

        <!-- SKELETON -->

        <template id="skeleton-card">
                <div class="bg-white border rounded animate-pulse">
                        <div class="h-56 bg-gray-200"></div>
                        <div class="p-4">
                                <div class="h-4 bg-gray-200 mb-2"></div>
                                <div class="h-4 bg-gray-200 w-2/3"></div>
                        </div>
                </div>
        </template>

        <script>
                const container = document.getElementById("productContainer");
                const skeletonTemplate = document.getElementById("skeleton-card");

                /* ================= GLOBAL STATE ================= */
                let selectedCategory = "all";
                let selectedBrands = [];
                let currentSort = "newest";
                let selectedMinPrice = 0;
                let selectedMaxPrice = 100000;

                /* ================= SIDEBAR ================= */
                function toggleSidebar() {
                        const sidebar = document.getElementById("sidebar");
                        const overlay = document.getElementById("sidebarOverlay");

                        sidebar.classList.toggle("-translate-x-full");
                        overlay.classList.toggle("hidden");
                }

                /* ================= LIMIT ================= */
                function getLimit() {
                        const cardWidth = 250;
                        const columns = Math.floor(container.clientWidth / cardWidth) || 1;
                        return columns * 2;
                }

                /* ================= SKELETON ================= */
                function showSkeletons() {
                        container.innerHTML = "";
                        for (let i = 0; i < getLimit(); i++) {
                                container.appendChild(skeletonTemplate.content.cloneNode(true));
                        }
                }

                /* ================= LOAD PRODUCTS ================= */
                async function loadProducts(page = 1) {
                        showSkeletons();

                        const params = new URLSearchParams({
                                page,
                                limit: getLimit(),
                                search: document.getElementById("searchInput").value.trim() || "",
                                category: selectedCategory,
                                brand: selectedBrands.join(","),
                                sort: currentSort,
                                minPrice: selectedMinPrice,
                                maxPrice: selectedMaxPrice
                        });

                        try {
                                const res = await fetch(`/shop?${params.toString()}`, {
                                        headers: { "Accept": "application/json" }
                                });

                                const data = await res.json();

                                const temp = document.createElement("div");
                                temp.innerHTML = data.cards;
                                container.replaceChildren(...temp.children);

                                document.getElementById("pagination").innerHTML = data.pagination;

                                updateTopBar(data);
                                updateClearButtonState();

                        } catch (err) {
                                container.innerHTML = "<p class='text-center text-red-500'>Error loading</p>";
                        }
                }

                /* ================= TOP BAR ================= */
                function updateTopBar(data) {
                        document.getElementById("currentCount").innerText = data.currentCount;
                        document.getElementById("totalProduct").innerText = data.totalProducts;
                }

                /* ================= CLEAR BUTTON STATE ================= */
                function updateClearButtonState() {
                        const hasFilters =
                                selectedCategory !== "all" ||
                                selectedBrands.length > 0 ||
                                selectedMinPrice !== 0 ||
                                selectedMaxPrice !== 100000 ||
                                document.getElementById("searchInput").value.trim() !== "" ||
                                currentSort !== "newest";

                        document.getElementById("clearFiltersBtn").disabled = !hasFilters;
                }

                /* ================= PAGINATION ================= */
                document.getElementById("pagination").addEventListener("click", (e) => {
                        const link = e.target.closest(".pagination-link");
                        if (link) loadProducts(parseInt(link.dataset.page));
                });

                /* ================= SEARCH ================= */
                let searchTimer;
                document.getElementById("searchInput").addEventListener("input", () => {
                        clearTimeout(searchTimer);
                        searchTimer = setTimeout(() => loadProducts(1), 400);
                });

                /* ================= CATEGORY + BRAND ================= */
                document.querySelector("aside").addEventListener("click", (e) => {
                        const item = e.target.closest(".category-item");
                        const brandItem = e.target.closest(".brand-item");

                        // CATEGORY
                        if (item) {
                                const clickedCategory = item.dataset.category;

                                if (selectedCategory === clickedCategory) {
                                        selectedCategory = "all";
                                        document.querySelectorAll(".category-item")
                                                .forEach(i => i.classList.remove("text-blue-600", "bg-blue-300"));
                                } else {
                                        selectedCategory = clickedCategory;
                                        document.querySelectorAll(".category-item")
                                                .forEach(i => i.classList.remove("text-blue-600", "bg-blue-300"));
                                        item.classList.add("text-blue-600", "bg-blue-300");
                                }

                                loadProducts(1);
                        }

                        // BRAND
                        if (brandItem) {
                                const clickedBrand = brandItem.dataset.brand;
                                const checkbox = brandItem.querySelector(".brand-checkbox");

                                checkbox.checked = !checkbox.checked;

                                if (checkbox.checked) {
                                        selectedBrands.push(clickedBrand);
                                } else {
                                        selectedBrands = selectedBrands.filter(b => b !== clickedBrand);
                                }

                                loadProducts(1);
                        }
                });

                /* ================= SORT ================= */
                document.getElementById("sortSelect").addEventListener("change", (e) => {
                        currentSort = e.target.value;
                        loadProducts(1);
                });

                /* ================= PRICE ================= */
                document.getElementById("minPriceSelect").addEventListener("change", () => {
                        selectedMinPrice = document.getElementById("minPriceSelect").value;
                        updateClearButtonState();
                });

                document.getElementById("maxPriceSelect").addEventListener("change", () => {
                        selectedMaxPrice = document.getElementById("maxPriceSelect").value;
                        updateClearButtonState();
                });

                /* ================= APPLY FILTER ================= */
                function applyFilters() {
                        if (Number(selectedMinPrice) > Number(selectedMaxPrice)) {
                                showToast("Min price cannot be greater than Max price", "warning");
                                return;
                        }
                        loadProducts(1);
                }

                /* ================= CLEAR (TOP BUTTON) ================= */
                document.getElementById("clearFiltersBtn").addEventListener("click", () => {
                        currentSort = "newest";
                        document.getElementById("sortSelect").value = currentSort;
                        loadProducts(1);
                });

                /* ================= CLEAR ALL ================= */
                document.getElementById("clearFiltersBtn1").addEventListener("click", () => {

                        selectedCategory = "all";
                        selectedBrands = [];
                        selectedMinPrice = 0;
                        selectedMaxPrice = 100000;
                        currentSort = "newest";

                        document.querySelectorAll(".category-item")
                                .forEach(i => i.classList.remove("text-blue-600", "bg-blue-300"));

                        document.querySelectorAll(".brand-checkbox")
                                .forEach(cb => cb.checked = false);

                        document.getElementById("minPriceSelect").value = "0";
                        document.getElementById("maxPriceSelect").value = "100000";

                        document.getElementById("sortSelect").value = "newest";
                        document.getElementById("searchInput").value = "";

                        loadProducts(1);

                        showToast("Filters cleared", "success");
                });


                function clearFilters() {
                        selectedCategory = "all";
                        selectedBrands = [];
                        selectedMinPrice = 0;
                        selectedMaxPrice = 100000;
                        currentSort = "newest";

                        document.getElementById("searchInput").value = "";
                        document.getElementById("sortSelect").value = "newest";
                        document.getElementById("minPriceSelect").value = "0";
                        document.getElementById("maxPriceSelect").value = "100000";

                        document.querySelectorAll(".brand-checkbox")
                                .forEach(cb => cb.checked = false);

                        document.querySelectorAll(".category-item")
                                .forEach(i => i.classList.remove("text-blue-600", "bg-blue-300"));

                        loadProducts(1);
                }
                /* ================= INIT ================= */
                document.addEventListener("DOMContentLoaded", () => {
                        loadProducts(1);
                        updateClearButtonState();
                });

        </script>

        <script type="module">
                import { showToast } from "/partials/errorMsg.utils.js";

                function applyFilters() {
                        if (Number(selectedMinPrice) > Number(selectedMaxPrice)) {
                                showToast("Min price cannot be greater than Max price", 'warning');
                                return;
                        }
                        loadProducts(1);
                }

                window.applyFilters = applyFilters;

                document.addEventListener('click', async (e) => {
                        const link = e.target.closest('.wishlist');

                        if (!link) return;

                        if (link.classList.contains("loading")) return;
                        link.classList.add("loading");

                        const variantId = link.dataset.variantId;
                        const productId = link.dataset.productId;

                        try {
                                const res = await fetch('/wishlist', {
                                        method: "POST",
                                        headers: {
                                                'Content-Type': 'application/json',
                                                'Accept': 'application/json'
                                        },
                                        body: JSON.stringify({
                                                productId,
                                                variantId
                                        })
                                });

                                const data = await res.json();

                                if (data.success) {

                                        const icon = link.querySelector("i"); // ✅ target icon

                                        if (data.added) {
                                                icon.classList.remove("fa-regular");
                                                icon.classList.add("fa-solid", "text-red-500"); // ❤️ filled
                                        } else {
                                                icon.classList.remove("fa-solid", "text-red-500");
                                                icon.classList.add("fa-regular"); // 🤍 outline
                                        }

                                        showToast(data.message || "Updated wishlist", "success");
                                        return
                                } else {
                                        showToast(data.message, 'error');
                                        return
                                }

                        } catch (err) {
                                console.error(err);
                                showToast(err.message || "Failed", "error");
                        } finally {
                                link.classList.remove("loading");
                        }
                });

        </script>

        <%- include("../../partials/user/footer.ejs") %>