<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<script src="https://cdn.tailwindcss.com"></script>

<%- include("../../partials/user/header.ejs") %>
        <main class="bg-gray-100 min-h-screen py-6">

                <div class="max-w-7xl mx-auto px-4">

                        <!-- MOBILE FILTER BUTTON -->
                        <button onclick="toggleSidebar()"
                                class="lg:hidden mb-4 w-full bg-blue-600 text-white py-2 rounded-lg">
                                Filters
                        </button>

                        <div class="flex flex-col lg:flex-row gap-6">

                                <!-- ================= SIDEBAR ================= -->
                                <div id="sidebar" class="fixed lg:static top-0 left-0 h-full lg:h-auto w-72 lg:w-1/4 bg-white z-50 
        transform -translate-x-full lg:translate-x-0 transition-transform duration-300 
        rounded-none lg:rounded-xl shadow-lg lg:shadow-sm p-5 overflow-y-auto z-0">

                                        <!-- SEARCH -->
                                        <h3 class="font-semibold text-gray-800 mb-3">SEARCH PRODUCTS</h3>
                                        <input type="text" value="<%= searchQuery || '' %>"
                                                class="w-full border px-3 py-2 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 outline-none"
                                                placeholder="Search for products...">

                                        <!-- CATEGORY -->
                                        <div class="mt-6">
                                                <h3 class="font-semibold text-gray-800 mb-3">CATEGORIES</h3>
                                                <div class="max-h-56 overflow-y-auto space-y-2">
                                                        <% categories.forEach(c=> { %>
                                                                <a href="#" class="flex justify-between text-sm px-2 py-1 rounded hover:bg-gray-100 
                <%= selectedCategory == c._id ? 'bg-blue-50 text-blue-600 font-semibold' : 'text-gray-600' %>">
                                                                        <span>
                                                                                <%= c.title %>
                                                                        </span>
                                                                        <span>(<%= c.productCount %>)</span>
                                                                </a>
                                                                <% }) %>
                                                </div>
                                        </div>

                                        <!-- BRANDS -->
                                        <div class="mt-6">
                                                <h3 class="font-semibold text-gray-800 mb-3">BRANDS</h3>
                                                <div class="max-h-56 overflow-y-auto space-y-2">
                                                        <% brands.forEach(b=> { %>
                                                                <a href="#" class="flex items-center justify-between text-sm px-2 py-1 rounded hover:bg-gray-100 
                <%= selectedBrand == b._id ? 'bg-blue-50 text-blue-600 font-semibold' : 'text-gray-600' %>">

                                                                        <div class="flex items-center gap-2">
                                                                                <img src="<%= b.logo %>"
                                                                                        class="w-5 h-5 object-contain">
                                                                                <span>
                                                                                        <%= b.title %>
                                                                                </span>
                                                                        </div>

                                                                        <span>(<%= b.productCount %>)</span>
                                                                </a>
                                                                <% }) %>
                                                </div>
                                        </div>

                                        <!-- PRICE -->
                                        <div class="mt-6">
                                                <h3 class="font-semibold text-gray-800 mb-3">PRICE</h3>

                                                <div class="flex gap-2">
                                                        <select id="minPriceSelect"
                                                                class="border px-2 py-2 w-full rounded">
                                                                <option value="0">Min</option>
                                                                <option value="500">₹500</option>
                                                                <option value="1000">₹1000</option>
                                                                <option value="5000">₹5000</option>
                                                        </select>

                                                        <select id="maxPriceSelect"
                                                                class="border px-2 py-2 w-full rounded">
                                                                <option value="100000">Max</option>
                                                                <option value="5000">₹5000</option>
                                                                <option value="10000">₹10000</option>
                                                                <option value="50000">₹50000</option>
                                                        </select>
                                                </div>

                                                <button
                                                        class="mt-3 w-full bg-blue-600 hover:bg-blue-700 text-white py-2 rounded-lg">
                                                        Apply
                                                </button>
                                        </div>

                                </div>

                                <!-- ================= PRODUCTS ================= -->
                                <div class="w-full lg:w-3/4">

                                        <!-- TOP BAR -->
                                        <div
                                                class="flex flex-col sm:flex-row justify-between items-center gap-3 mb-4 bg-white p-4 rounded-xl shadow-sm">

                                                <p class="text-sm text-gray-600">
                                                        Showing <%= products.length %> of <%= totalProducts %> products
                                                </p>

                                                <select onchange="location = this.value;"
                                                        class="border px-3 py-2 rounded-lg text-sm focus:ring-2 focus:ring-blue-500">
                                                        <option value="/shop?sort=priceLow">Sort by: Price Low</option>
                                                        <option value="/shop?sort=priceHigh">Sort by: Price High
                                                        </option>
                                                        <option value="/shop?sort=newest">Sort by: Newest</option>
                                                </select>

                                        </div>

                                        <!-- GRID (FINAL FIXED GRID) -->
                                        <div id="productContainer"
                                                class="grid grid-cols-3 md:grid-cols-3 lg:grid-cols-3 xl:grid-cols-4 gap-5">

                                                <%- include("partials/productCards", { products }) %>

                                        </div>

                                        <div id="pagination" class="flex justify-center mt-8">
                                                <%- include("partials/pagination", { currentPage, totalPages }) %>
                                        </div>


                                </div>

                        </div>

                </div>

        </main>


        <%- include("../../partials/user/footer.ejs") %>


        
        <script>
                const container = document.getElementById("productContainer");
                const paginationContainer = document.getElementById("pagination");

                let currentPage = 1;

                // ✅ RESPONSIVE LIMIT
                function getLimit() {
                        const w = window.innerWidth;

                        if (w >= 1280) return 12;   // xl → 4 cols × 3 rows
                        if (w >= 1024) return 8;    // lg → 3 × 3
                        if (w >= 768) return 6;     // md → 3 × 2
                        return 4;                   // mobile
                }

                // ✅ LOAD PRODUCTS
                async function loadProducts(page = 1) {
                        try {
                                const limit = getLimit();

                                const res = await fetch(`/shop?page=${page}&limit=${limit}`, {
                                        headers: { "Accept": "application/json" }
                                });

                                const data = await res.json();

                                container.innerHTML = data.cards;
                                paginationContainer.innerHTML = data.pagination;

                                currentPage = page;

                        } catch (err) {
                                console.error("Error loading products:", err);
                        }
                }

                // ✅ INITIAL LOAD (NO REDIRECT ❌)
                document.addEventListener("DOMContentLoaded", () => {
                        loadProducts(1);
                });

                // ✅ PAGINATION CLICK
                paginationContainer.addEventListener("click", (e) => {
                        const link = e.target.closest(".pagination-link");
                        if (!link) return;

                        e.preventDefault();

                        const page = parseInt(link.dataset.page);
                        loadProducts(page);
                });

                // ✅ AUTO RELOAD ON SCREEN RESIZE
                let resizeTimer;

                window.addEventListener("resize", () => {
                        clearTimeout(resizeTimer);

                        resizeTimer = setTimeout(() => {
                                loadProducts(1); // reload with new limit
                        }, 300);
                });
        </script>