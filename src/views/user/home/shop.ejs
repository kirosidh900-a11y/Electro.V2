<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<script src="https://cdn.tailwindcss.com"></script>

<%- include("../../partials/user/header.ejs") %>

        <style>
                body {
                        font-family: 'Inter', sans-serif;
                }

                img {
                        display: block;
                }

                .custom-scrollbar::-webkit-scrollbar {
                        width: 4px;
                }

                .custom-scrollbar::-webkit-scrollbar-thumb {
                        background: #d1d5db;
                        border-radius: 4px;
                }
        </style>

        <!-- MOBILE FILTER BUTTON -->

        <button onclick="toggleSidebar()"
                class="lg:hidden fixed top-4 left-4 z-[60] bg-blue-600 text-white p-2 rounded shadow"> <i
                        class="fa fa-filter"></i> </button>

        <!-- OVERLAY -->

        <div id="sidebarOverlay" class="fixed inset-0 bg-black/40 hidden z-40" onclick="toggleSidebar()"></div>

        <main class="bg-[#F1F3F6] min-h-screen py-6">
                <div class="max-w-[1280px] mx-auto px-4 flex flex-col lg:flex-row gap-4">


                        <aside id="sidebar" class="fixed lg:static top-0 left-0 h-full lg:h-auto w-[280px] bg-white 
  border-r border-gray-200 p-6 
  z-50  lg:z-0
  transform -translate-x-full lg:translate-x-0 
  transition-transform duration-300 shadow-xl lg:shadow-sm overflow-y-auto">

                                <div class="flex justify-between items-center mb-6 lg:hidden">
                                        <h2 class="font-bold text-lg">Filters</h2>
                                        <button onclick="toggleSidebar()">
                                                <i class="fa fa-times text-xl"></i>
                                        </button>
                                </div>

                                <!-- SEARCH -->
                                <div class="mb-6">
                                        <h3 class="text-xs font-semibold text-gray-500 uppercase mb-2">Search
                                        </h3>
                                        <div class="relative">
                                                <input id="searchInput" placeholder="Search..."
                                                        class="w-full border pl-9 pr-3 py-2 text-sm rounded focus:border-blue-500">
                                                <i
                                                        class="fa fa-search absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-xs"></i>
                                        </div>
                                </div>

                                <!-- CATEGORIES -->
                                <div class="mb-6">
                                        <h3 class="text-xs font-semibold text-gray-500 uppercase mb-3">
                                                Categories</h3>
                                        <ul class="space-y-2 max-h-40 overflow-y-auto custom-scrollbar">
                                                <% categories.forEach(c=> { %>
                                                        <li
                                                                class="flex justify-between text-sm text-gray-600 hover:text-blue-600 cursor-pointer">
                                                                <span>
                                                                        <%= c.title %>
                                                                </span>
                                                                <span class="text-xs text-gray-400">(<%= c.productCount
                                                                                %>)</span>
                                                        </li>
                                                        <% }) %>
                                        </ul>
                                </div>

                                <!-- BRANDS -->
                                <div class="mb-6">
                                        <h3 class="text-xs font-semibold text-gray-500 uppercase mb-3">Brands
                                        </h3>
                                        <div class="space-y-3">
                                                <% brands.forEach(b=> { %>
                                                        <label class="flex items-center gap-3 cursor-pointer">
                                                                <input type="checkbox" class="brand-checkbox w-4 h-4">
                                                                <img src="<%= b.logo %>" class="w-5 h-5 object-contain">
                                                                <span class="text-sm text-gray-600 hover:text-blue-600">
                                                                        <%= b.title %>
                                                                </span>
                                                        </label>
                                                        <% }) %>
                                        </div>
                                </div>

                                <!-- PRICE -->
                                <div class="mb-6">
                                        <h3 class="text-xs font-semibold text-gray-500 uppercase mb-3">Price
                                        </h3>
                                        <div class="flex gap-2">
                                                <input id="minPrice" placeholder="Min"
                                                        class="w-full border p-2 text-sm rounded">
                                                <input id="maxPrice" placeholder="Max"
                                                        class="w-full border p-2 text-sm rounded">
                                        </div>
                                </div>

                                <!-- BUTTONS -->
                                <div class="space-y-2">
                                        <button onclick="applyFilters()"
                                                class="w-full bg-blue-600 text-white py-2 rounded text-sm font-semibold hover:bg-blue-700">
                                                Apply Filters
                                        </button>
                                        <button onclick="window.location='/shop'"
                                                class="w-full border py-2 rounded text-sm hover:bg-gray-50">
                                                Clear All
                                        </button>
                                </div>

                        </aside>

                        <!-- PRODUCTS -->
                        <div class="flex-grow">

                                <!-- TOP BAR -->
                                <div class="bg-white border p-4 mb-4 flex justify-between items-center rounded">
                                        <p class="text-sm text-gray-600">
                                                Showing <span id="currentCount" class="font-bold">0</span>
                                                products
                                        </p>

                                        <select id="sortSelect" class="border p-2 text-sm rounded">
                                                <option value="newest">Relevance</option>
                                                <option value="priceLow">Price: Low to High</option>
                                                <option value="priceHigh">Price: High to Low</option>
                                        </select>
                                </div>

                                <!-- GRID -->
                                <div id="productContainer" class="grid gap-4"
                                        style="grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));">
                                </div>

                                <!-- PAGINATION -->
                                <div id="pagination" class="flex justify-center mt-10"></div>

                        </div>
                        ```

                </div>
        </main>

        <!-- SKELETON -->

        <template id="skeleton-card">
                <div class="bg-white border rounded animate-pulse">
                        <div class="h-56 bg-gray-200"></div>
                        <div class="p-4">
                                <div class="h-4 bg-gray-200 mb-2"></div>
                                <div class="h-4 bg-gray-200 w-2/3"></div>
                        </div>
                </div>
        </template>

        <script>
                const container = document.getElementById("productContainer");
                const skeletonTemplate = document.getElementById("skeleton-card");

                // SIDEBAR
                function toggleSidebar() {
                        const sidebar = document.getElementById("sidebar");
                        const overlay = document.getElementById("sidebarOverlay");

                        sidebar.classList.toggle("-translate-x-full");
                        overlay.classList.toggle("hidden");
                }

                // FIX DESKTOP
                window.addEventListener("resize", () => {
                        if (window.innerWidth >= 1024) {
                                document.getElementById("sidebar").classList.remove("-translate-x-full");
                                document.getElementById("sidebarOverlay").classList.add("hidden");
                        }
                });

                // LIMIT
                function getLimit() {
                        const cardWidth = 250;
                        const columns = Math.floor(container.clientWidth / cardWidth) || 1;
                        return columns * 2;
                }

                // SKELETON
                function showSkeletons() {
                        container.innerHTML = "";
                        for (let i = 0; i < getLimit(); i++) {
                                container.appendChild(skeletonTemplate.content.cloneNode(true));
                        }
                }

                // LOAD PRODUCTS
                async function loadProducts(page = 1) {
                        showSkeletons();

                        const params = new URLSearchParams({
                                page,
                                limit: getLimit(),
                                search: document.getElementById("searchInput").value.trim() || ""
                        });

                        try {
                                const res = await fetch(`/shop?${params.toString()}`, {
                                        headers: { "Accept": "application/json" }
                                });

                                const data = await res.json();

                                const temp = document.createElement("div");
                                temp.innerHTML = data.cards;
                                container.replaceChildren(...temp.children);

                                document.getElementById("pagination").innerHTML = data.pagination;
                                document.getElementById("currentCount").innerText = data.currentCount;

                        } catch (err) {
                                container.innerHTML = "<p class='text-center text-red-500'>Error loading</p>";
                        }
                }

                // FILTER
                function applyFilters() {
                        loadProducts(1);
                }

                // PAGINATION
                document.getElementById("pagination").addEventListener("click", (e) => {
                        const link = e.target.closest(".pagination-link");
                        if (link) {
                                loadProducts(parseInt(link.dataset.page));
                        }
                });


                let searchTimer;
                document.getElementById("searchInput").addEventListener("input", () => {
                        clearTimeout(searchTimer);

                        searchTimer = setTimeout(() => {
                                loadProducts(1); // reload with search
                        }, 400); // debounce
                });

                // INIT
                document.addEventListener("DOMContentLoaded", () => {
                        loadProducts(1);
                        window.addEventListener("resize", () => {
                                if (window.innerWidth >= 1024) {
                                        document.getElementById("sidebar").classList.remove("-translate-x-full");
                                        document.getElementById("sidebarOverlay").classList.add("hidden");
                                }
                        });

                });
        </script>

        <%- include("../../partials/user/footer.ejs") %>