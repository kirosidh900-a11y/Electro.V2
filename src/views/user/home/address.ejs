<script src="https://cdn.tailwindcss.com"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<%- include("../../partials/user/header") %>

        <main class="min-h-screen bg-gray-50 py-10">
                <div class="max-w-7xl mx-auto px-4 lg:px-8">
                        <div class="flex flex-col lg:flex-row gap-8">


                                <%- include("./partials/profileSidebar") %>


                                        <section class="flex-grow">
                                                <div
                                                        class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 mb-8">
                                                        <div
                                                                class="flex justify-between items-center border-b border-gray-100 pb-5 mb-6">
                                                                <div>
                                                                        <h2 class="text-2xl font-bold text-gray-800">My
                                                                                Addresses</h2>
                                                                        <p class="text-sm text-gray-500 mt-1">Manage
                                                                                your shipping and billing locations</p>
                                                                </div>
                                                                <button onclick="openAddressModal()"
                                                                        class="hidden md:flex items-center gap-2 bg-red-500 hover:bg-red-600 text-white px-5 py-2.5 rounded-xl transition-all shadow-md shadow-red-100">
                                                                        <i class="fa fa-plus-circle"></i>
                                                                        <span class="font-medium">Add New Address</span>
                                                                </button>
                                                        </div>

                                                        <div
                                                                class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">

                                                                <div onclick="openAddressModal()"
                                                                        class="group border-2 border-dashed border-gray-200 rounded-2xl p-6 flex flex-col items-center justify-center text-center cursor-pointer hover:border-red-400 hover:bg-red-50 transition-all min-h-[200px] h-full">
                                                                        <div
                                                                                class="w-12 h-12 bg-gray-50 group-hover:bg-red-100 rounded-full flex items-center justify-center mb-3 transition-colors">
                                                                                <i
                                                                                        class="fa fa-plus text-gray-400 group-hover:text-red-500 text-lg"></i>
                                                                        </div>
                                                                        <h3
                                                                                class="font-semibold text-gray-700 group-hover:text-red-600">
                                                                                Add New Address</h3>
                                                                        <p class="text-xs text-gray-400 mt-1 px-4">Save
                                                                                a new location for faster checkout</p>
                                                                </div>

                                                                <% if (addresses && addresses.length> 0) { %>
                                                                        <% addresses.forEach((addr)=> { %>
                                                                                <div
                                                                                        class="relative bg-white border border-gray-200 rounded-2xl p-5 hover:shadow-lg hover:border-red-200 transition-all group flex flex-col justify-between min-h-[200px] h-full">
                                                                                        <div>
                                                                                                <div
                                                                                                        class="flex justify-between items-start mb-4">
                                                                                                        <span
                                                                                                                class="px-3 py-1 bg-red-50 text-red-600 text-[10px] font-bold rounded-full uppercase tracking-wider">
                                                                                                                <i
                                                                                                                        class="fa <%= addr.addressType === 'Home' ? 'fa-home' : 'fa-briefcase' %> mr-1"></i>
                                                                                                                <%= addr.addressType
                                                                                                                        %>
                                                                                                        </span>
                                                                                                        <div
                                                                                                                class="flex gap-2">
                                                                                                                <button onclick="openAddressModal('<%= encodeURIComponent(JSON.stringify(addr)) %>')"
                                                                                                                        class="text-gray-400 hover:text-blue-600 transition-colors p-1">
                                                                                                                        <i
                                                                                                                                class="fa fa-pen-to-square"></i>
                                                                                                                </button>
                                                                                                                <button onclick="deleteAddress('<%= addr._id %>')"
                                                                                                                        class="text-gray-400 hover:text-red-600 transition-colors p-1">
                                                                                                                        <i
                                                                                                                                class="fa fa-trash-can"></i>
                                                                                                                </button>
                                                                                                        </div>
                                                                                                </div>

                                                                                                <h3
                                                                                                        class="font-bold text-gray-800 text-lg mb-2 truncate">
                                                                                                        <%= addr.name %>
                                                                                                </h3>

                                                                                                <div
                                                                                                        class="space-y-1.5 text-sm text-gray-600">
                                                                                                        <p
                                                                                                                class="truncate">
                                                                                                                <i
                                                                                                                        class="fa fa-location-dot text-gray-400 w-5 text-center"></i>
                                                                                                                <%= addr.city
                                                                                                                        %>
                                                                                                                        ,
                                                                                                                        <%= addr.district
                                                                                                                                %>
                                                                                                        </p>
                                                                                                        <p
                                                                                                                class="ml-5 text-gray-500 text-xs">
                                                                                                                <%= addr.state
                                                                                                                        %>
                                                                                                                        -
                                                                                                                        <span
                                                                                                                                class="font-mono text-gray-800 font-medium">
                                                                                                                                <%= addr.pincode
                                                                                                                                        %>
                                                                                                                        </span>
                                                                                                        </p>
                                                                                                </div>
                                                                                        </div>

                                                                                        <div
                                                                                                class="mt-4 pt-3 border-t border-gray-50">
                                                                                                <p
                                                                                                        class="text-sm text-gray-700 font-medium">
                                                                                                        <i
                                                                                                                class="fa fa-phone text-gray-400 w-5 text-center"></i>
                                                                                                        <%= addr.phone
                                                                                                                %>
                                                                                                </p>
                                                                                        </div>
                                                                                </div>
                                                                                <% }) %>
                                                                                        <% } %>

                                                        </div>
                                                </div>
                                        </section>
                        </div>
                </div>
        </main>

        <div id="addressModal"
                class="fixed inset-0 bg-black bg-opacity-50 hidden z-50 flex items-center justify-center p-4">
                <div class="bg-white rounded-xl shadow-xl w-full max-w-2xl overflow-hidden">
                        <div class="p-6 border-b flex justify-between items-center">
                                <h3 class="text-xl font-bold text-gray-800">Address Details</h3>
                                <button onclick="closeAddressModal()"
                                        class="text-gray-400 hover:text-gray-600">&times;</button>
                        </div>

                        <form id="addressForm" class="p-6">
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

                                        <div class="col-span-1">
                                                <label class="block text-xs font-bold text-gray-500 uppercase mb-1">Full Name *</label>
                                                <input name="name" type="text" autocomplete="off"
                                                        class="addr-input w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-red-500 outline-none transition-colors">
                                                <span class="field-err hidden text-red-500 text-xs mt-1 flex items-center gap-1"><i class="fa fa-circle-exclamation text-[10px]"></i><span class="err-text"></span></span>
                                        </div>

                                        <div class="col-span-1">
                                                <label class="block text-xs font-bold text-gray-500 uppercase mb-1">Phone Number *</label>
                                                <input name="phone" type="text" maxlength="10" autocomplete="off"
                                                        class="addr-input w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-red-500 outline-none transition-colors">
                                                <span class="field-err hidden text-red-500 text-xs mt-1 flex items-center gap-1"><i class="fa fa-circle-exclamation text-[10px]"></i><span class="err-text"></span></span>
                                        </div>

                                        <div class="col-span-1">
                                                <label class="block text-xs font-bold text-gray-500 uppercase mb-1">Pincode *</label>
                                                <input name="pincode" type="text" maxlength="6" autocomplete="off"
                                                        class="addr-input w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-red-500 outline-none transition-colors">
                                                <span class="field-err hidden text-red-500 text-xs mt-1 flex items-center gap-1"><i class="fa fa-circle-exclamation text-[10px]"></i><span class="err-text"></span></span>
                                        </div>

                                        <div class="col-span-1">
                                                <label class="block text-xs font-bold text-gray-500 uppercase mb-1">Locality *</label>
                                                <input name="locality" type="text" autocomplete="off"
                                                        class="addr-input w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-red-500 outline-none transition-colors">
                                                <span class="field-err hidden text-red-500 text-xs mt-1 flex items-center gap-1"><i class="fa fa-circle-exclamation text-[10px]"></i><span class="err-text"></span></span>
                                        </div>

                                        <div class="col-span-2">
                                                <label class="block text-xs font-bold text-gray-500 uppercase mb-1">Address (Area and Street) *</label>
                                                <textarea name="address" rows="3"
                                                        class="addr-input w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-red-500 outline-none transition-colors"></textarea>
                                                <span class="field-err hidden text-red-500 text-xs mt-1 flex items-center gap-1"><i class="fa fa-circle-exclamation text-[10px]"></i><span class="err-text"></span></span>
                                        </div>

                                        <div class="col-span-1">
                                                <label class="block text-xs font-bold text-gray-500 uppercase mb-1">City / Town *</label>
                                                <input name="city" type="text" autocomplete="off"
                                                        class="addr-input w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-red-500 outline-none transition-colors">
                                                <span class="field-err hidden text-red-500 text-xs mt-1 flex items-center gap-1"><i class="fa fa-circle-exclamation text-[10px]"></i><span class="err-text"></span></span>
                                        </div>

                                        <div class="col-span-1">
                                                <label class="block text-xs font-bold text-gray-500 uppercase mb-1">State *</label>
                                                <select name="state"
                                                        class="addr-input w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-red-500 outline-none transition-colors"></select>
                                                <span class="field-err hidden text-red-500 text-xs mt-1 flex items-center gap-1"><i class="fa fa-circle-exclamation text-[10px]"></i><span class="err-text"></span></span>
                                        </div>

                                        <div class="col-span-1">
                                                <label class="block text-xs font-bold text-gray-500 uppercase mb-1">District *</label>
                                                <select name="district"
                                                        class="addr-input w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-red-500 outline-none transition-colors"></select>
                                                <span class="field-err hidden text-red-500 text-xs mt-1 flex items-center gap-1"><i class="fa fa-circle-exclamation text-[10px]"></i><span class="err-text"></span></span>
                                        </div>

                                        <div class="col-span-1">
                                                <label class="block text-xs font-bold text-gray-500 uppercase mb-1">Landmark <span class="text-gray-400 normal-case font-normal">(Optional)</span></label>
                                                <input name="landmark" type="text" autocomplete="off"
                                                        class="addr-input w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-red-500 outline-none transition-colors">
                                        </div>

                                        <div class="col-span-1">
                                                <label class="block text-xs font-bold text-gray-500 uppercase mb-1">Alternate Phone <span class="text-gray-400 normal-case font-normal">(Optional)</span></label>
                                                <input name="altPhone" type="text" maxlength="10" autocomplete="off"
                                                        class="addr-input w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-red-500 outline-none transition-colors">
                                                <span class="field-err hidden text-red-500 text-xs mt-1 flex items-center gap-1"><i class="fa fa-circle-exclamation text-[10px]"></i><span class="err-text"></span></span>
                                        </div>

                                        <div class="col-span-1">
                                                <label class="block text-xs font-bold text-gray-500 uppercase mb-2">Address Type</label>
                                                <div class="flex gap-4">
                                                        <label class="flex items-center gap-2 cursor-pointer">
                                                                <input type="radio" name="addressType" value="home" checked> Home
                                                        </label>
                                                        <label class="flex items-center gap-2 cursor-pointer">
                                                                <input type="radio" name="addressType" value="work"> Work
                                                        </label>
                                                </div>
                                        </div>

                                        <div class="col-span-1 flex items-end">
                                                <label class="flex items-center gap-2 cursor-pointer">
                                                        <input name="isDefault" type="checkbox"
                                                                class="w-4 h-4 text-red-600 border-gray-300 rounded focus:ring-red-500">
                                                        <span class="text-sm font-medium text-gray-700">Set as default address</span>
                                                </label>
                                        </div>
                                </div>

                                <div class="mt-8 flex justify-end gap-3">
                                        <button type="button" onclick="closeAddressModal()"
                                                class="px-6 py-2 bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200">Cancel</button>
                                        <button type="submit"
                                                class="px-6 py-2 bg-red-500 text-white rounded-lg hover:bg-red-600 transition">Save Address</button>
                                </div>
                        </form>
                </div>
        </div>

        <%- include("../../partials/user/footer") %>

                <script type="module">
                        import { showToast } from "/partials/errorMsg.utils.js";
                        import { confirmAction } from "/partials/confirm.util.js";

                        // Store states
                        let statesData = [];

                        // LOAD STATES
                        async function loadStates() {
                                try {
                                        const res = await fetch('/location/states');
                                        statesData = await res.json();
                                } catch (err) {
                                        console.error("States fetch failed", err);
                                }
                        }
                        loadStates();

                        // LOAD DISTRICTS
                        async function loadDistricts(stateCode) {
                                try {
                                        const res = await fetch(`/location/districts/${stateCode}`);
                                        return await res.json();
                                } catch (err) {
                                        console.error("District fetch failed", err);
                                        return [];
                                }
                        }

                        // OPEN MODAL
                        window.openAddressModal = async function (addressJson = null) {
                                const addr = addressJson ? JSON.parse(decodeURIComponent(addressJson)) : {};
                                const isEdit = !!addr._id;

                                const modal = document.getElementById('addressModal');
                                const form = document.getElementById('addressForm');

                                // Clear all field errors on open
                                document.querySelectorAll('#addressForm .field-err').forEach(span => {
                                        span.classList.add('hidden');
                                        const et = span.querySelector('.err-text');
                                        if (et) et.textContent = '';
                                });
                                document.querySelectorAll('#addressForm .addr-input').forEach(el => el.classList.remove('border-red-400'));

                                modal.classList.remove('hidden');

                                // Fill basic fields
                                form.name.value = addr.name || '';
                                form.phone.value = addr.phone || '';
                                form.altPhone.value = addr.altPhone || '';
                                form.pincode.value = addr.pincode || '';
                                form.locality.value = addr.locality || '';
                                form.address.value = addr.address || '';
                                form.city.value = addr.city || '';
                                form.landmark.value = addr.landmark || '';
                                form.addressType.value = addr.addressType || 'home';
                                form.isDefault.checked = addr.isDefault || false;


                                const stateSelect = form.state;
                                const districtSelect = form.district;

                                // LOAD STATES DROPDOWN
                                stateSelect.innerHTML =
                                        '<option value="">Select State</option>' +
                                        statesData.map(s => `
            <option value="${s.isoCode}" ${s.isoCode === addr.stateCode ? 'selected' : ''}>
                ${s.name}
            </option>
        `).join('');

                                // LOAD DISTRICTS (EDIT MODE)
                                if (addr.stateCode) {
                                        const districts = await loadDistricts(addr.stateCode);

                                        districtSelect.innerHTML =
                                                '<option value="">Select District</option>' +
                                                districts.map(d => `
                <option value="${d}" ${d === addr.district ? 'selected' : ''}>
                    ${d}
                </option>
            `).join('');
                                } else {
                                        districtSelect.innerHTML = '<option value="">Select District</option>';
                                }

                                // STATE CHANGE → DISTRICTS
                                stateSelect.onchange = async () => {
                                        const stateCode = stateSelect.value;

                                        if (!stateCode) {
                                                districtSelect.innerHTML = '<option value="">Select District</option>';
                                                return;
                                        }

                                        const districts = await loadDistricts(stateCode);

                                        districtSelect.innerHTML =
                                                '<option value="">Select District</option>' +
                                                districts.map(d => `<option value="${d}">${d}</option>`).join('');
                                };

                                // SUBMIT FORM
                                form.onsubmit = async (e) => {
                                        e.preventDefault();

                                        //  VALIDATE FIRST
                                        if (!validateForm(form, stateSelect, districtSelect)) return;

                                        const formData = {
                                                name: form.name.value.trim(),
                                                phone: form.phone.value.trim(),
                                                altPhone: form.altPhone.value.trim() || null,
                                                pincode: form.pincode.value.trim(),
                                                locality: form.locality.value.trim(),
                                                address: form.address.value.trim(),
                                                city: form.city.value.trim(),

                                                // 🔥 IMPORTANT FIXa
                                                state: stateSelect.options[stateSelect.selectedIndex].text,
                                                stateCode: stateSelect.value,
                                                district: districtSelect.value,

                                                landmark: form.landmark.value.trim() || null,
                                                addressType: form.addressType.value,
                                                isDefault: form.isDefault.checked
                                        };

                                        try {
                                                const url = isEdit ? `/address/${addr._id}` : '/address';
                                                const method = isEdit ? 'PUT' : 'POST';

                                                const res = await fetch(url, {
                                                        method,
                                                        headers: {
                                                                "Content-Type": "application/json",
                                                                "Accept": "application/json"
                                                        },
                                                        body: JSON.stringify(formData)
                                                });

                                                const result = await res.json();

                                                if (!res.ok) throw new Error(result.message || "Failed to save address");

                                                showToast(result.message || "Address saved successfully", "success");
                                                setTimeout(() => location.reload(), 1000);

                                        } catch (error) {
                                                showToast(error.message, "error");
                                        }
                                };

                        };
                       
                        // ── Auto-format: digits only for phone/pincode ────────────────────────
                        document.addEventListener("input", (e) => {
                                const name = e.target.name;
                                if (name === "phone" || name === "altPhone") {
                                        e.target.value = e.target.value.replace(/\D/g, "").slice(0, 10);
                                }
                                if (name === "pincode") {
                                        e.target.value = e.target.value.replace(/\D/g, "").slice(0, 6);
                                }
                                // Clear error as user types
                                clearFieldErr(e.target);
                        });

                        // ── Blur validation — validate field when user leaves it ───────────────
                        document.addEventListener("blur", (e) => {
                                const el = e.target;
                                if (!el.closest('#addressForm')) return;
                                const rule = RULES[el.name];
                                if (rule) {
                                        const msg = rule(el.value.trim());
                                        if (msg) showFieldErr(el, msg);
                                        else clearFieldErr(el);
                                }
                        }, true);

                        // ── Validation rules ──────────────────────────────────────────────────
                        const RULES = {
                                name: (v) => {
                                        if (!v)                              return "Full name is required";
                                        if (v.length < 3)                    return "Name must be at least 3 characters";
                                        if (v.length > 60)                   return "Name cannot exceed 60 characters";
                                        if (!/^[A-Za-z\s.'\-]+$/.test(v))   return "Name can only contain letters, spaces, dots and hyphens";
                                        return null;
                                },
                                phone: (v) => {
                                        if (!v)                              return "Phone number is required";
                                        if (!/^[6-9]\d{9}$/.test(v))        return "Enter a valid 10-digit mobile number (starts with 6–9)";
                                        return null;
                                },
                                altPhone: (v) => {
                                        if (!v) return null; // optional
                                        if (!/^[6-9]\d{9}$/.test(v))        return "Alternate phone must be a valid 10-digit mobile number";
                                        return null;
                                },
                                pincode: (v) => {
                                        if (!v)                              return "Pincode is required";
                                        if (!/^[1-9][0-9]{5}$/.test(v))     return "Enter a valid 6-digit pincode (cannot start with 0)";
                                        return null;
                                },
                                locality: (v) => {
                                        if (!v)                              return "Locality / area is required";
                                        if (v.length < 3)                    return "Locality must be at least 3 characters";
                                        if (v.length > 100)                  return "Locality cannot exceed 100 characters";
                                        return null;
                                },
                                address: (v) => {
                                        if (!v)                              return "Street address is required";
                                        if (v.length < 5)                    return "Address is too short (min 5 characters)";
                                        if (v.length > 200)                  return "Address cannot exceed 200 characters";
                                        return null;
                                },
                                city: (v) => {
                                        if (!v)                              return "City / town is required";
                                        if (v.length < 2)                    return "City name must be at least 2 characters";
                                        if (!/^[A-Za-z\s.'\-]+$/.test(v))   return "City name can only contain letters, spaces, dots and hyphens";
                                        return null;
                                },
                        };

                        // ── Show / clear inline error ─────────────────────────────────────────
                        function showFieldErr(el, msg) {
                                el.classList.add("border-red-400");
                                el.classList.remove("border-gray-300", "border-green-400");
                                const span = el.parentNode.querySelector(".field-err");
                                if (span) {
                                        span.classList.remove("hidden");
                                        span.querySelector(".err-text").textContent = msg;
                                }
                        }

                        function clearFieldErr(el) {
                                el.classList.remove("border-red-400");
                                const span = el.parentNode.querySelector(".field-err");
                                if (span) {
                                        span.classList.add("hidden");
                                        span.querySelector(".err-text").textContent = "";
                                }
                        }

                        function showSelectErr(selectEl, msg) {
                                selectEl.classList.add("border-red-400");
                                const span = selectEl.parentNode.querySelector(".field-err");
                                if (span) {
                                        span.classList.remove("hidden");
                                        span.querySelector(".err-text").textContent = msg;
                                }
                        }

                        function clearSelectErr(selectEl) {
                                selectEl.classList.remove("border-red-400");
                                const span = selectEl.parentNode.querySelector(".field-err");
                                if (span) {
                                        span.classList.add("hidden");
                                        if (span.querySelector(".err-text")) span.querySelector(".err-text").textContent = "";
                                }
                        }

                        // ── Full form validation — shows ALL errors at once ───────────────────
                        function validateForm(form, stateSelect, districtSelect) {
                                let isValid = true;

                                // Clear all errors first
                                form.querySelectorAll('.addr-input').forEach(clearFieldErr);
                                clearSelectErr(stateSelect);
                                clearSelectErr(districtSelect);

                                // Validate each field
                                Object.entries(RULES).forEach(([fieldName, rule]) => {
                                        const el = form[fieldName];
                                        if (!el) return;
                                        const msg = rule(el.value.trim());
                                        if (msg) {
                                                showFieldErr(el, msg);
                                                isValid = false;
                                        }
                                });

                                // State
                                if (!stateSelect.value) {
                                        showSelectErr(stateSelect, "Please select a state");
                                        isValid = false;
                                }

                                // District
                                if (!districtSelect.value) {
                                        showSelectErr(districtSelect, "Please select a district");
                                        isValid = false;
                                }

                                // Scroll to first error
                                if (!isValid) {
                                        const firstErr = form.querySelector('.border-red-400');
                                        if (firstErr) firstErr.scrollIntoView({ behavior: 'smooth', block: 'center' });
                                }

                                return isValid;
                        }
                        // DELETE ADDRESS
                        window.deleteAddress = async function (id) {
                                const confirmed = await confirmAction("Delete Address?", "This action cannot be undone.");
                                if (confirmed) {
                                        try {
                                                const res = await fetch(`/address/${id}`, {
                                                        method: 'DELETE',
                                                        headers: { "Accept": "application/json" }
                                                });
                                                const data = await res.json();
                                                if (res.ok) location.reload();
                                                else throw new Error(data.message);
                                        } catch (error) {
                                                showToast(error.message, "error");
                                        }
                                }
                        };

                        // CLOSE MODAL
                        window.closeAddressModal = () => {
                                document.querySelectorAll('.field-err').forEach(span => {
                                        span.classList.add('hidden');
                                        if (span.querySelector('.err-text')) span.querySelector('.err-text').textContent = '';
                                });
                                document.querySelectorAll('.addr-input').forEach(el => el.classList.remove('border-red-400'));
                                document.getElementById('addressModal').classList.add('hidden');
                        };

                </script>