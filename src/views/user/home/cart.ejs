<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<script src="https://cdn.tailwindcss.com"></script>

<%- include("../../partials/user/header.ejs") %>

    <style>
        body {
            font-family: 'Outfit', sans-serif;
            background-color: #f9fafb;
        }

        .custom-scrollbar::-webkit-scrollbar {
            width: 4px;
        }

        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: #d1d5db;
            border-radius: 4px;
        }

        .loading {
            pointer-events: none;
            opacity: 0.5;
            filter: grayscale(1);
        }

        /* Smooth transitions */
        .cart-item {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
    </style>

    <main class="min-h-screen py-10">
        <div class="max-w-[1280px] mx-auto px-4 sm:px-6 lg:px-8">

            <!-- Cart Header -->
            <div class="flex flex-col sm:flex-row sm:items-end justify-between mb-8 sm:mb-10 gap-4">
                <div>
                    <h1 class="text-3xl font-bold text-gray-900 tracking-tight">Your Cart</h1>
                    <p class="text-gray-500 mt-2">You have <span id="cartCountHeader" class="font-medium text-gray-900">
                            <%= cart.items?.length || 0 %>
                        </span> items</span> in your cart</p>
                </div>
                <a href="/shop"
                    class="inline-flex items-center gap-2 text-sm font-medium text-gray-600 hover:text-black transition-colors bg-white px-5 py-2.5 rounded-full border shadow-sm hover:shadow">
                    <i class="fa-solid fa-arrow-left"></i> Continue Shopping
                </a>
            </div>

            <div class="flex flex-col lg:flex-row gap-10">

                <!-- Left Side: Cart Items -->
                <div class="lg:w-2/3 flex flex-col gap-6">

                    <!-- Empty Cart State (Hidden by default) -->
                    <div id="emptyCartState"
                        class="hidden bg-white rounded-2xl shadow-sm border border-gray-100 p-16 flex flex-col items-center justify-center text-center">
                        <div class="w-24 h-24 mb-6 relative">
                            <div class="absolute inset-0 bg-blue-100 rounded-full animate-ping opacity-20"></div>
                            <div
                                class="relative w-full h-full bg-blue-50 text-blue-600 rounded-full flex items-center justify-center text-4xl shadow-inner">
                                <i class="fa-solid fa-basket-shopping"></i>
                            </div>
                        </div>
                        <h2 class="text-2xl font-bold text-gray-900 mb-3">Your cart is feeling lonely</h2>
                        <p class="text-gray-500 mb-8 max-w-md mx-auto">Discover amazing products and fill your cart with
                            joy. We have tons of exclusive items waiting for you.</p>
                        <a href="/shop"
                            class="bg-black text-white px-8 py-3.5 rounded-full font-medium hover:bg-gray-800 hover:-translate-y-0.5 transition-all shadow-lg hover:shadow-xl">
                            Start Shopping Now
                        </a>
                    </div>

                    <!-- Products Container -->
                    <div id="cartItemsContainer" class="flex flex-col gap-5">

                        <% if (typeof cart !=='undefined' && cart && cart.items && cart.items.length> 0) { %>
                            <% cart.items.forEach(item=> { %>
                                <div class="bg-white p-5 sm:p-6 rounded-2xl shadow-sm border border-gray-100 flex flex-col sm:flex-row gap-6 cart-item hover:shadow-md"
                                    data-item-id="<%= item._id %>" data-stock="<%= item.variantId?.stock %>"
                                    data-product-id="<%= item.productId?._id %>"
                                    data-variant-id="<%= item.variantId?._id %>">

                                    <!-- Product Image -->
                                    <a href="/product/<%= item.productId?._id %>"
                                        class="relative shrink-0 w-28 h-28 sm:w-36 sm:h-36 bg-[#f8f9fa] rounded-xl flex items-center justify-center overflow-hidden group border border-gray-50">
                                        <img src="<%= item?.variantId?.images?.[0] || item?.variantId?.product_images?.[0]?.url || '/images/default.png' %>"
                                            alt="<%= item?.productId?.name || 'Product' %>"
                                            class="w-full h-full object-contain p-3 group-hover:scale-110 transition-transform duration-500 mix-blend-multiply">
                                        <% if (item.variantId?.stock===0) { %>
                                            <div
                                                class="absolute sold-out-badge inset-x-0 bottom-0 bg-red-500/90 py-1.5 backdrop-blur-sm flex justify-center">
                                                <span
                                                    class=" text-white text-[10px] font-bold tracking-widest uppercase">
                                                    Sold Out
                                                </span>
                                            </div>
                                            <% } else if (item.variantId?.stock> 0 && item.variantId?.stock <= 5) { %>
                                                    <div
                                                        class="few-left-badge absolute top-2 left-2 bg-orange-100 text-orange-700 px-2 py-0.5 rounded-md text-[10px] font-bold shadow-sm">
                                                        Few Left
                                                    </div>
                                                    <% } %>
                                    </a>

                                    <!-- Product Info -->
                                    <div class="flex-grow flex flex-col justify-between pt-1">

                                        <!-- Top -->
                                        <div class="flex flex-col sm:flex-row justify-between gap-4">

                                            <div class="flex-1 pr-4">
                                                <!-- Brand: Only output if name exists to prevent undefined -->
                                                <% if (item.productId?.brand?.name) { %>
                                                    <p
                                                        class="text-[11px] font-bold text-gray-400 uppercase tracking-widest mb-1.5">
                                                        <%= item.productId.brand.name %>
                                                    </p>
                                                    <% } %>

                                                        <!-- Title -->
                                                        <a href="/product/<%= item.productId?._id %>"
                                                            class="text-base sm:text-lg font-semibold text-gray-900 hover:text-blue-600 transition-colors line-clamp-2 leading-snug">
                                                            <%= item.productId?.name %>
                                                        </a>

                                                        <!-- Nested Attributes mapped from item.variantId.attributes -->
                                                        <div class="flex flex-wrap items-center gap-2 mt-3">
                                                            <% if (item.variantId?.attributes?.color) { %>
                                                                <div
                                                                    class="bg-gray-50 px-2.5 py-1 rounded-md text-xs font-medium text-gray-600 border border-gray-100">
                                                                    <span class="text-gray-400">Color:</span>
                                                                    <%= item.variantId.attributes.color %>
                                                                </div>
                                                                <% } %>
                                                                    <% if (item.variantId?.attributes?.ram) { %>
                                                                        <div
                                                                            class="bg-gray-50 px-2.5 py-1 rounded-md text-xs font-medium text-gray-600 border border-gray-100">
                                                                            <span class="text-gray-400">RAM:</span>
                                                                            <%= item.variantId.attributes.ram %>
                                                                        </div>
                                                                        <% } %>
                                                                            <% if (item.variantId?.attributes?.rom) { %>
                                                                                <div
                                                                                    class="bg-gray-50 px-2.5 py-1 rounded-md text-xs font-medium text-gray-600 border border-gray-100">
                                                                                    <span
                                                                                        class="text-gray-400">Storage:</span>
                                                                                    <%= item.variantId.attributes.rom %>
                                                                                </div>
                                                                                <% } %>
                                                                                    <% if
                                                                                        (item.variantId?.attributes?.processor)
                                                                                        { %>
                                                                                        <div class="bg-gray-50 px-2.5 py-1 rounded-md text-xs font-medium text-gray-600 border border-gray-100 max-w-[200px] truncate"
                                                                                            title="<%= item.variantId.attributes.processor %>">
                                                                                            <span
                                                                                                class="text-gray-400">CPU:</span>
                                                                                            <%= item.variantId.attributes.processor
                                                                                                %>
                                                                                        </div>
                                                                                        <% } %>
                                                                                            <% if
                                                                                                (item.variantId?.attributes?.size)
                                                                                                { %>
                                                                                                <div
                                                                                                    class="bg-gray-50 px-2.5 py-1 rounded-md text-xs font-medium text-gray-600 border border-gray-100">
                                                                                                    <span
                                                                                                        class="text-gray-400">Size:</span>
                                                                                                    <%= item.variantId.attributes.size
                                                                                                        %>
                                                                                                </div>
                                                                                                <% } %>
                                                        </div>

                                                        <!-- Stock Status Text -->
                                                        <div class="mt-3 text-xs">
                                                            <% if (item.variantId?.stock> 0 && item.variantId?.stock <=
                                                                    5) { %>
                                                                    <span
                                                                        class="text-orange-600 font-medium bg-orange-50 px-2.5 py-1 rounded border border-orange-100">Only
                                                                        <%= item.variantId.stock %> left in stock
                                                                    </span>
                                                                    <% } else if (item.variantId?.stock> 5) { %>
                                                                        <span
                                                                            class="text-green-600 font-medium bg-green-50 px-2.5 py-1 rounded border border-green-100"><i
                                                                                class="fa-solid fa-check text-[10px] mr-1"></i>In
                                                                            Stock</span>
                                                                        <% } else { %>
                                                                            <span
                                                                                class="text-red-600 font-medium bg-red-50 px-2.5 py-1 rounded border border-red-100">Out
                                                                                of Stock</span>
                                                                            <% } %>
                                                        </div>
                                            </div>

                                            <!-- Price -->
                                            <div class="text-left sm:text-right shrink-0 mt-4 sm:mt-0">
                                                <% const price=item.variantId?.regular_price || 0; const
                                                    finalPrice=item.variantId?.finalPrice ?? price; const savings=(price
                                                    - finalPrice); const discount=price> 0
                                                    ? Math.round((savings / price) * 100)
                                                    : 0;
                                                    %>

                                                    <div class="flex flex-col gap-1">

                                                        <!-- PRICE ROW -->
                                                        <div class="flex items-center gap-2 flex-wrap">

                                                            <!-- FINAL PRICE -->
                                                            <span
                                                                class="text-2xl font-bold text-gray-900 tracking-tight">
                                                                ₹<span class="item-price">
                                                                    <%= finalPrice.toLocaleString('en-IN') %>
                                                                </span>
                                                            </span>

                                                            <!-- ORIGINAL PRICE -->
                                                            <% if (finalPrice < price) { %>
                                                                <span
                                                                    class="text-sm text-gray-400 line-through font-medium">
                                                                    ₹<%= price.toLocaleString('en-IN') %>
                                                                </span>

                                                                <!-- DISCOUNT -->
                                                                <span
                                                                    class="bg-green-600 text-white text-[10px] font-bold px-2 py-0.5 rounded">
                                                                    <%= discount %>% OFF
                                                                </span>
                                                                <% } %>

                                                        </div>

                                                        <!-- SAVINGS -->
                                                        <% if (savings> 0) { %>
                                                            <span class="text-xs text-green-600 font-semibold">
                                                                You save ₹<%= savings.toLocaleString('en-IN') %>
                                                            </span>
                                                            <% } %>
                                                                <span class="text-xs text-gray-500">
                                                                    GST (<%= item.variantId.gstRate %>%): ₹<%=
                                                                            item.variantId.gstAmount %>
                                                                </span>

                                                                <!-- TAX TEXT -->
                                                                <span class="text-[11px] text-gray-500 font-medium">
                                                                    Inclusive of all taxes
                                                                </span>

                                                    </div>
                                            </div>

                                        </div>

                                        <!-- Bottom Actions -->
                                        <div
                                            class="flex items-end sm:items-center justify-between mt-5 pt-4 border-t border-gray-100/80">

                                            <!-- Qty Modern -->
                                            <div
                                                class="flex items-center bg-gray-50 border border-gray-200 rounded-lg p-0.5 shadow-sm">
                                                <button
                                                    class="w-8 h-8 flex items-center justify-center rounded-md hover:bg-white hover:shadow-sm text-gray-600 transition-all disabled:opacity-30 disabled:hover:bg-transparent disabled:hover:shadow-none decrease-qty"
                                                    <%=item.quantity <=1 ? 'disabled' : '' %>>
                                                    <i class="fa-solid fa-minus text-[10px]"></i>
                                                </button>

                                                <input type="number"
                                                    class="w-8 text-center text-sm font-semibold bg-transparent border-none focus:ring-0 p-0 item-qty"
                                                    value="<%= item.quantity %>" readonly>

                                                <button
                                                    class="w-8 h-8 flex items-center justify-center rounded-md hover:bg-white hover:shadow-sm text-gray-600 transition-all disabled:opacity-30 disabled:hover:bg-transparent disabled:hover:shadow-none increase-qty"
                                                    <%=item.quantity>= Math.min(item.variantId?.stock || 1, 5) ?
                                                    'disabled' : '' %>>
                                                    <i class="fa-solid fa-plus text-[10px]"></i>
                                                </button>
                                            </div>

                                            <!-- Actions -->
                                            <button
                                                class="remove-btn group flex items-center gap-2 px-3 py-1.5 rounded-lg text-sm font-medium text-gray-500 hover:text-red-600 hover:bg-red-50 transition-colors">
                                                <i class="fa-regular fa-trash-can group-hover:animate-bounce"></i>
                                                <span class="hidden sm:inline">Remove</span>
                                            </button>

                                        </div>

                                    </div>
                                </div>
                                <% }) %>
                                    <% } %>

                    </div>
                </div>

                <!-- Right Side: Order Summary -->
                <div class="lg:w-1/3">
                    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 sm:p-8 sticky top-10">
                        <h2 class="text-xl font-bold text-gray-900 mb-6 flex items-center gap-2">
                            Summary
                        </h2>

                        <div class="space-y-4 mb-6">

                            <!-- SUBTOTAL -->
                            <div class="flex justify-between items-center text-gray-600">
                                <span class="text-sm">Subtotal (<span id="summaryItemCount">0</span> items)</span>
                                <span class="font-semibold text-gray-900">
                                    ₹<span id="summarySubtotal">0.00</span>
                                </span>
                            </div>

                            <!-- TAX -->
                            <div class="flex justify-between items-center text-gray-600">
                                <span class="text-sm">Tax (GST 18%)</span>
                                <span class="font-medium text-gray-900">
                                    ₹<span id="summaryTax">0.00</span>
                                </span>
                            </div>

                            <!-- DELIVERY -->
                            <div class="flex justify-between items-center text-gray-600">
                                <span class="text-sm">Delivery Charges</span>
                                <span id="summaryDelivery"
                                    class="font-medium text-green-600 text-sm bg-green-50 px-2 py-0.5 rounded">
                                    Free Delivery
                                </span>
                            </div>

                        </div>

                        <div class="border-t border-gray-100 pt-6 mb-8">
                            <div class="flex justify-between items-end">
                                <div>
                                    <span class="block text-sm font-medium text-gray-500 mb-1">Total Amount</span>
                                    <span class="text-[10px] text-gray-400">Including taxes</span>
                                </div>
                                <span class="font-bold text-3xl text-gray-900 tracking-tight">₹<span
                                        id="summaryTotal">0.00</span></span>
                            </div>
                        </div>

                        <a id="checkoutBtn"
                            class="group relative w-full flex justify-center items-center gap-3 bg-black text-white py-4 rounded-xl font-semibold text-lg hover:bg-gray-800 transition-all shadow-lg hover:shadow-xl overflow-hidden disabled:opacity-50 disabled:cursor-not-allowed">
                            <span class="relative z-10 flex items-center gap-2">
                                Secure Checkout
                                <i
                                    class="fa-solid fa-lock text-sm bg-white/20 p-1.5 rounded-full group-hover:bg-white/30 transition-colors"></i>
                            </span>
                        </a>

                        <div class="mt-8 pt-6 border-t border-gray-100 grid grid-cols-2 gap-4">
                            <div class="flex items-center gap-3 text-gray-500">
                                <div class="w-8 h-8 rounded-full bg-gray-50 flex items-center justify-center shrink-0">
                                    <i class="fa-solid fa-shield-halved text-xs"></i>
                                </div>
                                <span
                                    class="text-[11px] font-bold uppercase tracking-wider leading-tight">Secure<br>Payments</span>
                            </div>
                            <div class="flex items-center gap-3 text-gray-500">
                                <div class="w-8 h-8 rounded-full bg-gray-50 flex items-center justify-center shrink-0">
                                    <i class="fa-solid fa-truck-fast text-xs"></i>
                                </div>
                                <span
                                    class="text-[11px] font-bold uppercase tracking-wider leading-tight">Fast<br>Delivery</span>
                            </div>
                        </div>

                    </div>
                </div>

            </div>
        </div>
    </main>

    <script src="/socket.io/socket.io.js"></script>
    <% if (typeof error !=="undefined" && error) { %>
        <script type="module">
            import { showToast } from "/partials/errorMsg.utils.js";
            showToast(<% - JSON.stringify(error) %>, "error");
        </script>

        <% } %>
            <script type="module">
                import { showToast } from "/partials/errorMsg.utils.js";
                import { confirmAction } from "/partials/confirm.util.js";


                //  SOCKET SETUP
                const socket = io();

                // 🔥 REAL-TIME STOCK UPDATE
                socket.on("stockUpdated", ({ productId, variantId, stock }) => {
                    const el = document.querySelector(
                        `.cart-item[data-product-id="${productId}"][data-variant-id="${variantId}"]`
                    );
                    if (!el) return;

                    el.dataset.stock = stock;

                    const qty = Number(el.querySelector('.item-qty').value);
                    const increaseBtn = el.querySelector('.increase-qty');
                    const stockText = el.querySelector(".mt-3.text-xs");

                    // IMAGE CONTAINER =
                    const imageWrapper = el.querySelector("a.relative");

                    //  HANDLE SOLD OUT BADGE
                    let soldOutBadge = imageWrapper.querySelector(".sold-out-badge");
                    let fewLeftBadge =
                        imageWrapper.querySelector(".few-left-badge")

                    if (stock === 0) {
                        // create if not exists
                        if (!soldOutBadge) {
                            const div = document.createElement("div");
                            div.className = "sold-out-badge absolute inset-x-0 bottom-0 bg-red-500/90 py-1.5 backdrop-blur-sm flex justify-center";
                            div.innerHTML = `
                <span class="text-white text-[10px] font-bold tracking-widest uppercase">
                    Sold Out
                </span>
            `;
                            imageWrapper.appendChild(div);
                        }
                    } else {
                        // remove if exists
                        if (soldOutBadge) {
                            soldOutBadge.remove();
                        }
                    }

                    // ---------- FEW LEFT ----------
                    if (stock > 0 && stock <= 5) {
                        if (!fewLeftBadge) {
                            const div = document.createElement("div");
                            div.className = "few-left-badge absolute top-2 left-2 bg-orange-100 text-orange-700 px-2 py-0.5 rounded-md text-[10px] font-bold shadow-sm";
                            div.innerText = "Few Left";
                            imageWrapper.appendChild(div);
                        }
                    } else {
                        if (fewLeftBadge) fewLeftBadge.remove();
                    }

                    //  STOCK TEXT UI
                    if (stockText) {
                        if (stock === 0) {
                            stockText.innerHTML = `<span class="text-red-600 font-medium bg-red-50 px-2.5 py-1 rounded border border-red-100">Out of Stock</span>`;
                        } else if (stock <= 5) {
                            stockText.innerHTML = `<span class="text-orange-600 font-medium bg-orange-50 px-2.5 py-1 rounded border border-orange-100">Only ${stock} left in stock</span>`;
                        } else {
                            stockText.innerHTML = `<span class="text-green-600 font-medium bg-green-50 px-2.5 py-1 rounded border border-green-100"><i class="fa-solid fa-check text-[10px] mr-1"></i>In Stock</span>`;
                        }
                    }

                    // BUTTON CONTROL
                    if (increaseBtn) {
                        qty >= stock
                            ? increaseBtn.setAttribute("disabled", true)
                            : increaseBtn.removeAttribute("disabled");
                    }

                    // HIGHLIGHT
                    el.classList.remove("border-red-500", "bg-red-50", "border-orange-400", "bg-orange-50");

                    if (stock === 0) {
                        el.classList.add("border-red-500", "bg-red-50");
                    } else if (qty > stock) {
                        el.classList.add("border-orange-400", "bg-orange-50");
                    }
                });

                //  QUANTITY HANDLERS
                document.querySelectorAll('.decrease-qty').forEach(btn => {
                    btn.addEventListener('click', async e => {
                        const el = e.target.closest('.cart-item');
                        const qty = +el.querySelector('.item-qty').value;
                        if (qty > 1) await updateQty(el, qty - 1);
                    });
                });

                document.querySelectorAll('.increase-qty').forEach(btn => {
                    btn.addEventListener('click', async e => {
                        const el = e.target.closest('.cart-item');
                        const qty = +el.querySelector('.item-qty').value;
                        const stock = +el.dataset.stock;

                        if (qty < stock) {
                            await updateQty(el, qty + 1);
                        } else {
                            showToast(`Only ${stock} items available`, "warning");
                        }
                    });
                });

                //  UPDATE QTY
                async function updateQty(el, qty) {
                    const itemId = el.dataset.itemId;

                    try {
                        const res = await fetch("/cart", {
                            method: "PATCH",
                            headers: { "Content-Type": "application/json" },
                            body: JSON.stringify({ itemId, quantity: qty })
                        });

                        const result = await res.json();

                        if (result.success) {
                            el.querySelector('.item-qty').value = qty;
                            calculateTotals();
                            highlightInvalidItems()
                        } else {
                            showToast(result.message, "error");
                        }

                    } catch {
                        showToast("Network error", "error");
                    }
                }

                //  REMOVE ITEM
                document.querySelectorAll('.remove-btn').forEach(btn => {
                    btn.addEventListener('click', async e => {
                        const el = e.target.closest('.cart-item');
                        if (await confirmAction("Remove item?")) {
                            await removeItem(el);
                        }
                    });
                });

                async function removeItem(el) {
                    const itemId = el.dataset.itemId;

                    try {
                        const res = await fetch("/cart", {
                            method: "DELETE",
                            headers: { "Content-Type": "application/json" },
                            body: JSON.stringify({ itemId })
                        });

                        const result = await res.json();

                        if (result.success) {
                            el.remove();
                            calculateTotals();
                            checkEmptyCart();
                        }

                    } catch {
                        showToast("Error removing item", "error");
                    }
                }

                //  CHECKOUT VALIDATION
                document.getElementById("checkoutBtn").addEventListener("click", async (e) => {
                    e.preventDefault();

                    try {
                        const res = await fetch("/api/user/cart/validate-stock-cart");
                        const data = await res.json();
                        console.log(data);

                        if (!data.success) {
                            showToast(data.items[0]?.reason || "Fix stock issues before checkout", "error");

                            // Optional: highlight items
                            console.log(data.items);

                            return; // 🚨 stop redirect
                        }

                        // ✅ only redirect if valid
                        window.location.href = "/cart/checkout";

                    } catch (err) {
                        console.error(err);
                        showToast("Something went wrong", "error");
                    }
                });
                //  HELPERS
                function calculateTotals() {
                    let total = 0;
                    let count = 0;

                    document.querySelectorAll('.cart-item').forEach(el => {
                        const price = +el.querySelector('.item-price').textContent.replace(/,/g, '');
                        const qty = +el.querySelector('.item-qty').value;

                        total += price * qty;
                        count += qty;
                    });

                    const GST_RATE = 18;

                    // GST INCLUDED CALCULATION
                    const gstAmount = (total * GST_RATE) / (100 + GST_RATE);

                    // 🚚 DELIVERY LOGIC
                    let delivery = total >= 500 ? 0 : 40;

                    // 🔥 EMPTY CART FIX
                    if (count === 0) delivery = 0;

                    const finalTotal = total + delivery;

                    // ================= UI UPDATE =================
                    document.getElementById('summaryItemCount').textContent = count;
                    document.getElementById('summarySubtotal').textContent = format(total);
                    document.getElementById('summaryTax').textContent = format(gstAmount);

                    // 🔥 DELIVERY UI HANDLING
                    const deliveryEl = document.getElementById('summaryDelivery');

                    if (count === 0) {
                        deliveryEl.textContent = "--";
                        deliveryEl.classList.remove("text-green-600", "bg-green-50");
                        deliveryEl.classList.add("text-gray-400");
                    } else if (delivery === 0) {
                        deliveryEl.textContent = "Free";
                        deliveryEl.classList.add("text-green-600", "bg-green-50");
                    } else {
                        deliveryEl.textContent = `₹${delivery}`;
                        deliveryEl.classList.remove("text-green-600", "bg-green-50");
                        deliveryEl.classList.add("text-gray-900");
                    }

                    document.getElementById('summaryTotal').textContent = format(finalTotal);
                }

                function checkEmptyCart() {
                    if (!document.querySelectorAll('.cart-item').length) {
                        document.getElementById('cartItemsContainer').classList.add('hidden');
                        document.getElementById('emptyCartState').classList.remove('hidden');
                    }
                }

                function format(n) {
                    return n.toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
                }

                function highlightInvalidItems() {
                    document.querySelectorAll('.cart-item').forEach(item => {
                        const stock = Number(item.dataset.stock);
                        const qty = Number(item.querySelector('.item-qty').value);

                        item.classList.remove("border-red-500", "bg-red-50", "border-orange-400", "bg-orange-50");

                        if (stock === 0) {
                            item.classList.add("border-red-500", "bg-red-50");
                        } else if (qty > stock) {
                            item.classList.add("border-orange-400", "bg-orange-50");
                        }
                    });
                }

                document.addEventListener('DOMContentLoaded', () => {
                    calculateTotals();
                    checkEmptyCart();
                    highlightInvalidItems();
                    document.getElementById('cartCount').textContent = document.querySelectorAll('.cart-item').length;
                });


                function getCookie(name) {
                    const value = `; ${document.cookie}`;
                    const parts = value.split(`; ${name}=`);
                    if (parts.length === 2) return parts.pop().split(';').shift();
                }

                const errorCookie = getCookie("cartError");

                if (errorCookie) {
                    try {
                        const data = JSON.parse(decodeURIComponent(errorCookie));

                        showToast(data.message, "error");

                        // 🔥 show detailed errors
                        data.items?.forEach(item => {
                            showToast(`${item.name} → ${item.reason}`, "error");
                        });

                    } catch (err) {
                        console.error("Cookie parse error:", err);
                    }

                    // ❌ clear cookie
                    document.cookie = "cartError=; path=/; expires=Thu, 01 Jan 1970 00:00:00 UTC;";
                }
            </script>

