<script>
    function getLimit() {
        const width = window.innerWidth;
        if (width >= 1024) return 8;
        if (width >= 640) return 6;
        return 6;
    }

    const container = document.getElementById("homeProductContainer");

    async function loadHomeProducts() {
        try {
            const params = new URLSearchParams({ ajax: true, limit: getLimit() });
            const res = await fetch(`/?${params.toString()}`, { headers: { "Accept": "application/json" } });
            const data = await res.json();
            const temp = document.createElement("div");
            temp.innerHTML = data.cards;
            container.replaceChildren(...temp.children);
        } catch (err) {
            console.error(err);
        }
    }

    document.addEventListener("DOMContentLoaded", loadHomeProducts);

    let resizeTimer;
    window.addEventListener("resize", () => {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(loadHomeProducts, 300);
    });

    // Tab switching
    function switchTab(tab) {
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        document.getElementById('tab-' + tab)?.classList.add('active');
    }

    // Scroll reveal
    const revealEls = document.querySelectorAll('.reveal');
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); } });
    }, { threshold: 0.1 });
    revealEls.forEach(el => observer.observe(el));
</script>

<script type="module">
    const isLoggedIn = <%= JSON.stringify(!!user) %>;
    import { showToast } from "/partials/errorMsg.utils.js";

    document.addEventListener('click', async (e) => {
        const link = e.target.closest('.wishlist');
        if (!link) return;
        if (!isLoggedIn) { showToast("Please log in to manage your wishlist.", "warning"); return; }
        if (link.classList.contains("loading")) return;
        link.classList.add("loading");
        const productId = link.dataset.productId;
        const variantId = link.dataset.variantId;
        if (!productId || !variantId) { showToast("Invalid product data", "error"); link.classList.remove("loading"); return; }
        try {
            const res = await fetch('/wishlist', { method: "POST", headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' }, body: JSON.stringify({ productId, variantId }) });
            const contentType = res.headers.get("content-type");
            if (!contentType || !contentType.includes("application/json")) throw new Error("Invalid response");
            const { data, success, message } = await res.json();
            if (!success) { showToast(message, "error"); return; }
            const icon = link.querySelector("i");
            const countEl = document.getElementById('wishlistCount');
            let current = +countEl.textContent || 0;
            if (data.added) { icon.classList.remove("fa-regular"); icon.classList.add("fa-solid", "text-red-500"); current += 1; }
            else { icon.classList.remove("fa-solid", "text-red-500"); icon.classList.add("fa-regular"); current = Math.max(0, current - 1); }
            countEl.textContent = current;
            icon.classList.add("scale-110");
            setTimeout(() => icon.classList.remove("scale-110"), 150);
            showToast(message || "Updated wishlist", "success");
        } catch (err) { console.error(err); showToast(err.message || "Failed", "error"); }
        finally { link.classList.remove("loading"); }
    });

    document.addEventListener('click', async (e) => {
        const btn = e.target.closest('.add-to-cart');
        if (!btn) return;
        if (!isLoggedIn) { showToast("Please log in to add items to cart.", "warning"); return; }
        if (btn.classList.contains("loading")) return;
        btn.classList.add("loading");
        const productId = btn.dataset.productId;
        const variantId = btn.dataset.variantId;
        const btnW = document.getElementById(`wishlist-${variantId}`);
        if (!productId || !variantId) { showToast("Invalid product", "error"); btn.classList.remove("loading"); return; }
        const cartCount = +document.getElementById('cartCount').textContent || 0;
        if (cartCount >= 5) { showToast("Maximum 5 different products allowed in cart.", "warning"); btn.classList.remove("loading"); return; }
        try {
            const res = await fetch('/cart', { method: "POST", headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' }, body: JSON.stringify({ productId, variantId, quantity: 1 }) });
            const contentType = res.headers.get("content-type");
            if (!contentType || !contentType.includes("application/json")) throw new Error("Invalid response");
            const result = await res.json();
            const { data } = result;
            if (!result.success) { showToast(result.message, "error"); return; }
            btn.textContent = "Added ✓";
            btn.classList.remove("bg-blue-600");
            btn.classList.add("bg-green-600");
            setTimeout(() => { btn.textContent = "Add to Cart"; btn.classList.remove("bg-green-600"); btn.classList.add("bg-blue-600"); }, 1500);
            if (data.added) {
                const cartCountId = document.getElementById('cartCount');
                cartCountId.textContent = (+cartCountId.textContent || 0) + 1;
                if (btnW) { btnW.disabled = true; btnW.classList.add("opacity-50", "cursor-not-allowed"); }
            }
            if (btnW) {
                const icon = btnW.querySelector("i");
                if (data.removedFromWishlist && icon) {
                    icon.classList.remove("fa-solid", "text-red-500");
                    icon.classList.add("fa-regular", "text-gray-600");
                    const countEl = document.getElementById("wishlistCount");
                    if (countEl) countEl.textContent = Math.max(0, (countEl.textContent || 1) - 1);
                }
            }
            showToast(result.message || "Added to cart", "success");
        } catch (err) { console.error(err); showToast(err.message || "Failed", "error"); }
        finally { btn.classList.remove("loading"); }
    });
</script>

