<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<script src="https://cdn.tailwindcss.com"></script>

<%- include("../../partials/user/header.ejs") %>

<style>
    body {
        font-family: 'Outfit', sans-serif;
        background-color: #f9fafb;
    }
</style>

<main class="min-h-[85vh] py-12 flex items-center justify-center">
    <!-- Main Card Container -->
    <div class="max-w-[650px] w-full mx-auto px-4 sm:px-6 lg:px-8">
        
        <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-8 sm:p-12 text-center relative overflow-hidden z-10">
            
            <!-- Decorative Background Glow for Premium Feel -->
            <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[350px] h-[350px] bg-green-50 rounded-full blur-[80px] -z-10 opacity-70 pointer-events-none"></div>
            
            <!-- Illustration / Success Animated Icon -->
            <div class="w-24 h-24 mx-auto mb-8 bg-green-50 rounded-full flex items-center justify-center border-4 border-white shadow-md relative">
                <!-- Pulse animation ring -->
                <div class="absolute inset-0 rounded-full border-4 border-green-200 animate-ping opacity-30"></div>
                
                <i class="fa-solid fa-check text-4xl text-green-500 drop-shadow-sm"></i>
                
                <!-- Floating decorative stars -->
                <i class="fa-solid fa-star absolute -top-1 -right-3 text-yellow-400 text-lg drop-shadow-sm opacity-90 animate-bounce" style="animation-duration: 2s;"></i>
                <i class="fa-solid fa-sparkles absolute bottom-1 -left-2 text-blue-300 text-sm opacity-80"></i>
            </div>
            
            <!-- Thank You Statement -->
            <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 tracking-tight mb-2">Order Successful!</h1>
            <p class="text-lg font-medium text-gray-600 mb-6">Thank you for your purchase.</p>
            
            <p class="text-gray-500 mb-8 max-w-sm mx-auto leading-relaxed text-sm">
                Your order has been confirmed and is now being processed. You will receive an email containing your order details shortly.
            </p>
            
            <!-- Order ID Tracker Pill -->
            <div class="inline-flex items-center gap-3 bg-[#f9fafb] border border-gray-200 px-6 py-3 rounded-full mb-10 shadow-sm relative group">
                <span class="text-sm font-medium text-gray-500">Order ID:</span>
                <span class="font-bold text-gray-900 tracking-wider">
                    <%= typeof orderId !== 'undefined' ? orderId : 'ORD-XXXXXXX' %>
                </span>
                
                <!-- Copy to Clipboard Button -->
                <button onclick="copyToClipboard('<%= typeof orderId !== 'undefined' ? orderId : 'ORD-XXXXXXX' %>')" 
                        class="text-gray-400 hover:text-black transition-colors w-8 h-8 flex items-center justify-center rounded-full hover:bg-gray-200 border border-transparent hover:border-gray-300" 
                        title="Copy Order ID">
                    <i class="fa-regular fa-copy"></i>
                </button>

                <!-- Tooltip for copy feedback -->
                <div id="copyTooltip" class="absolute -top-11 left-1/2 -translate-x-1/2 bg-black text-white text-xs px-3 py-1.5 rounded outline outline-1 outline-gray-700 opacity-0 transition-opacity duration-200 pointer-events-none shadow-lg whitespace-nowrap">
                    Copied!
                    <!-- Tooltip Caret -->
                    <div class="absolute -bottom-1.5 left-1/2 -translate-x-1/2 border-[4px] border-transparent border-t-black"></div>
                </div>
            </div>
            
            <!-- Call to Action Buttons -->
            <div class="flex flex-col sm:flex-row items-center justify-center gap-4 relative z-20">
                <!-- Redirect path depends on your backend routes -->
                <a href="/profile/orders" 
                   class="w-full sm:w-auto flex items-center justify-center gap-2 px-8 py-3.5 bg-black text-white text-sm font-semibold rounded-xl hover:bg-gray-800 transition-all shadow-lg hover:shadow-xl group">
                    <i class="fa-solid fa-box-open text-xs text-gray-300"></i>
                    View Order Details
                    <i class="fa-solid fa-arrow-right text-xs opacity-70 group-hover:opacity-100 group-hover:translate-x-1 transition-all"></i>
                </a>
                
                <a href="/shop" 
                   class="w-full sm:w-auto flex items-center justify-center gap-2 px-8 py-3.5 bg-white text-gray-700 text-sm font-semibold rounded-xl border border-gray-200 hover:border-black hover:text-black hover:bg-gray-50 transition-all hover:shadow">
                    <i class="fa-solid fa-bag-shopping text-xs text-gray-400 group-hover:text-black"></i>
                    Continue Shopping
                </a>
            </div>

            <!-- Footer Support Note -->
            <div class="mt-10 pt-6 border-t border-gray-100 text-sm text-gray-400">
                Need help with your order? 
                <a href="/contact" class="font-semibold text-gray-600 hover:text-black transition-colors inline-flex items-center gap-1">
                    Contact Support <i class="fa-solid fa-arrow-up-right-from-square text-[10px]"></i>
                </a>
            </div>

        </div>
        
    </div>
</main>

<!-- Utility Scripts -->
<script>
    // Copy to clipboard utility logic
    function copyToClipboard(text) {
        if (!navigator.clipboard) {
            console.warn("Clipboard API not available");
            return;
        }

        navigator.clipboard.writeText(text).then(() => {
            const tooltip = document.getElementById('copyTooltip');
            tooltip.classList.remove('opacity-0');
            tooltip.classList.add('opacity-100');
            
            // Hide tooltip after 2 seconds
            setTimeout(() => {
                tooltip.classList.remove('opacity-100');
                tooltip.classList.add('opacity-0');
            }, 2000);
        }).catch(err => {
            console.error('Failed to copy text: ', err);
            alert("Could not copy Order ID");
        });
    }
</script>

<%- include("../../partials/user/footer.ejs") %>
