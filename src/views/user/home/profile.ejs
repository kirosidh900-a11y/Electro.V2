<script src="https://cdn.tailwindcss.com"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

<body class="bg-gray-100 font-sans">

    <%- include("../../partials/user/header") %>

        <div class="min-h-screen p-4 sm:p-6 lg:p-10">

            <div class="max-w-6xl mx-auto flex flex-col lg:flex-row gap-6">

                <%- include("./partials/profileSidebar") %>

                    <!-- MAIN CONTENT -->
                    <main class="flex-1 bg-white rounded-xl shadow-sm p-8">

                        
                        <h1 class="text-2xl font-bold text-red-500 mb-10">Edit Your Profile</h1>

                        <!-- AVATAR -->
                        <div class="flex flex-col items-center pb-10 mb-10 border-b border-gray-100">

                            <div class="relative group">

                                <!-- Avatar -->
                                <img src="<%= user?.photo || 'https://res.cloudinary.com/dxtiklfxy/image/upload/v1773824246/profile/qhvfjaqer1o81nwkxvcz.png' %>"
                                    class="profile-avatar  w-32 h-32 rounded-full object-cover shadow-md border-4 border-white" />

                                <!-- Soft overlay -->
                                <div class="absolute inset-0 rounded-full bg-black/30 opacity-0 
            group-hover:opacity-100 transition duration-300"></div>

                                <!-- Camera button -->
                                <label for="photoUpload" class="absolute bottom-1 right-1 bg-white text-gray-700
            w-9 h-9 flex items-center justify-center rounded-full shadow-md
            cursor-pointer hover:bg-gray-100 transition">

                                    <i class="fa-solid fa-camera text-sm"></i>
                                </label>

                                <input type="file" id="photoUpload" accept="image/*" class="hidden" />

                            </div>

                            <!-- Remove Button -->

                            <button id="removePhotoBtn" class="<%= user?.photo ? '' : 'hidden' %> mt-3 px-4 py-1.5 text-sm rounded-full 
    border border-red-400 text-red-500 
    hover:text-white hover:bg-red-500 transition font-medium">
                                Remove Photo
                            </button>


                        </div>

                        <div class="space-y-8">

                            <!-- NAME -->
                            <section class="bg-gray-50 border border-gray-100 rounded-xl p-6 space-y-4">

                                <div class="flex justify-between items-center">
                                    <h3 class="font-semibold text-gray-800">Personal Information</h3>

                                    <button id="editNameBtn"
                                        class="text-xs font-semibold text-orange-500 hover:underline">
                                        Edit
                                    </button>
                                </div>

                                <div class="flex gap-3">

                                    <input id="nameInput" value="<%= user?.name %>" disabled
                                        class="flex-1 p-3 border border-gray-200 rounded-lg bg-white">

                                    <button id="saveNameBtn"
                                        class="hidden px-5 py-3 bg-red-500 text-white rounded-lg text-sm font-semibold">
                                        Save
                                    </button>

                                </div>

                            </section>

                            <!-- PASSWORD -->
                            <section class="bg-gray-50 border border-gray-100 rounded-xl p-6 space-y-4">

                                <div class="flex justify-between items-center">

                                    <h3 class="font-semibold text-gray-800">
                                        <%= user?.hasPassword ? "Password Change" : "Add Password" %>
                                    </h3>

                                    <button id="editPasswordBtn"
                                        class="text-xs font-semibold text-orange-500 hover:underline">

                                        <%= user?.hasPassword ? "Edit" : "Add Password" %>

                                    </button>

                                </div>

                                <div id="passwordFields" class="grid grid-cols-1 md:grid-cols-2 gap-6 hidden">

                                    <% if(user?.hasPassword){ %>

                                        <div class="md:col-span-2">
                                            <label class="text-sm text-gray-500">Current Password</label>
                                            <input id="crPassword" type="password" class="w-full p-3 border rounded-lg">
                                        </div>

                                        <% } %>

                                            <div>
                                                <label class="text-sm text-gray-500">New Password</label>
                                                <input id="password" type="password"
                                                    class="w-full p-3 border rounded-lg">
                                            </div>

                                            <div>
                                                <label class="text-sm text-gray-500">Confirm Password</label>
                                                <input id="cPassword" type="password"
                                                    class="w-full p-3 border rounded-lg">
                                            </div>

                                </div>

                                <div id="passwordActions" class="flex justify-end gap-3 hidden">

                                    <button id="cancelPasswordBtn" class="px-5 py-2 text-gray-500 hover:text-gray-700">
                                        Cancel
                                    </button>

                                    <button id="savePasswordBtn"
                                        class="px-5 py-2 bg-red-500 text-white font-semibold rounded-lg">
                                        Save
                                    </button>

                                </div>

                            </section>

                            <!-- EMAIL PHONE -->
                            <section class="bg-gray-50 border border-gray-100 rounded-xl p-6">

                                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

                                    <div>

                                        <div class="flex justify-between mb-2">
                                            <label class="text-sm text-gray-500">Email</label>

                                            <button id="editEmailBtn"
                                                class="text-xs font-semibold text-orange-500 hover:underline">
                                                Edit
                                            </button>
                                        </div>

                                        <div class="flex gap-3">

                                            <input id="emailInput" value="<%= user?.email %>" disabled
                                                class="flex-1 p-3 border rounded-lg">

                                            <button id="saveEmailBtn"
                                                class="hidden px-4 py-2 bg-red-500 text-white rounded-lg text-sm">
                                                Save
                                            </button>

                                        </div>

                                    </div>

                                    <div class="space-y-2">

                                        <div class="flex justify-between items-center">

                                            <label class="text-sm text-gray-500">Phone</label>

                                            <button id="editPhoneBtn"
                                                class="text-xs font-semibold text-orange-500 hover:underline">

                                                <%= user?.phone ? "Edit" : "Add" %>

                                            </button>

                                        </div>

                                        <div class="flex gap-3">

                                            <input id="phoneInput" type="text" value="<%= user?.phone || '' %>"
                                                placeholder="Enter your phone number" disabled
                                                class="flex-1 p-3 border border-gray-200 rounded-lg bg-white" />

                                            <button id="savePhoneBtn"
                                                class="hidden px-4 py-2 bg-red-500 text-white rounded-lg text-sm font-semibold">

                                                Save

                                            </button>

                                        </div>

                                    </div>

                                </div>

                            </section>

                        </div>

                    </main>

            </div>
        </div>

        <!-- OTP MODAL -->
        <div id="otpModal" class="fixed inset-0 bg-black/50 hidden items-center justify-center z-50">
            <div class="bg-white w-full max-w-md rounded-xl p-6 space-y-4">

                <h2 class="text-lg font-semibold text-gray-800">Verify Email</h2>

                <p class="text-sm text-gray-500">
                    Enter the OTP sent to your email
                </p>

                <input id="otpInput" type="text" maxlength="6"
                    class="w-full p-3 border rounded-lg text-center tracking-widest text-lg" placeholder="------" />

                <div class="flex justify-between items-center text-sm">

                    <button id="resendOtpBtn" class="text-blue-500 hover:underline">
                        Resend OTP
                    </button>

                    <span id="otpTimer" class="text-gray-400"></span>

                </div>

                <div class="flex justify-end gap-3">
                    <button id="closeOtpModal" class="px-4 py-2 text-gray-500">Cancel</button>
                    <button id="verifyOtpBtn" class="px-4 py-2 bg-red-500 text-white rounded-lg font-semibold">
                        Verify
                    </button>
                </div>

            </div>
        </div>

        <%- include("../../partials/user/footer") %>

            <script type="module">
                import { showToast } from "/partials/errorMsg.utils.js";
                import { confirmAction } from "/partials/confirm.util.js";

                // NAME EDIT
                const editNameBtn = document.getElementById("editNameBtn");
                const nameInput = document.getElementById("nameInput");
                const saveNameBtn = document.getElementById("saveNameBtn");
                const sidebarNameInput = document.getElementById('sidebarName');
                const headNameInput = document.getElementById('headName');
                const headNameInput1 = document.getElementById('headName1');

                let originalName = nameInput.value;

                editNameBtn.onclick = () => {
                    if (nameInput.disabled) {
                        nameInput.disabled = false;
                        editNameBtn.textContent = "Cancel";
                        saveNameBtn.classList.remove("hidden");
                        nameInput.focus();
                    } else {
                        nameInput.value = originalName;
                        nameInput.disabled = true;
                        editNameBtn.textContent = "Edit";
                        saveNameBtn.classList.add("hidden");
                    }
                }

                saveNameBtn.onclick = async () => {
                    try {

                        // name validation 
                        const namePattern = /^[A-Za-z]+(?: [A-Za-z]+)*$/;

                        const name = nameInput.value.trim();

                        if (!namePattern.test(name)) {
                            throw new Error("Invalid format!");
                        }

                        const res = await fetch('/name', {
                            method: 'PATCH',
                            headers: {
                                "Content-Type": "application/json"
                            },
                            body: JSON.stringify({ name })
                        });

                        const data = await res.json();

                        // Throw error if response is not OK
                        if (!res.ok) {
                            throw new Error(data.message || "Update failed");
                        }


                        originalName = name;
                        sidebarNameInput.textContent = name;
                        headNameInput.textContent = name;
                        headNameInput1.textContent = name;

                        nameInput.disabled = true;
                        editNameBtn.textContent = "Edit";
                        saveNameBtn.classList.add("hidden");

                        // ✅ Success
                        showToast(data.message || "Name updated successfully", "success");
                        return;

                    } catch (error) {
                        console.log(error);
                        showToast(error.message, "error")
                    }
                };

                // EMAIL EDIT
                const editEmailBtn = document.getElementById("editEmailBtn");
                const emailInput = document.getElementById("emailInput");

                const saveEmailBtn = document.getElementById("saveEmailBtn");

                let originalEmail = emailInput.value;
                let otpContext = null;

                editEmailBtn.onclick = () => {
                    if (emailInput.disabled) {
                        emailInput.disabled = false;
                        editEmailBtn.textContent = "Cancel";
                        saveEmailBtn.classList.remove("hidden");
                        emailInput.focus();
                    } else {
                        emailInput.value = originalEmail;
                        emailInput.disabled = true;
                        editEmailBtn.textContent = "Edit";
                        saveEmailBtn.classList.add("hidden");
                    }
                }

                saveEmailBtn.onclick = async () => {
                    try {

                        const emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
                        const newEmail = emailInput.value.trim();

                        if (!emailPattern.test(newEmail)) {
                            throw new Error("Invalid email format");
                        }

                        if (newEmail === originalEmail) {
                            throw new Error("No changes detected");
                        }


                        const res = await fetch('/email', {
                            method: 'POST',
                            headers: {
                                "Content-Type": "application/json",
                                "Accept": "application/json"
                            },
                            body: JSON.stringify({ newEmail })
                        });

                        const data = await res.json();

                        // Throw error if response is not OK
                        if (!res.ok) {
                            throw new Error(data.message || "Update failed");
                        }

                        originalEmail = emailInput.value;
                        emailInput.disabled = true;
                        editEmailBtn.textContent = "Edit";
                        saveEmailBtn.classList.add("hidden");
                        showToast(data.message || "OTP sent successfully", 'success')
                        otpContext = 'email';
                        openOtpModal();
                    } catch (error) {
                        console.error(error);
                        showToast(error.message || "Internal Server Error", 'error')
                    }
                }

                // PASSWORD EDIT
                const editPasswordBtn = document.getElementById("editPasswordBtn");
                const passwordFields = document.getElementById("passwordFields");
                const passwordActions = document.getElementById("passwordActions");
                const cancelPasswordBtn = document.getElementById("cancelPasswordBtn");

                editPasswordBtn.onclick = () => {
                    const hidden = passwordFields.classList.contains("hidden");
                    if (hidden) {
                        passwordFields.classList.remove("hidden");
                        passwordActions.classList.remove("hidden");
                        editPasswordBtn.textContent = "Cancel";
                    } else {
                        passwordFields.classList.add("hidden");
                        passwordActions.classList.add("hidden");
                        document.getElementById("password").value = "";
                        document.getElementById("cPassword").value = "";
                        if (document.getElementById("crPassword")) {
                            document.getElementById("crPassword").value = "";
                        }
                        editPasswordBtn.textContent = "<%= user?.hasPassword?'Edit':'Add Password' %>";
                    }
                }

                cancelPasswordBtn.onclick = () => {
                    passwordFields.classList.add("hidden");
                    passwordActions.classList.add("hidden");
                    document.getElementById("password").value = "";
                    document.getElementById("cPassword").value = "";
                    if (document.getElementById("crPassword")) {
                        document.getElementById("crPassword").value = "";
                    }
                    editPasswordBtn.textContent = "<%= user?.hasPassword?'Edit':'Add Password' %>";
                }

                const savePasswordBtn = document.getElementById("savePasswordBtn");

                savePasswordBtn.onclick = async () => {
                    try {
                        const currentPassword = document.getElementById("crPassword")?.value;
                        const newPassword = document.getElementById("password").value;
                        const confirmPassword = document.getElementById("cPassword").value;

                        // 🔥 Validation
                        if (!newPassword || !confirmPassword) {
                            throw new Error("All fields are required");
                        }

                        if (newPassword.length < 8) {
                            throw new Error("Password must be at least 8 characters");
                        }

                        const password = newPassword;

                        if (password.length < 8) throw new Error("Minimum 8 characters");
                        if (!/[A-Z]/.test(password)) throw new Error("Add uppercase letter");
                        if (!/[a-z]/.test(password)) throw new Error("Add lowercase letter");
                        if (!/\d/.test(password)) throw new Error("Add a number");
                        if (!/[@$!%*?&]/.test(password)) throw new Error("Add a special character");

                        if (newPassword === currentPassword) {
                            throw new Error("New password and Current password is same!")
                        }

                        if (newPassword !== confirmPassword) {
                            throw new Error("Passwords do not match");
                        }

                        // If user already has password → require current password
                        if (currentPassword !== undefined && !currentPassword) {
                            throw new Error("Current password is required");
                        }

                        // 🔥 API Call
                        const res = await fetch("/password", {
                            method: "PATCH",
                            headers: {
                                "Content-Type": "application/json",
                                "Accept": "application/json"
                            },
                            body: JSON.stringify({
                                currentPassword,
                                confirmPassword,
                                newPassword
                            })
                        });

                        const data = await res.json();

                        if (!res.ok) {
                            throw new Error(data.message || "Update failed");
                        }

                        // ✅ Success
                        showToast(data.message, "success");

                        // Reset UI
                        document.getElementById("passwordFields").classList.add("hidden");
                        document.getElementById("passwordActions").classList.add("hidden");

                        document.getElementById("editPasswordBtn").textContent =
                            "<%= user?.hasPassword ? 'Edit' : 'Add Password' %>";

                        document.getElementById("password").value = "";
                        document.getElementById("cPassword").value = "";
                        if (document.getElementById("crPassword")) {
                            document.getElementById("crPassword").value = "";
                        }

                    } catch (error) {
                        showToast(error.message, "error");
                    }
                };

                //verify otp
                //clone
                const verifyBtn = document.getElementById("verifyOtpBtn");

                verifyBtn.onclick = async () => {
                    try {
                        const otp = document.getElementById("otpInput").value.trim();

                        if (!/^\d{6}$/.test(otp)) {
                            throw new Error("Enter valid OTP");
                        }

                        let res, data;

                        if (otpContext === "email") {
                            res = await fetch("/email", {
                                method: "PATCH",
                                headers: {
                                    "Content-Type": "application/json",
                                    "Accept": "application/json"
                                },
                                body: JSON.stringify({
                                    otp,
                                    newEmail: emailInput.value.trim()
                                })
                            });

                            data = await res.json();

                            if (!res.ok) throw new Error(data.message);

                            document.getElementById('headerEmail').textContent = emailInput.value.trim();
                            showToast("Email updated successfully", "success");

                        } else if (otpContext === "phone") {

                            const phone = phoneInput.value.trim();

                            res = await fetch("/phone", {
                                method: "PATCH",
                                headers: {
                                    "Content-Type": "application/json",
                                    "Accept": "application/json"
                                },
                                body: JSON.stringify({ phone, otp })
                            });

                            data = await res.json();

                            if (!res.ok) throw new Error(data.message);

                            originalPhone = phone;
                            phoneInput.disabled = true;
                            savePhoneBtn.classList.add("hidden");
                            editPhoneBtn.textContent = "Edit";

                            showToast("Phone updated successfully", "success");
                        }

                        closeOtpModalFunc();

                    } catch (error) {
                        showToast(error.message, "error");
                    }
                };


                //resend Otp
                const resendBtn = document.getElementById("resendOtpBtn");

                resendBtn.onclick = async () => {
                    if (resendBtn.disabled) return;

                    try {
                        let payload = {};

                        if (otpContext === "email") {
                            payload = {
                                email: emailInput.value.trim(),
                                purpose: "reset-email"
                            };
                        } else if (otpContext === "phone") {
                            payload = {
                                phone: phoneInput.value.trim(),
                                purpose: "reset-phone"
                            };
                        }

                        const res = await fetch("/resend-otp", {
                            method: "POST",
                            headers: {
                                "Content-Type": "application/json",
                                "Accept": "application/json"
                            },
                            body: JSON.stringify(payload)
                        });

                        const data = await res.json();

                        if (!res.ok) throw new Error(data.message);

                        showToast("OTP resent", "success");
                        startOtpTimer();

                    } catch (error) {
                        showToast(error.message, "error");
                    }
                };


                //Phone
                const editPhoneBtn = document.getElementById("editPhoneBtn");
                const phoneInput = document.getElementById("phoneInput");
                const savePhoneBtn = document.getElementById("savePhoneBtn");

                let originalPhone = phoneInput.value;

                editPhoneBtn.onclick = () => {

                    if (phoneInput.disabled) {

                        phoneInput.disabled = false;
                        editPhoneBtn.textContent = "Cancel";
                        savePhoneBtn.classList.remove("hidden");

                        phoneInput.focus();

                    } else {

                        phoneInput.value = originalPhone;
                        phoneInput.disabled = true;

                        editPhoneBtn.textContent = originalPhone ? "Edit" : "Add";
                        savePhoneBtn.classList.add("hidden");

                    }

                };

                savePhoneBtn.onclick = async () => {
                    try {
                        const phone = phoneInput.value.trim();

                        if (!phone) throw new Error("Phone number is required");

                        const phonePattern = /^[6-9]\d{9}$/;

                        if (!phonePattern.test(phone)) {
                            throw new Error("Enter valid 10-digit phone number");
                        }

                        const res = await fetch("/phone", {
                            method: "POST",
                            headers: {
                                "Content-Type": "application/json",
                                "Accept": "application/json"
                            },
                            body: JSON.stringify({ phone })
                        });

                        const data = await res.json();

                        if (!res.ok) throw new Error(data.message);

                        showToast("OTP sent to your phone", "success");
                        otpContext = 'phone';
                        openOtpModal(); // 🔥 reuse same modal

                    } catch (error) {
                        showToast(error.message, "error");
                    }
                };

                //Profile photo

                const photoUpload = document.getElementById("photoUpload");

                photoUpload.onchange = async (e) => {
                    try {
                        const file = e.target.files[0];

                        console.log("FILE:", file);
                        console.log("TYPE:", typeof file);

                        if (!file) return;

                        const formData = new FormData();
                        formData.append("photo", file);

                        console.log("FormData:", formData);

                        const res = await fetch("/photo", {
                            method: "PATCH",
                            body: formData
                        });

                        const data = await res.json();

                        if (!res.ok) throw new Error(data.message);

                        // 🔥 Update UI instantly
                        const avatarImg = document.querySelector(".profile-avatar");
                        const sidebarImg = document.getElementById('sidebarImg');
                        const headImg = document.getElementById('headImg');
                        avatarImg.src = data.photo;
                        sidebarImg.src = data.photo;
                        headImg.src = data.photo;
                        document.getElementById("removePhotoBtn").classList.remove("hidden");

                        showToast("Profile photo updated", "success");
                        // 🔥 IMPORTANT FIX
                        photoUpload.value = "";

                    } catch (error) {
                        showToast(error.message, "error");
                    }
                };

                //Remove profile Photo
                const removeBtn = document.getElementById("removePhotoBtn");

                if (removeBtn) {
                    removeBtn.onclick = async () => {
                        try {
                            const res = await fetch("/photo", {
                                method: "DELETE",
                                headers: {
                                    "Accept": "application/json"
                                }
                            });

                            const data = await res.json();

                            if (!res.ok) throw new Error(data.message);

                            // 🔥 Reset avatar
                            const url = "https://res.cloudinary.com/dxtiklfxy/image/upload/v1773824246/profile/qhvfjaqer1o81nwkxvcz.png";

                            document.querySelector(".profile-avatar").src = url;
                            document.getElementById('headImg').src = url;
                            document.getElementById('sidebarImg').src = url;
                            document.getElementById("removePhotoBtn").classList.add("hidden");
                            showToast("Photo removed", "success");

                        } catch (error) {
                            showToast(error.message, "error");
                        }
                    };
                }

            </script>

            <script>
                const otpModal = document.getElementById("otpModal");

                const resendBtn = document.getElementById("resendOtpBtn");


                function openOtpModal() {
                    otpModal.classList.remove("hidden");
                    otpModal.classList.add("flex");

                    document.getElementById("otpInput").value = "";

                    startOtpTimer();
                }

                function closeOtpModalFunc() {
                    otpModal.classList.add("hidden");
                    otpModal.classList.remove("flex");

                    document.getElementById("otpInput").value = "";

                    clearInterval(timerInterval); // ✅ stop timer
                }

                document.getElementById("closeOtpModal").onclick = closeOtpModalFunc;


                let timerInterval;

                function startOtpTimer() {
                    let time = 50;

                    const timerEl = document.getElementById("otpTimer");

                    resendBtn.disabled = true;
                    resendBtn.classList.add("opacity-50", "cursor-not-allowed");

                    clearInterval(timerInterval);

                    timerInterval = setInterval(() => {

                        timerEl.textContent = `00:${time < 10 ? "0" : ""}${time}`;
                        resendBtn.textContent = `Resend in ${time}s`;

                        time--;

                        if (time < 0) {
                            clearInterval(timerInterval);

                            timerEl.textContent = "You can resend now";

                            resendBtn.disabled = false;
                            resendBtn.textContent = "Resend OTP";
                            resendBtn.classList.remove("opacity-50", "cursor-not-allowed");
                        }

                    }, 1000);
                }
            </script>

</body>