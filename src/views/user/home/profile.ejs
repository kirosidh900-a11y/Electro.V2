<script src="https://cdn.tailwindcss.com"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

<body class="bg-gray-100 font-sans">
    <%- include("../../partials/user/header") %>

    <div class="min-h-screen p-4 sm:p-6 lg:p-10">
        <div class="max-w-6xl mx-auto flex flex-col lg:flex-row gap-6">

            <aside class="w-full lg:w-1/4 bg-white rounded-xl shadow-sm overflow-hidden h-fit lg:sticky lg:top-6">
                <div class="p-6 flex items-center gap-4 border-b border-gray-50">
                    <div class="h-12 w-12 rounded-full bg-yellow-400 flex-shrink-0 flex items-center justify-center text-white overflow-hidden">
                        <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=Sidharth" alt="Avatar">
                    </div>
                    <div class="truncate">
                        <p class="text-xs text-gray-400">Hello,</p>
                        <h2 class="font-bold text-gray-800 truncate">Sidharth T</h2>
                    </div>
                </div>

                <nav class="p-4 space-y-1 overflow-x-auto">
                    <a href="#" class="flex items-center justify-between p-3 text-blue-600 bg-blue-50 rounded-lg font-medium">
                        <span class="flex items-center gap-3">
                            <i class="fa-solid fa-box"></i> My Orders
                        </span>
                        <i class="fa-solid fa-chevron-right text-xs hidden md:block"></i>
                    </a>

                    <div class="pt-4 pb-2 px-3 text-[10px] font-bold text-gray-400 uppercase tracking-widest">
                        Account Settings
                    </div>
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-1 gap-1">
                        <a href="#" class="block p-3 text-blue-600 font-medium hover:bg-gray-50 rounded-lg">Profile Information</a>
                        <a href="#" class="block p-3 text-gray-600 hover:bg-gray-50 rounded-lg">Manage Addresses</a>
                        <a href="#" class="block p-3 text-gray-600 hover:bg-gray-50 rounded-lg">My Referral Info</a>
                    </div>

                    <div class="pt-4 pb-2 px-3 text-[10px] font-bold text-gray-400 uppercase tracking-widest">
                        My Stuff
                    </div>
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-1 gap-1">
                        <a href="#" class="block p-3 text-gray-600 hover:bg-gray-50 rounded-lg">My Coupons</a>
                        <a href="#" class="block p-3 text-gray-600 hover:bg-gray-50 rounded-lg">My Reviews & Ratings</a>
                        <a href="#" class="block p-3 text-gray-600 hover:bg-gray-50 rounded-lg">My Wishlist</a>
                    </div>

                    <div class="mt-4 pt-4 border-t border-gray-100">
                        <button class="w-full flex items-center gap-3 p-3 text-red-500 hover:bg-red-50 rounded-lg transition-colors">
                            <i class="fa-solid fa-power-off"></i> Logout
                        </button>
                    </div>
                </nav>

                <div class="hidden lg:block p-4 space-y-2 bg-gray-50">
                    <p class="px-3 text-[10px] font-bold text-gray-400 uppercase">Frequently Visited</p>
                    <button class="w-full py-2 text-sm text-gray-600 bg-white border border-gray-200 rounded-md hover:shadow-sm">Track Order</button>
                    <button class="w-full py-2 text-sm text-gray-600 bg-white border border-gray-200 rounded-md hover:shadow-sm">Help Center</button>
                </div>
            </aside>

            <main class="flex-1 bg-white rounded-xl shadow-sm p-6 sm:p-8 md:p-12">
                <h1 class="text-xl md:text-2xl font-bold text-red-500 mb-8">Edit Your Profile</h1>

                <div class="flex flex-col items-center mb-10">
                    <div class="relative">
                        <div class="h-24 w-24 md:h-32 md:w-32 rounded-full bg-yellow-400 border-4 border-white shadow-lg overflow-hidden">
                            <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=Sidharth" alt="Avatar">
                        </div>
                        <button class="absolute -bottom-2 left-1/2 -translate-x-1/2 flex items-center gap-2 bg-slate-800 text-white px-4 py-2 rounded-full text-xs hover:bg-slate-700 whitespace-nowrap shadow-lg">
                            <i class="fa-solid fa-camera"></i> Upload Photo
                        </button>
                    </div>
                </div>

                <div class="space-y-8 w-full">
                    <section>
                        <div class="flex items-center justify-between mb-3">
                            <h3 class="font-bold text-gray-800">Personal Information</h3>
                            <button class="text-xs font-bold text-orange-500 hover:underline">Edit</button>
                        </div>
                        <input type="text" value="Sidharth T" class="w-full lg:w-2/3 p-3 border border-gray-200 rounded-lg bg-gray-50 focus:bg-white focus:ring-2 focus:ring-blue-500 outline-none transition-all">
                    </section>

                    <section class="space-y-4">
                        <h3 class="font-bold text-gray-800">Password Changes</h3>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                <label class="text-sm text-gray-500 mb-1 block">New Password</label>
                                <input type="password" placeholder="••••••••" class="w-full p-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none">
                            </div>
                            <div>
                                <label class="text-sm text-gray-500 mb-1 block">Confirm New Password</label>
                                <input type="password" placeholder="••••••••" class="w-full p-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none">
                            </div>
                        </div>
                        <div class="flex flex-col sm:flex-row justify-end gap-3 pt-2">
                            <button class="order-2 sm:order-1 px-6 py-2 text-gray-500 font-medium hover:text-gray-700">Cancel</button>
                            <button class="order-1 sm:order-2 px-6 py-2 bg-red-500 text-white font-bold rounded-lg shadow-md hover:bg-red-600 active:scale-95 transition-all">Add Password</button>
                        </div>
                    </section>

                    <section class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <div class="flex items-center justify-between mb-2">
                                <label class="text-sm font-medium text-gray-500">Email</label>
                                <button class="text-xs font-bold text-orange-500 hover:underline">Edit</button>
                            </div>
                            <input type="email" value="sidharth900@gmail.com" class="w-full p-3 border border-gray-200 rounded-lg bg-gray-50">
                        </div>
                        <div>
                            <div class="flex items-center justify-between mb-2">
                                <label class="text-sm font-medium text-gray-500">Phone</label>
                                <button class="text-xs font-bold text-orange-500 hover:underline">Edit</button>
                            </div>
                            <input type="text" placeholder="Enter your phone number" class="w-full p-3 border border-gray-200 rounded-lg bg-gray-50">
                        </div>
                    </section>
                </div>
            </main>
        </div>
    </div>

    <%- include("../../partials/user/footer") %>
</body>