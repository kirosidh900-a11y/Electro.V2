<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<script src="https://cdn.tailwindcss.com"></script>

<%- include("../../partials/user/header.ejs") %>

        <style>
                body {
                        font-family: 'Outfit', sans-serif;
                        background-color: #f9fafb;
                }

                .custom-scrollbar::-webkit-scrollbar {
                        width: 4px;
                }

                .custom-scrollbar::-webkit-scrollbar-thumb {
                        background: #d1d5db;
                        border-radius: 4px;
                }

                /* Shared Radio Selection Micro-Animations (Addresses & Payments) */
                .custom-radio:checked+.selectable-card {
                        border-color: #000;
                        background-color: #fafbfc;
                        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
                }

                .custom-radio:checked+.selectable-card .check-indicator {
                        border-color: #000;
                }

                .custom-radio:checked+.selectable-card .check-dot {
                        opacity: 1;
                        transform: scale(1);
                }
        </style>

        <main class="min-h-screen py-10">
                <div class="max-w-[1280px] mx-auto px-4 sm:px-6 lg:px-8">

                        <!-- Checkout Header -->
                        <div class="flex flex-col sm:flex-row sm:items-end justify-between mb-8 sm:mb-10 gap-4">
                                <div>
                                        <h1 class="text-3xl font-bold text-gray-900 tracking-tight">Checkout</h1>
                                        <p class="text-gray-500 mt-2">Complete your order securely</p>
                                </div>
                                <a href="/cart"
                                        class="inline-flex items-center gap-2 text-sm font-medium text-gray-600 hover:text-black transition-colors bg-white px-5 py-2.5 rounded-full border shadow-sm hover:shadow">
                                        <i class="fa-solid fa-arrow-left"></i> Back to Cart
                                </a>
                        </div>

                        <div class="flex flex-col lg:flex-row gap-10">

                                <!-- Left Side: Addresses & Payments -->
                                <div class="lg:w-2/3 flex flex-col gap-6">

                                        <!-- 1. Address Section -->
                                        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 sm:p-8">
                                                <div class="flex justify-between items-center mb-6">
                                                        <h2
                                                                class="text-xl font-bold text-gray-900 flex items-center gap-2">
                                                                <i class="fa-solid fa-location-dot text-black"></i>
                                                                Delivery Address
                                                        </h2>
                                                        <button onclick="openAddressModal()"
                                                                class="text-sm font-semibold text-blue-600 hover:text-blue-700 flex items-center gap-1 bg-blue-50 px-3 py-1.5 rounded-lg border border-blue-100 hover:bg-blue-100 transition-colors">
                                                                <i class="fa-solid fa-plus"></i> Add New
                                                        </button>
                                                </div>

                                                <div class="space-y-4">
                                                        <% if (typeof addresses !=='undefined' && addresses.length> 0) {
                                                                %>
                                                                <% addresses.forEach((addr, index)=> { %>
                                                                        <label
                                                                                class="block relative cursor-pointer group">
                                                                                <input type="radio"
                                                                                        name="selectedAddress"
                                                                                        value="<%= addr._id %>"
                                                                                        class="custom-radio peer sr-only"
                                                                                        <%=addr.isDefault || index===0
                                                                                        ? 'checked' : '' %>>

                                                                                <div
                                                                                        class="selectable-card p-5 rounded-xl border-2 border-gray-100 hover:border-gray-200 transition-all flex flex-col sm:flex-row gap-4">
                                                                                        <!-- Radio UI -->
                                                                                        <div class="mt-1 shrink-0">
                                                                                                <div
                                                                                                        class="check-indicator w-5 h-5 rounded-full border border-gray-300 flex items-center justify-center transition-colors">
                                                                                                        <div
                                                                                                                class="check-dot w-2.5 h-2.5 bg-black rounded-full opacity-0 scale-50 transition-all duration-200">
                                                                                                        </div>
                                                                                                </div>
                                                                                        </div>

                                                                                        <!-- Detail Block -->
                                                                                        <div class="flex-grow">
                                                                                                <div
                                                                                                        class="flex flex-wrap items-center gap-3 mb-1.5">
                                                                                                        <span
                                                                                                                class="font-bold text-gray-900 text-lg">
                                                                                                                <%= addr.name
                                                                                                                        %>
                                                                                                        </span>
                                                                                                        <span
                                                                                                                class="bg-gray-100 text-gray-600 text-[10px] font-bold px-2 py-0.5 rounded uppercase tracking-wider">
                                                                                                                <i
                                                                                                                        class="fa-solid <%= addr.addressType === 'Home' || addr.addressType === 'home' ? 'fa-home' : 'fa-briefcase' %> mr-1"></i>
                                                                                                                <%= addr.addressType
                                                                                                                        || 'HOME'
                                                                                                                        %>
                                                                                                        </span>
                                                                                                        <% if (addr.isDefault)
                                                                                                                { %>
                                                                                                                <span
                                                                                                                        class="bg-black text-white text-[10px] font-bold px-2 py-0.5 rounded shadow-sm">DEFAULT</span>
                                                                                                                <% } %>
                                                                                                </div>
                                                                                                <p
                                                                                                        class="text-gray-500 text-sm leading-relaxed mb-2">
                                                                                                        <%= addr.address
                                                                                                                %>, <%= addr.locality
                                                                                                                        %>
                                                                                                                        <br>
                                                                                                                        <%= addr.city
                                                                                                                                %>
                                                                                                                                ,
                                                                                                                                <%= addr.district
                                                                                                                                        %>
                                                                                                                                        <br>
                                                                                                                                        <%= addr.state
                                                                                                                                                %>
                                                                                                                                                -
                                                                                                                                                <span
                                                                                                                                                        class="font-medium text-gray-700">
                                                                                                                                                        <%= addr.pincode
                                                                                                                                                                %>
                                                                                                                                                </span>
                                                                                                </p>
                                                                                                <div
                                                                                                        class="flex items-center gap-2 text-sm font-medium text-gray-700">
                                                                                                        <i
                                                                                                                class="fa-solid fa-phone text-xs text-gray-400"></i>
                                                                                                        <%= addr.phone
                                                                                                                %>
                                                                                                </div>
                                                                                        </div>

                                                                                        <!-- Edit Actions -->
                                                                                        <div
                                                                                                class="flex flex-row sm:flex-col justify-end gap-2 shrink-0 z-10 relative">
                                                                                                <button type="button"
                                                                                                        onclick="openAddressModal('<%= encodeURIComponent(JSON.stringify(addr)) %>')"
                                                                                                        class="text-gray-400 hover:text-black p-2 rounded-lg hover:bg-gray-50 transition-colors tooltip-trigger"
                                                                                                        title="Edit Address">
                                                                                                        <i
                                                                                                                class="fa-solid fa-pen-to-square"></i>
                                                                                                </button>
                                                                                                <!-- <button type="button" onclick="deleteAddress('<%= addr._id %>')" class="text-gray-400 hover:text-red-500 p-2 rounded-lg hover:bg-red-50 transition-colors tooltip-trigger" title="Delete Address">
                                                <i class="fa-solid fa-trash-can"></i>
                                            </button> -->
                                                                                        </div>
                                                                                </div>
                                                                        </label>
                                                                        <% }) %>
                                                                                <% } else { %>
                                                                                        <!-- Empty State Address -->
                                                                                        <div
                                                                                                class="text-center py-10 bg-gray-50 rounded-xl border border-dashed border-gray-200">
                                                                                                <div
                                                                                                        class="w-16 h-16 bg-white rounded-full flex items-center justify-center mx-auto mb-4 shadow-sm border border-gray-100">
                                                                                                        <i
                                                                                                                class="fa-regular fa-address-book text-2xl text-gray-400"></i>
                                                                                                </div>
                                                                                                <h3
                                                                                                        class="text-gray-900 font-semibold mb-1">
                                                                                                        No Address Found
                                                                                                </h3>
                                                                                                <p
                                                                                                        class="text-gray-500 text-sm mb-5">
                                                                                                        Please add a
                                                                                                        delivery address
                                                                                                        to proceed.</p>
                                                                                                <button onclick="openAddressModal()"
                                                                                                        class="text-sm font-semibold text-white bg-black px-6 py-2.5 rounded-full hover:bg-gray-800 transition-colors shadow-lg hover:shadow-xl">
                                                                                                        Add New Address
                                                                                                </button>
                                                                                        </div>
                                                                                        <% } %>
                                                </div>
                                        </div>

                                        <!-- 2. Payment Method Section -->
                                        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 sm:p-8">
                                                <div class="flex items-center gap-2 mb-6">
                                                        <i class="fa-solid fa-wallet text-black text-xl"></i>
                                                        <h2 class="text-xl font-bold text-gray-900">Payment Options</h2>
                                                </div>

                                                <div class="space-y-4">
                                                        <!-- Online Payment (Razorpay/RuPay) -->
                                                        <label class="block relative cursor-pointer group">
                                                                <input type="radio" name="paymentMethod"
                                                                        value="razorpay"
                                                                        class="custom-radio peer sr-only" checked>
                                                                <div
                                                                        class="selectable-card p-5 rounded-xl border-2 border-gray-100 hover:border-gray-200 transition-all flex items-center gap-4">
                                                                        <div class="shrink-0 mt-0.5">
                                                                                <div
                                                                                        class="check-indicator w-5 h-5 rounded-full border border-gray-300 flex items-center justify-center transition-colors">
                                                                                        <div
                                                                                                class="check-dot w-2.5 h-2.5 bg-black rounded-full opacity-0 scale-50 transition-all duration-200">
                                                                                        </div>
                                                                                </div>
                                                                        </div>
                                                                        <div
                                                                                class="flex-grow flex justify-between items-center pr-2">
                                                                                <div>
                                                                                        <span
                                                                                                class="font-bold text-gray-900 block mb-0.5 text-base">Online
                                                                                                Payment
                                                                                                (Razorpay)</span>
                                                                                        <span
                                                                                                class="text-xs font-medium text-gray-500">Pay
                                                                                                securely via UPI, RuPay,
                                                                                                Credit/Debit
                                                                                                Cards</span>
                                                                                </div>
                                                                                <div class="flex gap-2">
                                                                                        <div
                                                                                                class="w-10 h-6 bg-gray-50 rounded border border-gray-200 flex items-center justify-center">
                                                                                                <i
                                                                                                        class="fa-brands fa-google-pay text-gray-600"></i>
                                                                                        </div>
                                                                                        <div
                                                                                                class="w-10 h-6 bg-gray-50 rounded border border-gray-200 flex items-center justify-center">
                                                                                                <i
                                                                                                        class="fa-regular fa-credit-card text-gray-600 text-xs"></i>
                                                                                        </div>
                                                                                </div>
                                                                        </div>
                                                                </div>
                                                        </label>

                                                        <!-- Cash on Delivery -->
                                                        <label class="block relative cursor-pointer group">
                                                                <input type="radio" name="paymentMethod" value="cod"
                                                                        class="custom-radio peer sr-only">
                                                                <div
                                                                        class="selectable-card p-5 rounded-xl border-2 border-gray-100 hover:border-gray-200 transition-all flex items-center gap-4">
                                                                        <div class="shrink-0 mt-0.5">
                                                                                <div
                                                                                        class="check-indicator w-5 h-5 rounded-full border border-gray-300 flex items-center justify-center transition-colors">
                                                                                        <div
                                                                                                class="check-dot w-2.5 h-2.5 bg-black rounded-full opacity-0 scale-50 transition-all duration-200">
                                                                                        </div>
                                                                                </div>
                                                                        </div>
                                                                        <div
                                                                                class="flex-grow flex justify-between items-center pr-2">
                                                                                <div>
                                                                                        <span
                                                                                                class="font-bold text-gray-900 block mb-0.5 text-base">Cash
                                                                                                on Delivery (COD)</span>
                                                                                        <span
                                                                                                class="text-xs font-medium text-gray-500">Pay
                                                                                                with cash when your
                                                                                                order arrives</span>
                                                                                </div>
                                                                                <div
                                                                                        class="w-10 h-6 bg-gray-50 rounded border border-gray-200 flex items-center justify-center">
                                                                                        <i
                                                                                                class="fa-solid fa-money-bill-wave text-green-600 text-xs"></i>
                                                                                </div>
                                                                        </div>
                                                                </div>
                                                        </label>
                                                </div>
                                        </div>

                                </div>

                                <!-- Right Side: Order Summary & Coupons -->
                                <div class="lg:w-1/3">
                                        <div
                                                class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 sm:p-8 sticky top-10">
                                                <h2
                                                        class="text-xl font-bold text-gray-900 mb-5 flex items-center gap-2 border-b border-gray-100 pb-4">
                                                        Order Summary
                                                </h2>

                                                <!-- 1. Mapping Cart Items -->
                                                <div
                                                        class="max-h-[300px] overflow-y-auto custom-scrollbar pr-2 mb-6 space-y-4 border-b border-gray-100 pb-6">
                                                        <% let subtotal=0; let totalDiscounts=0; let totalGstAmount=0;
                                                                let totalQuantity=0; if (typeof cart !=='undefined' &&
                                                                cart.items && cart.items.length> 0) {
                                                                cart.items.forEach(item => {
                                                                const regularPrice = item.variantId?.regular_price ?? item.variantId?.price ?? 0;
                                                                const finalPrice   = item.variantId?.finalPrice   ?? regularPrice;
                                                                const qty          = item.quantity || 1;

                                                                const itemTotal    = finalPrice * qty;
                                                                const itemDiscount = Math.max(regularPrice - finalPrice, 0) * qty;

                                                                const gstAmount    = item.variantId?.gstAmount ?? 0;
                                                                const gstChunk     = gstAmount * qty;

                                                                // subtotal = MRP total (so discount row makes sense)
                                                                subtotal        += regularPrice * qty;
                                                                totalDiscounts  += itemDiscount;
                                                                totalGstAmount  += gstChunk;
                                                                totalQuantity   += qty;
                                                                %>
                                                                <div class="flex gap-4 items-center">
                                                                        <a href="/product/<%= item?.productId?._id %>"
                                                                                class="relative shrink-0 w-16 h-16 bg-[#f8f9fa] rounded-xl flex items-center justify-center p-1.5 border border-gray-50 hover:opacity-80 transition">
                                                                                <img src="<%= item?.variantId?.images?.[0] || '/images/default.png' %>"
                                                                                        alt="<%= item?.productId?.name %>"
                                                                                        class="w-full h-full object-contain mix-blend-multiply">
                                                                                <span
                                                                                        class="absolute -top-1.5 -right-1.5 bg-gray-900 text-white text-[10px] font-bold w-5 h-5 flex items-center justify-center rounded-full shadow-sm">
                                                                                        <%= qty %>
                                                                                </span>
                                                                        </a>
                                                                        <div class="flex-grow flex flex-col">
                                                                                <% if (item.productId?.brand?.name) { %>
                                                                                        <span
                                                                                                class="text-[9px] font-bold text-gray-400 uppercase tracking-widest">
                                                                                                <%= item.productId.brand.name
                                                                                                        %>
                                                                                        </span>
                                                                                        <% } %>
                                                                                                <a href="/product/<%= item?.productId?._id %>"
                                                                                                        class="text-sm font-semibold text-gray-900 line-clamp-1 hover:text-blue-600 transition">
                                                                                                        <%= item.productId?.name
                                                                                                                %>
                                                                                                </a>
                                                                                                <div
                                                                                                        class="text-[11px] text-gray-500 mt-0.5 space-x-1">
                                                                                                        <% if (item.variantId?.attributes?.color)
                                                                                                                { %>
                                                                                                                <span>
                                                                                                                        <%= item.variantId.attributes.color
                                                                                                                                %>
                                                                                                                </span>
                                                                                                                <% } %>
                                                                                                                        <% if (item.variantId?.attributes?.rom)
                                                                                                                                {
                                                                                                                                %>
                                                                                                                                <span>| <%= item.variantId.attributes.rom
                                                                                                                                                %>
                                                                                                                                </span>
                                                                                                                                <% }
                                                                                                                                        %>
                                                                                                </div>
                                                                        </div>
                                                                        <div class="shrink-0 text-right">
                                                                                <div
                                                                                        class="text-sm font-bold text-gray-900">
                                                                                        ₹<%= itemTotal.toLocaleString('en-IN')
                                                                                                %>
                                                                                </div>
                                                                                <% if (itemDiscount> 0) { %>
                                                                                        <div
                                                                                                class="text-[10px] text-gray-400 line-through">
                                                                                                ₹<%= (regularPrice *
                                                                                                        qty).toLocaleString('en-IN')
                                                                                                        %>
                                                                                        </div>
                                                                                        <% } %>
                                                                        </div>
                                                                </div>
                                                                <% }); } %>
                                                </div>

                                                <!-- 2. Coupon Block — fully dynamic, no reload needed -->
                                                <div class="mb-6" id="couponBlock">
                                                        <label class="block text-sm font-bold text-gray-900 mb-2.5">Have a Coupon?</label>
                                                        <div class="flex gap-2">
                                                                <input type="text" id="couponInput"
                                                                        placeholder="Enter coupon code"
                                                                        class="flex-grow bg-white border border-gray-300 rounded-lg px-4 py-2.5 focus:ring-2 focus:ring-black focus:border-black outline-none transition-all text-sm font-medium uppercase placeholder:normal-case shadow-sm">
                                                                <button type="button" id="couponActionBtn"
                                                                        class="bg-gray-900 text-white px-5 py-2.5 rounded-lg text-sm font-semibold hover:bg-gray-800 transition-colors shadow-sm">
                                                                        Apply
                                                                </button>
                                                        </div>
                                                        <div id="couponMsg" class="mt-2.5 hidden"></div>
                                                </div>

                                                <% // Final Calculation
                                                        const couponDiscountAmount = cart?.appliedCoupon?.code ? (cart.couponDiscountAmount || 0) : 0;
                                                        let finalAmountAfterOfferAndCoupon = subtotal - totalDiscounts - couponDiscountAmount;
                                                        if (finalAmountAfterOfferAndCoupon < 0) finalAmountAfterOfferAndCoupon = 0;
                                                        let deliveryCharges = finalAmountAfterOfferAndCoupon >= 500 ? 0 : 40;
                                                        if (totalQuantity === 0) deliveryCharges = 0;
                                                        let finalGrandTotal = finalAmountAfterOfferAndCoupon + deliveryCharges;
                                                        %>

                                                        <!-- 3. Bill Breakup -->
                                                        <div
                                                                class="space-y-3 mb-6 bg-gray-50 p-4 rounded-xl border border-gray-100/50">
                                                                <div
                                                                        class="flex justify-between items-center text-gray-600">
                                                                        <span class="text-sm">Subtotal (<%=
                                                                                        totalQuantity %> items)</span>
                                                                        <span class="font-medium text-gray-900">₹<%=
                                                                                        subtotal.toLocaleString('en-IN')
                                                                                        %></span>
                                                                </div>

                                                                <% if (totalDiscounts> 0) { %>
                                                                        <div
                                                                                class="flex justify-between items-center text-green-600">
                                                                                <span class="text-sm">Product
                                                                                        Discounts</span>
                                                                                <span class="font-medium">- ₹<%=
                                                                                                totalDiscounts.toLocaleString('en-IN')
                                                                                                %></span>
                                                                        </div>
                                                                        <% } %>

                                                                                <% if (couponDiscountAmount> 0) { %>
                                                                                        <div id="couponSavingsRow"
                                                                                                class="flex justify-between items-center text-green-600">
                                                                                                <span
                                                                                                        class="text-sm flex items-center gap-1.5"><i
                                                                                                                class="fa-solid fa-tag text-[10px]"></i>
                                                                                                        Coupon
                                                                                                        Savings</span>
                                                                                                <span
                                                                                                        class="font-medium" id="couponSavingsAmt">-
                                                                                                        ₹<%= couponDiscountAmount.toLocaleString('en-IN')
                                                                                                                %>
                                                                                                </span>
                                                                                        </div>
                                                                                        <% } else { %>
                                                                                        <div id="couponSavingsRow" class="hidden flex justify-between items-center text-green-600">
                                                                                                <span class="text-sm flex items-center gap-1.5"><i class="fa-solid fa-tag text-[10px]"></i> Coupon Savings</span>
                                                                                                <span class="font-medium" id="couponSavingsAmt"></span>
                                                                                        </div>
                                                                                        <% } %>

                                                                                                <div
                                                                                                        class="flex justify-between items-center text-gray-600">
                                                                                                        <span
                                                                                                                class="text-sm">Tax
                                                                                                                (GST)
                                                                                                                <span
                                                                                                                        class="text-[10px] ml-1 text-gray-400">Included</span></span>
                                                                                                        <span
                                                                                                                class="font-medium text-gray-900">₹
                                                                                                                <%= Math.round(totalGstAmount).toLocaleString('en-IN')
                                                                                                                        %>
                                                                                                        </span>
                                                                                                </div>

                                                                                                <div
                                                                                                        class="flex justify-between items-center text-gray-600 border-t border-gray-200/50 pt-2 mt-2">
                                                                                                        <span
                                                                                                                class="text-sm">Delivery</span>
                                                                                                        <% if (deliveryCharges===0)
                                                                                                                { %>
                                                                                                                <span
                                                                                                                        class="font-medium text-green-600 text-sm bg-green-100/50 px-2 py-0.5 rounded">Free</span>
                                                                                                                <% } else
                                                                                                                        {
                                                                                                                        %>
                                                                                                                        <span
                                                                                                                                class="font-medium text-gray-900">₹
                                                                                                                                <%= deliveryCharges.toLocaleString('en-IN')
                                                                                                                                        %>
                                                                                                                        </span>
                                                                                                                        <% }
                                                                                                                                %>
                                                                                                </div>
                                                        </div>

                                                        <!-- 4. Grand Total -->
                                                        <div class="flex justify-between items-end mb-8 pt-1">
                                                                <div>
                                                                        <span class="block text-sm font-medium text-gray-500 mb-1">Total Amount</span>
                                                                        <span id="overallSaveLabel"
                                                                                class="text-[11px] text-green-600 font-semibold bg-green-50 px-2 py-1 rounded
                                                                                <%= (totalDiscounts + couponDiscountAmount) > 0 ? '' : 'hidden' %>">
                                                                                Overall save ₹<%= (totalDiscounts + couponDiscountAmount).toLocaleString('en-IN') %>
                                                                        </span>
                                                                </div>
                                                                <span id="grandTotalDisplay"
                                                                        class="font-bold text-3xl text-gray-900 tracking-tight">
                                                                        ₹<%= finalGrandTotal.toLocaleString('en-IN') %>
                                                                </span>
                                                        </div>

                                                        <button id="checkoutProceedBtn"
                                                                class="group relative w-full flex justify-center items-center gap-3 bg-black text-white py-4 rounded-xl font-semibold text-lg hover:bg-gray-800 transition-all shadow-lg hover:shadow-xl overflow-hidden disabled:opacity-50 disabled:cursor-not-allowed"
                                                                <%=totalQuantity===0 ? 'disabled' : '' %>>
                                                                <span class="relative z-10 flex items-center gap-2">
                                                                        Place Order
                                                                        <i
                                                                                class="fa-solid fa-arrow-right text-sm bg-white/20 p-1.5 rounded-full group-hover:bg-white/30 group-hover:translate-x-1 transition-all"></i>
                                                                </span>
                                                        </button>

                                                        <div
                                                                class="mt-5 text-center text-[11px] text-gray-400 flex items-center justify-center gap-4">
                                                                <span><i class="fa-solid fa-shield-halved mr-1"></i>
                                                                        Secure Checkout</span>
                                                                <span><i class="fa-solid fa-truck-fast mr-1"></i>
                                                                        Express Delivery</span>
                                                        </div>
                                        </div>
                                </div>

                        </div>
                </div>
        </main>

        <!-- Updated Advanced Address Modal aligned with Backend Specs -->
        <div id="addressModal" class="hidden fixed inset-0 z-50 flex items-center justify-center transition-opacity">
                <div class="absolute inset-0 bg-gray-900/40 backdrop-blur-sm transition-opacity"
                        onclick="closeAddressModal()"></div>

                <div
                        class="bg-white w-full max-w-2xl rounded-2xl shadow-2xl relative z-10 mx-4 max-h-[90vh] flex flex-col transform transition-all scale-100">
                        <!-- Header -->
                        <div class="px-6 py-5 border-b border-gray-100 flex justify-between items-center shrink-0">
                                <h3 class="text-xl font-bold text-gray-900" id="addressModalTitle">Address Details</h3>
                                <button onclick="closeAddressModal()"
                                        class="text-gray-400 hover:text-black transition-colors w-8 h-8 flex items-center justify-center rounded-full hover:bg-gray-100">
                                        <i class="fa-solid fa-xmark text-lg"></i>
                                </button>
                        </div>
                        <!-- Form Body -->
                        <div class="p-6 overflow-y-auto custom-scrollbar">
                                <form id="addressForm" class="space-y-5">
                                        <!-- Hidden state passed optionally -->
                                        <input type="hidden" id="addressId" name="addressId">
                                        <input type="hidden" id="addrStateCode" name="addrStateCode">

                                        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">

                                                <div class="col-span-1">
                                                        <label
                                                                class="block text-xs font-bold text-gray-500 uppercase mb-1.5">Full
                                                                Name *</label>
                                                        <input name="name" type="text" required
                                                                class="w-full bg-gray-50 border border-gray-200 rounded-lg px-4 py-3 focus:bg-white focus:ring-2 focus:ring-black focus:border-black outline-none transition-all text-sm">
                                                </div>

                                                <div class="col-span-1">
                                                        <label
                                                                class="block text-xs font-bold text-gray-500 uppercase mb-1.5">Phone
                                                                Number *</label>
                                                        <input name="phone" type="tel" required
                                                                class="w-full bg-gray-50 border border-gray-200 rounded-lg px-4 py-3 focus:bg-white focus:ring-2 focus:ring-black focus:border-black outline-none transition-all text-sm">
                                                </div>

                                                <div class="col-span-1">
                                                        <label
                                                                class="block text-xs font-bold text-gray-500 uppercase mb-1.5">Pincode
                                                                *</label>
                                                        <input name="pincode" type="text" required
                                                                class="w-full bg-gray-50 border border-gray-200 rounded-lg px-4 py-3 focus:bg-white focus:ring-2 focus:ring-black focus:border-black outline-none transition-all text-sm">
                                                </div>

                                                <div class="col-span-1">
                                                        <label
                                                                class="block text-xs font-bold text-gray-500 uppercase mb-1.5">Locality
                                                                *</label>
                                                        <input name="locality" type="text" required
                                                                class="w-full bg-gray-50 border border-gray-200 rounded-lg px-4 py-3 focus:bg-white focus:ring-2 focus:ring-black focus:border-black outline-none transition-all text-sm">
                                                </div>

                                                <div class="col-span-2">
                                                        <label
                                                                class="block text-xs font-bold text-gray-500 uppercase mb-1.5">Address
                                                                (Area and Street) *</label>
                                                        <textarea name="address" required rows="3"
                                                                class="w-full bg-gray-50 border border-gray-200 rounded-lg px-4 py-3 focus:bg-white focus:ring-2 focus:ring-black focus:border-black outline-none transition-all text-sm resize-none"></textarea>
                                                </div>

                                                <div class="col-span-1">
                                                        <label
                                                                class="block text-xs font-bold text-gray-500 uppercase mb-1.5">City/Town
                                                                *</label>
                                                        <input name="city" type="text" required
                                                                class="w-full bg-gray-50 border border-gray-200 rounded-lg px-4 py-3 focus:bg-white focus:ring-2 focus:ring-black focus:border-black outline-none transition-all text-sm">
                                                </div>

                                                <div class="col-span-1">
                                                        <label
                                                                class="block text-xs font-bold text-gray-500 uppercase mb-1.5">State
                                                                *</label>
                                                        <select name="state" required
                                                                class="w-full bg-white border border-gray-200 rounded-lg px-4 py-3 focus:ring-2 focus:ring-black focus:border-black outline-none transition-all text-sm cursor-pointer shadow-sm"></select>
                                                </div>

                                                <div class="col-span-1">
                                                        <label
                                                                class="block text-xs font-bold text-gray-500 uppercase mb-1.5">District
                                                                *</label>
                                                        <select name="district" required
                                                                class="w-full bg-white border border-gray-200 rounded-lg px-4 py-3 focus:ring-2 focus:ring-black focus:border-black outline-none transition-all text-sm cursor-pointer shadow-sm"></select>
                                                </div>

                                                <div class="col-span-1">
                                                        <label
                                                                class="block text-xs font-bold text-gray-500 uppercase mb-1.5">Landmark
                                                                (Optional)</label>
                                                        <input name="landmark" type="text"
                                                                class="w-full bg-gray-50 border border-gray-200 rounded-lg px-4 py-3 focus:bg-white focus:ring-2 focus:ring-black focus:border-black outline-none transition-all text-sm">
                                                </div>

                                                <div class="col-span-1">
                                                        <label
                                                                class="block text-xs font-bold text-gray-500 uppercase mb-1.5">Alternate
                                                                Phone (Optional)</label>
                                                        <input name="altPhone" type="tel"
                                                                class="w-full bg-gray-50 border border-gray-200 rounded-lg px-4 py-3 focus:bg-white focus:ring-2 focus:ring-black focus:border-black outline-none transition-all text-sm">
                                                </div>

                                                <!-- Address Type -->
                                                <div class="col-span-1">
                                                        <label
                                                                class="block text-xs font-bold text-gray-500 uppercase mb-2">Address
                                                                Type</label>
                                                        <div class="flex gap-4">
                                                                <label
                                                                        class="flex items-center gap-2 cursor-pointer group">
                                                                        <input type="radio" name="addressType"
                                                                                value="home" checked
                                                                                class="w-4 h-4 text-black border-gray-300 focus:ring-black">
                                                                        <span
                                                                                class="text-sm text-gray-700 group-hover:text-black">Home</span>
                                                                </label>
                                                                <label
                                                                        class="flex items-center gap-2 cursor-pointer group">
                                                                        <input type="radio" name="addressType"
                                                                                value="work"
                                                                                class="w-4 h-4 text-black border-gray-300 focus:ring-black">
                                                                        <span
                                                                                class="text-sm text-gray-700 group-hover:text-black">Work</span>
                                                                </label>
                                                        </div>
                                                </div>

                                                <!-- Default Switch -->
                                                <div class="col-span-2 pt-2">
                                                        <label
                                                                class="inline-flex items-center gap-3 cursor-pointer group">
                                                                <div class="relative flex items-center">
                                                                        <input type="checkbox" name="isDefault"
                                                                                class="peer w-5 h-5 appearance-none border-2 border-gray-300 rounded focus:ring-0 checked:bg-black checked:border-black transition-all cursor-pointer">
                                                                        <i
                                                                                class="fa-solid fa-check absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 text-white text-[10px] opacity-0 peer-checked:opacity-100 pointer-events-none transition-opacity"></i>
                                                                </div>
                                                                <span
                                                                        class="text-sm font-medium text-gray-700 group-hover:text-black transition-colors">Set
                                                                        as default delivery address</span>
                                                        </label>
                                                </div>

                                        </div>
                                </form>
                        </div>

                        <!-- Footer -->
                        <div
                                class="px-6 py-5 border-t border-gray-100 flex justify-end gap-3 shrink-0 bg-gray-50 rounded-b-2xl">
                                <button type="button" onclick="closeAddressModal()"
                                        class="px-6 py-2.5 text-sm font-semibold text-gray-600 hover:text-black hover:bg-gray-200 rounded-lg transition-colors">Cancel</button>
                                <button type="submit" form="addressForm"
                                        class="px-6 py-2.5 text-sm font-semibold text-white bg-black hover:bg-gray-800 rounded-lg transition-all shadow-md hover:shadow-lg">Save
                                        Address</button>
                        </div>
                </div>
        </div>

        <div id="confirmModal" class="hidden fixed inset-0 z-50 flex items-center justify-center">
                <div class="absolute inset-0 bg-black/40 backdrop-blur-sm"></div>

                <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md mx-4 relative z-10 p-6">

                        <h3 id="confirmTitle" class="text-lg font-bold text-gray-900 mb-2">
                                Confirm Action
                        </h3>

                        <p id="confirmMessage" class="text-sm text-gray-500 mb-6">
                                Are you sure?
                        </p>

                        <div class="flex justify-end gap-3">
                                <button id="confirmCancelBtn"
                                        class="px-4 py-2 text-sm font-semibold text-gray-600 hover:bg-gray-100 rounded-lg">
                                        Cancel
                                </button>

                                <button id="confirmOkBtn"
                                        class="px-4 py-2 text-sm font-semibold bg-black text-white rounded-lg hover:bg-gray-800">
                                        Continue
                                </button>
                        </div>
                </div>
        </div>

        <script src="https://checkout.razorpay.com/v1/checkout.js"></script>

        <script type="module">
                import { showToast } from "/partials/errorMsg.utils.js";
                import { confirmAction } from "/partials/confirm.util.js";

                // ---------------- Location Logic APIs ----------------
                let statesData = [];

                async function loadStates() {
                        try {
                                const res = await fetch('/location/states');
                                statesData = await res.json();
                        } catch (err) {
                                console.error("States fetch failed", err);
                        }
                }
                loadStates();

                async function loadDistricts(stateCode) {
                        try {
                                const res = await fetch(`/location/districts/${stateCode}`);
                                return await res.json();
                        } catch (err) {
                                console.error("District fetch failed", err);
                                return [];
                        }
                }

                // ---------------- Modal Core Interactions ----------------
                window.openAddressModal = async function (addressJson = null) {
                        const addr = addressJson ? JSON.parse(decodeURIComponent(addressJson)) : {};
                        const isEdit = !!addr._id;

                        const modal = document.getElementById('addressModal');
                        const form = document.getElementById('addressForm');

                        modal.classList.remove('hidden');

                        // Pre-fill Values
                        form.name.value = addr.name || '';
                        form.phone.value = addr.phone || '';
                        form.altPhone.value = addr.altPhone || '';
                        form.pincode.value = addr.pincode || '';
                        form.locality.value = addr.locality || '';
                        form.address.value = addr.address || '';
                        form.city.value = addr.city || '';
                        form.landmark.value = addr.landmark || '';

                        if (addr.addressType) {
                                form.addressType.value = (addr.addressType.toLowerCase() === 'home') ? 'Home' : 'Work';
                        } else {
                                form.addressType.value = 'Home';
                        }

                        form.isDefault.checked = addr.isDefault || false;

                        document.getElementById('addressId').value = addr._id || '';

                        // Dynamic State Dropdown Initializer
                        const stateSelect = form.state;
                        const districtSelect = form.district;

                        stateSelect.innerHTML = '<option value="">Select State</option>' +
                                statesData.map(s => `
                <option value="${s.isoCode}" ${s.isoCode === addr.stateCode ? 'selected' : ''}>
                    ${s.name}
                </option>
            `).join('');

                        // Populate District if Edit Mode contains state
                        if (addr.stateCode) {
                                const districts = await loadDistricts(addr.stateCode);
                                districtSelect.innerHTML = '<option value="">Select District</option>' +
                                        districts.map(d => `
                    <option value="${d}" ${d === addr.district ? 'selected' : ''}>${d}</option>
                `).join('');
                        } else {
                                districtSelect.innerHTML = '<option value="">Select District</option>';
                        }

                        // State Change Event Mapping Context
                        stateSelect.onchange = async () => {
                                const stateCode = stateSelect.value;
                                if (!stateCode) {
                                        districtSelect.innerHTML = '<option value="">Select District</option>';
                                        return;
                                }
                                const districts = await loadDistricts(stateCode);
                                districtSelect.innerHTML = '<option value="">Select District</option>' +
                                        districts.map(d => `<option value="${d}">${d}</option>`).join('');
                        };
                };

                window.closeAddressModal = () => {
                        document.getElementById('addressModal').classList.add('hidden');
                };

                // Form Validator (Extracted directly from backend logic)
                function validateForm(form, stateSelect, districtSelect) {
                        const name = form.name.value.trim();
                        const phone = form.phone.value.trim();
                        const altPhone = form.altPhone.value.trim();
                        const pincode = form.pincode.value.trim();
                        const locality = form.locality.value.trim();
                        const address = form.address.value.trim();
                        const city = form.city.value.trim();
                        const state = stateSelect.value;
                        const district = districtSelect.value;

                        if (!/^[A-Za-z ]{3,}$/.test(name)) { showToast("Name must be at least 3 letters", "warning"); form.name.focus(); return false; }
                        if (!/^[6-9]\d{9}$/.test(phone)) { showToast("Enter valid 10-digit phone number", "warning"); form.phone.focus(); return false; }
                        if (altPhone && !/^[6-9]\d{9}$/.test(altPhone)) { showToast("Invalid alternate phone number", "warning"); form.altPhone.focus(); return false; }
                        if (!/^[1-9][0-9]{5}$/.test(pincode)) { showToast("Invalid pincode", "warning"); form.pincode.focus(); return false; }
                        if (locality.length < 3) { showToast("Locality must be at least 3 characters", "warning"); form.locality.focus(); return false; }
                        if (address.length < 5) { showToast("Address too short", "warning"); form.address.focus(); return false; }
                        if (!/^[A-Za-z ]{2,}$/.test(city)) { showToast("Enter valid city name", "warning"); form.city.focus(); return false; }
                        if (!state) { showToast("Please select state", "warning"); return false; }
                        if (!district) { showToast("Please select district", "warning"); return false; }

                        return true;
                }

                // Capture Submit Action for Modal Form
                document.getElementById('addressForm').onsubmit = async (e) => {
                        e.preventDefault();

                        const form = e.target;
                        const stateSelect = form.state;
                        const districtSelect = form.district;
                        const isEdit = document.getElementById('addressId').value !== '';
                        const addressId = document.getElementById('addressId').value;

                        if (!validateForm(form, stateSelect, districtSelect)) return;

                        const formData = {
                                name: form.name.value.trim(),
                                phone: form.phone.value.trim(),
                                altPhone: form.altPhone.value.trim() || null,
                                pincode: form.pincode.value.trim(),
                                locality: form.locality.value.trim(),
                                address: form.address.value.trim(),
                                city: form.city.value.trim(),
                                state: stateSelect.options[stateSelect.selectedIndex].text,
                                stateCode: stateSelect.value,
                                district: districtSelect.value,
                                landmark: form.landmark.value.trim() || null,
                                addressType: form.addressType.value,
                                isDefault: form.isDefault.checked
                        };

                        try {
                                const url = isEdit ? `/address/${addressId}` : '/address';
                                const method = isEdit ? 'PUT' : 'POST';

                                const res = await fetch(url, {
                                        method,
                                        headers: { "Content-Type": "application/json", "Accept": "application/json" },
                                        body: JSON.stringify(formData)
                                });

                                const result = await res.json();
                                if (!res.ok) throw new Error(result.message || "Failed to save address");

                                showToast(result.message || "Address saved successfully", "success");
                                setTimeout(() => location.reload(), 1000);

                        } catch (error) {
                                showToast(error.message, "error");
                        }
                };

                // Auto-formatting Input RegEx Events
                document.addEventListener("input", (e) => {
                        if (e.target.name === "phone" || e.target.name === "altPhone") {
                                e.target.value = e.target.value.replace(/\D/g, "").slice(0, 10);
                        }
                        if (e.target.name === "pincode") {
                                e.target.value = e.target.value.replace(/\D/g, "").slice(0, 6);
                        }
                });

                // Delete Logic Extracted from backend specs
                window.deleteAddress = async function (id) {
                        if (await confirmAction("Delete Address?", "This action cannot be undone.")) {
                                try {
                                        const res = await fetch(`/address/${id}`, {
                                                method: 'DELETE',
                                                headers: { "Accept": "application/json" }
                                        });
                                        const data = await res.json();

                                        if (res.ok) {
                                                showToast("Address deleted securely", "success");
                                                setTimeout(() => location.reload(), 500);
                                        } else throw new Error(data.message);
                                } catch (error) {
                                        showToast(error.message, "error");
                                }
                        }
                };

                // ---------------- Coupon Handlers (dynamic, no reload) ----------------
                const couponInput     = document.getElementById('couponInput');
                const couponActionBtn = document.getElementById('couponActionBtn');
                const couponMsg       = document.getElementById('couponMsg');
                const couponSavingsRow = document.getElementById('couponSavingsRow');
                const couponSavingsAmt = document.getElementById('couponSavingsAmt');
                const grandTotalDisplay = document.getElementById('grandTotalDisplay');
                const overallSaveLabel  = document.getElementById('overallSaveLabel');

                // Base totals from server — subtotal is MRP, discounts are offer savings
                const BASE_SUBTOTAL   = <%= subtotal %>;
                const BASE_DISCOUNTS  = <%= totalDiscounts %>;
                const BASE_GST        = <%= Math.round(totalGstAmount) %>;
                let   activeCouponDiscount = <%= couponDiscountAmount %>;

                // Store initial coupon state — applied after functions are defined below
                const INITIAL_COUPON_CODE     = <%- JSON.stringify(cart?.appliedCoupon?.code || null) %>;
                const INITIAL_COUPON_DISCOUNT = <%= cart?.couponDiscountAmount || 0 %>;

                function fmt(n) {
                        return n.toLocaleString('en-IN');
                }

                function recalcTotal(couponDiscount) {
                        activeCouponDiscount = couponDiscount;
                        const afterDiscount  = Math.max(0, BASE_SUBTOTAL - BASE_DISCOUNTS - couponDiscount);
                        const delivery       = afterDiscount >= 500 ? 0 : 40;
                        const grand          = afterDiscount + delivery;
                        const totalSavings   = BASE_DISCOUNTS + couponDiscount;

                        grandTotalDisplay.textContent = '₹' + fmt(grand);

                        if (couponDiscount > 0) {
                                couponSavingsRow.classList.remove('hidden');
                                couponSavingsAmt.textContent = '- ₹' + fmt(couponDiscount);
                        } else {
                                couponSavingsRow.classList.add('hidden');
                        }

                        if (totalSavings > 0) {
                                overallSaveLabel.textContent = 'Overall save ₹' + fmt(totalSavings);
                                overallSaveLabel.classList.remove('hidden');
                        } else {
                                overallSaveLabel.classList.add('hidden');
                        }
                }

                function setCouponAppliedState(code, discount) {
                        couponInput.value    = code;
                        couponInput.readOnly = true;
                        couponActionBtn.dataset.state = 'applied';
                        couponActionBtn.textContent   = 'Remove';
                        couponActionBtn.className     = 'bg-red-50 text-red-600 border border-red-100 hover:bg-red-100 px-4 py-2.5 rounded-lg text-sm font-semibold transition-colors';
                        couponActionBtn.disabled      = false;
                        couponMsg.innerHTML  = '<i class="fa-solid fa-circle-check text-green-500 text-xs mr-1.5"></i><span class="text-xs font-semibold text-green-600">Coupon applied! You save ₹' + fmt(discount) + '</span>';
                        couponMsg.classList.remove('hidden');
                        recalcTotal(discount);
                }

                function setCouponRemovedState() {
                        couponInput.value    = '';
                        couponInput.readOnly = false;
                        couponActionBtn.dataset.state = 'idle';
                        couponActionBtn.textContent   = 'Apply';
                        couponActionBtn.className     = 'bg-gray-900 text-white px-5 py-2.5 rounded-lg text-sm font-semibold hover:bg-gray-800 transition-colors shadow-sm';
                        couponActionBtn.disabled      = false;
                        couponMsg.classList.add('hidden');
                        recalcTotal(0);
                        couponInput.focus();
                }

                // Pre-fill applied coupon state on page load (after functions defined)
                if (INITIAL_COUPON_CODE) {
                        setCouponAppliedState(INITIAL_COUPON_CODE, INITIAL_COUPON_DISCOUNT);
                }

                couponActionBtn.addEventListener('click', async () => {
                        const isApplied = couponActionBtn.dataset.state === 'applied';

                        if (isApplied) {
                                couponActionBtn.disabled    = true;
                                couponActionBtn.textContent = 'Removing...';
                                try {
                                        const res    = await fetch('/cart/coupon/remove', { method: 'DELETE' });
                                        const result = await res.json();
                                        if (result.success) {
                                                showToast('Coupon removed', 'success');
                                                setCouponRemovedState();
                                        } else {
                                                showToast(result.message || 'Failed to remove', 'error');
                                                couponActionBtn.disabled    = false;
                                                couponActionBtn.textContent = 'Remove';
                                        }
                                } catch {
                                        showToast('Network error', 'error');
                                        couponActionBtn.disabled    = false;
                                        couponActionBtn.textContent = 'Remove';
                                }

                        } else {
                                const code = couponInput.value.trim();
                                if (!code) return showToast('Please enter a coupon code', 'warning');

                                couponActionBtn.disabled    = true;
                                couponActionBtn.textContent = 'Applying...';
                                try {
                                        const res    = await fetch('/cart/coupon/apply', {
                                                method:  'POST',
                                                headers: { 'Content-Type': 'application/json' },
                                                body:    JSON.stringify({ code }),
                                        });
                                        const result = await res.json();
                                        if (result.success) {
                                                showToast(result.message, 'success');
                                                setCouponAppliedState(code.toUpperCase(), result.discountAmount);
                                        } else {
                                                showToast(result.message || 'Invalid coupon', 'error');
                                                couponActionBtn.disabled    = false;
                                                couponActionBtn.textContent = 'Apply';
                                        }
                                } catch {
                                        showToast('Network error applying coupon', 'error');
                                        couponActionBtn.disabled    = false;
                                        couponActionBtn.textContent = 'Apply';
                                }
                        }
                });

                // uppercase as user types
                couponInput.addEventListener('input', () => {
                        couponInput.value = couponInput.value.toUpperCase();
                });

                // ---------------- Checkout Order Submission ----------------
                document.getElementById('checkoutProceedBtn').addEventListener('click', async () => {
                        const selectedAddress = document.querySelector('input[name="selectedAddress"]:checked');
                        const selectedPayment = document.querySelector('input[name="paymentMethod"]:checked');

                        if (!selectedAddress) return showToast("Select address", "warning");
                        if (!selectedPayment) return showToast("Select payment method", "warning");

                        const btn = document.getElementById('checkoutProceedBtn');
                        const original = btn.innerHTML;

                        btn.disabled = true;
                        btn.innerHTML = "Processing...";

                        try {
                                // ✅ STOCK VALIDATION
                                const stockRes = await fetch("/api/user/cart/validate-stock-cart");
                                const stockData = await stockRes.json();

                                if (!stockData.success) {
                                        showToast("Stock issue. Redirecting...", "error");
                                        setTimeout(() => location.href = "/cart", 2000);
                                        return;
                                }

                                // ================= COD =================
                                if (selectedPayment.value === "cod") {

                                        const res = await fetch('/api/user/order/place', {
                                                method: 'POST',
                                                headers: { "Content-Type": "application/json" },
                                                body: JSON.stringify({
                                                        addressId: selectedAddress.value,
                                                        paymentMethod: "cod"
                                                })
                                        });

                                        const result = await res.json();

                                        if (!result.success) throw new Error(result.message);

                                        window.location.href = result.redirectUrl;
                                }

                                // ================= RAZORPAY =================
                                else {
                                        const res = await fetch('/api/user/payment/create-order', {
                                                method: 'POST',
                                                headers: { "Content-Type": "application/json", "Accept": "application/json" },
                                                body: JSON.stringify({ addressId: selectedAddress.value })
                                        });

                                        const data = await res.json();

                                        if (!data.success) throw new Error(data.message || "Failed to create payment order");

                                        const rzp = new Razorpay({
                                                key: data.key,
                                                amount: data.amount,
                                                currency: "INR",
                                                order_id: data.razorpayOrderId,
                                                theme: { color: "#3399cc" },

                                                handler: async function (response) {
                                                        try {
                                                                const verifyRes = await fetch('/api/user/payment/verify', {
                                                                        method: 'POST',
                                                                        headers: { "Content-Type": "application/json" },
                                                                        body: JSON.stringify({ ...response, orderId: data.orderId })
                                                                });
                                                                const result = await verifyRes.json();

                                                                if (!verifyRes.ok || !result.success) {
                                                                        window.location.href = `/order/failure/${data.orderId}?error=Payment+failed&orderNumber=${data.orderNumber}`;
                                                                        return;
                                                                }
                                                                window.location.href = `/order/success/${data.orderId}`;
                                                        } catch (err) {
                                                                window.location.href = `/order/failure/${data.orderId}?error=Payment+failed&orderNumber=${data.orderNumber}`;
                                                        }
                                                },

                                                modal: {
                                                        ondismiss: async function () {
                                                                await fetch("/api/user/payment/failure", {
                                                                        method: "POST",
                                                                        headers: { "Content-Type": "application/json" },
                                                                        body: JSON.stringify({ orderId: data.orderId })
                                                                });
                                                                btn.disabled = false;
                                                                btn.innerHTML = original;
                                                        }
                                                }
                                        });

                                        rzp.on("payment.failed", async function (response) {
                                                await fetch("/api/user/payment/failure", {
                                                        method: "POST",
                                                        headers: { "Content-Type": "application/json" },
                                                        body: JSON.stringify({ orderId: data.orderId })
                                                });
                                                window.location.href = `/order/failure/${data.orderId}?error=Payment+failed&orderNumber=${data.orderNumber}`;
                                        });

                                        rzp.open();
                                }

                        } catch (err) {
                                showToast(err.message || "Something went wrong", "error");
                                btn.disabled = false;
                                btn.innerHTML = original;
                        }
                });

                function customConfirm(title, message) {
                        return new Promise((resolve) => {
                                const modal = document.getElementById("confirmModal");
                                const titleEl = document.getElementById("confirmTitle");
                                const messageEl = document.getElementById("confirmMessage");
                                const okBtn = document.getElementById("confirmOkBtn");
                                const cancelBtn = document.getElementById("confirmCancelBtn");

                                titleEl.textContent = title;
                                messageEl.textContent = message;

                                modal.classList.remove("hidden");

                                const cleanup = () => {
                                        modal.classList.add("hidden");
                                        okBtn.onclick = null;
                                        cancelBtn.onclick = null;
                                };

                                okBtn.onclick = () => {
                                        cleanup();
                                        resolve(true);
                                };

                                cancelBtn.onclick = () => {
                                        cleanup();
                                        resolve(false);
                                };
                        });
                }
        </script>

