        <script src="https://checkout.razorpay.com/v1/checkout.js"></script>

        <!-- ─── Plain script: all Razorpay open() calls live here ───────────────
             rzp.open() must be called from a plain (non-module) script so the
             browser keeps the user-gesture trust chain intact. Calling it from
             an ES-module (even via window.*) breaks that chain and causes Chrome
             to open a blank popup instead of the inline payment modal.          -->
        <script>
          /* ── Checkout: online payment ── */
          function openRazorpay(data) {
            var rzp = new Razorpay({
              key:         data.key,
              amount:      data.amount,
              currency:    'INR',
              order_id:    data.razorpayOrderId,
              name:        'Electro Shop',
              description: 'Order Payment',
              theme:       { color: '#3399cc' },
              config:      { display: { hide: [{ method: 'netbanking' }] } },

              handler: function (response) {
                // Show a full-screen processing overlay so the user knows something is happening
                var overlay = document.getElementById('rzpProcessingOverlay');
                if (overlay) overlay.classList.remove('hidden');

                fetch('/api/user/payment/verify', {
                  method:  'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({
                    razorpay_order_id:   response.razorpay_order_id,
                    razorpay_payment_id: response.razorpay_payment_id,
                    razorpay_signature:  response.razorpay_signature,
                    orderId: data.orderId
                  })
                })
                .then(function (r) { return r.json(); })
                .then(function (result) {
                  if (result.success) {
                    window.location.href = '/order/success/' + data.orderId;
                  } else {
                    if (overlay) overlay.classList.add('hidden');
                    window.location.href = '/order/failure/' + data.orderId +
                      '?error=' + encodeURIComponent(result.message || 'Payment failed') +
                      '&orderNumber=' + data.orderNumber;
                  }
                })
                .catch(function () {
                  if (overlay) overlay.classList.add('hidden');
                  window.location.href = '/order/failure/' + data.orderId +
                    '?error=Payment+failed&orderNumber=' + data.orderNumber;
                });
              },

              modal: {
                ondismiss: function () {
                  if (window._rzpResetBtn) window._rzpResetBtn();
                }
              }
            });

            rzp.on('payment.failed', function (response) {
              fetch('/api/user/payment/failure', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ orderId: data.orderId })
              }).finally(function () {
                window.location.href = '/order/failure/' + data.orderId +
                  '?error=' + encodeURIComponent((response.error && response.error.description) || 'Payment failed') +
                  '&orderNumber=' + data.orderNumber;
              });
            });

            rzp.open();
          }

          /* ── Checkout: wallet top-up ── */
          function openRazorpayTopup(orderData, amount, onSuccess, onDismiss) {
            var rzp = new Razorpay({
              key:         orderData.key,
              amount:      orderData.amount,
              currency:    'INR',
              order_id:    orderData.razorpayOrderId,
              name:        'Electro Shop',
              description: 'Wallet Top-up',
              theme:       { color: '#2874F0' },
              config:      { display: { hide: [{ method: 'netbanking' }] } },

              handler: function (response) {
                fetch('/api/user/payment/wallet/verify', {
                  method:  'POST',
                  headers: { 'Content-Type': 'application/json' },
                  credentials: 'include',
                  body: JSON.stringify({
                    razorpay_order_id:   response.razorpay_order_id,
                    razorpay_payment_id: response.razorpay_payment_id,
                    razorpay_signature:  response.razorpay_signature,
                    amount: amount
                  })
                })
                .then(function (r) { return r.json(); })
                .then(function (result) {
                  if (result.success || result.message === undefined) {
                    onSuccess && onSuccess(amount);
                  } else {
                    throw new Error(result.message);
                  }
                })
                .catch(function (e) {
                  if (window._showToast) window._showToast(e.message || 'Verification failed', 'error');
                });
              },

              modal: {
                ondismiss: function () {
                  onDismiss && onDismiss();
                }
              }
            });

            rzp.open();
          }

          /* ── Pre-fetched Razorpay order cache ────────────────────────────────
             We eagerly fetch the Razorpay order as soon as the user selects
             Razorpay as payment method (or on page load if it's pre-selected).
             This means rzp.open() is called synchronously on button click —
             no async gap, no broken user-gesture trust chain, no blank popup.  */
          var _rzpCache = null;          // { addressId, data }
          var _rzpFetching = false;      // prevent concurrent fetches
          var _rzpFetchError = null;     // last fetch error message

          function prefetchRazorpayOrder(addressId) {
            // Already cached for this address — nothing to do
            if (_rzpCache && _rzpCache.addressId === addressId) return;

            _rzpCache = null;
            _rzpFetchError = null;
            _rzpFetching = true;

            fetch('/api/user/payment/create-order', {
              method:  'POST',
              headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
              body: JSON.stringify({ addressId: addressId })
            })
            .then(function (r) { return r.json(); })
            .then(function (data) {
              _rzpFetching = false;
              if (data.success) {
                _rzpCache = { addressId: addressId, data: data };
              } else {
                _rzpFetchError = data.message || 'Failed to prepare payment';
              }
            })
            .catch(function (err) {
              _rzpFetching = false;
              _rzpFetchError = err.message || 'Failed to prepare payment';
            });
          }

          /* ── Checkout proceed button — entire handler in plain script ──────────
             MUST be here (not in the ES module) because rzp.open() must be called
             synchronously within the user-gesture event handler.                 */
          document.addEventListener('DOMContentLoaded', function () {
            var proceedBtn = document.getElementById('checkoutProceedBtn');
            if (!proceedBtn) return;

            // Pre-fetch when Razorpay is already selected on load
            var initialPayment = document.querySelector('input[name="paymentMethod"]:checked');
            var initialAddress = document.querySelector('input[name="selectedAddress"]:checked');
            if (initialPayment && initialPayment.value === 'razorpay' && initialAddress) {
              prefetchRazorpayOrder(initialAddress.value);
            }

            // Re-fetch when address changes
            document.querySelectorAll('input[name="selectedAddress"]').forEach(function (radio) {
              radio.addEventListener('change', function () {
                var paymentMethod = document.querySelector('input[name="paymentMethod"]:checked');
                if (paymentMethod && paymentMethod.value === 'razorpay') {
                  prefetchRazorpayOrder(this.value);
                }
              });
            });

            // Pre-fetch when user switches to Razorpay
            document.querySelectorAll('input[name="paymentMethod"]').forEach(function (radio) {
              radio.addEventListener('change', function () {
                if (this.value === 'razorpay') {
                  var addr = document.querySelector('input[name="selectedAddress"]:checked');
                  if (addr) prefetchRazorpayOrder(addr.value);
                }
              });
            });

            proceedBtn.addEventListener('click', function () {
              var selectedAddress = document.querySelector('input[name="selectedAddress"]:checked');
              var selectedPayment = document.querySelector('input[name="paymentMethod"]:checked');

              if (!selectedAddress) {
                var el = document.getElementById('addressSelectionError');
                if (el) { el.textContent = 'Please select a delivery address'; el.classList.remove('hidden'); }
                return;
              }
              var addrErr = document.getElementById('addressSelectionError');
              if (addrErr) addrErr.classList.add('hidden');

              if (!selectedPayment) {
                var el2 = document.getElementById('paymentSelectionError');
                if (el2) { el2.textContent = 'Please select a payment method'; el2.classList.remove('hidden'); }
                return;
              }
              var payErr = document.getElementById('paymentSelectionError');
              if (payErr) payErr.classList.add('hidden');

              var btn      = proceedBtn;
              var original = btn.innerHTML;
              btn.disabled = true;
              btn.innerHTML = '<span class="inline-flex items-center gap-2"><svg class="animate-spin h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path></svg>Processing...</span>';

              var method = selectedPayment.value;

              // ── COD ──
              if (method === 'cod') {
                fetch('/api/user/cart/validate-stock-cart')
                .then(function (r) { return r.json(); })
                .then(function (stockData) {
                  if (!stockData.success) {
                    if (window._showToast) window._showToast('Stock issue. Redirecting...', 'error');
                    setTimeout(function () { location.href = '/cart'; }, 2000);
                    btn.disabled = false; btn.innerHTML = original;
                    return;
                  }
                  return fetch('/api/user/order/place', {
                    method:  'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ addressId: selectedAddress.value, paymentMethod: 'cod' })
                  });
                })
                .then(function (r) { return r && r.json(); })
                .then(function (result) {
                  if (!result) return;
                  if (!result.success) throw new Error(result.message);
                  window.location.href = result.redirectUrl;
                })
                .catch(function (err) {
                  if (window._showToast) window._showToast(err.message || 'Something went wrong', 'error');
                  btn.disabled = false; btn.innerHTML = original;
                });
                return;
              }

              // ── WALLET ──
              if (method === 'wallet') {
                fetch('/api/user/cart/validate-stock-cart')
                .then(function (r) { return r.json(); })
                .then(function (stockData) {
                  if (!stockData.success) {
                    if (window._showToast) window._showToast('Stock issue. Redirecting...', 'error');
                    setTimeout(function () { location.href = '/cart'; }, 2000);
                    btn.disabled = false; btn.innerHTML = original;
                    return;
                  }
                  return fetch('/api/user/order/place', {
                    method:  'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ addressId: selectedAddress.value, paymentMethod: 'wallet' })
                  });
                })
                .then(function (r) { return r && r.json(); })
                .then(function (result) {
                  if (!result) return;
                  if (!result.success) throw new Error(result.message);
                  window.location.href = result.redirectUrl;
                })
                .catch(function (err) {
                  if (window._showToast) window._showToast(err.message || 'Something went wrong', 'error');
                  btn.disabled = false; btn.innerHTML = original;
                });
                return;
              }

              // ── RAZORPAY ──
              // rzp.open() MUST be called synchronously here (user-gesture trust chain).
              // We use the pre-fetched order data — no async gap.
              window._rzpResetBtn = function () {
                btn.disabled = false;
                btn.innerHTML = original;
              };

              // If still fetching, wait briefly then open
              function tryOpenRazorpay(attempts) {
                if (_rzpFetchError) {
                  if (window._showToast) window._showToast(_rzpFetchError, 'error');
                  btn.disabled = false; btn.innerHTML = original;
                  // Re-trigger prefetch for next attempt
                  _rzpFetchError = null;
                  prefetchRazorpayOrder(selectedAddress.value);
                  return;
                }

                if (_rzpCache && _rzpCache.addressId === selectedAddress.value) {
                  // ✅ Open Razorpay synchronously — no async gap, trust chain intact.
                  // Stock was already validated during prefetch (order creation).
                  // If stock runs out between prefetch and payment, handlePaymentSuccessService
                  // will catch it server-side and auto-refund.
                  openRazorpay(_rzpCache.data);
                  // Invalidate cache so next order gets a fresh Razorpay order
                  _rzpCache = null;
                  return;
                }

                // Cache miss — prefetch hasn't completed yet.
                // Don't use setTimeout (breaks trust chain). Instead, tell the user to retry.
                if (!_rzpFetching) {
                  prefetchRazorpayOrder(selectedAddress.value);
                }
                if (window._showToast) window._showToast('Almost ready — please click again in a moment.', 'info');
                btn.disabled = false; btn.innerHTML = original;
              }

              tryOpenRazorpay();
            });
          });
        </script>

        <script type="module">
                import { showToast } from "/partials/errorMsg.utils.js";
                import { confirmAction } from "/partials/confirm.util.js";
                import { confirmPayment } from "/partials/paymentConfirm.util.js";

                // Expose showToast to plain scripts (topup handler)
                window._showToast = showToast;

                // ── Inline wallet top-up from checkout page ───────────────────────────
                window.checkoutTopup = async () => {
                  const input  = document.getElementById('checkoutTopupInput');
                  const btn    = document.getElementById('checkoutTopupBtn');
                  const amount = parseFloat(input?.value) || parseFloat(input?.placeholder) || 0;

                  if (!amount || amount < 1) {
                    const errEl = document.getElementById('checkoutTopupError');
                    if (errEl) { errEl.textContent = 'Enter a valid amount (min ₹1)'; errEl.classList.remove('hidden'); }
                    return;
                  }
                  if (document.getElementById('checkoutTopupError')) document.getElementById('checkoutTopupError').classList.add('hidden');

                  btn.disabled  = true;
                  btn.innerHTML = 'Processing...';

                  try {
                    const orderRes  = await fetch('/api/user/payment/wallet/create-order', {
                      method:  'POST',
                      headers: { 'Content-Type': 'application/json' },
                      credentials: 'include',
                      body: JSON.stringify({ amount }),
                    });
                    const orderData = await orderRes.json();
                    if (!orderRes.ok) throw new Error(orderData.message || 'Failed');

                    // openRazorpayTopup is in the plain script above — keeps popup trust chain
                    openRazorpayTopup(
                      orderData,
                      amount,
                      function onSuccess(amt) {
                        showToast('₹' + amt + ' added to wallet!', 'success');
                        setTimeout(() => location.reload(), 900);
                      },
                      function onDismiss() {
                        btn.disabled  = false;
                        btn.innerHTML = '<i class="fa-solid fa-plus text-[10px]"></i> Add Money';
                      }
                    );

                  } catch (err) {
                    showToast(err.message || 'Something went wrong', 'error');
                    btn.disabled  = false;
                    btn.innerHTML = '<i class="fa-solid fa-plus text-[10px]"></i> Add Money';
                  }
                };

                // ---------------- Location Logic APIs ----------------
                let statesData = [];

                async function loadStates() {
                        try {
                                const res = await fetch('/location/states');
                                statesData = await res.json();
                        } catch (err) {
                                console.error("States fetch failed", err);
                        }
                }
                loadStates();

                async function loadDistricts(stateCode) {
                        try {
                                const res = await fetch(`/location/districts/${stateCode}`);
                                return await res.json();
                        } catch (err) {
                                console.error("District fetch failed", err);
                                return [];
                        }
                }

                // ---------------- Modal Core Interactions ----------------
                window.openAddressModal = async function (addressJson = null) {
                        const addr = addressJson ? JSON.parse(decodeURIComponent(addressJson)) : {};
                        const isEdit = !!addr._id;

                        const modal = document.getElementById('addressModal');
                        const form = document.getElementById('addressForm');

                        // Clear all field errors on open
                        form.querySelectorAll('.field-err').forEach(span => {
                                span.classList.add('hidden');
                                const et = span.querySelector('.err-text');
                                if (et) et.textContent = '';
                        });
                        form.querySelectorAll('.addr-input').forEach(el => el.classList.remove('border-red-400'));

                        modal.classList.remove('hidden');

                        // Pre-fill Values
                        form.name.value = addr.name || '';
                        form.phone.value = addr.phone || '';
                        form.altPhone.value = addr.altPhone || '';
                        form.pincode.value = addr.pincode || '';
                        form.locality.value = addr.locality || '';
                        form.address.value = addr.address || '';
                        form.city.value = addr.city || '';
                        form.landmark.value = addr.landmark || '';

                        if (addr.addressType) {
                                form.addressType.value = (addr.addressType.toLowerCase() === 'home') ? 'Home' : 'Work';
                        } else {
                                form.addressType.value = 'Home';
                        }

                        form.isDefault.checked = addr.isDefault || false;

                        document.getElementById('addressId').value = addr._id || '';

                        // Dynamic State Dropdown Initializer
                        const stateSelect = form.state;
                        const districtSelect = form.district;

                        stateSelect.innerHTML = '<option value="">Select State</option>' +
                                statesData.map(s => `
                <option value="${s.isoCode}" ${s.isoCode === addr.stateCode ? 'selected' : ''}>
                    ${s.name}
                </option>
            `).join('');

                        // Populate District if Edit Mode contains state
                        if (addr.stateCode) {
                                const districts = await loadDistricts(addr.stateCode);
                                districtSelect.innerHTML = '<option value="">Select District</option>' +
                                        districts.map(d => `
                    <option value="${d}" ${d === addr.district ? 'selected' : ''}>${d}</option>
                `).join('');
                        } else {
                                districtSelect.innerHTML = '<option value="">Select District</option>';
                        }

                        // State Change Event Mapping Context
                        stateSelect.onchange = async () => {
                                const stateCode = stateSelect.value;
                                if (!stateCode) {
                                        districtSelect.innerHTML = '<option value="">Select District</option>';
                                        return;
                                }
                                const districts = await loadDistricts(stateCode);
                                districtSelect.innerHTML = '<option value="">Select District</option>' +
                                        districts.map(d => `<option value="${d}">${d}</option>`).join('');
                        };
                };

                window.closeAddressModal = () => {
                        const form = document.getElementById('addressForm');
                        form?.querySelectorAll('.field-err').forEach(span => {
                                span.classList.add('hidden');
                                const et = span.querySelector('.err-text');
                                if (et) et.textContent = '';
                        });
                        form?.querySelectorAll('.addr-input').forEach(el => el.classList.remove('border-red-400'));
                        document.getElementById('addressModal').classList.add('hidden');
                };

                // ── Validation rules ──────────────────────────────────────────────────
                const ADDR_RULES = {
                        name: (v) => {
                                if (!v)                             return "Full name is required";
                                if (v.length < 3)                   return "Name must be at least 3 characters";
                                if (v.length > 60)                  return "Name cannot exceed 60 characters";
                                if (!/^[A-Za-z\s.'\-]+$/.test(v))  return "Name can only contain letters, spaces, dots and hyphens";
                                return null;
                        },
                        phone: (v) => {
                                if (!v)                             return "Phone number is required";
                                if (!/^[6-9]\d{9}$/.test(v))       return "Enter a valid 10-digit mobile number (starts with 6–9)";
                                return null;
                        },
                        altPhone: (v) => {
                                if (!v) return null;
                                if (!/^[6-9]\d{9}$/.test(v))       return "Alternate phone must be a valid 10-digit mobile number";
                                return null;
                        },
                        pincode: (v) => {
                                if (!v)                             return "Pincode is required";
                                if (!/^[1-9][0-9]{5}$/.test(v))    return "Enter a valid 6-digit pincode (cannot start with 0)";
                                return null;
                        },
                        locality: (v) => {
                                if (!v)                             return "Locality / area is required";
                                if (v.length < 3)                   return "Locality must be at least 3 characters";
                                return null;
                        },
                        address: (v) => {
                                if (!v)                             return "Street address is required";
                                if (v.length < 5)                   return "Address is too short (min 5 characters)";
                                return null;
                        },
                        city: (v) => {
                                if (!v)                             return "City / town is required";
                                if (v.length < 2)                   return "City name must be at least 2 characters";
                                if (!/^[A-Za-z\s.'\-]+$/.test(v))  return "City name can only contain letters, spaces, dots and hyphens";
                                return null;
                        },
                };

                // ── Auto-format: digits only for phone/pincode ────────────────────────
                document.addEventListener("input", (e) => {
                        if (!e.target.closest('#addressForm')) return;
                        const name = e.target.name;
                        if (name === "phone" || name === "altPhone") {
                                e.target.value = e.target.value.replace(/\D/g, "").slice(0, 10);
                        }
                        if (name === "pincode") {
                                e.target.value = e.target.value.replace(/\D/g, "").slice(0, 6);
                        }
                        // Clear error as user types
                        _clearFieldErr(e.target);
                });

                // ── Blur validation ───────────────────────────────────────────────────
                document.addEventListener("blur", (e) => {
                        const el = e.target;
                        if (!el.closest('#addressForm')) return;
                        const rule = ADDR_RULES[el.name];
                        if (rule) {
                                const msg = rule(el.value.trim());
                                if (msg) _showFieldErr(el, msg);
                                else _clearFieldErr(el);
                        }
                }, true);

                // ── Show / clear helpers ──────────────────────────────────────────────
                function _showFieldErr(el, msg) {
                        el.classList.add("border-red-400");
                        el.classList.remove("border-gray-200");
                        const span = el.parentNode.querySelector(".field-err");
                        if (span) {
                                span.classList.remove("hidden");
                                span.querySelector(".err-text").textContent = msg;
                        }
                }
                function _clearFieldErr(el) {
                        el.classList.remove("border-red-400");
                        const span = el.parentNode.querySelector(".field-err");
                        if (span) {
                                span.classList.add("hidden");
                                const et = span.querySelector(".err-text");
                                if (et) et.textContent = "";
                        }
                }
                function _showSelectErr(sel, msg) {
                        sel.classList.add("border-red-400");
                        const span = sel.parentNode.querySelector(".field-err");
                        if (span) { span.classList.remove("hidden"); span.querySelector(".err-text").textContent = msg; }
                }
                function _clearSelectErr(sel) {
                        sel.classList.remove("border-red-400");
                        const span = sel.parentNode.querySelector(".field-err");
                        if (span) { span.classList.add("hidden"); const et = span.querySelector(".err-text"); if (et) et.textContent = ""; }
                }

                // Form Validator — shows ALL errors at once
                function validateForm(form, stateSelect, districtSelect) {
                        let isValid = true;

                        // Clear all first
                        form.querySelectorAll('.addr-input').forEach(_clearFieldErr);
                        _clearSelectErr(stateSelect);
                        _clearSelectErr(districtSelect);

                        // Validate each field
                        Object.entries(ADDR_RULES).forEach(([fieldName, rule]) => {
                                const el = form[fieldName];
                                if (!el) return;
                                const msg = rule(el.value.trim());
                                if (msg) { _showFieldErr(el, msg); isValid = false; }
                        });

                        if (!stateSelect.value) { _showSelectErr(stateSelect, "Please select a state"); isValid = false; }
                        if (!districtSelect.value) { _showSelectErr(districtSelect, "Please select a district"); isValid = false; }

                        // Scroll to first error
                        if (!isValid) {
                                const firstErr = form.querySelector('.border-red-400');
                                if (firstErr) firstErr.scrollIntoView({ behavior: 'smooth', block: 'center' });
                        }

                        return isValid;
                }

                // Capture Submit Action for Modal Form
                document.getElementById('addressForm').onsubmit = async (e) => {
                        e.preventDefault();

                        const form = e.target;
                        const stateSelect = form.state;
                        const districtSelect = form.district;
                        const isEdit = document.getElementById('addressId').value !== '';
                        const addressId = document.getElementById('addressId').value;

                        if (!validateForm(form, stateSelect, districtSelect)) return;

                        const formData = {
                                name: form.name.value.trim(),
                                phone: form.phone.value.trim(),
                                altPhone: form.altPhone.value.trim() || null,
                                pincode: form.pincode.value.trim(),
                                locality: form.locality.value.trim(),
                                address: form.address.value.trim(),
                                city: form.city.value.trim(),
                                state: stateSelect.options[stateSelect.selectedIndex].text,
                                stateCode: stateSelect.value,
                                district: districtSelect.value,
                                landmark: form.landmark.value.trim() || null,
                                addressType: form.addressType.value,
                                isDefault: form.isDefault.checked
                        };

                        try {
                                const url = isEdit ? `/address/${addressId}` : '/address';
                                const method = isEdit ? 'PUT' : 'POST';

                                const res = await fetch(url, {
                                        method,
                                        headers: { "Content-Type": "application/json", "Accept": "application/json" },
                                        body: JSON.stringify(formData)
                                });

                                const result = await res.json();
                                if (!res.ok) throw new Error(result.message || "Failed to save address");

                                showToast(result.message || "Address saved successfully", "success");
                                setTimeout(() => location.reload(), 1000);

                        } catch (error) {
                                showToast(error.message, "error");
                        }
                };

                // Auto-formatting Input RegEx Events
                document.addEventListener("input", (e) => {
                        if (e.target.name === "phone" || e.target.name === "altPhone") {
                                e.target.value = e.target.value.replace(/\D/g, "").slice(0, 10);
                        }
                        if (e.target.name === "pincode") {
                                e.target.value = e.target.value.replace(/\D/g, "").slice(0, 6);
                        }
                });

                // Delete Logic Extracted from backend specs
                window.deleteAddress = async function (id) {
                        if (await confirmAction("Delete Address?", "This action cannot be undone.")) {
                                try {
                                        const res = await fetch(`/address/${id}`, {
                                                method: 'DELETE',
                                                headers: { "Accept": "application/json" }
                                        });
                                        const data = await res.json();

                                        if (res.ok) {
                                                showToast("Address deleted securely", "success");
                                                setTimeout(() => location.reload(), 500);
                                        } else throw new Error(data.message);
                                } catch (error) {
                                        showToast(error.message, "error");
                                }
                        }
                };

                // ---------------- Coupon Handlers (dynamic, no reload) ----------------
                const couponInput     = document.getElementById('couponInput');
                const couponActionBtn = document.getElementById('couponActionBtn');
                const couponMsg       = document.getElementById('couponMsg');
                const couponSavingsRow = document.getElementById('couponSavingsRow');
                const couponSavingsAmt = document.getElementById('couponSavingsAmt');
                const grandTotalDisplay = document.getElementById('grandTotalDisplay');
                const overallSaveLabel  = document.getElementById('overallSaveLabel');

                // Base totals from server — subtotal is MRP, discounts are offer savings
                const BASE_SUBTOTAL   = <%= subtotal %>;
                const BASE_DISCOUNTS  = <%= totalDiscounts %>;
                const BASE_GST        = <%= Math.round(totalGstAmount) %>;
                let   activeCouponDiscount = <%= couponDiscountAmount %>;

                // Store initial coupon state — applied after functions are defined below
                const INITIAL_COUPON_CODE     = <%- JSON.stringify(cart?.appliedCoupon?.code || null) %>;
                const INITIAL_COUPON_DISCOUNT = <%= cart?.couponDiscountAmount || 0 %>;

                function fmt(n) {
                        return n.toLocaleString('en-IN');
                }

                function recalcTotal(couponDiscount) {
                        activeCouponDiscount = couponDiscount;
                        const afterDiscount  = Math.max(0, BASE_SUBTOTAL - BASE_DISCOUNTS - couponDiscount);
                        const delivery       = afterDiscount >= 500 ? 0 : 40;
                        const grand          = afterDiscount + delivery;
                        const totalSavings   = BASE_DISCOUNTS + couponDiscount;

                        if (grandTotalDisplay) grandTotalDisplay.textContent = '₹' + fmt(grand);

                        if (couponSavingsRow) {
                                if (couponDiscount > 0) {
                                        couponSavingsRow.classList.remove('hidden');
                                        if (couponSavingsAmt) couponSavingsAmt.textContent = '- ₹' + fmt(couponDiscount);
                                } else {
                                        couponSavingsRow.classList.add('hidden');
                                }
                        }

                        if (overallSaveLabel) {
                                if (totalSavings > 0) {
                                        overallSaveLabel.textContent = 'Overall save ₹' + fmt(totalSavings);
                                        overallSaveLabel.classList.remove('hidden');
                                } else {
                                        overallSaveLabel.classList.add('hidden');
                                }
                        }
                }

                // Coupon block only exists on regular checkout (not Buy Now)
                if (couponInput && couponActionBtn) {

                        function setCouponAppliedState(code, discount) {
                                couponInput.value    = code;
                                couponInput.readOnly = true;
                                couponActionBtn.dataset.state = 'applied';
                                couponActionBtn.textContent   = 'Remove';
                                couponActionBtn.className     = 'bg-red-50 text-red-600 border border-red-100 hover:bg-red-100 px-4 py-2.5 rounded-lg text-sm font-semibold transition-colors';
                                couponActionBtn.disabled      = false;
                                if (couponMsg) {
                                        couponMsg.innerHTML = '<i class="fa-solid fa-circle-check text-green-500 text-xs mr-1.5"></i><span class="text-xs font-semibold text-green-600">Coupon applied! You save ₹' + fmt(discount) + '</span>';
                                        couponMsg.classList.remove('hidden');
                                }
                                recalcTotal(discount);
                        }

                        function setCouponRemovedState() {
                                couponInput.value    = '';
                                couponInput.readOnly = false;
                                couponActionBtn.dataset.state = 'idle';
                                couponActionBtn.textContent   = 'Apply';
                                couponActionBtn.className     = 'bg-gray-900 text-white px-5 py-2.5 rounded-lg text-sm font-semibold hover:bg-gray-800 transition-colors shadow-sm';
                                couponActionBtn.disabled      = false;
                                if (couponMsg) couponMsg.classList.add('hidden');
                                recalcTotal(0);
                                couponInput.focus();
                        }

                        // Pre-fill applied coupon state on page load
                        if (INITIAL_COUPON_CODE) {
                                setCouponAppliedState(INITIAL_COUPON_CODE, INITIAL_COUPON_DISCOUNT);
                        } else {
                                // Ensure button starts in idle state
                                couponActionBtn.dataset.state = 'idle';
                        }

                        // Load available coupons
                        async function loadAvailableCoupons() {
                                const couponsList = document.getElementById('availableCouponsList');
                                if (!couponsList) return;

                                try {
                                        const res = await fetch('/cart/coupon/available');
                                        const result = await res.json();

                                        if (result.success && result.coupons.length > 0) {
                                                couponsList.innerHTML = result.coupons.map(coupon => `
                                                        <div class="coupon-card bg-gradient-to-r from-blue-50 to-indigo-50 border border-blue-100 rounded-lg p-3 cursor-pointer hover:shadow-md transition-all ${!coupon.isApplicable ? 'opacity-60' : ''}"
                                                                data-code="${coupon.code}"
                                                                onclick="applyCouponFromCard('${coupon.code}', ${coupon.isApplicable})">
                                                                <div class="flex items-start justify-between gap-3">
                                                                        <div class="flex-1">
                                                                                <div class="flex items-center gap-2 mb-1">
                                                                                        <span class="font-mono font-bold text-blue-700 text-sm">${coupon.code}</span>
                                                                                        ${!coupon.isApplicable ? '<span class="text-[9px] bg-orange-100 text-orange-600 px-1.5 py-0.5 rounded font-semibold">MIN ₹' + coupon.minOrderAmount + '</span>' : ''}
                                                                                </div>
                                                                                <p class="text-xs text-gray-600 mb-1">${coupon.description}</p>
                                                                                <p class="text-xs font-bold text-green-600">${coupon.discountText}</p>
                                                                        </div>
                                                                        <button type="button" class="text-xs font-semibold ${coupon.isApplicable ? 'text-blue-600 hover:text-blue-700' : 'text-gray-400'} bg-white px-3 py-1.5 rounded-md border ${coupon.isApplicable ? 'border-blue-200 hover:bg-blue-50' : 'border-gray-200'} transition-colors">
                                                                                ${coupon.isApplicable ? 'APPLY' : 'N/A'}
                                                                        </button>
                                                                </div>
                                                        </div>
                                                `).join('');
                                        } else {
                                                couponsList.innerHTML = `
                                                        <div class="text-center py-6 text-gray-400 text-sm">
                                                                <i class="fa-solid fa-ticket text-2xl mb-2 block opacity-30"></i>
                                                                <p>No coupons available at the moment</p>
                                                        </div>
                                                `;
                                        }
                                } catch (error) {
                                        console.error('Error loading coupons:', error);
                                        couponsList.innerHTML = `
                                                <div class="text-center py-4 text-red-400 text-sm">
                                                        <i class="fa-solid fa-exclamation-circle"></i> Failed to load coupons
                                                </div>
                                        `;
                                }
                        }

                        // Apply coupon from card click
                        window.applyCouponFromCard = async function(code, isApplicable) {
                                if (!isApplicable) {
                                        showToast('Minimum order amount not met for this coupon', 'warning');
                                        return;
                                }

                                couponInput.value = code;
                                couponActionBtn.click();
                        };

                        // Refresh coupons button
                        const refreshBtn = document.getElementById('refreshCouponsBtn');
                        if (refreshBtn) {
                                refreshBtn.addEventListener('click', loadAvailableCoupons);
                        }

                        // Load coupons on page load
                        loadAvailableCoupons();

                        couponActionBtn.addEventListener('click', async () => {
                                const isApplied = couponActionBtn.dataset.state === 'applied';

                                if (isApplied) {
                                        couponActionBtn.disabled    = true;
                                        couponActionBtn.textContent = 'Removing...';
                                        try {
                                                const res    = await fetch('/cart/coupon/remove', { method: 'DELETE' });
                                                const result = await res.json();
                                                if (result.success) {
                                                        showToast('Coupon removed', 'success');
                                                        setCouponRemovedState();
                                                        window.updateWalletCard?.(0);
                                                } else {
                                                        showToast(result.message || 'Failed to remove', 'error');
                                                        couponActionBtn.disabled    = false;
                                                        couponActionBtn.textContent = 'Remove';
                                                }
                                        } catch {
                                                showToast('Network error', 'error');
                                                couponActionBtn.disabled    = false;
                                                couponActionBtn.textContent = 'Remove';
                                        }

                                } else {
                                        const code = couponInput.value.trim();
                                        if (!code) {
                                                if (couponMsg) { couponMsg.innerHTML = '<span class="text-xs text-red-500">Please enter a coupon code</span>'; couponMsg.classList.remove('hidden'); }
                                                return;
                                        }

                                        couponActionBtn.disabled    = true;
                                        couponActionBtn.textContent = 'Applying...';
                                        try {
                                                const res    = await fetch('/cart/coupon/apply', {
                                                        method:  'POST',
                                                        headers: { 'Content-Type': 'application/json' },
                                                        body:    JSON.stringify({ code }),
                                                });
                                                const result = await res.json();
                                                if (result.success) {
                                                        showToast(result.message, 'success');
                                                        setCouponAppliedState(code.toUpperCase(), result.discountAmount);
                                                        window.updateWalletCard?.(result.discountAmount);
                                                } else {
                                                        showToast(result.message || 'Invalid coupon', 'error');
                                                        couponActionBtn.disabled    = false;
                                                        couponActionBtn.textContent = 'Apply';
                                                }
                                        } catch {
                                                showToast('Network error applying coupon', 'error');
                                                couponActionBtn.disabled    = false;
                                                couponActionBtn.textContent = 'Apply';
                                        }
                                }
                        });

                        // Uppercase as user types
                        couponInput.addEventListener('input', () => {
                                couponInput.value = couponInput.value.toUpperCase();
                        });

                } // end coupon block guard

                function customConfirm(title, message) {
                        return new Promise((resolve) => {
                                const modal = document.getElementById("confirmModal");
                                const titleEl = document.getElementById("confirmTitle");
                                const messageEl = document.getElementById("confirmMessage");
                                const okBtn = document.getElementById("confirmOkBtn");
                                const cancelBtn = document.getElementById("confirmCancelBtn");

                                titleEl.textContent = title;
                                messageEl.textContent = message;

                                modal.classList.remove("hidden");

                                const cleanup = () => {
                                        modal.classList.add("hidden");
                                        okBtn.onclick = null;
                                        cancelBtn.onclick = null;
                                };

                                okBtn.onclick = () => {
                                        cleanup();
                                        resolve(true);
                                };

                                cancelBtn.onclick = () => {
                                        cleanup();
                                        resolve(false);
                                };
                        });
                }
        </script>

