<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
<script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
<script src="https://cdn.tailwindcss.com"></script>
<link rel="stylesheet" href="https://use.fontawesome.com/releases/v5.15.4/css/all.css" />

<script>
  tailwind.config = {
    theme: {
      extend: {
        fontFamily: { sans: ['Outfit','sans-serif'] },
        colors: {
          brand: { 50:'#eef2ff',100:'#e0e7ff',500:'#6366f1',600:'#4f46e5',700:'#4338ca',900:'#1e1b4b' }
        }
      }
    }
  }
</script>
<style>
  body { font-family:'Outfit',sans-serif; background:linear-gradient(to bottom,#f8fafc,#eef2ff); overflow-x:hidden; }
  .hide-scrollbar::-webkit-scrollbar { display:none; }
  .hide-scrollbar { -ms-overflow-style:none; scrollbar-width:none; }
  @media (hover:hover) and (pointer:fine) {
    #mainImage { will-change:transform; transition:transform 0.2s ease-out; cursor:zoom-in; }
  }
  .variant-option.active { border-color:#2563eb; background-color:#eff6ff; box-shadow:0 4px 15px rgba(37,99,235,.15); }
  .thumb.active { border-color:#2563eb; box-shadow:0 4px 10px rgba(37,99,235,.2); }
  .variant-out-of-stock img { filter:grayscale(1); opacity:.5; }
  .glass-panel { background:rgba(255,255,255,.7); backdrop-filter:blur(12px); -webkit-backdrop-filter:blur(12px); }
  .line-clamp-3 { display:-webkit-box; -webkit-line-clamp:3; -webkit-box-orient:vertical; overflow:hidden; }
  /* Fixed bottom action bar — below lg breakpoint (1024px) */
  .pd-action-bar {
    position:fixed; bottom:0; left:0; right:0; z-index:40;
    background:#fff; border-top:1px solid #e2e8f0;
    padding:10px 16px 14px; display:flex; gap:10px; align-items:center;
    box-shadow:0 -4px 20px rgba(0,0,0,.08);
  }
  @media (min-width:1024px) { .pd-action-bar { display:none !important; } }
  .pd-section { padding-bottom:90px; }
  @media (min-width:1024px) { .pd-section { padding-bottom:0; } }
</style>

<%- include("../../partials/user/header.ejs") %>

<section class="text-slate-900 font-sans antialiased pt-4 lg:pt-6 pd-section">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Breadcrumb -->
    <nav class="flex text-xs text-slate-500 mb-4 items-center flex-wrap gap-x-1.5 gap-y-1 font-medium">
      <a href="/" class="hover:text-blue-600 transition">Home</a>
      <i class="fas fa-chevron-right text-[8px] text-slate-300"></i>
      <a href="/shop" class="hover:text-blue-600 transition">Products</a>
      <% if (product.category?.title) { %>
        <i class="fas fa-chevron-right text-[8px] text-slate-300"></i>
        <a href="/shop?category=<%= product.category._id %>" class="hover:text-blue-600 transition"><%= product.category.title %></a>
      <% } %>
      <i class="fas fa-chevron-right text-[8px] text-slate-300"></i>
      <span class="text-slate-900 font-bold truncate max-w-[180px]"><%= product.name %></span>
    </nav>

    <!-- ═══ TWO-COLUMN LAYOUT ═══ -->
    <div class="lg:grid lg:grid-cols-12 lg:gap-10">

      <!-- ── LEFT: Images ── -->
      <div class="lg:col-span-5 mb-5 lg:mb-0">
        <div class="lg:sticky lg:top-24">

          <!-- Main image -->
          <div id="mainImageContainer"
            class="w-full bg-white border border-slate-100 rounded-2xl flex items-center justify-center relative overflow-hidden shadow-md mb-3"
            style="height: clamp(240px, 45vw, 500px);">
            <div class="absolute inset-0 bg-gradient-to-tr from-slate-50 to-transparent z-0 pointer-events-none"></div>
            <img id="mainImage"
              src="<%= product.variants?.[0]?.product_images?.[0]?.url || '/images/placeholder.png' %>"
              alt="<%= product.name %>"
              class="relative z-10 max-h-[80%] max-w-[80%] object-contain select-none">
          </div>

          <!-- Thumbnails — horizontal scroll -->
          <div id="thumbnailList" class="flex flex-row gap-2 overflow-x-auto hide-scrollbar py-1"></div>
        </div>
      </div>

      <!-- ── RIGHT: Details ── -->
      <div class="lg:col-span-7">
        <div class="flex flex-col">

          <!-- Category + Title -->
          <div class="mb-4 flex flex-col items-start gap-2">
            <span class="bg-brand-50 text-brand-600 font-bold tracking-wide uppercase text-[10px] px-3 py-1.5 rounded-full border border-brand-100 shadow-sm">
              <%= product.category?.title || 'Electronics' %>
            </span>
            <h1 class="text-xl sm:text-2xl lg:text-3xl xl:text-4xl font-black text-slate-900 leading-tight tracking-tight">
              <%= product.name %>
            </h1>
          </div>

          <!-- Rating + Brand -->
          <div class="flex items-center gap-3 flex-wrap mb-4">
            <div class="flex items-center gap-2 bg-white border border-slate-100 rounded-2xl p-1.5 pr-3 shadow-sm">
              <div class="flex items-center bg-slate-900 text-white px-2.5 py-1 rounded-xl text-xs font-black shadow-lg">
                <%= (product.rating || 5).toFixed(1) %> <i class="fas fa-star ml-1 text-[9px] text-yellow-400"></i>
              </div>
              <a href="#reviews" class="text-slate-500 text-xs font-bold hover:text-brand-600 transition">
                <%= product.reviewCount || 0 %> Reviews
              </a>
            </div>
            <% if (product.brand) { %>
              <div class="flex items-center gap-2">
                <img class="h-7 w-7 object-contain rounded-full bg-white shadow-sm border border-slate-100 p-1"
                  src="<%= product.brand.logo || '/images/placeholder.png' %>" alt="Brand">
                <span class="text-slate-700 font-extrabold text-xs"><%= product.brand.title %></span>
              </div>
            <% } %>
          </div>

          <!-- Price & Stock Card -->
          <div class="bg-white rounded-2xl border border-slate-100 shadow-lg mb-4 relative overflow-hidden">
            <div id="stockTopBar" class="absolute top-0 left-0 h-[4px] w-full bg-emerald-500 transition-colors duration-500"></div>
            <div class="p-4">
              <div class="flex justify-between items-start gap-3">
                <div id="priceContainer" class="flex-1 min-w-0"></div>
                <button class="w-9 h-9 rounded-full bg-slate-50 text-slate-400 hover:text-brand-600 hover:bg-brand-50 flex items-center justify-center transition shrink-0">
                  <i class="fas fa-share-alt text-sm"></i>
                </button>
              </div>
              <div class="flex flex-wrap items-center justify-between gap-2 mt-3 pt-3 border-t border-slate-100">
                <div id="stockWrapper" class="flex items-center gap-2"></div>
                <div class="flex items-center gap-1.5 text-xs font-bold text-slate-700 bg-slate-50 px-3 py-1.5 rounded-xl">
                  <i class="fas fa-truck-fast text-brand-500"></i> Free Delivery
                </div>
              </div>
            </div>
          </div>

          <!-- Description -->
          <div class="bg-white rounded-2xl border border-slate-100 shadow-sm mb-4 p-4">
            <h3 class="text-sm font-extrabold mb-2 flex items-center gap-2">
              <div class="w-1.5 h-4 bg-brand-500 rounded-full shrink-0"></div>Description
            </h3>
            <p id="dynamicDescription" class="text-slate-600 text-sm font-medium leading-relaxed line-clamp-3">Loading...</p>
            <button id="readMoreBtn" class="mt-2 text-brand-600 text-xs font-bold hover:underline hidden">Read More</button>
          </div>

          <!-- Variants -->
          <% if (product.variants && product.variants.length > 0) { %>
          <div class="bg-white rounded-2xl border border-slate-100 shadow-sm mb-4 p-4">
            <h3 class="text-sm font-extrabold mb-3 flex items-center gap-2">
              <div class="w-1.5 h-4 bg-brand-500 rounded-full shrink-0"></div>Choose Variant
            </h3>
            <div class="flex flex-wrap gap-2" id="variantOptions">
              <% product.variants.forEach((variant, index) => {
                const attrs = variant.attributes || {};
                const primary = attrs.color || attrs.ram || Object.values(attrs)[0] || "Variant";
                const isOutOfStock = (variant.stock <= 0); %>
                <button type="button"
                  class="variant-option border-2 relative <%= index === 0 ? 'active border-brand-600' : 'border-slate-100' %> <%= isOutOfStock ? 'opacity-60' : 'cursor-pointer hover:border-brand-300 hover:shadow-md hover:-translate-y-0.5' %> flex flex-col items-center justify-center rounded-xl p-2 transition-all bg-white w-[76px]"
                  data-index="<%= index %>">
                  <% if (isOutOfStock) { %>
                    <span class="absolute -top-2.5 left-1/2 -translate-x-1/2 bg-slate-800 text-white text-[8px] font-black px-1.5 py-0.5 rounded-full z-10 uppercase whitespace-nowrap">Sold Out</span>
                  <% } else { %>
                    <div class="check-icon absolute -top-1.5 -right-1.5 h-5 w-5 bg-brand-600 text-white rounded-full flex items-center justify-center shadow-md scale-0 transition-transform duration-300 <%= index === 0 ? 'scale-100' : '' %>">
                      <i class="fas fa-check text-[9px]"></i>
                    </div>
                  <% } %>
                  <img class="h-10 w-10 object-contain rounded-lg drop-shadow-sm mb-1"
                    src="<%= variant.product_images?.[0]?.url || '/images/no-image.png' %>" alt="variant">
                  <p class="text-[10px] font-bold text-slate-800 text-center leading-tight"><%= primary %></p>
                </button>
              <% }) %>
            </div>
          </div>
          <% } %>

          <!-- Action buttons — always in DOM, desktop row hidden below lg via CSS -->
          <div class="hidden lg:flex gap-3 mb-6">
            <form id="cartForm" class="flex-1">
              <input type="hidden" name="productId" value="<%= product._id %>">
              <input type="hidden" name="variantId" id="cartVariantId" value="">
              <input type="hidden" name="quantity" value="1">
              <button type="submit"
                style="background:#f1f5f9; color:#0f172a;"
                class="w-full py-3.5 font-black rounded-2xl transition hover:opacity-90 active:scale-95 flex items-center justify-center gap-2 text-sm">
                <i class="fas fa-shopping-bag"></i> ADD TO CART
              </button>
            </form>
            <form id="buyNowForm" action="/checkout" method="GET" class="flex-1">
              <input type="hidden" name="productId" value="<%= product._id %>">
              <input type="hidden" name="variantId" id="checkoutVariantId" value="">
              <input type="hidden" name="qty" value="1">
              <button type="submit"
                style="background:#4f46e5; color:#fff;"
                class="w-full py-3.5 font-black rounded-2xl transition hover:opacity-90 active:scale-95 flex items-center justify-center gap-2 text-sm shadow-lg">
                <i class="fas fa-bolt" style="color:#fde047;"></i> BUY NOW
              </button>
            </form>
            <div id="notifyAction" class="hidden w-full">
              <form id="notifyForm" action="/product/notify" method="POST">
                <input type="hidden" name="productId" value="<%= product._id %>">
                <input type="hidden" name="variantId" id="notifyVariantId" value="">
                <button type="submit"
                  style="background:#0f172a; color:#fff;"
                  class="w-full py-3.5 font-black rounded-2xl transition hover:opacity-90 active:scale-95 flex items-center justify-center gap-2 text-sm">
                  <i class="fas fa-bell animate-pulse"></i> ALERT ME WHEN BACK IN STOCK
                </button>
              </form>
            </div>
            <button id="wishlistBtn" data-product-id="<%= product._id %>" data-variant-id="" type="button"
              style="background:#fff; border:2px solid #e2e8f0; color:#94a3b8;"
              class="p-3.5 rounded-2xl flex items-center justify-center transition drop-shadow-sm group shrink-0 hover:border-red-200 hover:bg-red-50">
              <i id="heartIcon" class="fa-regular fa-heart text-xl group-hover:scale-110 transition-transform" style="color:inherit;"></i>
            </button>
          </div>

          <!-- Hidden inputs for mobile action bar (no duplicate IDs — these are the only forms) -->
          <!-- The mobile bar buttons reference cartForm/buyNowForm above via JS -->

          <!-- Features -->
          <div class="grid grid-cols-3 gap-2 mb-4">
            <div class="glass-panel border border-slate-100 p-3 rounded-xl flex flex-col items-center text-center gap-1.5">
              <div class="w-8 h-8 rounded-full bg-brand-50 text-brand-600 flex items-center justify-center shrink-0">
                <i class="fas fa-truck-fast text-sm"></i>
              </div>
              <h4 class="text-[11px] font-black text-slate-800 leading-tight">Swift Delivery</h4>
              <p class="text-[10px] text-slate-500 hidden sm:block">24hrs</p>
            </div>
            <div class="glass-panel border border-slate-100 p-3 rounded-xl flex flex-col items-center text-center gap-1.5">
              <div class="w-8 h-8 rounded-full bg-brand-50 text-brand-600 flex items-center justify-center shrink-0">
                <i class="fas fa-undo text-sm"></i>
              </div>
              <h4 class="text-[11px] font-black text-slate-800 leading-tight">Easy Returns</h4>
              <p class="text-[10px] text-slate-500 hidden sm:block">7 Days</p>
            </div>
            <div class="glass-panel border border-slate-100 p-3 rounded-xl flex flex-col items-center text-center gap-1.5">
              <div class="w-8 h-8 rounded-full bg-brand-50 text-brand-600 flex items-center justify-center shrink-0">
                <i class="fas fa-shield-check text-sm"></i>
              </div>
              <h4 class="text-[11px] font-black text-slate-800 leading-tight">Warranty</h4>
              <p class="text-[10px] text-slate-500 hidden sm:block">Brand backed</p>
            </div>
          </div>

          <!-- Specifications (dynamic) -->
          <div class="specifications-section space-y-4 mb-4"></div>

        </div>
      </div>
    </div>

    <!-- ═══ SIMILAR PRODUCTS ═══ -->
    <% if (typeof similarProducts !== 'undefined' && similarProducts.length > 0) { %>
    <div class="mt-10 pt-8 border-t border-slate-200">
      <div class="flex items-center justify-between mb-6">
        <div>
          <h3 class="text-xl sm:text-2xl font-black text-slate-900 tracking-tight">You Might Also Like</h3>
          <p class="text-xs text-slate-500 mt-1">Customers who viewed this also bought.</p>
        </div>
        <a href="/shop" class="hidden sm:flex items-center gap-1.5 px-4 py-2 bg-white border border-slate-200 rounded-full text-xs font-bold text-slate-700 hover:border-brand-300 hover:text-brand-600 transition shadow-sm">
          View All <i class="fas fa-arrow-right text-[9px]"></i>
        </a>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3 sm:gap-4">
        <% similarProducts.forEach(simProd => {
          const simVariant = simProd.variants?.[0];
          const simVariantId = simVariant?._id;
          const simPrice = simVariant?.price || 0;
          const simFinalPrice = simVariant?.finalPrice ?? simVariant?.regular_price ?? simPrice;
          const simKey = `${simProd._id}_${simVariantId}`;
          const simIsWishlisted = wishlistSet?.has(simKey);
          const simIsCarted = cartSet?.has(simKey);
        %>
        <div class="group bg-white border border-slate-100 rounded-2xl p-3 sm:p-4 transition-all duration-300 hover:shadow-xl hover:-translate-y-1 relative">
          <a href="/product/<%= simProd._id %>" class="block absolute inset-0 z-10 w-full h-full rounded-2xl"></a>
          <div class="relative w-full aspect-square rounded-xl bg-slate-50 flex items-center justify-center overflow-hidden mb-3 group-hover:bg-slate-100 transition-colors">
            <img src="<%= simVariant?.product_images?.[0]?.url || '/images/placeholder.png' %>"
              alt="<%= simProd.name %>"
              class="max-w-[70%] max-h-[70%] object-contain group-hover:scale-110 transition-transform duration-500">
            <% if (simFinalPrice < simPrice) { %>
              <div class="absolute top-2 left-2 bg-red-500 text-white text-[9px] font-black uppercase px-2 py-0.5 rounded-lg z-20">Sale</div>
            <% } %>
            <% if (simVariantId) { %>
              <button id="wishlist-<%= simVariantId %>" data-product-id="<%= simProd._id %>" data-variant-id="<%= simVariantId %>"
                <%= simIsCarted ? 'disabled' : '' %>
                class="wishlist absolute top-2 right-2 z-20 w-7 h-7 bg-white/90 backdrop-blur rounded-full shadow flex items-center justify-center hover:bg-red-50 transition <%= simIsCarted ? 'opacity-50 cursor-not-allowed' : '' %>">
                <i class="fa-heart <%= simIsWishlisted ? 'fa-solid text-red-500' : 'fa-regular text-gray-500' %> text-xs"></i>
              </button>
            <% } %>
          </div>
          <h4 class="text-slate-900 font-black text-xs sm:text-sm mb-1 line-clamp-2 group-hover:text-brand-600 transition-colors leading-snug">
            <%= simProd.name %>
          </h4>
          <div class="flex items-end justify-between mt-2">
            <div class="flex flex-col">
              <% if (simFinalPrice < simPrice) { %>
                <span class="text-[10px] text-slate-400 line-through font-bold">₹<%= Number(simPrice).toLocaleString('en-IN') %></span>
              <% } %>
              <span class="text-brand-600 font-black text-sm sm:text-base leading-none">₹<%= Number(simFinalPrice).toLocaleString('en-IN') %></span>
            </div>
            <% if (simVariantId) { %>
              <% if (!simIsCarted) { %>
                <button data-product-id="<%= simProd._id %>" data-variant-id="<%= simVariantId %>"
                  class="add-to-cart relative z-20 w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center text-slate-500 group-hover:bg-slate-900 group-hover:text-white transition-all shadow-sm">
                  <i class="fas fa-shopping-cart text-xs"></i>
                </button>
              <% } else { %>
                <button data-product-id="<%= simProd._id %>" data-variant-id="<%= simVariantId %>"
                  class="add-to-cart increase relative z-20 w-8 h-8 rounded-full bg-slate-900 flex items-center justify-center text-white transition-all shadow-sm">
                  <i class="fas fa-check text-xs"></i>
                </button>
              <% } %>
            <% } %>
          </div>
        </div>
        <% }) %>
      </div>
    </div>
    <% } %>

    <!-- ═══ REVIEWS ═══ -->
    <div id="reviews" class="mt-10 pt-8 border-t border-slate-200">
      <!-- Header -->
      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 mb-6 bg-white p-5 sm:p-6 rounded-2xl shadow-md border border-slate-50">
        <div>
          <h3 class="text-xl sm:text-2xl font-black text-slate-900 tracking-tight">Verified Feedback</h3>
          <p class="text-slate-500 text-xs mt-1">Real reviews from people who bought this gadget.</p>
        </div>
        <div class="flex items-center gap-4 bg-slate-50 p-3 rounded-2xl border border-slate-100 w-fit">
          <div class="text-center px-2">
            <div class="text-2xl sm:text-3xl font-black text-slate-900 leading-none"><%= (product.rating || 0).toFixed(1) %></div>
            <div class="text-[9px] text-slate-400 font-black uppercase tracking-widest mt-1">Average</div>
          </div>
          <div class="h-8 w-[1px] bg-slate-200 rounded-full"></div>
          <div class="text-center px-2">
            <div class="text-2xl sm:text-3xl font-black text-brand-600 leading-none"><%= product.reviewCount || 0 %></div>
            <div class="text-[9px] text-slate-400 font-black uppercase tracking-widest mt-1">Reviews</div>
          </div>
        </div>
      </div>

      <div class="grid lg:grid-cols-12 gap-6">
        <!-- Review Form -->
        <div class="lg:col-span-4">
          <div class="lg:sticky lg:top-24 bg-white border border-slate-100 p-5 sm:p-6 rounded-2xl shadow-md">
            <h4 class="text-base font-black text-slate-900 mb-4 flex items-center gap-2">
              <span class="w-1.5 h-5 bg-brand-600 rounded-full"></span> Share your thoughts
            </h4>
            <form id="reviewForm" action="/product/review" method="POST" class="space-y-4">
              <input type="hidden" name="productId" value="<%= product._id %>">
              <div class="bg-slate-50 p-3 rounded-xl border border-slate-100">
                <div class="flex justify-between items-center mb-2">
                  <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Rate Experience</label>
                  <span id="ratingStatus" class="text-[10px] font-bold text-brand-600 bg-brand-50 px-2 py-0.5 rounded-md">Select Stars</span>
                </div>
                <div class="flex items-center gap-2 text-2xl text-slate-200 cursor-pointer justify-center py-1" id="starRating">
                  <i class="fas fa-star transition-all hover:scale-110" data-rating="1"></i>
                  <i class="fas fa-star transition-all hover:scale-110" data-rating="2"></i>
                  <i class="fas fa-star transition-all hover:scale-110" data-rating="3"></i>
                  <i class="fas fa-star transition-all hover:scale-110" data-rating="4"></i>
                  <i class="fas fa-star transition-all hover:scale-110" data-rating="5"></i>
                </div>
                <input type="hidden" name="rating" id="ratingValue" value="0">
              </div>
              <div>
                <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest block mb-2">Detailed Review</label>
                <textarea name="comment" rows="4"
                  class="w-full bg-slate-50 border border-slate-200 rounded-xl p-4 text-slate-700 focus:outline-none focus:ring-2 focus:ring-brand-500/30 focus:border-brand-400 focus:bg-white transition-all text-sm resize-none font-medium placeholder:text-slate-400"
                  placeholder="What makes this special to you?"></textarea>
              </div>
              <button type="submit"
                class="w-full bg-slate-900 text-white font-black py-3 rounded-xl transition-all hover:bg-brand-600 active:scale-95 flex items-center justify-center gap-2 text-sm group">
                POST REVIEW <i class="fas fa-paper-plane text-[10px] group-hover:-translate-y-0.5 group-hover:translate-x-0.5 transition-transform"></i>
              </button>
            </form>
          </div>
        </div>

        <!-- Review List -->
        <div class="lg:col-span-8 space-y-4">
          <% if (typeof product.reviews !== 'undefined' && product.reviews.length > 0) { %>
            <% product.reviews.forEach(review => { %>
            <div class="bg-white border border-slate-100 p-5 sm:p-6 rounded-2xl transition-all hover:border-brand-200 hover:shadow-lg">
              <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-3 mb-3">
                <div class="flex items-center gap-3">
                  <div class="h-11 w-11 bg-gradient-to-br from-slate-800 to-slate-900 text-white rounded-full flex items-center justify-center font-black text-base shadow-md border-4 border-slate-50 shrink-0">
                    <%= review.user?.name?.charAt(0) || 'U' %>
                  </div>
                  <div>
                    <h5 class="text-sm font-black text-slate-900"><%= review.user?.name || 'Anonymous User' %></h5>
                    <div class="flex items-center gap-2 mt-1">
                      <div class="flex text-yellow-400 text-[10px]">
                        <% for(let i=1; i<=5; i++) { %>
                          <i class="fas fa-star <%= i <= review.rating ? '' : 'text-slate-200' %>"></i>
                        <% } %>
                      </div>
                      <span class="text-[9px] text-emerald-700 font-extrabold uppercase bg-emerald-100 px-1.5 py-0.5 rounded-full inline-flex items-center gap-0.5">
                        <i class="fas fa-check-circle"></i> Verified
                      </span>
                    </div>
                  </div>
                </div>
                <span class="text-[10px] font-bold text-slate-400 bg-slate-50 px-2.5 py-1 rounded-lg border border-slate-100 shrink-0">
                  <%= new Date(review.createdAt || Date.now()).toLocaleDateString('en-US', {month:'short',day:'numeric',year:'numeric'}) %>
                </span>
              </div>
              <p class="text-sm text-slate-600 font-medium leading-relaxed sm:pl-14">"<%= review.comment %>"</p>
              <div class="mt-4 sm:pl-14 flex items-center gap-4">
                <button class="text-[11px] font-bold text-slate-400 hover:text-brand-600 hover:bg-brand-50 px-2.5 py-1 rounded-lg transition-all flex items-center gap-1 border border-transparent hover:border-brand-100">
                  <i class="far fa-thumbs-up"></i> Helpful
                </button>
                <button class="text-[11px] font-bold text-slate-400 hover:text-red-500 hover:bg-red-50 px-2.5 py-1 rounded-lg transition-all flex items-center gap-1 border border-transparent hover:border-red-100">
                  <i class="far fa-flag"></i> Report
                </button>
              </div>
            </div>
            <% }) %>
          <% } else { %>
            <div class="flex flex-col items-center justify-center min-h-[300px] bg-slate-50/50 rounded-2xl border border-dashed border-slate-200 p-8">
              <div class="w-16 h-16 bg-white rounded-2xl shadow-md flex items-center justify-center mb-4">
                <i class="far fa-comments text-brand-300 text-3xl"></i>
              </div>
              <h5 class="text-lg text-slate-900 font-black tracking-tight">No reviews yet</h5>
              <p class="text-slate-500 text-sm font-medium mt-1 text-center max-w-xs">Be the first to share your thoughts on this product!</p>
            </div>
          <% } %>
        </div>
      </div>
    </div>

  </div>
</section>

<!-- ═══ MOBILE FIXED ACTION BAR (below lg) ═══ -->
<div class="pd-action-bar" id="pdActionBar">
  <button id="mobileCartBtn"
    class="flex-1 h-12 bg-gray-100 text-gray-900 font-black rounded-xl flex items-center justify-center gap-2 text-sm active:scale-95 transition">
    <i class="fas fa-shopping-bag text-sm"></i> Add to Cart
  </button>
  <button id="mobileBuyBtn"
    style="background:#4f46e5; color:#fff;"
    class="flex-1 h-12 font-black rounded-xl flex items-center justify-center gap-2 text-sm active:scale-95 transition shadow-lg">
    <i class="fas fa-bolt text-yellow-300 text-sm"></i> Buy Now
  </button>
  <button id="mobileWishBtn"
    class="w-12 h-12 bg-white border-2 border-gray-200 rounded-xl flex items-center justify-center text-gray-400 active:scale-95 transition shrink-0">
    <i id="mobileHeartIcon" class="fa-regular fa-heart text-base"></i>
  </button>
</div>

<script type="module">
  import { showToast } from "/partials/errorMsg.utils.js";
  window.showMessage = showToast;
</script>

<script>
  // ── Desktop zoom (hover devices only) ────────────────────────────────────
  const isHoverDevice = window.matchMedia('(hover: hover) and (pointer: fine)').matches;
  if (isHoverDevice) {
    const _zoomContainer = document.getElementById("mainImageContainer");
    const _zoomImage = document.getElementById("mainImage");
    if (_zoomContainer && _zoomImage) {
      _zoomContainer.addEventListener("mousemove", (e) => {
        const rect = _zoomContainer.getBoundingClientRect();
        const xPct = ((e.clientX - rect.left) / rect.width) * 100;
        const yPct = ((e.clientY - rect.top) / rect.height) * 100;
        _zoomImage.style.transformOrigin = `${xPct}% ${yPct}%`;
        _zoomImage.style.transform = "scale(2)";
      });
      _zoomContainer.addEventListener("mouseleave", () => {
        _zoomImage.style.transform = "scale(1)";
        _zoomImage.style.transformOrigin = "center center";
      });
    }
  }
</script>

<script>
  const productVariants = <%- JSON.stringify((product.variants || []).map(v => ({
    _id: String(v._id || ''),
    price: v.regular_price || 0,
    finalPrice: v.finalPrice ?? v.price ?? 0,
    stock: Number(v.stock || 0),
    description: v.description || "",
    attributes: v.attributes || {},
    product_images: (v.product_images || []).map(img => ({ url: img.url || '' }))
  }))) %>;

  const isLoggedIn = <%= user ? 'true' : 'false' %>;
  let currentVariant = null;
  let isInCart = false;

  // ── Element refs ──────────────────────────────────────────────────────────
  const wishlistBtn     = document.getElementById('wishlistBtn');
  const heartIcon       = document.getElementById('heartIcon');
  const mobileHeartIcon = document.getElementById('mobileHeartIcon');
  const cartForm        = document.getElementById('cartForm');
  const cartBtn         = cartForm?.querySelector("button");
  const mobileCartBtn   = document.getElementById('mobileCartBtn');
  const mobileBuyBtn    = document.getElementById('mobileBuyBtn');
  const mobileWishBtn   = document.getElementById('mobileWishBtn');

  // ── Heart UI ──────────────────────────────────────────────────────────────
  function setHeart(active) {
    if (heartIcon) heartIcon.className = active
      ? "fa-solid fa-heart text-red-500 text-xl group-hover:scale-110 transition-transform"
      : "fa-regular fa-heart text-xl group-hover:scale-110 transition-transform";
    if (mobileHeartIcon) mobileHeartIcon.className = active
      ? "fa-solid fa-heart text-red-500 text-base"
      : "fa-regular fa-heart text-base";
  }

  // ── Price render ──────────────────────────────────────────────────────────
  function renderPrice(v) {
    const pc = document.getElementById('priceContainer');
    if (!pc || !v) return;
    const price = v.price || 0;
    const fp    = v.finalPrice ?? price;
    if (fp < price) {
      const disc  = Math.round(((price - fp) / price) * 100);
      const saved = price - fp;
      pc.innerHTML = `
        <div class="flex flex-col gap-1 min-w-0">
          <div class="flex items-baseline gap-2 flex-wrap">
            <span class="text-xl sm:text-2xl lg:text-3xl font-black text-brand-600 tracking-tight">&#8377;${fp.toLocaleString('en-IN')}</span>
            <span class="text-xs text-slate-400 line-through font-bold">&#8377;${price.toLocaleString('en-IN')}</span>
            <span class="bg-green-600 text-white text-[10px] font-bold px-2 py-0.5 rounded-md whitespace-nowrap">${disc}% OFF</span>
          </div>
          <span class="text-xs text-green-600 font-bold">You save &#8377;${saved.toLocaleString('en-IN')}</span>
          <span class="text-[11px] text-slate-500">Inclusive of all taxes</span>
        </div>`;
    } else {
      pc.innerHTML = `
        <div class="flex flex-col gap-1 min-w-0">
          <span class="text-xl sm:text-2xl lg:text-3xl font-black text-brand-600 tracking-tight">&#8377;${price.toLocaleString('en-IN')}</span>
          <span class="text-[11px] text-slate-500">Inclusive of all taxes</span>
        </div>`;
    }
  }

  // ── Stock render ──────────────────────────────────────────────────────────
  function renderStock(v) {
    if (!v) return;
    const sw  = document.getElementById('stockWrapper');
    const stb = document.getElementById('stockTopBar');
    const bnBtn = document.getElementById('buyNowForm')?.querySelector('button');
    if (v.stock > 0) {
      if (sw) sw.innerHTML = `<div class="w-2.5 h-2.5 rounded-full bg-emerald-500 animate-pulse"></div><span class="text-xs font-black text-emerald-600">In Stock (${v.stock} left)</span>`;
      if (stb) stb.className = "absolute top-0 left-0 h-[4px] w-full bg-emerald-500 transition-colors duration-500";
      if (cartBtn) { cartBtn.disabled = false; cartBtn.style.opacity = "1"; cartBtn.style.cursor = "pointer"; }
      if (bnBtn)   { bnBtn.disabled = false;   bnBtn.style.opacity = "1"; bnBtn.style.cursor = "pointer"; }
      if (mobileCartBtn) { mobileCartBtn.disabled = false; mobileCartBtn.style.opacity = "1"; mobileCartBtn.style.cursor = "pointer"; }
      if (mobileBuyBtn)  { mobileBuyBtn.disabled = false;  mobileBuyBtn.style.opacity = "1"; mobileBuyBtn.style.cursor = "pointer"; }
    } else {
      if (sw) sw.innerHTML = `<span class="text-xs font-black text-red-500"><i class="fas fa-times-circle mr-1"></i>Out of Stock</span>`;
      if (stb) stb.className = "absolute top-0 left-0 h-[4px] w-full bg-red-500 transition-colors duration-500";
      if (cartBtn) { cartBtn.disabled = true; cartBtn.style.opacity = "0.5"; cartBtn.style.cursor = "not-allowed"; }
      if (bnBtn)   { bnBtn.disabled = true;   bnBtn.style.opacity = "0.5"; bnBtn.style.cursor = "not-allowed"; }
      if (mobileCartBtn) { mobileCartBtn.disabled = true; mobileCartBtn.style.opacity = "0.5"; mobileCartBtn.style.cursor = "not-allowed"; }
      if (mobileBuyBtn)  { mobileBuyBtn.disabled = true;  mobileBuyBtn.style.opacity = "0.5"; mobileBuyBtn.style.cursor = "not-allowed"; }
    }
  }

  // ── Image render ──────────────────────────────────────────────────────────
  function renderImages(v) {
    if (!v) return;
    const mainImg = document.getElementById('mainImage');
    const thumbList = document.getElementById('thumbnailList');
    const imgs = (v.product_images?.length) ? v.product_images : [{ url: '/images/placeholder.png' }];
    if (mainImg) mainImg.src = imgs[0].url;
    if (!thumbList) return;
    thumbList.innerHTML = '';
    imgs.forEach((img, i) => {
      const btn = document.createElement('button');
      btn.className = "thumb border-2 border-slate-100 rounded-xl overflow-hidden hover:border-brand-300 transition-colors h-14 w-14 bg-white shrink-0";
      if (i === 0) btn.classList.add("active","border-brand-600");
      btn.innerHTML = `<img src="${img.url}" class="w-full h-full object-contain p-1" loading="lazy">`;
      btn.onclick = () => {
        if (mainImg) mainImg.src = img.url;
        thumbList.querySelectorAll('.thumb').forEach(t => { t.classList.remove('active','border-brand-600'); t.classList.add('border-slate-100'); });
        btn.classList.add('active','border-brand-600'); btn.classList.remove('border-slate-100');
      };
      thumbList.appendChild(btn);
    });
  }

  // ── Description render ────────────────────────────────────────────────────
  function renderDescription(v) {
    const el = document.getElementById("dynamicDescription");
    if (el) el.innerText = v?.description || "No description available for this variant.";
  }

  // ── Specifications render ─────────────────────────────────────────────────
  function renderSpecifications() {
    const sc = document.querySelector(".specifications-section");
    if (!sc) return;
    const productAttrs = <%- JSON.stringify(product.attributes || {}) %>;
    const variantAttrs = currentVariant?.attributes || {};
    const allSpecs = { ...productAttrs, ...variantAttrs };
    if (!Object.keys(allSpecs).length) { sc.innerHTML = ""; return; }
    sc.innerHTML = `
      <div class="bg-white border border-slate-100 rounded-2xl p-4 sm:p-5 shadow-sm">
        <h3 class="text-sm font-extrabold mb-3 flex items-center gap-2">
          <div class="w-1.5 h-4 bg-brand-500 rounded-full"></div>Specifications
        </h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
          ${Object.entries(allSpecs).map(([k,val]) => `
            <div class="flex justify-between bg-slate-50 px-3 py-2.5 rounded-xl gap-2">
              <span class="text-slate-500 text-xs font-bold capitalize shrink-0">${k.replace(/_/g," ")}</span>
              <span class="text-slate-900 text-xs font-extrabold text-right">${val}</span>
            </div>`).join("")}
        </div>
      </div>`;
  }

  // ── Variant change ────────────────────────────────────────────────────────
  function setActiveVariant(index) {
    currentVariant = productVariants[index];
    if (!currentVariant) return;
    if (wishlistBtn) wishlistBtn.dataset.variantId = currentVariant._id;
    ['cartVariantId','checkoutVariantId','notifyVariantId'].forEach(id => {
      const el = document.getElementById(id); if (el) el.value = currentVariant._id;
    });
    renderPrice(currentVariant);
    renderStock(currentVariant);
    renderImages(currentVariant);
    renderSpecifications();
    renderDescription(currentVariant);
    document.querySelectorAll('.variant-option').forEach(el => {
      el.classList.remove('active','border-brand-600'); el.classList.add('border-slate-100');
      const chk = el.querySelector('.check-icon'); if (chk) chk.classList.replace('scale-100','scale-0');
    });
    const ab = document.querySelector(`[data-index="${index}"]`);
    if (ab && !ab.classList.contains('variant-out-of-stock')) {
      ab.classList.add('active','border-brand-600'); ab.classList.remove('border-slate-100');
      const chk = ab.querySelector('.check-icon'); if (chk) chk.classList.replace('scale-0','scale-100');
    }
    checkWishlistStatus();
    checkCartStatus();
  }

  // ── Cart status ───────────────────────────────────────────────────────────
  async function checkCartStatus() {
    if (!isLoggedIn || !currentVariant) return;
    try {
      const pid = wishlistBtn?.dataset.productId || '<%= product._id %>';
      const res = await fetch(`/cart/status?productId=${pid}&variantId=${currentVariant._id}`);
      if (!res.ok) return;
      const data = await res.json();
      isInCart = data.inCart;
      if (isInCart) {
        if (cartBtn) {
          cartBtn.innerHTML = `GO TO CART <i class="fas fa-arrow-right text-xs"></i>`;
          cartBtn.style.cssText = "background:#10b981; color:#fff;";
          cartBtn.className = "w-full py-3.5 font-black rounded-2xl transition hover:opacity-90 active:scale-95 flex items-center justify-center gap-2 text-sm shadow-lg";
          cartBtn.disabled = false;
        }
        if (mobileCartBtn) {
          mobileCartBtn.innerHTML = `<i class="fas fa-arrow-right text-sm"></i> Go to Cart`;
          mobileCartBtn.style.cssText = "background:#10b981; color:#fff;";
          mobileCartBtn.className = "flex-1 h-12 font-black rounded-xl flex items-center justify-center gap-2 text-sm active:scale-95 transition";
        }
        if (wishlistBtn) { wishlistBtn.disabled = true; wishlistBtn.classList.add("opacity-50","cursor-not-allowed"); }
        if (mobileWishBtn) { mobileWishBtn.disabled = true; mobileWishBtn.classList.add("opacity-50","cursor-not-allowed"); }
      } else {
        if (currentVariant.stock > 0) {
          if (cartBtn) {
            cartBtn.innerHTML = `<i class="fas fa-shopping-bag"></i> ADD TO CART`;
            cartBtn.style.cssText = "background:#f1f5f9; color:#0f172a;";
            cartBtn.className = "w-full py-3.5 font-black rounded-2xl transition hover:opacity-90 active:scale-95 flex items-center justify-center gap-2 text-sm";
            cartBtn.disabled = false;
          }
          if (mobileCartBtn) {
            mobileCartBtn.innerHTML = `<i class="fas fa-shopping-bag text-sm"></i> Add to Cart`;
            mobileCartBtn.style.cssText = "background:#f1f5f9; color:#0f172a;";
            mobileCartBtn.className = "flex-1 h-12 font-black rounded-xl flex items-center justify-center gap-2 text-sm active:scale-95 transition";
          }
        }
        if (wishlistBtn) { wishlistBtn.disabled = false; wishlistBtn.classList.remove("opacity-50","cursor-not-allowed"); }
        if (mobileWishBtn) { mobileWishBtn.disabled = false; mobileWishBtn.classList.remove("opacity-50","cursor-not-allowed"); }
      }
    } catch(e) { console.log(e); }
  }

  // ── Add to cart ───────────────────────────────────────────────────────────
  async function doAddToCart(btn) {
    if (!isLoggedIn) return showMessage("Please log in to add items to your cart.", "warning");
    if (isInCart) { window.location.href = "/cart"; return; }
    if (!currentVariant || currentVariant.stock <= 0) { showMessage("This item is currently out of stock", "error"); return; }
    const cc = +document.getElementById('cartCount').textContent || 0;
    if (cc >= 5) { showMessage("Maximum 5 different products allowed in cart.", "warning"); return; }
    const orig = btn.innerHTML;
    btn.disabled = true; btn.innerHTML = `<i class="fas fa-spinner fa-spin"></i>`;
    try {
      const res = await fetch("/cart", { method:"POST", headers:{"Content-Type":"application/json"}, body:JSON.stringify({ productId:'<%= product._id %>', variantId:currentVariant._id, quantity:1 }) });
      const result = await res.json();
      if (!res.ok) throw new Error(result.message || "Failed");
      const data = result.data || {};
      showMessage(result.message || "Added to Cart!", "success");
      const wc = document.getElementById('wishlistCount');
      const cc2 = document.getElementById('cartCount');
      if (data.removedFromWishlit && wc) { setHeart(false); wc.textContent = Math.max(0, +wc.textContent - 1); }
      if (data.added && cc2) cc2.textContent = +cc2.textContent + 1;
      isInCart = true; checkCartStatus();
    } catch(err) { showMessage(err.message, "error"); btn.disabled = false; btn.innerHTML = orig; checkCartStatus(); }
  }

  // ── Wishlist toggle ───────────────────────────────────────────────────────
  async function toggleWishlist() {
    if (!isLoggedIn) return showMessage("Please log in to manage your wishlist.", "warning");
    if (isInCart) { showMessage("This item is already in your cart!", "warning"); return; }
    try {
      if (wishlistBtn) { wishlistBtn.disabled = true; }
      if (heartIcon) heartIcon.className = "fas fa-spinner fa-spin text-xl text-slate-400";
      const res = await fetch("/api/wishlist", { method:"POST", headers:{"Content-Type":"application/json"}, body:JSON.stringify({ productId:wishlistBtn?.dataset.productId || '<%= product._id %>', variantId:currentVariant._id }) });
      const result = await res.json();
      if (!res.ok) throw new Error(result.message);
      const data = result.data || {};
      const wc = document.getElementById('wishlistCount');
      let cur = +(wc?.textContent || 0);
      if (data.added || result.message?.toLowerCase().includes("added")) { cur++; setHeart(true); }
      else { cur = Math.max(0, cur - 1); setHeart(false); }
      if (wc) wc.textContent = cur;
      showMessage(result.message || "Wishlist updated", "success");
    } catch(err) { showMessage(err.message, "error"); checkWishlistStatus(); }
    finally { if (!isInCart && wishlistBtn) wishlistBtn.disabled = false; }
  }

  // ── Wishlist status ───────────────────────────────────────────────────────
  async function checkWishlistStatus() {
    if (!isLoggedIn || !currentVariant) return;
    try {
      const pid = wishlistBtn?.dataset.productId || '<%= product._id %>';
      const res = await fetch(`/wishlist/status?productId=${pid}&variantId=${currentVariant._id}`);
      if (!res.ok) return;
      const data = await res.json();
      setHeart(data.inWishlist);
    } catch(e) { console.log(e); }
  }

  // ── Event wiring ──────────────────────────────────────────────────────────
  cartForm?.addEventListener("submit", async (e) => { e.preventDefault(); await doAddToCart(cartBtn); });
  mobileCartBtn?.addEventListener("click", async () => { if (isInCart) { window.location.href="/cart"; return; } await doAddToCart(mobileCartBtn); });
  mobileBuyBtn?.addEventListener("click", () => {
    if (!isLoggedIn) { showMessage("Please log in to continue.", "warning"); return; }
    if (!currentVariant || currentVariant.stock <= 0) { showMessage("Out of stock", "error"); return; }
    document.getElementById('buyNowForm')?.submit();
  });
  mobileWishBtn?.addEventListener("click", toggleWishlist);

  // ── Star rating ───────────────────────────────────────────────────────────
  const starIcons = document.querySelectorAll("#starRating i");
  const ratingVal = document.getElementById("ratingValue");
  const ratingStatus = document.getElementById("ratingStatus");
  starIcons.forEach(star => {
    star.addEventListener("click", () => {
      const r = parseInt(star.dataset.rating);
      if (ratingVal) ratingVal.value = r;
      starIcons.forEach(s => {
        const sr = parseInt(s.dataset.rating);
        s.classList.toggle("text-yellow-400", sr <= r);
        s.classList.toggle("text-slate-200", sr > r);
      });
      if (ratingStatus) ratingStatus.innerText = `${r} Stars - ${['Terrible','Bad','Okay','Good','Excellent!'][r-1]}`;
    });
  });
  document.getElementById("reviewForm")?.addEventListener("submit", (e) => {
    if (ratingVal?.value === "0") { e.preventDefault(); showMessage("Please select a star rating first!", "warning"); }
  });

  // ── Init ──────────────────────────────────────────────────────────────────
  document.addEventListener("DOMContentLoaded", () => {
    let idx = 0;
    const inStock = productVariants.findIndex(v => v.stock > 0);
    if (inStock !== -1) idx = inStock;
    if (productVariants.length) setActiveVariant(idx);
    document.getElementById('variantOptions')?.addEventListener('click', e => {
      const btn = e.target.closest('.variant-option');
      if (!btn) return;
      if (btn.classList.contains('variant-out-of-stock')) { showMessage("This variant is out of stock", "warning"); return; }
      setActiveVariant(btn.dataset.index);
    });
    if (wishlistBtn) wishlistBtn.addEventListener("click", toggleWishlist);
  });
</script>

<script src="/socket.io/socket.io.js"></script>
<script>
  const _socket = io();
  const _thisProductId = "<%= String(product._id) %>";
  _socket.on("stockUpdated", ({ productId, variantId, stock }) => {
    if (String(productId) !== _thisProductId) return;
    const _v = productVariants.find(v => String(v._id) === String(variantId));
    if (!_v) return;
    _v.stock = stock;
    const _idx = productVariants.indexOf(_v);
    const _btn = document.querySelector(`.variant-option[data-index="${_idx}"]`);
    if (_btn) {
      const _badge = _btn.querySelector('.sold-out-badge');
      if (stock <= 0) {
        _btn.classList.add('opacity-60','variant-out-of-stock');
        _btn.classList.remove('cursor-pointer','hover:border-brand-300');
        if (!_badge) { const b = document.createElement('span'); b.className='sold-out-badge absolute -top-2.5 left-1/2 -translate-x-1/2 bg-slate-800 text-white text-[8px] font-black px-1.5 py-0.5 rounded-full z-10 uppercase whitespace-nowrap'; b.textContent='Sold Out'; _btn.appendChild(b); }
      } else {
        _btn.classList.remove('opacity-60','variant-out-of-stock');
        _btn.classList.add('cursor-pointer','hover:border-brand-300');
        if (_badge) _badge.remove();
      }
    }
    if (currentVariant && String(currentVariant._id) === String(variantId)) { currentVariant.stock = stock; renderStock(currentVariant); }
  });
</script>

<script>
  // Similar products wishlist + cart handlers
  const _isLoggedInSim = <%= typeof user !== 'undefined' && user ? 'true' : 'false' %>;
  document.addEventListener('click', async (e) => {
    const link = e.target.closest('.wishlist');
    if (!link) return;
    if (!_isLoggedInSim) { window.showMessage("Please log in to manage your wishlist.", "warning"); return; }
    if (link.classList.contains("loading")) return;
    link.classList.add("loading");
    const productId = link.dataset.productId, variantId = link.dataset.variantId;
    if (!productId || !variantId) { link.classList.remove("loading"); return; }
    try {
      const res = await fetch('/wishlist', { method:"POST", headers:{'Content-Type':'application/json','Accept':'application/json'}, body:JSON.stringify({productId,variantId}) });
      const { success, data, message } = await res.json();
      if (!success) { window.showMessage(message,"error"); return; }
      const icon = link.querySelector("i");
      const wc = document.getElementById('wishlistCount');
      let cur = +(wc?.textContent || 0);
      if (data.added) { icon?.classList.replace("fa-regular","fa-solid"); icon?.classList.add("text-red-500"); if(wc) wc.textContent = cur+1; }
      else { icon?.classList.replace("fa-solid","fa-regular"); icon?.classList.remove("text-red-500"); if(wc) wc.textContent = Math.max(0,cur-1); }
      window.showMessage(message || "Wishlist updated","success");
    } catch(err) { window.showMessage("Failed to update wishlist","error"); }
    finally { link.classList.remove("loading"); }
  });

  document.addEventListener('click', async (e) => {
    const btn = e.target.closest('.add-to-cart');
    if (!btn) return;
    if (btn.closest('#cartForm')) return;
    if (!_isLoggedInSim) { window.showMessage("Please log in to add to cart.","warning"); return; }
    if (btn.classList.contains("loading")) return;
    btn.classList.add("loading");
    const productId = btn.dataset.productId, variantId = btn.dataset.variantId;
    if (!productId || !variantId) { btn.classList.remove("loading"); return; }
    const ccEl = document.getElementById('cartCount');
    if (+(ccEl?.textContent||0) >= 5) { window.showMessage("Maximum 5 different products allowed in cart.","warning"); btn.classList.remove("loading"); return; }
    try {
      const res = await fetch('/cart', { method:"POST", headers:{'Content-Type':'application/json','Accept':'application/json'}, body:JSON.stringify({productId,variantId,quantity:1}) });
      const result = await res.json();
      if (!result.success) { window.showMessage(result.message,"error"); return; }
      const icon = btn.querySelector("i");
      if (icon) { icon.classList.remove("fa-shopping-cart"); icon.classList.add("fa-check"); }
      btn.classList.remove("bg-slate-100","text-slate-500"); btn.classList.add("bg-slate-900","text-white");
      if (result.data?.added && ccEl) ccEl.textContent = +(ccEl.textContent||0)+1;
      window.showMessage(result.message || "Added to cart","success");
    } catch(err) { window.showMessage("Failed to add to cart","error"); }
    finally { btn.classList.remove("loading"); }
  });
</script>

