<% products.forEach(product => {
    const variantId = product.variantId;
    if (!variantId) return;

    const image       = product?.image || "https://placehold.co/400x400";
    const brand       = product?.brand || "Brand";
    const brandLogo   = product?.brandLogo || "/images/placeholder.png";
    const sellingPrice = product?.price || 0;
    const regularPrice = product?.regular_price || sellingPrice;
    const finalPrice   = product?.finalPrice ?? sellingPrice;
    const savings      = product?.savings || 0;
    const discountPct  = regularPrice > 0 ? Math.round(((regularPrice - finalPrice) / regularPrice) * 100) : 0;
    const key          = `${product._id}_${variantId}`;
    const isWishlisted = wishlistSet?.has(key);
    const isCarted     = cartSet?.has(key);
%>

<div class="product-card group relative bg-white rounded-2xl overflow-hidden border border-gray-100 shadow-sm flex flex-col"
     data-product-id="<%= product._id %>"
     data-variant-id="<%= variantId %>">

    <!-- IMAGE AREA -->
    <div class="relative w-full aspect-square overflow-hidden bg-gray-50 group-hover:bg-white transition-colors duration-300 cursor-pointer"
         onclick="window.location.href='/product/<%= product._id %>'">

        <img src="<%= image %>"
             alt="<%= product.name %>"
             loading="lazy"
             class="w-full h-full object-contain p-5 group-hover:scale-108 transition-transform duration-500 mix-blend-multiply"
             style="--tw-scale-x:1.08;--tw-scale-y:1.08;">

        <!-- Discount badge -->
        <% if (discountPct > 0) { %>
        <span class="absolute top-3 left-3 bg-red-500 text-white text-[10px] font-black px-2.5 py-1 rounded-xl tracking-wide">
            -<%= discountPct %>%
        </span>
        <% } %>

        <!-- Action buttons — slide in from right on hover -->
        <div class="absolute top-3 right-3 flex flex-col gap-2
                    opacity-100 lg:opacity-0 lg:translate-x-3
                    lg:group-hover:translate-x-0 lg:group-hover:opacity-100
                    transition-all duration-300">

            <!-- Wishlist -->
            <button id="wishlist-<%= variantId %>"
                    data-product-id="<%= product._id %>"
                    data-variant-id="<%= variantId %>"
                    <%= isCarted ? 'disabled' : '' %>
                    class="wishlist w-9 h-9 bg-white shadow-md rounded-xl flex items-center justify-center hover:bg-red-50 transition-colors <%= isCarted ? 'opacity-40 cursor-not-allowed' : '' %>">
                <i class="fa-heart text-sm <%= isWishlisted ? 'fa-solid text-red-500' : 'fa-regular text-gray-500' %>"></i>
            </button>

            <!-- Cart -->
            <% if (!isCarted) { %>
            <button data-product-id="<%= product._id %>"
                    data-variant-id="<%= variantId %>"
                    class="add-to-cart w-9 h-9 bg-white shadow-md rounded-xl flex items-center justify-center hover:bg-blue-50 transition-colors">
                <i class="fa-solid fa-cart-shopping text-sm text-gray-500 hover:text-blue-600"></i>
            </button>
            <% } else { %>
            <button data-product-id="<%= product._id %>"
                    data-variant-id="<%= variantId %>"
                    class="add-to-cart increase w-9 h-9 bg-green-500 shadow-md rounded-xl flex items-center justify-center">
                <i class="fa-solid fa-check text-sm text-white"></i>
            </button>
            <% } %>
        </div>
    </div>

    <!-- INFO AREA -->
    <div class="p-4 flex-1 flex flex-col">

        <!-- Brand -->
        <div class="flex items-center gap-1.5 mb-2">
            <img src="<%= brandLogo %>" alt="<%= brand %>" class="w-4 h-4 object-contain opacity-70">
            <span class="text-[10px] text-gray-400 font-semibold uppercase tracking-widest"><%= brand %></span>
        </div>

        <!-- Name -->
        <a href="/product/<%= product._id %>"
           class="text-gray-900 text-sm font-semibold leading-snug line-clamp-2 mb-2 hover:text-red-500 transition-colors">
            <%= product.name %>
        </a>

        <!-- Free delivery -->
        <span class="text-[10px] text-emerald-600 font-semibold mb-3 flex items-center gap-1">
            <i class="fa-solid fa-truck-fast"></i> FREE Delivery
        </span>

        <!-- Price row -->
        <div class="mt-auto">
            <div class="flex items-baseline gap-2 flex-wrap">
                <span class="text-red-500 text-lg font-black">₹<%= finalPrice.toLocaleString('en-IN') %></span>
                <% if (discountPct > 0) { %>
                <span class="text-xs text-gray-400 line-through">₹<%= regularPrice.toLocaleString('en-IN') %></span>
                <% } %>
            </div>
            <% if (savings > 0) { %>
            <p class="text-[10px] text-emerald-600 font-semibold mt-0.5">Save ₹<%= savings.toLocaleString('en-IN') %></p>
            <% } %>
        </div>

        <!-- Quick add button (mobile-friendly) -->
        <% if (!isCarted) { %>
        <button data-product-id="<%= product._id %>"
                data-variant-id="<%= variantId %>"
                class="add-to-cart mt-3 w-full py-2.5 rounded-xl bg-gray-900 hover:bg-red-500 text-white text-xs font-bold transition-all duration-200 flex items-center justify-center gap-2">
            <i class="fa-solid fa-cart-shopping text-xs"></i> Add to Cart
        </button>
        <% } else { %>
        <div class="mt-3 w-full py-2.5 rounded-xl bg-emerald-500 text-white text-xs font-bold flex items-center justify-center gap-2">
            <i class="fa-solid fa-check text-xs"></i> In Cart
        </div>
        <% } %>
    </div>
</div>

<% }) %>
