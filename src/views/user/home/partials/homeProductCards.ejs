<% products.forEach(product=> {

    // Variant (safe)
    const variantId = product.variantId


    if (!variantId) return;

    // Safe fallbacks
    const image = product?.image || "https://placehold.co/400x400";
    const brand = product?.brand || "Brand";
    const brandLogo = product?.brandLogo || "/images/placeholder.png";

    // Price
    const price = product?.price || 0;
    const original = price + 2000;
    const discount = original > 0
    ? Math.round(((original - price) / original) * 100)
    : 0;

    //Riview
    const rating = product.rating || (Math.random() * (5 - 3.8) + 3.8).toFixed(1);
    const reviews = product.numReviews || Math.floor(Math.random() * 5000) + 10;


    // Wishlist& Cart key
    const key = `${product._id}_${variantId}`;
    const isWishlisted = wishlistSet?.has(key);
    const isCarted = cartSet?.has(key);

    %>

    <div class="product-card flex flex-col group relative bg-white rounded-xl overflow-hidden 
shadow-sm hover:shadow-2xl transition-all duration-300 border border-gray-100">

        <!-- IMAGE -->
        <div class="relative w-full aspect-[4/5] sm:aspect-square flex items-center justify-center 
    overflow-hidden cursor-pointer p-4 md:p-8 bg-[#f8f9fa] group-hover:bg-white transition-colors">

            <img src="<%= image %>" onclick="window.location.href='/product/<%= product._id %>'" alt="<%= product.name
                %>" class="w-full h-full object-contain group-hover:scale-110 transition-transform duration-500
                mix-blend-multiply">

            <!-- DISCOUNT -->
            <% if (discount> 0) { %>
                <span class="absolute bottom-2 left-2 bg-green-600 text-white text-[10px] px-2 py-0.5 rounded">
                    <%= discount %>% OFF
                </span>
                <% } %>

                    <!-- HOVER BUTTONS -->
                    <div class="absolute top-3 right-3 flex flex-col gap-2 
        opacity-100 lg:opacity-0 lg:translate-x-4 
        lg:group-hover:translate-x-0 lg:group-hover:opacity-100 
        transition-all duration-300">

                        <!-- ❤️ WISHLIST -->
                        <button id="wishlist-<%= variantId %>" data-product-id="<%= product._id %>"
                            data-variant-id="<%= variantId %>" <%=isCarted ? 'disabled' : '' %>
                            class="wishlist bg-white/90 backdrop-blur p-2 rounded-full shadow hover:bg-red-50 transition
                            <%= isCarted ? 'opacity-50 cursor-not-allowed' : '' %>"
                                >
                                <i
                                    class="fa-heart <%= isWishlisted ? 'fa-solid text-red-500' : 'fa-regular text-gray-600' %> hover:text-red-500"></i>
                        </button>

                        <!-- 🛒 CART -->
                        <% if (!isCarted) { %>
                            <!-- 🛒 ADD TO CART -->
                            <button data-product-id="<%= product._id %>" data-variant-id="<%= variantId %>"
                                class="add-to-cart bg-white/90 backdrop-blur p-2 rounded-full shadow hover:bg-blue-50 transition">

                                <i class="fa-solid fa-cart-shopping text-gray-600 hover:text-blue-600"></i>
                            </button>
                            <% } else { %>

                                <!-- 🔢 QUANTITY CONTROL -->
                                <div
                                    class="flex items-center bg-white/90 backdrop-blur rounded-full shadow overflow-hidden">
                                    <button data-product-id="<%= product._id %>" data-variant-id="<%= variantId %>"
                                        class=" add-to-cart increase px-2 py-1 text-green-600">+
                                        <span class="px-2 text-sm font-semibold">
                                            Add
                                        </span>
                                    </button>
                                </div>

                                <% } %>

                    </div>
        </div>

        <!-- INFO -->
        <div class="p-4 md:p-5 flex-1 flex flex-col bg-white">

            <!-- BRAND -->
            <div class="flex items-center gap-2 mb-1">
                <img src="<%= brandLogo %>" alt="brand" class="w-4 h-4 object-contain">
                <span class="text-[11px] text-gray-500 font-medium uppercase">
                    <%= brand %>
                </span>
            </div>

            <!-- TITLE -->
            <h6
                class="text-gray-900 text-sm md:text-base font-semibold mb-1 line-clamp-2 group-hover:text-blue-600 transition">
                <%= product.name %>
            </h6>

            <!-- DELIVERY -->
            <span class="text-[10px] md:text-xs text-green-500 font-semibold mb-2 block">
                <i class="fa-solid fa-truck-fast mr-1"></i> FREE Delivery
            </span>

            <!-- PRICE -->
            <div class="flex items-center gap-2 mt-auto">
                <span class="text-red-500 text-lg md:text-xl font-bold">
                    ₹<%= price %>
                </span>

                <span class="text-xs text-gray-400 line-through">
                    ₹<%= original %>
                </span>
            </div>

            <!-- SAVE -->
            <p class="text-[11px] text-green-600 font-medium">
                You save ₹<%= original - price %>
            </p>

        </div>
    </div>

    <% }) %>