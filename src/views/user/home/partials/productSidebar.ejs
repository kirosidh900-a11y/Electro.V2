<aside id="sidebar" class="fixed lg:static top-0 left-0 h-full lg:h-auto w-[280px] bg-white 
  border-r border-gray-200 p-6 
  z-50  lg:z-0
  transform -translate-x-full lg:translate-x-0 
  transition-transform duration-300 shadow-xl lg:shadow-sm overflow-y-auto">

        <div class="flex justify-between items-center mb-6 lg:hidden">
                <h2 class="font-bold text-lg">Filters</h2>
                <button onclick="toggleSidebar()">
                        <i class="fa fa-times text-xl"></i>
                </button>
        </div>

        <!-- SEARCH -->
        <div class="mb-6">
                <h3 class="text-xs font-semibold text-gray-500 uppercase mb-2">
                        Search
                </h3>

                <div class="relative">
                        <!-- Search Input -->
                        <input id="searchInput" placeholder="Search..."
                                class="w-full border pl-9 pr-9 py-2 text-sm rounded focus:border-blue-500">

                        <!-- Search Icon -->
                        <i class="fa fa-search absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-xs"></i>

                        <!-- Clear Button -->
                        <button id="clearBtn"
                                class="hidden absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-red-500 text-sm">
                                ✖
                        </button>
                </div>
        </div>

        <!-- CATEGORIES -->
        <div class="mb-6">
                <h3 class="text-xs font-semibold text-gray-500 uppercase mb-3">
                        Categories</h3>
                <ul class="space-y-2 max-h-40 overflow-y-auto custom-scrollbar">
                        <% categories.forEach(c=> { %>
                                <li class="category-item flex justify-between text-sm text-gray-600 hover:text-blue-600 cursor-pointer"
                                        data-category="<%= c._id %>">
                                        <span>
                                                <%= c.title %>
                                        </span>
                                        <span class="text-xs text-gray-400">(<%= c.productCount %>)</span>
                                </li>
                                <% }) %>
                </ul>
        </div>

        <!-- BRANDS -->
        <div class="mb-6">
                <h3 class="text-xs font-semibold text-gray-500 uppercase mb-3">Brands
                </h3>
                <div class="space-y-3">
                        <% brands.forEach(b=> { %>
                                <label class="brand-item flex items-center gap-3 cursor-pointer"
                                        data-brand="<%=b._id%>">
                                        <input type="checkbox" class="brand-checkbox w-4 h-4 cursor-pointer">
                                        <img src="<%= b.logo %>" class="w-5 h-5 object-contain">
                                        <span class="text-sm text-gray-600 hover:text-blue-600">
                                                <%= b.title %>
                                        </span>
                                </label>
                                <% }) %>
                </div>
        </div>

        <!-- PRICE -->
        <div class="mb-6">
                <h3 class="text-xs font-semibold text-gray-500 uppercase mb-3">Price</h3>

                <div class="flex gap-2 items-center">

                        <!-- MIN -->
                        <div class="relative w-full">
                                <span class="absolute left-2.5 top-1/2 -translate-y-1/2 text-gray-400 text-sm">₹</span>
                                <input type="number" id="minPriceSelect" min="0" placeholder="Min"
                                        class="w-full border pl-6 pr-2 py-2 text-sm rounded focus:ring-2 focus:ring-blue-500 focus:outline-none">
                        </div>

                        <span class="text-gray-400 text-sm shrink-0">to</span>

                        <!-- MAX -->
                        <div class="relative w-full">
                                <span class="absolute left-2.5 top-1/2 -translate-y-1/2 text-gray-400 text-sm">₹</span>
                                <input type="number" id="maxPriceSelect" min="0" placeholder="Max"
                                        class="w-full border pl-6 pr-2 py-2 text-sm rounded focus:ring-2 focus:ring-blue-500 focus:outline-none">
                        </div>

                </div>
        </div>

        <!-- BUTTONS -->
        <div class="space-y-2">
                <button onclick="applyFilters()"
                        class="w-full bg-blue-600 text-white py-2 rounded text-sm font-semibold hover:bg-blue-700">
                        Apply Filters
                </button>
                <button id="clearFiltersBtn1" class="w-full border py-2 rounded text-sm hover:bg-gray-50">
                        Clear All
                </button>
        </div>
</aside>