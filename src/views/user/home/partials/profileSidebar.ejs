<!-- SIDEBAR -->
<aside class="w-full lg:w-1/4 bg-white rounded-xl shadow-sm overflow-hidden h-fit lg:sticky lg:top-6">

    <!-- USER -->
    <div class="p-6 flex items-center gap-4 border-b border-gray-100">

        <div class="h-12 w-12 rounded-full overflow-hidden">
            <img id="sidebarImg"
                src="<%= user?.photo || 'https://res.cloudinary.com/dxtiklfxy/image/upload/v1773824246/profile/qhvfjaqer1o81nwkxvcz.png' %>"
                class="w-full h-full object-cover">
        </div>

        <div>
            <p class="text-xs text-gray-400">Hello,</p>
            <h2 id="sidebarName" class="font-semibold text-gray-800">
                <%= user?.name %>
            </h2>
        </div>

    </div>

    <!-- NAV -->
    <nav class="p-4 space-y-1">

        <!-- ORDERS -->
        <a href="/orders" class="flex items-center justify-between p-3 rounded-lg font-medium transition
            <%= currentRoute === '/orders'
            ? 'text-blue-600 bg-blue-50'
            : 'text-gray-600 hover:bg-gray-50' %>">

            <span class="flex items-center gap-3">
                <i class="fa-solid fa-box"></i> My Orders
            </span>

            <i class="fa-solid fa-chevron-right text-xs"></i>
        </a>

        <!-- ACCOUNT SETTINGS -->
        <p class="text-[10px] font-bold text-gray-400 uppercase px-3 pt-5 pb-2">
            Account Settings
        </p>

        <!-- PROFILE -->
        <a href="/myProfile" class="block p-3 rounded-lg font-medium transition
            <%= currentRoute === '/myProfile'
            ? 'text-blue-600 bg-blue-50'
            : 'text-gray-600 hover:bg-gray-50' %>">

            Profile Information
        </a>

        <!-- ADDRESS -->
        <a href="/address" class="block p-3 rounded-lg font-medium transition
            <%= currentRoute === '/address'
            ? 'text-blue-600 bg-blue-50'
            : 'text-gray-600 hover:bg-gray-50' %>">

            Manage Addresses
        </a>

        <!-- REFERRAL -->
        <a href="/referral" class="block p-3 rounded-lg font-medium transition
            <%= currentRoute === '/referral'
            ? 'text-blue-600 bg-blue-50'
            : 'text-gray-600 hover:bg-gray-50' %>">

            My Referral Info
        </a>

        <!-- MY STUFF -->
        <p class="text-[10px] font-bold text-gray-400 uppercase px-3 pt-5 pb-2">
            My Stuff
        </p>

        <a href="/wallet" class="flex items-center justify-between p-3 rounded-lg transition
            <%= currentRoute === '/wallet'
            ? 'text-green-600 bg-green-50'
            : 'text-gray-600 hover:bg-gray-50' %>">
            <span class="flex items-center gap-3">
                <i class="fa-solid fa-wallet text-green-500"></i> My Wallet
            </span>
        </a>

        <a href="/coupons" class="block p-3 rounded-lg transition
            <%= currentRoute === '/coupons'
            ? 'text-blue-600 bg-blue-50'
            : 'text-gray-600 hover:bg-gray-50' %>">

            My Coupons
        </a>

        <a href="/reviews" class="block p-3 rounded-lg transition
            <%= currentRoute === '/reviews'
            ? 'text-blue-600 bg-blue-50'
            : 'text-gray-600 hover:bg-gray-50' %>">

            My Reviews & Ratings
        </a>

        <a href="/wishlist" class="block p-3 rounded-lg transition
            <%= currentRoute === '/wishlist'
            ? 'text-blue-600 bg-blue-50'
            : 'text-gray-600 hover:bg-gray-50' %>">

            My Wishlist
        </a>

        <!-- LOGOUT -->
        <div class="mt-4 pt-4 border-t border-gray-100">
            <a id="logout2" class="flex items-center gap-3 p-3 text-red-500 hover:bg-red-50 rounded-lg transition">
                <i class="fa-solid fa-power-off"></i> Logout
            </a>
        </div>

    </nav>

</aside>

<!-- Logout Modal -->
<div id="logoutModal2" class="fixed inset-0 hidden items-center justify-center bg-black/50 backdrop-blur-sm z-50">

    <div class="bg-gray-900 text-white rounded-2xl shadow-2xl w-[90%] max-w-md p-7 border border-gray-800">

        <!-- Icon -->
        <div class="flex items-center justify-center mb-4">
            <div class="flex items-center justify-center w-14 h-14 rounded-full bg-red-500/20 text-red-400">
                <i class="fa-solid fa-right-from-bracket text-2xl"></i>
            </div>
        </div>

        <!-- Title -->
        <h2 class="text-xl font-semibold text-center mb-2">
            Logout from Shop?
        </h2>

        <!-- Message -->
        <p class="text-gray-400 text-center mb-6 text-sm">
            You will be signed out of your account and need to login again to continue parchese.
        </p>

        <!-- Buttons -->
        <div class="flex justify-center gap-3">

            <button id="cancelLogout2" class="px-5 py-2 rounded-lg bg-gray-700 hover:bg-gray-600 transition text-sm">
                Cancel
            </button>

            <button id="confirmLogout2"
                class="px-5 py-2 rounded-lg bg-red-500 hover:bg-red-600 transition text-sm font-medium shadow-lg">
                Logout
            </button>

        </div>

    </div>
</div>

<script type="module">
    import { showToast } from "/partials/errorMsg.utils.js";

    document.addEventListener("DOMContentLoaded", () => {

        const logoutBtn = document.getElementById("logout2");
        const modal = document.getElementById("logoutModal2");
        const cancelBtn = document.getElementById("cancelLogout2");
        const confirmBtn = document.getElementById('confirmLogout2');

        logoutBtn?.addEventListener("click", (e) => {
            e.preventDefault();
            modal.classList.remove("hidden");
            modal.classList.add("flex");
        });

        cancelBtn?.addEventListener("click", () => {
            modal.classList.add("hidden");
            modal.classList.remove("flex");
        });

        confirmBtn?.addEventListener("click", async () => {
            try {
                const response = await fetch("/auth/logout", {
                    method: "POST",
                    headers: { "Content-Type": "application/json", "Accept": 'application/json' },
                });

                if (!response.ok) throw new Error("Logout failed");

                window.location.href = "/";
            } catch (error) {
                showToast(error.message, "error");
            }
        });
    });
</script>